.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  width: 80rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  display: flex;
  align-items: center;
}

.header-icon {
  width: 24rpx;
  height: 24rpx;
  margin-left: 20rpx;
}

/* 内容区域 */
.content {
  padding: 20rpx 0;
  background-color: #fff;
  margin-bottom: 120rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  width: 150rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
  padding-right: 20rpx;
}

/* 头像按钮 */
.avatar-button {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
}

/* 性别选择 */
.gender-select {
  display: flex;
  align-items: center;
}

.gender-text {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.gender-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 保存按钮 */
.save-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #4CAF50;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.save-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 输入框占位符样式 */
input::placeholder {
  color: #999;
  font-size: 28rpx;
}
