.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.header-left {
  width: 80rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 80rpx;
  text-align: right;
}

.add-btn {
  font-size: 28rpx;
  color: #d4a76a;
  font-weight: 500;
  transition: color 0.3s ease;
}

.add-btn:hover {
  color: #b88d54;
}



/* 地址列表 */
.address-list {
  padding: 20rpx 30rpx;
}

/* 地址项 */
.address-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background-color: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.address-item:hover {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transform: translateY(-2rpx);
}

.address-info {
  flex: 1;
  margin-right: 20rpx;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  flex-wrap: wrap;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.default-tag {
  font-size: 20rpx;
  color: #d4a76a;
  border: 1rpx solid #d4a76a;
  border-radius: 4rpx;
  padding: 4rpx 12rpx;
  background-color: rgba(212, 167, 106, 0.05);
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
}

/* 地址操作 */
.address-actions {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.action-icon {
  width: 36rpx;
  height: 36rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.action-icon:hover {
  transform: scale(1.1);
  opacity: 0.8;
}

/* 空地址提示 */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 0;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 30rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.add-first-btn {
  width: 280rpx;
  height: 70rpx;
  background-color: #d4a76a;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
}

.add-first-btn:hover {
  background-color: #b88d54;
  box-shadow: 0 6rpx 16rpx rgba(212, 167, 106, 0.4);
  transform: translateY(-2rpx);
}

.add-first-btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

/* 添加地址按钮 */
.add-address-btn {
  margin: 30rpx;
  height: 100rpx;
  background-color: #d4a76a;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.3);
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.add-address-btn:hover {
  background-color: #b88d54;
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.4);
  transform: translateY(-2rpx);
}

.add-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
}

.add-address-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

/* 选择的地址信息 */
.chosen-address {
  background-color: #fff;
  margin: 20rpx 30rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  padding: 30rpx;
  border-left: 8rpx solid #d4a76a;
}

.chosen-address-header {
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chosen-address-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.chosen-address-badge {
  font-size: 20rpx;
  color: #d4a76a;
  background-color: rgba(212, 167, 106, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.chosen-address-info {
  padding-top: 10rpx;
}

.chosen-address-header-info {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.chosen-address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.chosen-address-phone {
  font-size: 28rpx;
  color: #666;
}

.chosen-address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  word-break: break-all;
  padding-left: 20rpx;
  border-left: 2rpx solid #f0f0f0;
}
