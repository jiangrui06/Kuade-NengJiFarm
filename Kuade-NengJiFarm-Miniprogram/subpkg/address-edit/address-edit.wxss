.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #fff;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.header-left {
  width: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back-icon {
  font-size: 36rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s ease;
}

.back-icon:active {
  transform: scale(0.9);
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  text-align: center;
}

.header-right {
  width: auto;
  text-align: right;
}

.save-btn {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  padding: 16rpx 32rpx;
  border-radius: 24rpx;
  background-color: #d4a76a;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.4);
  transition: all 0.3s ease;
  display: inline-block;
  text-align: center;
  white-space: nowrap;
}

.save-btn:active {
  background-color: #c4975a;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.3);
  transform: scale(0.95);
}

/* 表单内容 */
.form-content {
  background-color: #fff;
  margin-top: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s ease;
}

.form-item:last-child {
  border-bottom: none;
}

.form-item:active {
  background-color: #fafafa;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  width: 150rpx;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
  padding-right: 20rpx;
  height: 48rpx;
  line-height: 48rpx;
  border: none;
  outline: none;
  background: transparent;
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  min-height: 140rpx;
  padding: 16rpx 20rpx 16rpx 0;
  text-align: right;
  line-height: 1.5;
  border: none;
  outline: none;
  background: transparent;
  resize: none;
}

/* 所在地区选择 */
.region-select {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 20rpx;
  height: 48rpx;
  line-height: 48rpx;
}

.region-text {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
  text-align: right;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.region-arrow {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  transition: all 0.3s ease;
}

/* 复选框 */
.checkbox-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.checkbox-container {
  padding-right: 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  background-color: #fff;
}

.checkbox.checked {
  background-color: #d4a76a;
  border-color: #d4a76a;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.3);
}

.checkbox-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

/* 输入框占位符样式 */
input::placeholder,
textarea::placeholder {
  color: #999;
  font-size: 28rpx;
  font-weight: 400;
}

/* 响应式设计 */
@media (max-width: 375rpx) {
  .header {
    padding: 16rpx 24rpx;
  }
  
  .form-item {
    padding: 24rpx 24rpx;
  }
  
  .form-label {
    font-size: 26rpx;
    width: 130rpx;
  }
  
  .form-input,
  .form-textarea,
  .region-text {
    font-size: 26rpx;
  }
}
