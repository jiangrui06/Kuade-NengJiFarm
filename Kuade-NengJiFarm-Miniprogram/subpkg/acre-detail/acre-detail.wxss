.page {
  min-height: 100vh;
  background: #FAF6F0;
}

.detail-swiper {
  width: 100%;
  height: 500rpx;
  background: #FAF6F0;
}

.detail-swiper-image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.detail-swiper-video {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.detail-card {
  margin: 20rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 24rpx;
  position: relative;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  height: 36rpx;
  line-height: 36rpx;
}

.detail-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

.detail-price {
  font-size: 36rpx;
  color: #D4A76A;
  font-weight: 700;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
}

.detail-desc {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 32rpx;
  padding-left: 20rpx;
}

/* 购买统计信息 */
.purchase-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-top: 2rpx solid #FAF6F0;
  margin-top: 24rpx;
}

.stat-item {
  text-align: center;
  padding: 0 20rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #D4A76A;
}

/* 农场示例图片 */
.example-section {
  margin: 20rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 24rpx;
  position: relative;
  letter-spacing: 2rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

.example-images-vertical {
  display: flex;
  flex-direction: column;
  gap: 0rpx;
}

.example-images-vertical image {
  width: 100%;
  height: 400rpx !important;
  object-fit: cover !important;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  display: block !important;
  margin: 0 !important;
  padding: 0 !important;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .example-images-vertical image {
    height: 300rpx;
  }
}

@media (min-width: 750px) {
  .example-images-vertical image {
    height: 500rpx;
  }
}

/* 无图片提示 */
.no-images {
  text-align: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 28rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
  margin: 20rpx 0;
}

/* 已卖完提示 */
.sold-out {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #FFF3F3;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #E64340;
  border: 2rpx solid #FFE0E0;
}

/* 例子图片和介绍 */
.example-section {
  margin: 20rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
  margin-bottom: 140rpx;
}

/* 农场示例标题与图片容器 */
.example-section .example-long-image {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 28rpx;
  padding-left: 24rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
  margin-right: 0;
}

.example-long-image {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  background: #FAF6F0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.long-image {
  width: 100%;
  display: block;
  height: 400rpx;
  object-fit: cover;
  background-color: #FAF6F0;
}

/* 底部图片列表 - 垂直排列成长图（无缝拼接） */
.example-images-vertical {
  display: block;
  width: 100%;
  margin-top: 24rpx;
  overflow: hidden;
  background: #ffffff;
  font-size: 0;
  line-height: 0;
}

.example-images-vertical image {
  display: block !important;
  width: 100%;
  height: 250rpx;
  object-fit: cover;
  margin: 0 !important;
  padding: 0 !important;
  border: 0 !important;
  vertical-align: top;
  font-size: 0;
  line-height: 0;
  float: left;
  clear: both;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 20rpx;
  background: #ffffff;
  border-top: 2rpx solid #FAF6F0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  display: flex;
  gap: 20rpx;
}

.service-btn {
  background: #FAF6F0;
  color: #D4A76A;
  border: 2rpx solid #D4A76A;
  border-radius: 12rpx;
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.service-btn:active {
  background: #D4A76A;
  color: #ffffff;
  transform: scale(0.98);
}

.buy-btn {
  background: #D4A76A;
  color: #ffffff;
  border-radius: 12rpx;
  flex: 1;
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.3);
  transition: all 0.3s ease;
}

.buy-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.2);
}

.buy-btn:disabled {
  background: #CCCCCC;
  color: #FFFFFF;
  box-shadow: none;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .detail-swiper {
    height: 400rpx;
  }
  
  .long-image {
    height: 300rpx;
  }
  
  .detail-title {
    font-size: 32rpx;
  }
  
  .detail-price {
    font-size: 32rpx;
  }
  
  .bottom-bar {
    padding: 20rpx;
  }
  
  .service-btn,
  .buy-btn {
    height: 80rpx;
    font-size: 28rpx;
  }
}
