.container {
  background-color: #FAF6F0; /* 丝苗米白 */
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 商品图片 */
.goods-image-container {
  width: 100%;
  height: 600rpx;
  background-color: #fff;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.goods-info {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price {
  font-size: 40rpx;
  font-weight: bold;
  color: #D4A76A;
  margin-bottom: 10rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 15rpx;
}

/* 销售信息 */
.sales-info {
  display: flex;
  justify-content: space-between;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sold {
  font-size: 24rpx;
  color: #666;
}

.stock {
  font-size: 24rpx;
  color: #666;
}

/* 商品详情图片 */
.detail-image {
  width: 100%;
  height: 400rpx;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.detail-image image {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 10;
}

.cart-icon {
  position: relative;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.cart-text {
  font-size: 40rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 30rpx;
  height: 30rpx;
  background-color: #D4A76A;
  color: #fff;
  border-radius: 15rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-container {
  flex: 1;
  display: flex;
  gap: 15rpx;
}

.add-cart-btn {
  flex: 1;
  height: 60rpx;
  background-color: #fff;
  color: #D4A76A;
  border: 1rpx solid #D4A76A;
  border-radius: 30rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.buy-btn {
  flex: 1;
  height: 60rpx;
  background-color: #D4A76A;
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 桌台提示浮窗 */
.table-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.table-modal-content {
  width: 80%;
  max-width: 500rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.table-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}

.table-modal-message {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.table-modal-buttons {
  display: flex;
  gap: 20rpx;
}

.table-modal-button {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.table-modal-button.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.table-modal-button.confirm {
  background-color: #D4A76A;
  color: #fff;
}

