<view class="container">

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 物流信息 -->
  <view wx:else class="logistics-content">
    <!-- 物流状态头部 -->
    <view class="logistics-header">
      <view class="logistics-status">
        <text class="status-icon">{{statusIcon}}</text>
        <text class="status-text">{{logisticsInfo.statusText || '运输中'}}</text>
      </view>
    </view>

    <!-- 快递公司和单号 -->
    <view class="company-section">
      <view class="company-info">
        <text class="company-name">{{logisticsInfo.companyName || '快递公司'}}</text>
        <text class="waybill-no">运单号：{{logisticsInfo.waybillNo || orderId}}</text>
      </view>
      <view class="copy-btn" bindtap="copyWaybillNo">复制</view>
    </view>

    <!-- 收货地址 -->
    <view wx:if="{{shippingAddress}}" class="address-section">
      <view class="section-title">收货地址</view>
      <view class="address-info">
        <view class="address-name">{{shippingAddress.name}}</view>
        <view class="address-phone">{{shippingAddress.phone}}</view>
        <view class="address-detail">{{shippingAddress.address}}</view>
      </view>
    </view>

    <!-- 商品信息 -->
    <view wx:if="{{orderItems && orderItems.length > 0}}" class="goods-section">
      <view class="section-title">商品信息</view>
      <view class="goods-list">
        <view class="goods-item" wx:for="{{orderItems}}" wx:key="id">
          <image class="goods-image" src="{{item.image}}" />
          <view class="goods-info">
            <view class="goods-name">{{item.name}}</view>
            <view class="goods-price">￥{{item.price}} × {{item.quantity}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 物流轨迹 -->
    <view class="trace-section">
      <view class="section-title">物流轨迹</view>
      <view wx:if="{{logisticsTrace && logisticsTrace.length > 0}}" class="trace-list">
        <view wx:for="{{logisticsTrace}}" wx:key="index" class="trace-item {{index === 0 ? 'current' : ''}}">
          <view class="trace-dot"></view>
          <view class="trace-line" wx:if="{{index !== logisticsTrace.length - 1}}"></view>
          <view class="trace-content">
            <view class="trace-time">{{item.time}}</view>
            <view class="trace-desc">{{item.desc}}</view>
            <view wx:if="{{item.location}}" class="trace-location">{{item.location}}</view>
          </view>
        </view>
      </view>
      <view wx:else class="no-trace">
        <text>暂无物流轨迹</text>
      </view>
    </view>
  </view>
</view>
