/* 物流详情页面样式 */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 20rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  background-color: #fff;
  padding: 0 20rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  color: #333;
  font-weight: 300;
}

.nav-title {
  font-size: 34rpx;
  color: #333;
  font-weight: 500;
}

.nav-placeholder {
  width: 60rpx;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #07c160;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 物流内容 */
.logistics-content {
  padding: 20rpx;
}

/* 物流状态头部 */
.logistics-header {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.logistics-status {
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.status-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 500;
}

/* 快递公司和单号 */
.company-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.company-info {
  flex: 1;
}

.company-name {
  display: block;
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.waybill-no {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.copy-btn {
  padding: 12rpx 24rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

/* 通用区块标题 */
.section-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

/* 收货地址 */
.address-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.address-info {
  padding-left: 10rpx;
}

.address-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 商品信息 */
.goods-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.goods-list {
  padding-left: 10rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price {
  font-size: 26rpx;
  color: #999;
}

/* 物流轨迹 */
.trace-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.trace-list {
  padding-left: 10rpx;
}

.trace-item {
  display: flex;
  position: relative;
  padding-bottom: 40rpx;
}

.trace-item:last-child {
  padding-bottom: 0;
}

.trace-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #ddd;
  margin-right: 24rpx;
  margin-top: 8rpx;
  flex-shrink: 0;
}

.trace-item.current .trace-dot {
  width: 24rpx;
  height: 24rpx;
  background-color: #07c160;
  margin-top: 6rpx;
  box-shadow: 0 0 0 6rpx rgba(7, 193, 96, 0.15);
}

.trace-line {
  position: absolute;
  left: 9rpx;
  top: 36rpx;
  width: 2rpx;
  height: calc(100% - 36rpx);
  background-color: #eee;
}

.trace-content {
  flex: 1;
}

.trace-time {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.trace-item.current .trace-time {
  color: #07c160;
  font-weight: 500;
}

.trace-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 4rpx;
}

.trace-item.current .trace-desc {
  color: #07c160;
  font-weight: 500;
}

.trace-location {
  font-size: 24rpx;
  color: #999;
}

.no-trace {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
