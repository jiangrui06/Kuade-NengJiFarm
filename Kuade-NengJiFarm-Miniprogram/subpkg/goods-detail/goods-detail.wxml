<view class="container">
  <swiper
    class="detail-swiper"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    circular="{{true}}"
    interval="3000"
    duration="500"
  >
    <!-- 有视频时第一个轮播项显示视频 -->
    <swiper-item wx:if="{{hasVideo}}">
      <video
        class="detail-swiper-video"
        src="{{goods.videoUrl}}"
        poster="{{goods.image}}"
        controls="true"
        autoplay="false"
        loop="false"
        muted="false"
        object-fit="cover"
        show-center-play-btn="true"
        enable-progress-gesture="true"
        show-play-btn="true"
        show-fullscreen-btn="true"
        enable-playback-rate="true"
        volume="1.0"
        show-mute-btn="true"
        show-volume-btn="true"
      />
    </swiper-item>
    <block wx:for="{{swiperList}}" wx:key="id">
      <swiper-item>
        <image
          class="detail-swiper-image"
          src="{{item.image}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-url="{{item.image}}"
        />
      </swiper-item>
    </block>
  </swiper>

  <view class="goods-info">
    <view class="goods-price">￥{{goods.price}}</view>
    <view class="goods-name">{{goods.name}}</view>
   
    <view class="goods-description">
      {{goods.description}}
    </view>

    <view class="delivery-info">
      <view class="delivery-label">配送</view>
      <view class="delivery-text">包邮</view>
    </view>

    <view class="service-info">
      <view class="service-item">
        <text class="service-label">服务</text>
        <text class="service-text">称重退差价</text>
      </view>
    </view>
  </view>

  <view class="spec-info">
    <view class="spec-title">规格信息</view>
    <view class="spec-item">
      <view class="spec-label">净含量</view>
      <view class="spec-value">{{goods.weight}}</view>
    </view>
    <view class="spec-item">
      <view class="spec-label">保存条件</view>
      <view class="spec-value">{{goods.storage}}</view>
    </view>
  </view>

  <view class="goods-display-image">
    <image class="display-image" src="{{goods.detailImage}}" bindtap="previewDetailImages" data-url="{{goods.detailImage}}" />
  </view>

  <view class="goods-detail-images">
    <view class="detail-image-container">
      <image class="detail-image" src="{{goods.detailImage}}" bindtap="previewDetailImages" data-url="{{goods.detailImage}}" />
      <image class="detail-image" src="{{goods.image}}" bindtap="previewDetailImages" data-url="{{goods.image}}" />
    </view>
  </view>

  <!-- 立即购买弹窗 -->
  <view class="buy-modal" hidden="{{!showBuyModal}}">
    <view class="buy-mask" bindtap="hideBuyModal"></view>
    <view class="buy-content">
      <view class="buy-header">
        <view class="buy-title">确认购买</view>
        <view class="buy-close" bindtap="hideBuyModal">✕</view>
      </view>
      <view class="buy-body">
        <view class="buy-goods-info">
          <image class="buy-goods-image" src="{{goods.image}}" />
          <view class="buy-goods-details">
            <view class="buy-goods-name">{{goods.name}}</view>
            <view class="buy-goods-price">￥{{goods.price}}</view>
            <view class="buy-goods-quantity">
              <view class="quantity-control">
                <view class="quantity-btn minus" bindtap="decreaseQuantity" wx:if="{{quantity > 1}}">-</view>
                <view class="quantity-btn minus disabled" wx:else>-</view>
                <view class="quantity-input">{{quantity}}</view>
                <view class="quantity-btn plus" bindtap="increaseQuantity">+</view>
              </view>
            </view>
          </view>
        </view>
        
        <view class="buy-address-section">
          <view class="buy-section-title">
            <text>收货地址</text>
            <text class="select-more-address" bindtap="toggleAddressList" wx:if="{{addressList.length > 0}}">选择更多地址</text>
          </view>
          <view class="buy-address-list" wx:if="{{showAllAddresses}}">
            <view class="buy-address-item {{selectedAddress === item.id ? 'active' : ''}}" 
                  wx:for="{{addressList}}" 
                  wx:key="id">
              <view class="address-info" bindtap="selectAddress" data-id="{{item.id}}">
                <view class="address-name">{{item.name}}</view>
                <view class="address-phone">{{item.phone}}</view>
                <view class="address-detail">{{item.address}}</view>
              </view>
              <view class="address-actions">
                <view class="address-check" wx:if="{{selectedAddress === item.id}}">✓</view>
                <view class="address-edit" bindtap="editAddress" data-id="{{item.id}}">编辑</view>
              </view>
            </view>
            <button class="add-address-btn" bindtap="addAddress">添加地址</button>
          </view>
          <view class="buy-address-list" wx:else>
            <view wx:if="{{defaultAddress}}">
              <view class="buy-address-item active">
                <view class="address-info">
                  <view class="address-name">{{defaultAddress.name}}</view>
                  <view class="address-phone">{{defaultAddress.phone}}</view>
                  <view class="address-detail">{{defaultAddress.address}}</view>
                </view>
                <view class="address-actions">
                  <view class="address-check">✓</view>
                  <view class="address-edit" bindtap="editAddress" data-id="{{defaultAddress.id}}">编辑</view>
                </view>
              </view>
            </view>
            <view wx:else class="no-address">
              <text class="no-address-text">请添加收货地址</text>
              <button class="add-address-btn" bindtap="addAddress">添加地址</button>
            </view>
          </view>
        </view>
        
        <view class="buy-total">
          <view class="total-label">总计</view>
          <view class="total-price">￥{{totalPrice}}</view>
        </view>
      </view>
      <view class="buy-footer">
        <button class="buy-cancel-btn" bindtap="hideBuyModal">取消</button>
        <button class="buy-confirm-btn" bindtap="confirmBuy">确认购买</button>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="cart-icon" bindtap="goToCart">
      <text class="cart-text">🛒</text>
      <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
    </view>
    <button class="add-to-cart-btn" bindtap="addToCart">加入购物车</button>
    <button class="buy-now-btn" bindtap="buyNow">立即购买</button>
  </view>

  <!-- 客服按钮 -->
  <button class="service-button function-item function-item-btn" open-type="contact">
    <image class="service-icon" src="https://img.icons8.com/ios-glyphs/24/666666/headset.png" />
  </button>
</view>