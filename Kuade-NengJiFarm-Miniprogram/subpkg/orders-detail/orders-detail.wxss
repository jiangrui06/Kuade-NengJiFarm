/* ============================================
   基础布局
   ============================================ */
.container {
  background-color: #f7f4ef;
  min-height: 100vh;
  padding: 20rpx 0 140rpx;
}

/* ============================================
   通用卡片
   ============================================ */
.card {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 1rpx 8rpx rgba(180, 160, 130, 0.08);
}

/* 卡片标题 */
.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0ece4;
}

.card-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.card-title-arrow {
  font-size: 32rpx;
  color: #c8c0b4;
  font-weight: 300;
}

/* 可点击卡片 */
.clickable-card {
  transition: all 0.2s ease;
}

.clickable-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 卡片内容 */
.card-body {
  padding: 28rpx 32rpx;
}

.card-body.rows {
  padding: 12rpx 0;
}

/* ============================================
   订单状态
   ============================================ */
.status-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.countdown {
  background: #fff9f4;
  border-radius: 12rpx;
  padding: 12rpx 32rpx;
  margin-top: 12rpx;
}

.countdown-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #e05a2b;
  letter-spacing: 2rpx;
}

/* 二维码 */
.qrcode-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 28rpx;
}

.qrcode-title {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.qrcode-img {
  width: 300rpx;
  height: 300rpx;
  border-radius: 16rpx;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}

.qrcode-btn {
  font-size: 28rpx;
  color: #c99a5a;
  border: 2rpx solid #e0d4c0;
  border-radius: 40rpx;
  padding: 14rpx 48rpx;
  background: transparent;
}

.qrcode-btn:active {
  background: #faf6ee;
}

/* ============================================
   物流信息
   ============================================ */
.logistics-list {
  padding-left: 8rpx;
}

.logistics-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 36rpx;
  position: relative;
}

.logistics-item:last-child {
  padding-bottom: 0;
}

/* 左侧时间线 */
.logistics-item::before {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 24rpx;
  bottom: 0;
  width: 1rpx;
  background: #ece8e0;
}

.logistics-item:last-child::before {
  display: none;
}

.logistics-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #d8d0c4;
  flex-shrink: 0;
  margin-top: 6rpx;
  position: relative;
  z-index: 1;
}

.logistics-item:first-child .logistics-dot {
  background: #c99a5a;
  width: 22rpx;
  height: 22rpx;
  margin-top: 4rpx;
  box-shadow: 0 0 0 4rpx rgba(201, 154, 90, 0.15);
}

.logistics-info {
  flex: 1;
}

.logistics-desc {
  font-size: 27rpx;
  color: #444;
  line-height: 1.5;
  margin-bottom: 6rpx;
}

.logistics-item:first-child .logistics-desc {
  color: #1a1a1a;
  font-weight: 500;
}

.logistics-time {
  font-size: 24rpx;
  color: #bbb;
}

.empty-tip {
  font-size: 26rpx;
  color: #ccc;
  text-align: center;
  padding: 40rpx 0;
}

/* ============================================
   收货地址
   ============================================ */
.addr-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.addr-phone {
  font-size: 26rpx;
  color: #888;
}

.addr-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 6rpx;
}

/* ============================================
   通用行（订单信息、价格明细）
   ============================================ */
.row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f8f5f0;
}

.row:last-child {
  border-bottom: none;
}

.row-lbl {
  font-size: 26rpx;
  color: #aaa;
  flex-shrink: 0;
}

.row-val {
  font-size: 26rpx;
  color: #444;
  text-align: right;
  word-break: break-all;
}

.row-total {
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #ece4d8;
}

.row-total .row-lbl {
  color: #666;
  font-weight: 600;
}

.row-total-val {
  font-size: 38rpx;
  font-weight: 700;
  color: #c99a5a;
}

/* ============================================
   商品信息
   ============================================ */
.goods-body {
  padding: 0 32rpx 28rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f8f5f0;
  gap: 20rpx;
}

.goods-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.goods-item:first-child {
  padding-top: 0;
}

.goods-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: #f5f0e8;
  flex-shrink: 0;
}

.goods-mid {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-rule {
  font-size: 24rpx;
  color: #bbb;
}

.goods-price {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  flex-shrink: 0;
}

/* ============================================
   操作按钮
   ============================================ */
.btn-area {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 32rpx 24rpx 48rpx;
}

.btn {
  flex: 1;
  min-width: 44%;
  max-width: 46%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  margin: 0;
  padding: 0;
}

.btn::after {
  border: none;
}

.btn-gold {
  background: #c99a5a;
  color: #fff;
}

.btn-gold:active {
  background: #b88a4a;
}

.btn-line {
  background: transparent;
  color: #888;
  border: 2rpx solid #e0d8cc;
}

.btn-line:active {
  background: #f8f5f0;
}

/* ============================================
   加载中
   ============================================ */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-ring {
  width: 52rpx;
  height: 52rpx;
  border: 4rpx solid #ece4d8;
  border-top-color: #c99a5a;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: #bbb;
}

/* ============================================
   深色模式
   ============================================ */
@media (prefers-color-scheme: dark) {
  .container {
    background-color: #141210;
  }

  .card {
    background: #1e1c18;
    box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.3);
  }

  .card-title {
    border-bottom-color: #2e2c28;
  }

  .card-title-text {
    color: #e8e0d4;
  }

  .card-title-arrow {
    color: #555;
  }

  .status-text {
    color: #e8e0d4;
  }

  .countdown {
    background: #2a2218;
  }

  .countdown-num {
    color: #e8804a;
  }

  .qrcode-title {
    color: #888;
  }

  .qrcode-tip {
    color: #555;
  }

  .qrcode-btn {
    color: #c99a5a;
    border-color: #3a3428;
  }

  .qrcode-btn:active {
    background: #252018;
  }

  .logistics-item::before {
    background: #2e2c28;
  }

  .logistics-dot {
    background: #4a4438;
  }

  .logistics-item:first-child .logistics-dot {
    background: #c99a5a;
  }

  .logistics-desc {
    color: #aaa;
  }

  .logistics-item:first-child .logistics-desc {
    color: #e8e0d4;
  }

  .logistics-time {
    color: #555;
  }

  .empty-tip {
    color: #444;
  }

  .addr-name {
    color: #e8e0d4;
  }

  .addr-phone {
    color: #666;
  }

  .addr-detail {
    color: #888;
  }

  .row {
    border-bottom-color: #262420;
  }

  .row-lbl {
    color: #666;
  }

  .row-val {
    color: #aaa;
  }

  .row-total {
    border-top-color: #3a3428;
  }

  .row-total .row-lbl {
    color: #888;
  }

  .row-total-val {
    color: #c99a5a;
  }

  .goods-item {
    border-bottom-color: #262420;
  }

  .goods-name {
    color: #e8e0d4;
  }

  .goods-rule {
    color: #555;
  }

  .goods-price {
    color: #e8e0d4;
  }

  .btn-gold {
    background: #c99a5a;
  }

  .btn-gold:active {
    background: #b88a4a;
  }

  .btn-line {
    color: #888;
    border-color: #3a3428;
  }

  .btn-line:active {
    background: #262018;
  }

  .loading-txt {
    color: #555;
  }

  .loading-ring {
    border-color: #2e2c28;
    border-top-color: #c99a5a;
  }
}
