<view class="container">
  <!-- 轮播图（视频 + 图片） -->
  <swiper
    class="activity-swiper"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    circular="{{true}}"
    interval="3000"
    duration="500"
  >
    <!-- 有视频时显示视频作为第一个轮播项 -->
    <swiper-item wx:if="{{hasVideo}}">
      <video
        class="activity-swiper-video"
        src="{{activity.videoUrl}}"
        poster="{{activity.image && activity.image.startsWith('http') ? activity.image : ''}}"
        controls="true"
        autoplay="false"
        loop="false"
        muted="false"
        object-fit="cover"
        show-center-play-btn="true"
        enable-progress-gesture="true"
        show-play-btn="true"
        show-fullscreen-btn="true"
        enable-playback-rate="true"
        volume="1.0"
        show-mute-btn="true"
        show-volume-btn="true"
      />
    </swiper-item>
    <!-- 主图 -->
    <swiper-item>
      <image
        class="activity-swiper-image"
        src="{{activity.image}}"
        mode="aspectFill"
        bindtap="previewImage"
        data-index="0"
      />
    </swiper-item>
    <!-- 活动图片列表 -->
    <block wx:for="{{activity.images}}" wx:key="index" wx:if="{{item !== activity.image}}">
      <swiper-item>
        <image
          class="activity-swiper-image"
          src="{{item}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-index="{{index + 1}}"
        />
      </swiper-item>
    </block>
  </swiper>

  <!-- 活动信息 -->
  <view class="activity-info">
    <view class="activity-title">{{activity.title}}</view>
    <view class="activity-meta">
      <view class="activity-price">￥{{activity.price}}</view>
      <view class="activity-date">{{activity.date}}</view>
    </view>
    <view class="activity-description">{{activity.description}}</view>
  </view>
  
  <!-- 活动详情 -->
  <view class="activity-details">

    <view class="detail-item">
      <view class="detail-label">活动时间</view>
      <view class="detail-value">{{activity.date}}</view>
    </view>
    <view class="detail-item">
      <view class="detail-label">活动地点</view>
      <view class="detail-value">{{activity.location}}</view>
    </view>
    <view class="detail-item">
      <view class="detail-label">活动费用</view>
      <view class="detail-value">￥{{activity.price}}</view>
    </view>
    <view class="detail-item">
      <view class="detail-label">已参加人数</view>
      <view class="detail-value highlight">{{activity.participants || 0}}人</view>
    </view>
    <view class="detail-item">
      <view class="detail-label">剩余名额</view>
      <view class="detail-value success">{{activity.remainingSlots || 0}}人</view>
    </view>
    <view class="detail-item">
      <view class="detail-label">活动内容</view>
      <view class="detail-value">{{activity.content}}</view>
    </view>
  </view>
  
  <!-- 活动图片展示 -->
  <view class="activity-gallery">
    <view class="section-title">活动图片</view>
    <!-- 垂直排列成长图 -->
    <view class="example-images-vertical" wx:if="{{activity.images && activity.images.length > 0}}">
      <block wx:for="{{activity.images}}" wx:key="index">
        <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}" />
      </block>
    </view>
    <!-- 无图片时的提示 -->
    <view class="no-images" wx:else>
      <text>暂无活动图片</text>
    </view>
  </view>
  
  <!-- 底部按钮 -->
  <view class="bottom-buttons" wx:if="{{!showQRCode}}">
    <button class="register-btn" bindtap="registerActivity" disabled="{{activity.remainingSlots <= 0}}">
      {{activity.remainingSlots <= 0 ? '已报满' : '立即报名'}}
    </button>
  </view>
  
  <!-- 客服按钮 -->
  <button class="service-button function-item function-item-btn" open-type="contact">
    <image class="service-icon" src="https://img.icons8.com/ios-glyphs/24/666666/headset.png" />
  </button>
  
  <!-- 二维码页面 -->
  <view class="qrcode-container" wx:if="{{showQRCode}}">
    <view class="qrcode-content">
      <view class="qrcode-title">活动报名成功</view>
      <view class="qrcode-subtitle">请出示此二维码验券</view>
      <view class="qrcode-image">
        <image src="{{qrCodeUrl}}" mode="aspectFit" />
      </view>
      <view class="qrcode-hint">
        <text>1. 请向工作人员出示此二维码</text>
        <text>2. 工作人员扫描二维码验券</text>
        <text>3. 验券成功后即可参加活动</text>
      </view>
      <button class="back-btn" bindtap="backToDetail">返回</button>
    </view>
  </view>
</view>