.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  /* 确保不影响 fixed 定位 */
  position: relative;
}

/* 导航栏 - 微信风格 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  background-color: #ededed;
  padding-top: 88rpx; /* 状态栏高度 */
  height: 176rpx; /* 状态栏(88rpx) + 导航栏内容(88rpx) */
  padding-left: 16rpx;
  padding-right: 16rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-back {
  width: 80rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back-icon {
  font-size: 70rpx;
  color: #000;
  font-weight: 300;
  line-height: 1;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 500;
  color: #000;
}

.nav-placeholder {
  width: 80rpx;
}

/* 搜索栏 - 微信风格 */
.search-bar {
  background-color: #ededed;
  padding: 16rpx 24rpx;
  position: fixed;
  top: 176rpx;
  left: 0;
  right: 0;
  z-index: 999;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 64rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  border: none;
  font-weight: 400;
}

.search-input::placeholder {
  color: #999;
}

.search-btn {
  font-size: 28rpx;
  color: #d4a76a;
  font-weight: 500;
  margin-left: 16rpx;
  padding: 8rpx 16rpx;
}

/* 标签栏 - 微信风格 */
.tab-bar {
  background-color: #fff;
  position: fixed;
  top: 272rpx;
  left: 0;
  right: 0;
  z-index: 998;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-list {
  display: flex;
  padding: 0 16rpx;
}

.tab-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
  margin-right: 32rpx;
  position: relative;
}

.tab-item.active {
  color: #d4a76a;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background-color: #d4a76a;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 24rpx;
  padding-top: 360rpx;
  min-height: 100vh;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top: 4rpx solid #d4a76a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 订单卡片 */
.order-card {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.order-header {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-top {
  display: flex;
  align-items: center;
}

.order-type {
  display: flex;
  align-items: center;
}

.type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  background-color: #f5f5f5;
  color: #666;
}

.order-id {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.order-status-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.order-status {
  font-size: 28rpx;
  color: #d4a76a;
  font-weight: 500;
}

.order-countdown {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
}

.countdown-label {
  color: #999;
}

.countdown-time {
  color: #ff4d4f;
  font-weight: 600;
  font-size: 28rpx;
}

.order-content {
  padding: 20rpx 24rpx;
}

.order-items {
  margin-bottom: 20rpx;
}

.order-item-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f8f8f8;
}

.order-item-row:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 26rpx;
  color: #666;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.order-total {
  display: flex;
  flex-direction: column;
}

.order-total text {
  font-size: 24rpx;
  color: #999;
}

.total-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-top: 4rpx;
}

.order-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  border: none;
  min-width: 120rpx;
  text-align: center;
}

.primary-btn {
  background: linear-gradient(135deg, #d4a76a 0%, #c4975a 100%);
  color: #fff;
}

.secondary-btn {
  background-color: #f5f5f5;
  color: #666;
}

.delete-btn {
  background-color: #fff5f5;
  color: #ff4d4f;
}

/* 无订单状态 */
.empty-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #d4a76a;
}
