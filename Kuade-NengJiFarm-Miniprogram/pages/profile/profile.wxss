/* ─────────────────────────────────────────
   个人中心样式 - 能记农场
   色系：稻田黄 #D4A76A | 丝苗米白 #FAF6F0
   ───────────────────────────────────────── */

.container {
  min-height: 100vh;
  background-color: #FAF6F0;
}

/* 会员中心头部 */
.member-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
}

.member-info {
  display: flex;
  align-items: center;
}

.avatar-button {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 24rpx 0 0;
  border: none;
  background: transparent;
  line-height: 1;
  overflow: hidden;
}

.avatar-button::after {
  border: none;
}

.member-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background-color: rgba(255, 255, 255, 0.2);
  display: block;
}

.member-details {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #fff;
}

.member-email {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.member-actions {
  padding: 16rpx;
}

.member-actions .action-icon {
  width: 48rpx;
  height: 48rpx;
  padding: 12rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  box-sizing: border-box;
}

/* 通用 section 样式 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #fff;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 24rpx;
  background-color: #D4A76A;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* 我的订单 */
.order-section {
  background-color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.08);
}

.order-states {
  display: flex;
  padding: 32rpx 16rpx;
  justify-content: space-around;
}

.order-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
}

.state-icon-container {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.state-icon-container:active {
  transform: scale(0.95);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.state-icon-container.pending {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
}

.state-icon-container.paid {
  background: linear-gradient(135deg, #4ecdc4 0%, #45b7d1 100%);
}

.state-icon-container.shipping {
  background: linear-gradient(135deg, #45b7d1 0%, #4361ee 100%);
}

.state-icon-container.all {
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
}

.state-icon {
  width: 40rpx;
  height: 40rpx;
  padding: 0;
  background-color: transparent;
  border-radius: 0;
  box-sizing: border-box;
  display: block;
  object-fit: contain;
}

.state-icon-text {
  font-size: 32rpx;
  line-height: 1;
  text-align: center;
}

.state-text {
  font-size: 24rpx;
  color: #666;
}

.state-badge {
  position: absolute;
  top: -8rpx;
  right: 50%;
  transform: translateX(50%);
  background-color: #D4A76A;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* 推荐商品 */
.recommend-section {
  padding: 0 24rpx;
  margin: 20rpx 0;
}

.recommend-image {
  width: 100%;
  border-radius: 16rpx;
  height: 200rpx;
  object-fit: cover;
}

/* 功能列表 */
.function-section {
  background-color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.08);
}

.function-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #FAF6F0;
  transition: background-color 0.3s ease;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background-color: #FAF6F0;
}

.function-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 24rpx;
  padding: 8rpx;
  background-color: #FAF6F0;
  border-radius: 10rpx;
  box-sizing: border-box;
}

.function-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.function-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.4;
}
