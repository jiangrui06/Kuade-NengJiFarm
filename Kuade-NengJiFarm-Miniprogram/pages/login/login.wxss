.container {
  background: linear-gradient(135deg, #f5f5f5 0%, #e8f0f2 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}
/* 背景层 */
.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
}

.bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    160deg,
    rgba(30, 60, 40, 0.6) 0%,
    rgba(20, 45, 30, 0.75) 40%,
    rgba(10, 30, 20, 0.85) 100%
  );
}

/* 装饰元素 */
.decorations {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}

.sun
.container::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(230, 67, 64, 0.05) 0%, transparent 70%);
  animation: pulse 8s ease-in-out infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.1);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 0.5;
  }
}

/* 登录页面标题 */
.login-header {
  text-align: center;
  margin-bottom: 60rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

/* 登录卡片 */
.login-card {
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  max-width: 600rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  position: relative;
  z-index: 1;
  transition: all 0.3s ease;
}

.login-card:hover {
  box-shadow: 0 15rpx 50rpx rgba(0, 0, 0, 0.12);
  transform: translateY(-5rpx);
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.logo-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #D4A76A;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 登录内容 */
.login-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 一键登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(212, 167, 106, 0.4);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border: none;
  outline: none;
}

.login-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(212, 167, 106, 0.5);
}

.login-btn:active {
  transform: translateY(0);
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.3);
}

.login-btn-wrapper {
  width: 100%;
  position: relative;
}

.login-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  border-radius: 48rpx;
  background-color: transparent;
  cursor: not-allowed;
}

.login-btn-disabled {
  opacity: 0.55;
  background: #c0b0a0;
  box-shadow: none;
}

.login-btn-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.login-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

/* 分隔线 */
.divider {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background-color: #e0e0e0;
}

.divider-text {
  font-size: 22rpx;
  color: #bbb;
  margin: 0 24rpx;
  white-space: nowrap;
}

/* 手机号快捷登录按钮 */
.phone-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.35);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn:active {
  transform: translateY(0);
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.25);
}

.phone-login-btn[disabled] {
  opacity: 0.6;
}

.phone-login-disabled {
  opacity: 0.55;
  background: #07a055 !important;
  box-shadow: none;
}

.phone-login-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.phone-login-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

/* 其他登录方式 */
.other-login {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-login-text {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 32rpx;
  position: relative;
}

.other-login-text::before,
.other-login-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 120rpx;
  height: 1rpx;
  background-color: #e0e0e0;
}

.other-login-text::before {
  left: -140rpx;
}

.other-login-text::after {
  right: -140rpx;
}

.login-methods {
  display: flex;
  justify-content: center;
  gap: 80rpx;
}

.login-method {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  padding: 20rpx;
  border-radius: 12rpx;
  background: transparent;
  border: none;
  line-height: normal;
}

.login-method::after {
  border: none;
}

.login-method:hover {
  background-color: #f0f0f0;
  transform: translateY(-4rpx);
}

.method-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.method-text {
  font-size: 20rpx;
  color: #666;
}

/* 底部协议 */
.login-footer {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
  color: #999;
  width: 100%;
  text-align: center;
  flex-wrap: wrap;
  gap: 6rpx;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

.agreement-link {
  color: #e64340;
  margin: 0 6rpx;
  text-decoration: none;
  transition: color 0.3s ease;
}

.agreement-link:hover {
  color: #d53a37;
  text-decoration: underline;
}

/* 按钮点击效果 */
.login-btn::before,
.login-method::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.login-btn:active::before,
.login-method:active::before {
  width: 600rpx;
  height: 600rpx;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .login-header {
    margin-bottom: 60rpx;
  }
  
  .logo-icon {
    font-size: 64rpx;
  }
  
  .logo-text {
    font-size: 32rpx;
  }
  
  .login-title {
    font-size: 28rpx;
  }
  
  .login-subtitle {
    font-size: 20rpx;
  }
  
  .login-btn {
    height: 80rpx;
    border-radius: 40rpx;
  }
  
  .login-btn-text {
    font-size: 28rpx;
  }
  
  .login-methods {
    gap: 60rpx;
  }
  
  .method-icon {
    font-size: 40rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-header,
.login-content,
.login-footer {
  animation: fadeIn 0.6s ease-out forwards;
}

.login-header {
  animation-delay: 0.1s;
}

.login-content {
  animation-delay: 0.3s;
}

.login-footer {
  animation-delay: 0.5s;
}