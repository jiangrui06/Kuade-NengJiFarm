/* ─────────────────────────────────────────
   购物车样式 - 能记农场
   色系：稻田黄 #D4A76A | 丝苗米白 #FAF6F0
   ───────────────────────────────────────── */

   .container {
    min-height: 100vh;
    background-color: #FAF6F0;
    padding-bottom: 120rpx;
  }
  
  .container.fixed {
    overflow: hidden;
  }
  
  /* 空购物车提示 */
  .empty-cart {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120rpx 0;
    min-height: 50vh;
  }
  
  .empty-cart text {
    font-size: 28rpx;
    color: #999;
  }
  
  /* 全选栏 */
  .select-all-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 32rpx;
    background-color: #fff;
    border-bottom: 1rpx solid #FAF6F0;
  }
  
  .select-all {
    display: flex;
    align-items: center;
    gap: 16rpx;
  }
  
  .clear-cart {
    color: #999;
    font-size: 26rpx;
  }
  
  /* 勾选框样式 */
  .checkbox {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 16rpx;
  }
  
  .checkbox-circle {
    width: 40rpx;
    height: 40rpx;
    border-radius: 50%;
    border: 2rpx solid #D4A76A;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #fff;
    transition: all 0.3s ease;
  }
  
  .checkbox-circle.checked {
    background-color: #D4A76A;
    border-color: #D4A76A;
  }
  
  .checkbox-circle text {
    color: #fff;
    font-size: 24rpx;
    font-weight: bold;
  }

  /* 区域分组样式 */
  .region-section {
    margin: 0 24rpx;
    margin-bottom: 24rpx;
    border-radius: 16rpx;
    overflow: hidden;
    background-color: #fff;
    box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.08);
  }

  .region-header {
    display: flex;
    align-items: center;
    padding: 20rpx 24rpx;
    background-color: #FAF6F0;
    border-bottom: 1rpx solid #F0E6D2;
  }

  .region-checkbox {
    padding-right: 16rpx;
  }

  .region-title {
    display: flex;
    align-items: center;
    flex: 1;
  }

  .region-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
  }

  .region-count {
    font-size: 24rpx;
    color: #999;
    margin-left: 8rpx;
  }

  /* 到店吃选项 */
  .take-away-option {
    display: flex;
    align-items: center;
    margin-left: auto;
  }

  .take-away-option text {
    font-size: 24rpx;
    color: #666;
    margin-right: 8rpx;
  }

  .take-away-switch {
    transform: scale(0.8);
  }

  .region-items {
    padding: 0 24rpx 24rpx;
  }

  /* 商品项样式 */
  .cart-item {
    display: flex;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 1rpx solid #F5F5F5;
  }

  .cart-item:last-child {
    border-bottom: none;
  }

  .cart-item:first-child {
    padding-top: 24rpx;
  }
  
  /* 商品图片 */
  .item-img {
    width: 160rpx;
    height: 160rpx;
    border-radius: 12rpx;
    margin: 0 20rpx;
    background-color: #FAF6F0;
  }
  
  /* 商品信息 */
  .item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  
  .item-name {
    font-size: 28rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 8rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  
  .item-tag {
    font-size: 22rpx;
    color: #D4A76A;
    background-color: #FAF6F0;
    padding: 4rpx 12rpx;
    border-radius: 4rpx;
    display: inline-block;
    margin-bottom: 8rpx;
  }
  
  .item-price {
    font-size: 32rpx;
    font-weight: 600;
    color: #D4A76A;
  }
  
  .item-stock {
    font-size: 22rpx;
    color: #999;
    margin-top: 4rpx;
  }
  
  /* 数量加减 */
  .item-count {
    display: flex;
    align-items: center;
    background-color: #FAF6F0;
    border-radius: 32rpx;
    padding: 8rpx 16rpx;
    gap: 24rpx;
  }
  
  .count-btn {
    width: 56rpx;
    height: 56rpx;
    border-radius: 50%;
    background-color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 36rpx;
    color: #333;
    font-weight: 300;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  }
  
  .count-btn:active {
    background-color: #D4A76A;
    color: #fff;
  }
  
  .count-num {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
    min-width: 48rpx;
    text-align: center;
  }
  
  /* 底部结算栏 */
  .cart-bottom {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100rpx;
    background-color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32rpx;
    box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
    z-index: 100;
  }

  .left-section {
    display: flex;
    align-items: center;
  }

  .cart-badge {
    position: relative;
    margin-right: 20rpx;
  }

  .cart-icon {
    font-size: 56rpx;
  }

  .total-price {
    font-size: 28rpx;
    color: #333;
  }
  
  .total-price text {
    font-size: 32rpx;
    font-weight: 600;
    color: #D4A76A;
  }
  
  .settle-btn {
    background-color: #D4A76A;
    color: #fff;
    padding: 16rpx 48rpx;
    border-radius: 44rpx;
    font-size: 28rpx;
    font-weight: 500;
    box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.3);
  }
  
  .settle-btn:active {
    opacity: 0.9;
    transform: scale(0.98);
  }
  
  /* 弹窗样式 */
  .modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 200;
  }
  
  .modal-mask {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
  }
  
  .modal-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #fff;
    border-radius: 32rpx 32rpx 0 0;
    max-height: 80vh;
    overflow-y: auto;
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32rpx;
    border-bottom: 1rpx solid #FAF6F0;
  }
  
  .modal-title {
    font-size: 32rpx;
    font-weight: 600;
    color: #333;
  }
  
  .modal-close {
    padding: 8rpx;
  }
  
  .modal-body {
    padding: 24rpx 32rpx;
  }
  
  /* 商品详情列表 */
  /* 收货地址 */
  .address-section {
    background-color: #FAF6F0;
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 24rpx;
  }
  
  .address-header {
    margin-bottom: 20rpx;
  }
  
  .address-title {
    font-size: 30rpx;
    font-weight: 600;
    color: #333;
  }
  
  .address-list {
    margin-bottom: 0;
  }

  .address-item {
    background-color: #fff;
    border-radius: 12rpx;
    padding: 20rpx;
    margin-bottom: 16rpx;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    transition: all 0.3s ease;
    border: 2rpx solid transparent;
  }

  .address-item:last-child {
    margin-bottom: 0;
  }

  .address-item.active {
    border-color: #D4A76A;
    background-color: #FFFDF8;
  }

  .address-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .address-top-row {
    display: flex;
    align-items: center;
    margin-bottom: 8rpx;
  }

  .address-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
  }

  .default-tag {
    font-size: 18rpx;
    color: #fff;
    background-color: #D4A76A;
    padding: 4rpx 12rpx;
    border-radius: 6rpx;
    margin-left: 12rpx;
  }

  .address-phone {
    font-size: 26rpx;
    color: #666;
    margin-bottom: 8rpx;
  }
  
  .address-detail {
    font-size: 24rpx;
    color: #999;
    line-height: 1.5;
    word-break: break-all;
  }

  .address-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12rpx;
    margin-left: 16rpx;
    min-width: 100rpx;
  }

  .address-check-container {
    width: 40rpx;
    height: 40rpx;
    border-radius: 50%;
    border: 2rpx solid #D4A76A;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .address-item.active .address-check-container {
    background-color: #D4A76A;
  }

  .address-check {
    width: 40rpx;
    height: 40rpx;
    border-radius: 50%;
    background-color: #D4A76A;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24rpx;
    font-weight: bold;
  }

  .set-default-btn {
    font-size: 22rpx;
    color: #D4A76A;
    padding: 8rpx 20rpx;
    border: 1rpx solid #D4A76A;
    border-radius: 24rpx;
    background-color: #fff;
    transition: all 0.3s ease;
  }

  .set-default-btn:active {
    background-color: #FAF6F0;
  }

  .default-text {
    font-size: 22rpx;
    color: #999;
    padding: 8rpx 20rpx;
  }

  .cart-detail-list {
    max-height: 400rpx;
    overflow-y: auto;
  }
  
  .cart-detail-item {
    display: flex;
    align-items: center;
    padding: 20rpx 0;
    border-bottom: 1rpx solid #FAF6F0;
  }
  
  .cart-detail-item:last-child {
    border-bottom: none;
  }
  
  .detail-item-img {
    width: 100rpx;
    height: 100rpx;
    border-radius: 8rpx;
    margin-right: 20rpx;
    background-color: #FAF6F0;
  }
  
  .detail-item-info {
    flex: 1;
  }
  
  .detail-item-name {
    font-size: 26rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 8rpx;
  }
  
  .detail-item-tag {
    font-size: 22rpx;
    color: #D4A76A;
    background-color: #FAF6F0;
    padding: 4rpx 12rpx;
    border-radius: 4rpx;
    display: inline-block;
    margin-bottom: 8rpx;
  }
  
  .detail-item-price {
    font-size: 28rpx;
    font-weight: 600;
    color: #D4A76A;
  }
  
  .detail-item-quantity {
    font-size: 28rpx;
    color: #666;
    margin-left: 20rpx;
  }
  
  /* 订单信息 */
  .order-info {
    background-color: #FAF6F0;
    border-radius: 12rpx;
    padding: 20rpx;
    margin-top: 20rpx;
  }
  
  .info-item {
    display: flex;
    justify-content: space-between;
    padding: 8rpx 0;
  }
  
  .info-label {
    font-size: 26rpx;
    color: #666;
  }
  
  .info-value {
    font-size: 26rpx;
    color: #333;
    font-weight: 500;
  }
  
  .info-value.price {
    color: #D4A76A;
    font-weight: 600;
    font-size: 28rpx;
  }
  
  .confirm-text {
    text-align: center;
    font-size: 26rpx;
    color: #999;
    margin-top: 24rpx;
    padding: 20rpx;
    background-color: #FAF6F0;
    border-radius: 8rpx;
  }
  
  /* 弹窗按钮 */
  .modal-footer {
    display: flex;
    border-top: 1rpx solid #FAF6F0;
  }
  
  .modal-btn {
    flex: 1;
    padding: 28rpx;
    text-align: center;
    font-size: 30rpx;
    transition: all 0.3s ease;
  }
  
  .modal-btn.cancel {
    color: #666;
    background-color: #fff;
  }
  
  .modal-btn.cancel:active {
    background-color: #FAF6F0;
  }
  
  .modal-btn.confirm {
    color: #fff;
    background-color: #D4A76A;
    font-weight: 500;
  }
  
  .modal-btn.confirm:active {
    opacity: 0.9;
  }

  /* 分别结算弹窗样式 */
  .separate-settle-modal {
    max-height: 80vh;
    overflow-y: auto;
  }

  .settle-section {
    background-color: #FAF6F0;
    border-radius: 16rpx;
    padding: 0;
    margin-bottom: 24rpx;
    overflow: hidden;
  }

  .settle-section-header {
    display: flex;
    align-items: center;
    padding: 20rpx 24rpx;
    border-bottom: 1rpx solid #F0E6D2;
  }

  .section-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
    margin-right: 12rpx;
  }

  .section-tag {
    font-size: 20rpx;
    color: #fff;
    background-color: #D4A76A;
    padding: 4rpx 12rpx;
    border-radius: 4rpx;
  }

  .settle-content {
    padding: 20rpx 24rpx;
  }

  .settle-goods-preview {
    display: flex;
    align-items: center;
    margin-bottom: 12rpx;
  }

  .preview-img {
    width: 80rpx;
    height: 80rpx;
    border-radius: 8rpx;
    margin-right: 8rpx;
    background-color: #fff;
  }

  .preview-more {
    width: 80rpx;
    height: 80rpx;
    border-radius: 8rpx;
    background-color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-more text {
    font-size: 24rpx;
    color: #999;
  }

  .settle-section-desc {
    font-size: 24rpx;
    color: #666;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .settle-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16rpx 24rpx;
    background-color: #fff;
  }

  .settle-total {
    display: flex;
    align-items: baseline;
  }

  .settle-label {
    font-size: 24rpx;
    color: #666;
    margin-right: 8rpx;
  }

  .settle-price {
    font-size: 32rpx;
    font-weight: 600;
    color: #D4A76A;
  }

  .settle-btn {
    background-color: #D4A76A;
    color: #fff;
    border: none;
    border-radius: 40rpx;
    padding: 12rpx 40rpx;
    font-size: 26rpx;
    font-weight: 500;
    box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  }

  .settle-btn::after {
    border: none;
  }

  .settle-btn:active {
    opacity: 0.9;
    transform: scale(0.98);
  }