<view class="container {{showModal ? 'fixed' : ''}} {{showCartDetail ? 'fixed' : ''}}">
  <view class="cart-list">
    <!-- 空购物车提示 -->
    <view class="empty-cart" wx:if="{{cartList.length === 0}}">
      <text>购物车是空的，快去添加商品吧~</text>
    </view>

    <!-- 全选栏 -->
    <view class="select-all-bar" wx:if="{{cartList.length > 0}}">
      <view class="select-all" bindtap="handleSelectAll">
        <view class="checkbox-circle {{selectAll ? 'checked' : ''}}">
          <text wx:if="{{selectAll}}">✓</text>
        </view>
        <text>全选</text>
      </view>
      <view class="clear-cart" bindtap="handleClearCart">
        <text>清空</text>
      </view>
    </view>

    <!-- 类型分组 -->
    <!-- 点餐区域 -->
    <view class="region-section" wx:if="{{regions.food.items.length > 0}}">
      <!-- 区域头部 -->
      <view class="region-header" bindtap="toggleRegionSelect" data-region="food">
        <view class="region-checkbox">
          <view class="checkbox-circle {{regions.food.selected ? 'checked' : ''}}">
            <text wx:if="{{regions.food.selected}}">✓</text>
          </view>
        </view>
        <view class="region-title">
          <text class="region-name">{{regions.food.name}}</text>
          <text class="region-count">（{{regions.food.items.length}}件）</text>
        </view>
        <!-- 到店吃选项 -->
        <view class="take-away-option">
          <text>到店吃</text>
          <switch class="take-away-switch" bindchange="toggleTakeAway" checked="{{isTakeAway}}" />
        </view>
      </view>
      <!-- 区域商品 -->
      <view class="region-items">
        <view class="cart-item" wx:for="{{regions.food.items}}" wx:key="id">
          <!-- 勾选框：空心圆样式 -->
          <view class="checkbox" bindtap="toggleSelect" data-id="{{item.id}}">
            <view class="checkbox-circle {{item.checked ? 'checked' : ''}}">
              <text wx:if="{{item.checked}}">✓</text>
            </view>
          </view>

          <!-- 商品图片 -->
          <image class="item-img" src="{{item.image}}" mode="aspectFill"></image>

          <!-- 商品信息 -->
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
            <view class="item-tag">{{item.tag}}</view>
            <view class="item-price">￥{{item.price}}</view>
            <view class="item-stock" wx:if="{{item.stock}}">仅剩{{item.stock}}件</view>
          </view>

          <!-- 数量加减 -->
          <view class="item-count">
            <view class="count-btn" bindtap="handleMinus" data-id="{{item.id}}">-</view>
            <view class="count-num">{{item.count}}</view>
            <view class="count-btn" bindtap="handlePlus" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 商品区域 -->
    <view class="region-section" wx:if="{{regions.goods.items.length > 0}}">
      <!-- 区域头部 -->
      <view class="region-header" bindtap="toggleRegionSelect" data-region="goods">
        <view class="region-checkbox">
          <view class="checkbox-circle {{regions.goods.selected ? 'checked' : ''}}">
            <text wx:if="{{regions.goods.selected}}">✓</text>
          </view>
        </view>
        <view class="region-title">
          <text class="region-name">{{regions.goods.name}}</text>
          <text class="region-count">（{{regions.goods.items.length}}件）</text>
        </view>
      </view>
      <!-- 区域商品 -->
      <view class="region-items">
        <view class="cart-item" wx:for="{{regions.goods.items}}" wx:key="id">
          <!-- 勾选框：空心圆样式 -->
          <view class="checkbox" bindtap="toggleSelect" data-id="{{item.id}}">
            <view class="checkbox-circle {{item.checked ? 'checked' : ''}}">
              <text wx:if="{{item.checked}}">✓</text>
            </view>
          </view>

          <!-- 商品图片 -->
          <image class="item-img" src="{{item.image}}" mode="aspectFill"></image>

          <!-- 商品信息 -->
          <view class="item-info">
            <view class="item-name">{{item.name}}</view>
            <view class="item-tag">{{item.tag}}</view>
            <view class="item-price">￥{{item.price}}</view>
            <view class="item-stock" wx:if="{{item.stock}}">仅剩{{item.stock}}件</view>
          </view>

          <!-- 数量加减 -->
          <view class="item-count">
            <view class="count-btn" bindtap="handleMinus" data-id="{{item.id}}">-</view>
            <view class="count-num">{{item.count}}</view>
            <view class="count-btn" bindtap="handlePlus" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 3. 底部结算栏 -->
  <view class="cart-bottom">
    <view class="left-section">
      <view class="cart-badge" bindtap="handleCartIconClick">
        <text class="cart-icon">🛒</text>
      </view>
      <view class="total-price">合计: ￥{{totalPrice}}</view>
    </view>
    <view class="settle-btn" bindtap="handleSettle">
      {{selectedCount > 0 ? '结算(' + selectedCount + ')' : '结算'}}
    </view>
  </view>

</view>

<!-- 🌟 结算弹窗：是否确认购买 -->
<view class="modal" wx:if="{{showModal}}">
  <view class="modal-mask" bindtap="handleCancelModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">确认购买</text>
      <icon class="modal-close" type="clear" size="20" color="#999" bindtap="handleCancelModal"></icon>
    </view>
    <view class="modal-body">
      <!-- 收货地址 -->
      <view class="address-section">
        <view class="address-header">
          <text class="address-title">收货地址</text>
        </view>
        <view wx:if="{{addressList.length > 0}}">
          <view class="address-list">
            <view class="address-item {{selectedAddress === item.id ? 'active' : ''}}" 
                  wx:for="{{addressList}}" 
                  wx:key="id" 
                  bindtap="selectAddress" 
                  data-id="{{item.id}}">
              <view class="address-info">
                <view class="address-name">{{item.name}}</view>
                <view class="address-phone">{{item.phone}}</view>
                <view class="address-detail">{{item.address}}</view>
              </view>
              <view class="address-check-container">
                <view class="address-check" wx:if="{{selectedAddress === item.id}}">✓</view>
              </view>
            </view>
          </view>
        </view>
        <view wx:else class="no-address">
          <button class="add-address-btn" bindtap="addAddress">添加新地址</button>
        </view>
      </view>
      
      <!-- 区域商品详细信息 -->
      <!-- 点餐区域 -->
      <view wx:if="{{regions.food.selected}}">
        <view class="cart-detail-list">
          <view class="cart-detail-item" wx:for="{{regions.food.items}}" wx:key="id" wx:if="{{item.checked}}">
            <image class="detail-item-img" src="{{item.image}}" mode="aspectFill"></image>
            <view class="detail-item-info">
              <view class="detail-item-name">{{item.name}}</view>
              <view class="detail-item-tag">{{item.tag}}</view>
              <view class="detail-item-price">￥{{item.price}}</view>
            </view>
            <view class="detail-item-quantity">×{{item.count}}</view>
          </view>
        </view>
      </view>

      <!-- 商品区域 -->
      <view wx:if="{{regions.goods.selected}}">
        <view class="cart-detail-list">
          <view class="cart-detail-item" wx:for="{{regions.goods.items}}" wx:key="id" wx:if="{{item.checked}}">
            <image class="detail-item-img" src="{{item.image}}" mode="aspectFill"></image>
            <view class="detail-item-info">
              <view class="detail-item-name">{{item.name}}</view>
              <view class="detail-item-tag">{{item.tag}}</view>
              <view class="detail-item-price">￥{{item.price}}</view>
            </view>
            <view class="detail-item-quantity">×{{item.count}}</view>
          </view>
        </view>
      </view>
      
      <!-- 分别结算提示 -->
      <view class="settle-tip" wx:if="{{regions.food.selected && regions.goods.selected}}">
        <text>请分别结算以下类型</text>
      </view>
      
      <!-- 订单信息 -->
      <view class="order-info">
        <view class="info-item">
          <text class="info-label">商品数量：</text>
          <text class="info-value">{{selectedCount}}件</text>
        </view>
        <view class="info-item">
          <text class="info-label">合计金额：</text>
          <text class="info-value price">￥{{totalPrice}}</text>
        </view>
      </view>
      <view class="confirm-text">确认购买以上商品吗？</view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="handleCancelModal">取消</view>
      <view class="modal-btn confirm" bindtap="handleConfirmPurchase">确认购买</view>
    </view>
  </view>
</view>

<!-- 🌟 购物车详情弹窗 -->
<view class="modal" wx:if="{{showCartDetail}}">
  <view class="modal-mask" bindtap="handleCloseCartDetail"></view>
  <view class="modal-content cart-detail-modal">
    <view class="modal-header">
      <text class="modal-title">购物车详情</text>
      <icon class="modal-close" type="clear" size="20" color="#999" bindtap="handleCloseCartDetail"></icon>
    </view>
    <view class="modal-body">
      <!-- 商品详细信息 -->
      <view class="cart-detail-list">
        <view class="cart-detail-item" wx:for="{{cartList}}" wx:key="id">
          <image class="detail-item-img" src="{{item.image}}" mode="aspectFill"></image>
          <view class="detail-item-info">
            <view class="detail-item-name">{{item.name}}</view>
            <view class="detail-item-tag">{{item.tag}}</view>
            <view class="detail-item-price">￥{{item.price}}</view>
            <view class="detail-item-stock" wx:if="{{item.stock}}">仅剩{{item.stock}}件</view>
          </view>
          <view class="detail-item-quantity">×{{item.count}}</view>
        </view>
      </view>
      
      <!-- 合计信息 -->
      <view class="cart-detail-total">
        <text class="total-label">合计：</text>
        <text class="total-price">￥{{totalPrice}}</text>
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="handleCloseCartDetail">关闭</view>
      <view class="modal-btn confirm" bindtap="handleSettle">去结算</view>
    </view>
  </view>
</view>

<!-- 🌟 分别结算弹窗 -->
<view class="modal" wx:if="{{showSeparateSettleModal}}">
  <view class="modal-mask" bindtap="handleCloseSeparateSettleModal"></view>
  <view class="modal-content separate-settle-modal">
    <view class="modal-header">
      <text class="modal-title">请分别结算以下类型</text>
      <icon class="modal-close" type="clear" size="20" color="#999" bindtap="handleCloseSeparateSettleModal"></icon>
    </view>
    <view class="modal-body">
      <!-- 点餐区域 -->
      <view class="settle-section" wx:if="{{regions.food.selected}}">
        <view class="settle-section-header">
          <text class="section-name">{{regions.food.name}}</text>
          <text class="section-tag">{{isTakeAway ? '到店吃' : '外卖'}}</text>
        </view>
        <view class="settle-content">
          <view class="settle-goods-preview">
            <image 
              class="preview-img" 
              wx:for="{{regions.food.previewImages}}" 
              wx:key="index" 
              src="{{item}}" 
              mode="aspectFill">
            </image>
            <view class="preview-more" wx:if="{{regions.food.moreCount > 0}}">
              <text>+{{regions.food.moreCount}}</text>
            </view>
          </view>
          <view class="settle-section-desc">{{regions.food.checkedItemNames.join('、')}}</view>
        </view>
        <view class="settle-footer">
          <view class="settle-total">
            <text class="settle-label">合计:</text>
            <text class="settle-price">￥{{regions.food.totalPrice}}</text>
          </view>
          <button class="settle-btn" bindtap="settleFood">结算</button>
        </view>
      </view>

      <!-- 商品区域 -->
      <view class="settle-section" wx:if="{{regions.goods.selected}}">
        <view class="settle-section-header">
          <text class="section-name">{{regions.goods.name}}</text>
          <text class="section-tag">配送</text>
        </view>
        <view class="settle-content">
          <view class="settle-goods-preview">
            <image 
              class="preview-img" 
              wx:for="{{regions.goods.previewImages}}" 
              wx:key="index" 
              src="{{item}}" 
              mode="aspectFill">
            </image>
            <view class="preview-more" wx:if="{{regions.goods.moreCount > 0}}">
              <text>+{{regions.goods.moreCount}}</text>
            </view>
          </view>
          <view class="settle-section-desc">{{regions.goods.checkedItemNames.join('、')}}</view>
        </view>
        <view class="settle-footer">
          <view class="settle-total">
            <text class="settle-label">合计:</text>
            <text class="settle-price">￥{{regions.goods.totalPrice}}</text>
          </view>
          <button class="settle-btn" bindtap="settleGoods">结算</button>
        </view>
      </view>
    </view>
  </view>
</view>