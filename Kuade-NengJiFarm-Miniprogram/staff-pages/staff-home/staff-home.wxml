<view class="staff-page">
  <!-- 顶部信息栏 -->
  <view class="staff-header">
    <view class="header-bg"></view>
    <view class="header-decor-circle1"></view>
    <view class="header-decor-circle2"></view>
    <view class="header-content">
      <view class="avatar-wrap">
        <text class="avatar-emoji">👷</text>
      </view>
      <view class="header-info">
        <view class="name-row">
          <text class="staff-name">{{staffName || '员工'}}</text>
          <view class="role-badge">员工端</view>
        </view>
        <text class="staff-greeting">今天也要加油哦 💪</text>
      </view>
      <view class="logout-btn" bindtap="logout">
        <text class="logout-text">退出</text>
      </view>
    </view>
  </view>

  <!-- 今日数据卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <view class="stat-info">
        <text class="stat-number">{{todayVerifyCount}}</text>
        <text class="stat-label">今日核销</text>
      </view>
    </view>
  </view>

  <!-- 核心功能 -->
  <view class="work-section">
    <view class="section-title">
      <view class="title-bar"></view>
      <text>核心功能</text>
    </view>
    <view class="work-grid">
      <!-- 核销券类 -->
      <view class="work-item verify-card" bindtap="goToVerify">
        <view class="work-icon-wrap verify-gradient">
          <text class="work-emoji">🎫</text>
        </view>
        <view class="work-info">
          <text class="work-text">核销券类</text>
          <text class="work-desc">采摘券 / 活动券核销</text>
        </view>
        <text class="work-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 底部导航栏（手动模拟 tabBar） -->
  <view class="custom-bottom-bar">
    <view class="bar-item selected">
      <image class="bar-icon" src="/images/rroom.png" mode="aspectFit" />
      <text class="bar-text bar-text-active">工作台</text>
    </view>
    <view class="bar-item" bindtap="goToProfile">
      <image class="bar-icon" src="/images/user.png" mode="aspectFit" />
      <text class="bar-text">我的</text>
    </view>
  </view>
</view>
