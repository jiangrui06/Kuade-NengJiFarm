.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(120rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #FAF6F0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #EDE8DD;
  z-index: 9999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0 16rpx;
}

.tab-icon {
  width: 52rpx !important;
  height: 52rpx !important;
  margin-bottom: 10rpx;
  display: block;
}

.tab-text {
  font-size: 22rpx;
  color: #B8A98E;
  line-height: 1.2;
}

.selected .tab-text {
  color: #D4A76A;
  font-weight: 600;
}
