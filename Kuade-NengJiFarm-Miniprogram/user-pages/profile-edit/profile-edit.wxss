.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 内容区域 */
.content {
  padding: 20rpx;
  margin: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
  margin-bottom: 140rpx;
}

/* 表单项 */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 30rpx;
  color: #333;
  width: 160rpx;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 30rpx;
  color: #666;
  text-align: right;
  padding-right: 10rpx;
}

/* 头像按钮 */
.avatar-button {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.2);
}

/* 头像 */
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  object-fit: cover;
}

/* 昵称按钮 */
.nickname-button {
  flex: 1;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* 手机号按钮 */
.phone-button {
  flex: 1;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

/* 性别选择 */
.gender-select {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #FAF6F0 0%, #F5F0E6 100%);
  border-radius: 20rpx;
}

.gender-text {
  font-size: 28rpx;
  color: #D4A76A;
  margin-right: 10rpx;
  font-weight: 500;
}

.gender-arrow {
  font-size: 24rpx;
  color: #D4A76A;
}

/* 保存按钮 */
.save-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -4rpx 16rpx rgba(212, 167, 106, 0.3);
}

.save-btn:active {
  background: linear-gradient(135deg, #C99A5A 0%, #B8894A 100%);
}

.save-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 输入框占位符样式 */
input::placeholder {
  color: #999;
  font-size: 28rpx;
}
