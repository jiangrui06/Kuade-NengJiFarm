<!-- 确认订单页面 -->
<view class="container">
  <!-- 点餐显示桌号，商品显示地址 -->
  <view wx:if="{{orderType === 'food'}}" class="table-number-display" bindtap="showTableModal">
    <text class="table-label">桌号：</text>
    <text class="table-value {{tableNumber ? '' : 'placeholder'}}">{{tableNumber || '请选择'}}</text>
    <text class="arrow">▼</text>
  </view>

  <view wx:if="{{orderType === 'goods'}}" class="address-section">
    <view class="address-header">
      <text class="section-title">收货地址</text>
      <text class="select-more-address" bindtap="toggleAddressList" wx:if="{{addressList.length > 1}}">选择更多地址</text>
    </view>
    <!-- 展开全部地址 -->
    <view class="address-list" wx:if="{{showAllAddresses}}">
      <view class="address-item {{selectedAddress === item.id ? 'active' : ''}}" 
            wx:for="{{addressList}}" 
            wx:key="id">
        <view class="address-info" bindtap="selectAddress" data-id="{{item.id}}">
          <view class="address-top-row">
            <text class="address-name">{{item.name}}</text>
            <text wx:if="{{item.isDefault}}" class="default-tag">默认</text>
          </view>
          <text class="address-phone">{{item.phone}}</text>
          <text class="address-detail">{{item.address}}</text>
        </view>
        <view class="address-actions">
          <view class="address-check-container">
            <text wx:if="{{selectedAddress === item.id}}" class="address-check">✓</text>
          </view>
          <view class="edit-address-btn" 
                bindtap="editAddress" 
                data-id="{{item.id}}">
            <text>编辑</text>
          </view>
        </view>
      </view>
      <button class="add-address-btn" bindtap="addAddress">添加地址</button>
    </view>
    <!-- 默认只显示一条地址 -->
    <view class="address-list" wx:else>
      <view wx:if="{{defaultAddress}}">
        <view class="address-item active">
          <view class="address-info">
            <view class="address-top-row">
              <text class="address-name">{{defaultAddress.name}}</text>
              <text wx:if="{{defaultAddress.isDefault}}" class="default-tag">默认</text>
            </view>
            <text class="address-phone">{{defaultAddress.phone}}</text>
            <text class="address-detail">{{defaultAddress.address}}</text>
          </view>
          <view class="address-actions">
            <view class="address-check-container">
              <text class="address-check">✓</text>
            </view>
            <view class="edit-address-btn" 
                  bindtap="editAddress" 
                  data-id="{{defaultAddress.id}}">
              <text>编辑</text>
            </view>
          </view>
        </view>
      </view>
      <view wx:else class="no-address">
        <text class="no-address-text">请添加收货地址</text>
        <button class="add-address-btn" bindtap="addAddress">添加地址</button>
      </view>
    </view>
  </view>

  <!-- 订单商品列表 -->
  <view class="order-items">
    <view class="section-title">商品信息</view>
    <view wx:for="{{orderInfo.items}}" wx:key="id" class="order-item">
      <image class="item-image" src="{{item.image}}" />
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-price">￥{{item.price}}</view>
      </view>
      <view class="item-quantity">x{{orderType === 'food' ? item.quantity : item.count}}</view>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section">
    <view class="section-title">支付方式</view>
    <view wx:for="{{paymentMethods}}" wx:key="id" 
          class="payment-item {{selectedPayment === item.id ? 'selected' : ''}}"
          bindtap="selectPayment" data-id="{{item.id}}">
      <view class="payment-icon">{{item.icon}}</view>
      <view class="payment-name">{{item.name}}</view>
      <view class="payment-check" wx:if="{{selectedPayment === item.id}}">✓</view>
    </view>
  </view>

  <!-- 订单汇总 -->
  <view class="order-summary">
    <view class="summary-item">
      <text>商品数量</text>
      <text>{{orderInfo.totalCount}}件</text>
    </view>
    <view class="summary-item">
      <text>合计</text>
      <text class="total-price">￥{{orderInfo.totalPrice}}</text>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="total-info">
      <text>合计：</text>
      <text class="total-price">￥{{orderInfo.totalPrice}}</text>
    </view>
    <button class="confirm-btn" bindtap="confirmOrder" disabled="{{loading}}">
      确认订单
    </button>
  </view>

  <!-- 桌台选择弹窗 -->
  <view class="table-modal" wx:if="{{showTableModal && orderType === 'food'}}">
    <view class="table-modal-content">
      <view class="table-modal-header">
        <text class="table-modal-title">选择桌台</text>
        <view class="table-modal-close" bindtap="hideTableModal">×</view>
      </view>
      <view class="table-modal-body">
        <view class="table-grid">
          <view
            wx:for="{{tableList}}"
            wx:key="id"
            class="table-item {{tableNumber === item.id ? 'selected' : ''}}"
            bindtap="selectTableNumber"
            data-table-id="{{item.id}}"
          >
            {{item.name}}
          </view>
        </view>
      </view>
    </view>
  </view>

<!-- 加载遮罩 -->
<view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <view class="loading-text">处理中...</view>
    </view>
  </view>
</view>
