.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索头部 */
.search-header {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background-color: #fff;
  border-bottom: 2rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 64rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  border: none;
  outline: none;
  background: transparent;
  padding-right: 16rpx;
}

.search-input::placeholder {
  color: #999;
  font-size: 26rpx;
}

.search-btn {
  font-size: 28rpx;
  color: #d4a76a;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.search-btn:active {
  background-color: rgba(212, 167, 106, 0.1);
  transform: scale(0.95);
}

.cancel-btn {
  margin-left: 24rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  transition: all 0.3s ease;
}

.cancel-btn:active {
  color: #d4a76a;
  transform: scale(0.95);
}

/* 搜索历史 */
.search-history {
  background-color: #fff;
  margin: 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.clear-history {
  font-size: 24rpx;
  color: #999;
  transition: all 0.3s ease;
}

.clear-history:active {
  color: #d4a76a;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-tag {
  font-size: 24rpx;
  color: #666;
  background-color: #f8f8f8;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  transition: all 0.3s ease;
}

.history-tag:active {
  background-color: #f0e6d2;
  color: #d4a76a;
  transform: scale(0.95);
}

/* 搜索结果 */
.search-results {
  background-color: #fff;
  margin: 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.results-header {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.results-header text {
  font-size: 26rpx;
  color: #666;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goods-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.goods-item:active {
  background-color: #f0f0f0;
  transform: translateY(-2rpx);
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  object-fit: cover;
  background-color: #f0f0f0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 20rpx;
  color: #d4a76a;
  background-color: #f0e6d2;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #e63e3e;
  margin-bottom: 4rpx;
}

.goods-original-price {
  font-size: 24rpx;
  font-weight: 400;
  color: #999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.goods-stock {
  font-size: 22rpx;
  color: #999;
}

/* 搜索中 */
.searching {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 无结果 */
.no-results {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 150rpx 0;
  color: #999;
  font-size: 28rpx;
}

.no-results-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.4;
}

.no-results-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.no-results-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 响应式设计 */
@media (max-width: 375rpx) {
  .search-header {
    padding: 12rpx 24rpx;
  }
  
  .search-box {
    height: 56rpx;
    padding: 0 20rpx;
  }
  
  .search-input {
    font-size: 26rpx;
  }
  
  .search-btn {
    font-size: 26rpx;
  }
  
  .cancel-btn {
    font-size: 26rpx;
    margin-left: 20rpx;
  }
  
  .search-history,
  .search-results {
    margin: 12rpx;
    padding: 20rpx;
  }
  
  .goods-image {
    width: 140rpx;
    height: 140rpx;
  }
}
