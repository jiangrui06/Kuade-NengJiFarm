.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #f8f5e9;
}

.status-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.loading-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  animation: spin 2s linear infinite;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #d4a76a;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.failed-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #d4a76a;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.price {
  font-size: 48rpx;
  font-weight: bold;
  color: #d4a76a;
  margin-bottom: 48rpx;
}

.view-order-btn,
.retry-btn,
.complete-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.view-order-btn {
  background-color: #d4a76a;
  color: white;
}

.complete-btn {
  background-color: #d4a76a;
  color: white;
}

.retry-btn {
  background-color: #d4a76a;
  color: white;
  margin-bottom: 0;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
