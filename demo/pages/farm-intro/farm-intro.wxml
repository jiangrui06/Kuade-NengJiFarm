<view class="container">
  <image class="background-image" src="/images/NengJi5.jpg" mode="aspectFill" />

  <!-- 加载中提示 -->
  <view wx:if="{{loading}}" class="loading-container">
    <text>加载中...</text>
  </view>
  
  <!-- 农场信息 -->
  <view wx:else>
    <!-- 农场主图 -->
    <view class="main-image-container">
      <image class="main-image" src="{{farmInfo.mainImage}}" mode="aspectFill" />
    </view>
    
    <!-- 农场简介 -->
    <view class="section">
      <view class="section-title">农场简介</view>
      <view class="section-content">
        <text class="content-text">{{farmInfo.introduction}}</text>
      </view>
    </view>
    
 
    
    <!-- 农场理念 -->
    <view class="section">
      <view class="section-title">农场理念</view>
      <view class="section-content">
        <text class="content-text">{{farmInfo.philosophy}}</text>
      </view>
    </view>
    
    <!-- 联系方式 -->
    <view class="section">
      <view class="section-title">联系方式</view>
      <view class="contact-info">
        <view class="contact-item">
          <text class="contact-label">地址：</text>
          <text class="contact-value">{{farmInfo.contact.address}}</text>
        </view>
        <view class="contact-item">
          <text class="contact-label">电话：</text>
          <text class="contact-value">{{farmInfo.contact.phone}}</text>
        </view>
        <view class="contact-item">
          <text class="contact-label">邮箱：</text>
          <text class="contact-value">{{farmInfo.contact.email}}</text>
        </view>
      </view>
    </view>
  </view>
</view>