.container {
  padding: 0;
  margin: 0;
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 背景图 */
.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  object-fit: cover;
}

/* 内容容器 */
.content-wrapper {
  padding: 20rpx;
  min-height: 100vh;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 24rpx;
  color: #999;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-top: 0;
  margin-bottom: 0;
  color: #333;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
}

.main-image-container {
  margin-bottom: 0;
  border-radius: 0;
  overflow: hidden;
  box-shadow: none;
}

.main-image {
  width: 100%;
  height: 500rpx;
  display: block;
}

.section {
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 0;
  padding: 20rpx;
  margin-bottom: 0;
  box-shadow: none;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #d4a76a; /* 稻田黄 */
  border-left: 6rpx solid #d4a76a; /* 稻田黄 */
  padding-left: 15rpx;
}

.section-content {
  font-size: 24rpx;
  line-height: 40rpx;
  color: #666;
}

.feature-list {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.feature-item {
  flex: 1;
  text-align: center;
  margin: 0 10rpx;
}

.feature-image {
  width: 100%;
  height: 150rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.feature-text {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.contact-info {
  margin-top: 10rpx;
}

.contact-item {
  font-size: 24rpx;
  margin-bottom: 10rpx;
  color: #666;
}

.contact-label {
  font-weight: 500;
  color: #333;
}

.contact-value {
  margin-left: 10rpx;
}

/* 农场图片展示 */
.farm-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.farm-image {
  width: 48%;
  height: 200rpx;
  border-radius: 8rpx;
  object-fit: cover;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.farm-image:nth-child(2n+1) {
  margin-right: 4%;
}

/* 推荐图片 */
.recommend-section {
  margin: 20rpx 0;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.recommend-image {
  width: 100%;
  height: 300rpx;
  display: block;
}