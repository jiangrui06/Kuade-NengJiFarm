.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

/* 登录页面标题 */
.login-header {
  text-align: center;
  margin-top: 120rpx;
  margin-bottom: 80rpx;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.logo-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #e64340;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #999;
}

/* 登录内容 */
.login-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 一键登录按钮 */
.login-btn {
  width: 100%;
  height: 90rpx;
  background-color: #e64340;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.3);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.login-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(230, 67, 64, 0.4);
  background-color: #d53a37;
}

.login-btn:active {
  transform: translateY(0);
  box-shadow: 0 4rpx 16rpx rgba(230, 67, 64, 0.3);
}

.login-btn-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

/* 其他登录方式 */
.other-login {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-login-text {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 32rpx;
  position: relative;
}

.other-login-text::before,
.other-login-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 120rpx;
  height: 1rpx;
  background-color: #e0e0e0;
}

.other-login-text::before {
  left: -140rpx;
}

.other-login-text::after {
  right: -140rpx;
}

.login-methods {
  display: flex;
  justify-content: center;
  gap: 80rpx;
}

.login-method {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  padding: 20rpx;
  border-radius: 12rpx;
}

.login-method:hover {
  background-color: #f0f0f0;
  transform: translateY(-4rpx);
}

.method-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.method-text {
  font-size: 20rpx;
  color: #666;
}

/* 底部协议 */
.login-footer {
  margin-top: auto;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  font-size: 18rpx;
  color: #999;
}

.agreement-link {
  color: #e64340;
  margin: 0 8rpx;
}

/* 按钮点击效果 */
.login-btn::before,
.login-method::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.login-btn:active::before,
.login-method:active::before {
  width: 600rpx;
  height: 600rpx;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .login-header {
    margin-top: 80rpx;
    margin-bottom: 60rpx;
  }
  
  .logo-icon {
    font-size: 64rpx;
  }
  
  .logo-text {
    font-size: 32rpx;
  }
  
  .login-title {
    font-size: 28rpx;
  }
  
  .login-subtitle {
    font-size: 20rpx;
  }
  
  .login-btn {
    height: 80rpx;
    border-radius: 40rpx;
  }
  
  .login-btn-text {
    font-size: 28rpx;
  }
  
  .login-methods {
    gap: 60rpx;
  }
  
  .method-icon {
    font-size: 40rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-header,
.login-content,
.login-footer {
  animation: fadeIn 0.6s ease-out forwards;
}

.login-header {
  animation-delay: 0.1s;
}

.login-content {
  animation-delay: 0.3s;
}

.login-footer {
  animation-delay: 0.5s;
}