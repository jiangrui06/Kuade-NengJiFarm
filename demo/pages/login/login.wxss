.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 40rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 背景层 */
.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
}

.bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    160deg,
    rgba(30, 60, 40, 0.6) 0%,
    rgba(20, 45, 30, 0.75) 40%,
    rgba(10, 30, 20, 0.85) 100%
  );
}

/* 装饰元素 */
.decorations {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}

.sun {
  position: absolute;
  top: 80rpx;
  right: 60rpx;
  width: 80rpx;
  height: 80rpx;
  background: radial-gradient(circle, rgba(255, 220, 100, 0.9) 0%, rgba(255, 200, 50, 0.6) 50%, transparent 70%);
  border-radius: 50%;
  animation: sunPulse 4s ease-in-out infinite;
}

@keyframes sunPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.8;
  }
  50% {
    transform: scale(1.1);
    opacity: 1;
  }
}

/* 登录页面标题 */
.login-header {
  text-align: center;
  margin-bottom: 60rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

/* 登录卡片 */
.login-card {
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 32rpx;
  padding: 60rpx 50rpx;
  width: 100%;
  max-width: 620rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 2;
  transition: all 0.3s ease;
}

.login-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #e64340, transparent);
  border-radius: 32rpx 32rpx 0 0;
}

.login-card:hover {
  box-shadow: 0 25rpx 80rpx rgba(0, 0, 0, 0.2);
  transform: translateY(-8rpx);
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  gap: 20rpx;
}

.logo-icon {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.logo-text-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.logo-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #e64340;
  letter-spacing: 2rpx;
}

.logo-en {
  font-size: 20rpx;
  color: #999;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.login-subtitle {
  font-size: 24rpx;
  color: #888;
}

/* 登录内容 */
.login-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
}

/* 一键登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #e64340 0%, #ff6b6b 50%, #e64340 100%);
  background-size: 200% 200%;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(230, 67, 64, 0.4);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  border: none;
  outline: none;
  animation: btnGradient 3s ease infinite;
}

@keyframes btnGradient {
  0%, 100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

.login-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx rgba(230, 67, 64, 0.5);
}

.login-btn:active {
  transform: translateY(0);
  box-shadow: 0 6rpx 20rpx rgba(230, 67, 64, 0.3);
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  0% {
    left: -100%;
  }
  100% {
    left: 100%;
  }
}

.login-btn-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.login-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}

/* 其他登录方式 */
.other-login {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.other-login-text {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 32rpx;
  position: relative;
}

.other-login-text::before,
.other-login-text::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 120rpx;
  height: 1rpx;
  background-color: #e0e0e0;
}

.other-login-text::before {
  left: -140rpx;
}

.other-login-text::after {
  right: -140rpx;
}

.login-methods {
  display: flex;
  justify-content: center;
  gap: 80rpx;
}

.login-method {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
  padding: 20rpx;
  border-radius: 12rpx;
  background: transparent;
  border: none;
  line-height: normal;
}

.login-method::after {
  border: none;
}

.login-method:hover {
  background-color: rgba(240, 240, 240, 0.5);
  transform: translateY(-4rpx);
}

.method-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.method-text {
  font-size: 20rpx;
  color: #666;
}

/* 底部协议 */
.login-footer {
  margin-top: 40rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  width: 100%;
  text-align: center;
  flex-wrap: wrap;
  gap: 8rpx;
  line-height: 1.6;
  position: relative;
  z-index: 2;
}

.agreement-link {
  color: #ffdd57;
  margin: 0 6rpx;
  text-decoration: none;
  transition: all 0.3s ease;
}

.agreement-link:hover {
  color: #fff;
  text-shadow: 0 0 10rpx rgba(255, 221, 87, 0.5);
}

/* 版本信息 */
.version-info {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  z-index: 2;
}

/* 动画效果 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.login-header {
  animation: fadeInUp 0.6s ease-out forwards;
}

.login-content {
  animation: fadeInUp 0.6s ease-out 0.2s forwards;
  opacity: 0;
}

.login-footer {
  animation: fadeInUp 0.6s ease-out 0.4s forwards;
  opacity: 0;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .login-card {
    padding: 50rpx 40rpx;
  }
  
  .logo-icon {
    font-size: 64rpx;
  }
  
  .logo-text {
    font-size: 36rpx;
  }
  
  .login-title {
    font-size: 30rpx;
  }
  
  .login-subtitle {
    font-size: 22rpx;
  }
  
  .login-btn {
    height: 88rpx;
    border-radius: 44rpx;
  }
  
  .login-btn-text {
    font-size: 30rpx;
  }
}