.container {
  padding: 0;
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 10px 15px;
  background-color: #f5f5f5;
  border-bottom: 1px solid #e0e0e0;
}

.search-input {
  flex: 1;
  height: 36px;
  background-color: #fff;
  border-radius: 18px;
  padding: 0 15px;
  font-size: 14px;
  border: 1px solid #e0e0e0;
}

.search-btn {
  margin-left: 10px;
  padding: 6px 15px;
  background-color: #2196F3;
  color: #fff;
  border-radius: 18px;
  font-size: 14px;
  font-weight: 500;
}

/* 选项卡样式 */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 15px;
  border-bottom: 1px solid #f0f0f0;
}

.tab {
  flex: 1;
  padding: 15px 0;
  text-align: center;
  font-size: 14px;
  color: #666;
  position: relative;
}

.tab.active {
  color: #2196F3;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 2px;
  background-color: #2196F3;
}

/* 活动列表样式 */
.activity-list {
  padding: 15px;
}

.activity-item {
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 15px;
}

.activity-image {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.activity-info {
  padding: 15px;
}

.activity-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 10px;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
}

.activity-price {
  color: #e64340;
}

.activity-date {
  color: #999;
}