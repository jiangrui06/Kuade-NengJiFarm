.container {
  padding: 0;
}

/* 选项卡样式 */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 15px;
  border-bottom: 1px solid #f0f0f0;
}

.tab {
  flex: 1;
  padding: 15px 0;
  text-align: center;
  font-size: 14px;
  color: #666;
  position: relative;
}

.tab.active {
  color: #2196F3;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 2px;
  background-color: #2196F3;
}

/* 活动列表样式 */
.activity-list {
  padding: 15px;
}

.activity-item {
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 15px;
}

.activity-image {
  width: 100%;
  height: 180px;
  object-fit: cover;
}

.activity-info {
  padding: 15px;
}

.activity-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 10px;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
}

.activity-price {
  color: #e64340;
}

.activity-date {
  color: #999;
}