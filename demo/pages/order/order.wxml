<!-- 商店信息 -->
<view class="shop-info">
  <view class="shop-header">
    <view class="shop-name">
      <text class="icon">📍</text>
      农场直购
    </view>
    <text class="shop-hours">00:00-23:59</text>
  </view>
  <view class="shop-info-row">
    <view class="table-info">
      <text class="table-label">桌台号码：</text>
      <text class="table-number" bindtap="selectTable">{{tableNumber || '请选择'}}</text>
    </view>
    <view class="contact-buttons">
      <text class="contact-btn" bindtap="testScanCode">测试扫码</text>
      <text class="contact-btn">联系商家</text>
    </view>
  </view>
</view>

<!-- 桌台选择弹窗 -->
<view class="table-modal" wx:if="{{showTableModal}}">
  <view class="table-modal-content">
    <view class="table-modal-header">
      <text class="table-modal-title">选择桌台</text>
      <view class="table-modal-close" bindtap="hideTableModal">×</view>
    </view>
    <view class="table-modal-body">
      <view class="table-grid">
        <view 
          wx:for="{{tableList}}" 
          wx:key="id"
          class="table-item {{tableNumber === item.id ? 'selected' : ''}}"
          bindtap="selectTableNumber" 
          data-table-id="{{item.id}}"
        >
          {{item.name}}
        </view>
      </view>
    </view>
  </view>
</view>

<view class="content">
  <!-- 左侧分类 -->
  <view class="category-list">
    <view 
      wx:for="{{categories}}" 
      wx:key="id"
      class="category-item {{activeCategory === item.id ? 'active' : ''}}"
      bindtap="switchCategory"
      data-category="{{item.id}}"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 右侧商品列表 -->
  <view class="goods-list">
    <block wx:if="{{loading}}">
      <view class="loading">加载中...</view>
    </block>
    <block wx:else>
      <view 
        wx:for="{{goodsList[activeCategory]}}" 
        wx:key="id"
        class="goods-item"
      >
        <view class="goods-image-container">
          <image class="goods-image" src="{{item.image}}" bindtap="navigateToGoodsDetail" data-id="{{item.id}}" />
          <view class="goods-price">¥{{item.price}}</view>
        </view>
        <view class="goods-info">
          <view class="goods-name" bindtap="navigateToGoodsDetail" data-id="{{item.id}}">{{item.name}}</view>
          <view class="goods-sales">
            <text class="sold">已售 {{item.sold}}</text>
            <text class="stock">仅剩 {{item.stock}}份</text>
          </view>
          <view class="goods-bottom">
            <view class="quantity-control">
              <view class="quantity-btn" catchtap="decreaseQuantity" data-category="{{activeCategory}}" data-index="{{index}}" wx:if="{{cart[item.id] && cart[item.id].quantity > 0}}">-</view>
              <view class="quantity-input" wx:if="{{cart[item.id] && cart[item.id].quantity > 0}}">{{cart[item.id].quantity}}</view>
              <view class="add-btn" catchtap="addToCart" data-category="{{activeCategory}}" data-index="{{index}}">+</view>
            </view>
          </view>
        </view>
      </view>
      <block wx:if="{{!goodsList[activeCategory] || goodsList[activeCategory].length === 0}}">
        <view class="empty">暂无商品</view>
      </block>
      
      <!-- 懒加载提示 -->
      <block wx:if="{{lazyLoading}}">
        <view class="lazy-loading">
          <view class="loading-spinner"></view>
          <view class="loading-text">加载中...</view>
        </view>
      </block>
    </block>
  </view>
</view>

<!-- 底部结算栏 -->
<view class="bottom-bar">
  <view class="cart-icon" bindtap="viewCart">
    <text class="cart-text">🛒</text>
    <block wx:if="{{cartCount > 0}}">
      <view class="cart-badge">{{cartCount}}</view>
    </block>
  </view>
  <view class="total-price">
    <text>¥{{totalPrice}}</text>
  </view>
  <button class="checkout-btn" bindtap="viewCart">去结算</button>
</view>

<!-- 购物车弹窗 -->
<view class="cart-modal" wx:if="{{showCartModal}}">
  <view class="cart-modal-content">
    <view class="cart-modal-header">
      <text class="cart-modal-title">购物车</text>
      <view class="cart-modal-close" bindtap="hideCartModal">×</view>
    </view>
    <view class="cart-modal-body">
      <block wx:for="{{cartItems}}" wx:key="id">
        <view class="cart-item">
          <image class="cart-item-image" src="{{item.image}}" />
          <view class="cart-item-info">
            <view class="cart-item-name">{{item.name}}</view>
            <view class="cart-item-price">¥{{item.price}}</view>
          </view>
          <view class="cart-item-quantity">
            <view class="quantity-btn" bindtap="decreaseQuantity" data-id="{{item.id}}">-</view>
            <view class="quantity-input">{{item.quantity}}</view>
            <view class="quantity-btn" bindtap="increaseQuantity" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </block>
      <block wx:if="{{cartCount === 0}}">
        <view class="empty-cart">购物车为空</view>
      </block>
    </view>
    <view class="cart-modal-footer">
      <view class="cart-total">
        <text>合计：</text>
        <text class="cart-total-price">¥{{totalPrice}}</text>
      </view>
      <button class="cart-checkout-btn" bindtap="checkout">结算({{cartCount}})</button>
    </view>
  </view>
</view>

