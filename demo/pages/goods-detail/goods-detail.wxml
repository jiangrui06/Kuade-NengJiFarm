<view class="container">
  <!-- 商品图片 -->
  <view class="goods-image-container">
    <image class="goods-image" src="{{goods.image}}" />
  </view>
  
  <!-- 商品信息 -->
  <view class="goods-info">
    <view class="goods-price">¥{{goods.price.toFixed(2)}}</view>
    <view class="goods-name">{{goods.name}}</view>
    <view class="goods-tags">
      <view class="tag">香甜可口</view>
      <view class="tag">饱满</view>
    </view>
    
    <!-- 商品描述 -->
    <view class="goods-description">
      {{goods.description}}
    </view>
    
    <!-- 配送信息 -->
    <view class="delivery-info">
      <view class="delivery-label">配送</view>
      <view class="delivery-text">立即下单，预计明日 07:00-07:30 送达</view>
    </view>
    
    <!-- 领券信息 -->
    <view class="coupon-info">
      <view class="coupon-item">
        <text class="coupon-text">满99减6</text>
      </view>
      <view class="coupon-item">
        <text class="coupon-text">满120减20</text>
      </view>
    </view>
    
    <!-- 服务信息 -->
    <view class="service-info">
      <view class="service-item">
        <text class="service-label">服务</text>
        <text class="service-text">称重退差价</text>
      </view>
    </view>
  </view>
  
  <!-- 规格信息 -->
  <view class="spec-info">
    <view class="spec-title">规格信息</view>
    <view class="spec-item">
      <view class="spec-label">净含量</view>
      <view class="spec-value">{{goods.weight}}</view>
    </view>
    <view class="spec-item">
      <view class="spec-label">保存条件</view>
      <view class="spec-value">{{goods.storage}}</view>
    </view>
  </view>
  
  <!-- 商品详情图片 -->
  <view class="goods-detail-images">
    <image class="detail-image" src="{{goods.detailImage}}" />
  </view>
  
  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="cart-icon">
      <text class="cart-text">🛒</text>
    </view>
    <button class="add-to-cart-btn">加入购物车</button>
    <button class="buy-now-btn">立即购买</button>
  </view>
</view>