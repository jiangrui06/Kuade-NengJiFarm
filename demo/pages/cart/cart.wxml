<view class="container {{showModal ? 'fixed' : ''}} {{showCartDetail ? 'fixed' : ''}}">
  <view class="cart-list">
    <!-- 空购物车提示 -->
    <view class="empty-cart" wx:if="{{cartList.length === 0}}">
      <text>购物车是空的，快去添加商品吧~</text>
    </view>

    <!-- 全选栏 -->
    <view class="select-all-bar" wx:if="{{cartList.length > 0}}">
      <view class="select-all" bindtap="handleSelectAll">
        <view class="checkbox-circle {{selectAll ? 'checked' : ''}}">
          <text wx:if="{{selectAll}}">✓</text>
        </view>
        <text>全选</text>
      </view>
      <view class="clear-cart" bindtap="handleClearCart">
        <text>清空</text>
      </view>
    </view>

    <!-- 商品循环 -->
    <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
      <!-- 勾选框：空心圆样式 -->
      <view class="checkbox" bindtap="toggleSelect" data-id="{{item.id}}">
        <view class="checkbox-circle {{item.checked ? 'checked' : ''}}">
          <text wx:if="{{item.checked}}">✓</text>
        </view>
      </view>

      <!-- 商品图片 -->
      <image class="item-img" src="{{item.image}}" mode="aspectFill"></image>

      <!-- 商品信息 -->
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-tag">{{item.tag}}</view>
        <view class="item-price">¥{{item.price}}</view>
        <view class="item-stock" wx:if="{{item.stock}}">仅剩{{item.stock}}件</view>
      </view>

      <!-- 数量加减 -->
      <view class="item-count">
        <view class="count-btn" bindtap="handleMinus" data-id="{{item.id}}">-</view>
        <view class="count-num">{{item.count}}</view>
        <view class="count-btn" bindtap="handlePlus" data-id="{{item.id}}">+</view>
      </view>
    </view>
  </view>

  <!-- 3. 底部结算栏 -->
  <view class="cart-bottom">
    <view class="cart-badge" bindtap="handleCartIconClick">
      <text class="cart-icon">🛒</text>
      <view class="badge" wx:if="{{selectedCount > 0}}">{{selectedCount}}</view>
    </view>
    <view class="total-price">合计: ¥{{totalPrice}}</view>
    <view class="settle-btn" bindtap="handleSettle">
      {{selectedCount > 0 ? '结算(' + selectedCount + ')' : '结算'}}
    </view>
  </view>

</view>

<!-- 🌟 结算弹窗：是否确认购买 -->
<view class="modal" wx:if="{{showModal}}">
  <view class="modal-mask" bindtap="handleCancelModal"></view>
  <view class="modal-content">
    <view class="modal-header">
      <text class="modal-title">确认购买</text>
      <icon class="modal-close" type="clear" size="20" color="#999" bindtap="handleCancelModal"></icon>
    </view>
    <view class="modal-body">
      <!-- 地址选择 -->
      <view class="address-section">
        <text class="section-title">收货地址</text>
        <view class="address-list">
          <view class="address-item" wx:for="{{addresses}}" wx:key="id" bindtap="selectAddress" data-id="{{item.id}}" style="{{selectedAddressId === item.id ? 'border-color: #e64340; background-color: #fef0f0;' : ''}}">
            <view class="address-info">
              <view class="address-name">{{item.name}} {{item.phone}}</view>
              <view class="address-detail">{{item.address}}</view>
            </view>
            <view class="address-check" wx:if="{{selectedAddressId === item.id}}">✓</view>
          </view>
        </view>
      </view>
      
      <!-- 订单信息 -->
      <view class="order-info">
        <view class="info-item">
          <text class="info-label">商品数量：</text>
          <text class="info-value">{{selectedCount}}件</text>
        </view>
        <view class="info-item">
          <text class="info-label">合计金额：</text>
          <text class="info-value price">¥{{totalPrice}}</text>
        </view>
      </view>
      <view class="confirm-text">确认购买以上商品吗？</view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="handleCancelModal">取消</view>
      <view class="modal-btn confirm" bindtap="handleConfirmPurchase">确认购买</view>
    </view>
  </view>
</view>

<!-- 🌟 购物车详情弹窗 -->
<view class="modal" wx:if="{{showCartDetail}}">
  <view class="modal-mask" bindtap="handleCloseCartDetail"></view>
  <view class="modal-content cart-detail-modal">
    <view class="modal-header">
      <text class="modal-title">购物车详情</text>
      <icon class="modal-close" type="clear" size="20" color="#999" bindtap="handleCloseCartDetail"></icon>
    </view>
    <view class="modal-body">
      <!-- 商品详细信息 -->
      <view class="cart-detail-list">
        <view class="cart-detail-item" wx:for="{{cartList}}" wx:key="id">
          <image class="detail-item-img" src="{{item.image}}" mode="aspectFill"></image>
          <view class="detail-item-info">
            <view class="detail-item-name">{{item.name}}</view>
            <view class="detail-item-tag">{{item.tag}}</view>
            <view class="detail-item-price">¥{{item.price}}</view>
            <view class="detail-item-stock" wx:if="{{item.stock}}">仅剩{{item.stock}}件</view>
          </view>
          <view class="detail-item-quantity">×{{item.count}}</view>
        </view>
      </view>
      
      <!-- 合计信息 -->
      <view class="cart-detail-total">
        <text class="total-label">合计：</text>
        <text class="total-price">¥{{totalPrice}}</text>
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="handleCloseCartDetail">关闭</view>
      <view class="modal-btn confirm" bindtap="handleSettle">去结算</view>
    </view>
  </view>
</view>