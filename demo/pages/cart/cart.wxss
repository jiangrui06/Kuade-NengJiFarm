.container {
    padding-bottom: 100rpx;
    background: #f5f5f5;
    min-height: 100vh;
  }
  .container.fixed {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
  }
  
  .cart-header {
    padding: 20rpx;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-header .cart-icon {
    margin-right: 15rpx;
    font-size: 40rpx;
    color: #e64340;
  }
  .cart-badge .cart-icon {
    font-size: 40rpx;
    color: #e64340;
  }
  .cart-title {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .empty-cart {
    text-align: center;
    padding: 100rpx 0;
    color: #999;
    font-size: 28rpx;
  }

  .select-all-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx;
    background: #fff;
    margin-bottom: 10rpx;
    border-radius: 12rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  }
  .select-all {
    display: flex;
    align-items: center;
  }
  .select-all .checkbox-circle {
    margin-right: 10rpx;
  }
  .select-all text {
    font-size: 28rpx;
    color: #333;
  }
  .clear-cart {
    font-size: 28rpx;
    color: #e64340;
  }
  .clear-cart:active {
    color: #c43532;
  }
  
  .cart-item {
    display: flex;
    align-items: center;
    padding: 20rpx;
    background: #fff;
    margin-bottom: 10rpx;
    border-radius: 12rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
    transition: all 0.3s ease;
  }
  .cart-item:active {
    transform: scale(0.98);
  }
/* 勾选框：空心圆样式 */
.checkbox {
    margin-right: 20rpx;
  }
  .checkbox-circle {
    width: 32rpx;
    height: 32rpx;
    border: 2rpx solid #ddd; /* 空心圆边框 */
    border-radius: 50%; /* 变成圆形 */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* 选中状态：绿色圆 + 白色对勾 */
  .checkbox-circle.checked {
    background: #07c160;
    border-color: #07c160;
    color: #fff;
  }
  .item-img {
    width: 120rpx;
    height: 120rpx;
    border-radius: 8rpx;
    margin-right: 20rpx;
  }
  .item-info {
    flex: 1;
  }
  .item-name {
    font-size: 30rpx;
    margin-bottom: 8rpx;
    line-height: 1.4;
  }
  .item-tag {
    font-size: 24rpx;
    color: #999;
    margin-bottom: 8rpx;
  }
  .item-price {
    font-size: 32rpx;
    color: #e64340;
    font-weight: bold;
  }
  .item-stock {
    font-size: 22rpx;
    color: #999;
    margin-top: 4rpx;
  }
  .item-count {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 8rpx;
    overflow: hidden;
  }
  .count-btn {
    width: 50rpx;
    height: 50rpx;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    background: #f5f5f5;
    color: #333;
    transition: all 0.3s ease;
  }
  .count-btn:active {
    background: #e0e0e0;
  }
  .count-btn.disabled {
    color: #ccc;
    pointer-events: none;
  }
  .count-btn.disabled:active {
    background: #f5f5f5;
  }
  .count-num {
    width: 60rpx;
    text-align: center;
    font-size: 28rpx;
    background: #fff;
    height: 50rpx;
    line-height: 50rpx;
    border-left: 1rpx solid #eee;
    border-right: 1rpx solid #eee;
  }
  
  .cart-bottom {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    padding: 20rpx 30rpx;
    background: #fff;
    border-top: 1rpx solid #eee;
    padding-bottom: 30rpx;
  }
  .cart-badge { 
    position: relative; 
    margin-right: 30rpx; 
    display: flex;
    align-items: center;
  }
  .badge {
    position: absolute; 
    top: -20rpx; 
    right: -25rpx;
    background: #e64340; 
    color: #fff;
    font-size: 20rpx; 
    width: 36rpx; 
    height: 36rpx;
    border-radius: 50%; 
    display: flex; 
    align-items: center; 
    justify-content: center;
  }
  .total-price {
    flex: 1;
    font-size: 32rpx;
    font-weight: bold;
    color: #e64340;
  }
  .settle-btn {
    background: #e64340;
    color: #fff;
    padding: 20rpx 40rpx;
    border-radius: 50rpx;
    font-size: 30rpx;
  }
  

  /* 弹窗样式 */
  .modal {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    z-index: 1000; display: flex; align-items: center; justify-content: center;
  }
  .modal-mask {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.3);
    animation: fadeIn 0.3s ease;
  }
  .modal-content {
    width: 80%; background: #fff; border-radius: 16rpx; overflow: hidden;
    box-shadow: 0 0 40rpx rgba(255, 255, 255, 0.8), 0 0 60rpx rgba(255, 71, 87, 0.3);
    animation: slideIn 0.3s ease;
    background: linear-gradient(135deg, #ffffff 0%, #f8f9ff 100%);
    position: relative;
  }
  .modal-content::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, rgba(255,255,255,0.3) 0%, rgba(255,255,255,0) 100%);
    pointer-events: none;
  }
  .modal-header {
    padding: 24rpx; display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1rpx solid #e8f0fe;
    background: #f8f9ff;
  }
  .modal-title { font-size: 32rpx; font-weight: bold; color: #1a1a1a; text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.1); }
  .modal-close { margin-right: 10rpx; color: #4a4a4a; }
  .modal-close:active {
    transform: scale(0.8);
  }
  .modal-body {
    padding: 40rpx;
    background: #ffffff;
  }
  .order-info {
    background: #f0f7ff;
    padding: 24rpx;
    border-radius: 8rpx;
    margin-bottom: 32rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  }
  .info-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 16rpx;
  }
  .info-item:last-child {
    margin-bottom: 0;
  }
  .info-label {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
  }
  .info-value {
    font-size: 28rpx;
    color: #1a1a1a;
    font-weight: 600;
  }
  .info-value.price {
    color: #ff4757;
    font-weight: bold;
    text-shadow: 0 1rpx 2rpx rgba(255,71,87,0.3);
  }
  .confirm-text {
    text-align: center;
    font-size: 28rpx;
    color: #1a1a1a;
    font-weight: 500;
  }
  
  /* 地址选择样式 */
  .address-section {
    margin-bottom: 32rpx;
  }
  .section-title {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 16rpx;
  }
  .address-list {
    display: flex;
    flex-direction: column;
    gap: 16rpx;
  }
  .address-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx;
    border: 2rpx solid #e0e0e0;
    border-radius: 8rpx;
    transition: all 0.3s ease;
  }
  .address-item:active {
    background-color: #f5f5f5;
  }
  .address-info {
    flex: 1;
  }
  .address-name {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
    margin-bottom: 8rpx;
  }
  .address-detail {
    font-size: 24rpx;
    color: #666;
    line-height: 1.4;
  }
  .address-check {
    font-size: 24rpx;
    color: #e64340;
    font-weight: bold;
  }
  
  /* 购物车详情弹窗样式 */
  .cart-detail-modal {
    width: 90%;
    max-height: 80vh;
  }
  .cart-detail-list {
    max-height: 400rpx;
    overflow-y: auto;
    margin-bottom: 32rpx;
  }
  .cart-detail-item {
    display: flex;
    align-items: center;
    padding: 20rpx;
    border-bottom: 1rpx solid #f0f0f0;
    justify-content: space-between;
  }
  .detail-item-img {
    width: 100rpx;
    height: 100rpx;
    border-radius: 8rpx;
    margin-right: 20rpx;
  }
  .detail-item-info {
    flex: 1;
  }
  .detail-item-name {
    font-size: 28rpx;
    margin-bottom: 8rpx;
    line-height: 1.4;
  }
  .detail-item-tag {
    font-size: 22rpx;
    color: #999;
    margin-bottom: 8rpx;
  }
  .detail-item-price {
    font-size: 28rpx;
    color: #e64340;
    font-weight: bold;
    margin-bottom: 8rpx;
  }
  .detail-item-stock {
    font-size: 20rpx;
    color: #999;
    margin-bottom: 12rpx;
  }
  .detail-item-count {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 8rpx;
    overflow: hidden;
    width: fit-content;
  }
  .cart-detail-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20rpx;
    border-top: 1rpx solid #f0f0f0;
  }
  .total-label {
    font-size: 28rpx;
    font-weight: 600;
    color: #333;
  }
  .cart-detail-total .total-price {
    font-size: 32rpx;
    font-weight: bold;
    color: #e64340;
  }
  .detail-item-quantity {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-left: 20rpx;
  }
  .modal-footer {
    display: flex; border-top: 1rpx solid #f0f0f0;
  }
  .modal-btn {
    flex: 1; padding: 28rpx; text-align: center; font-size: 30rpx;
    transition: all 0.3s ease;
  }
  .modal-btn:not(.confirm):active {
    transform: scale(0.98);
  }
  .modal-btn.confirm {
    background: #ff4757;
    color: #fff;
    font-weight: bold;
    box-shadow: 0 0 20rpx rgba(255, 71, 87, 0.6);
    position: relative;
    overflow: hidden;
  }
  .modal-btn.confirm::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      to bottom right,
      rgba(255, 255, 255, 0.3) 0%,
      rgba(255, 255, 255, 0) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: rotate(45deg);
    animation: shine 3s infinite;
  }
  .modal-btn.confirm:active {
    background: #ff4757;
    box-shadow: 0 0 30rpx rgba(255, 71, 87, 0.8);
    transform: scale(1);
  }
  @keyframes shine {
    0% {
      transform: translateX(-100%) rotate(45deg);
    }
    100% {
      transform: translateX(100%) rotate(45deg);
    }
  }
  .modal-btn.cancel {
    color: #666;
    border-right: 1rpx solid #f0f0f0;
  }
  .modal-btn.cancel:active {
    background: #f5f5f5;
  }
  
  /* 动画效果 */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(50rpx);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }