.container {
    padding-bottom: 100rpx;
    background: #f5f5f5;
    min-height: 100vh;
  }
  
  .cart-header {
    padding: 20rpx;
    background: #fff;
    border-bottom: 1rpx solid #eee;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-header .cart-icon {
    margin-right: 15rpx;
    font-size: 40rpx;
    color: #e64340;
  }
  .cart-badge .cart-icon {
    font-size: 40rpx;
    color: #e64340;
  }
  .cart-title {
    font-size: 36rpx;
    font-weight: bold;
  }
  
  .empty-cart {
    text-align: center;
    padding: 100rpx 0;
    color: #999;
    font-size: 28rpx;
  }
  
  .cart-item {
    display: flex;
    align-items: center;
    padding: 20rpx;
    background: #fff;
    margin-bottom: 10rpx;
    border-radius: 12rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
    transition: all 0.3s ease;
  }
  .cart-item:active {
    transform: scale(0.98);
  }
/* 勾选框：空心圆样式 */
.checkbox {
    margin-right: 20rpx;
  }
  .checkbox-circle {
    width: 32rpx;
    height: 32rpx;
    border: 2rpx solid #ddd; /* 空心圆边框 */
    border-radius: 50%; /* 变成圆形 */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  /* 选中状态：绿色圆 + 白色对勾 */
  .checkbox-circle.checked {
    background: #07c160;
    border-color: #07c160;
    color: #fff;
  }
  .item-img {
    width: 120rpx;
    height: 120rpx;
    border-radius: 8rpx;
    margin-right: 20rpx;
  }
  .item-info {
    flex: 1;
  }
  .item-name {
    font-size: 30rpx;
    margin-bottom: 8rpx;
    line-height: 1.4;
  }
  .item-tag {
    font-size: 24rpx;
    color: #999;
    margin-bottom: 8rpx;
  }
  .item-price {
    font-size: 32rpx;
    color: #e64340;
    font-weight: bold;
  }
  .item-count {
    display: flex;
    align-items: center;
    background: #f5f5f5;
    border-radius: 8rpx;
    overflow: hidden;
  }
  .count-btn {
    width: 50rpx;
    height: 50rpx;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    background: #f5f5f5;
    color: #333;
    transition: all 0.3s ease;
  }
  .count-btn:active {
    background: #e0e0e0;
  }
  .count-num {
    width: 60rpx;
    text-align: center;
    font-size: 28rpx;
    background: #fff;
    height: 50rpx;
    line-height: 50rpx;
    border-left: 1rpx solid #eee;
    border-right: 1rpx solid #eee;
  }
  
  .cart-bottom {
    position: fixed;
    bottom: 100rpx;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    padding: 20rpx 30rpx;
    background: #fff;
    border-top: 1rpx solid #eee;
  }
  .cart-badge { 
    position: relative; 
    margin-right: 30rpx; 
    display: flex;
    align-items: center;
  }
  .badge {
    position: absolute; 
    top: -20rpx; 
    right: -25rpx;
    background: #e64340; 
    color: #fff;
    font-size: 20rpx; 
    width: 36rpx; 
    height: 36rpx;
    border-radius: 50%; 
    display: flex; 
    align-items: center; 
    justify-content: center;
  }
  .total-price {
    flex: 1;
    font-size: 32rpx;
    font-weight: bold;
    color: #e64340;
  }
  .settle-btn {
    background: #e64340;
    color: #fff;
    padding: 20rpx 40rpx;
    border-radius: 50rpx;
    font-size: 30rpx;
  }
  

  /* 弹窗样式 */
  .modal {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0;
    z-index: 1000; display: flex; align-items: center; justify-content: center;
  }
  .modal-mask {
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0,0,0,0.5);
    animation: fadeIn 0.3s ease;
  }
  .modal-content {
    width: 80%; background: #fff; border-radius: 16rpx; overflow: hidden;
    box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
    animation: slideIn 0.3s ease;
  }
  .modal-header {
    padding: 24rpx; display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1rpx solid #f0f0f0;
  }
  .modal-title { font-size: 32rpx; font-weight: bold; color: #333; }
  .modal-close { margin-right: 10rpx; }
  .modal-close:active {
    transform: scale(0.8);
  }
  .modal-body {
    padding: 40rpx;
  }
  .order-info {
    background: #f9f9f9;
    padding: 24rpx;
    border-radius: 8rpx;
    margin-bottom: 32rpx;
  }
  .info-item {
    display: flex;
    justify-content: space-between;
    margin-bottom: 16rpx;
  }
  .info-item:last-child {
    margin-bottom: 0;
  }
  .info-label {
    font-size: 28rpx;
    color: #666;
  }
  .info-value {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
  }
  .info-value.price {
    color: #e64340;
    font-weight: bold;
  }
  .confirm-text {
    text-align: center;
    font-size: 28rpx;
    color: #333;
  }
  .modal-footer {
    display: flex; border-top: 1rpx solid #f0f0f0;
  }
  .modal-btn {
    flex: 1; padding: 28rpx; text-align: center; font-size: 30rpx;
    transition: all 0.3s ease;
  }
  .modal-btn:active {
    transform: scale(0.98);
  }
  .modal-btn.confirm {
    background: #e64340;
    color: #fff;
    font-weight: bold;
  }
  .modal-btn.confirm:active {
    background: #d53a37;
  }
  .modal-btn.cancel {
    color: #666;
    border-right: 1rpx solid #f0f0f0;
  }
  .modal-btn.cancel:active {
    background: #f5f5f5;
  }
  
  /* 动画效果 */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(50rpx);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }