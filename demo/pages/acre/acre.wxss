.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.swiper-container {
  width: 100%;
  height: 300rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx;
  color: #333;
}

.acre-list {
  padding: 0 20rpx 20rpx;
}

.acre-item {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  display: flex;
  gap: 20rpx;
}

.acre-image {
  width: 200rpx;
  height: 150rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.acre-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.acre-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.acre-desc {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.price-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.acre-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #e64340;
}

.buy-button {
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 6rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  height: 60rpx;
  line-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.buy-button:hover {
  background-color: #40a9ff;
}

.buy-button:active {
  background-color: #096dd9;
}