.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 15rpx 20rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.search-input-container {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  padding: 0 20rpx;
  height: 60rpx;
}

.search-icon {
  font-size: 24rpx;
  color: #999;
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  font-size: 24rpx;
  background-color: transparent;
  border: none;
  outline: none;
  height: 100%;
}

.search-btn {
  margin-left: 20rpx;
  background-color: #e64340;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 22rpx;
}

.category-btn {
  margin-left: 15rpx;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f0f0;
  border-radius: 50%;
}

.category-btn .category-icon {
  font-size: 24rpx;
  color: #666;
}

/* 分类界面样式 */
.category-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-panel {
  width: 80%;
  max-height: 80%;
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background-color: #f9f9f9;
}

.category-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.category-list {
  padding: 20rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.category-list .category-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  width: 100%;
  margin-bottom: 0;
}

.category-list .category-item:last-child {
  border-bottom: none;
}

.category-item-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #fff;
}

.category-item-name {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

/* 轮播图样式 */
.swiper-container {
  width: 100%;
  height: 300rpx;
  margin-bottom: 20rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 10rpx;
  margin: 0 20rpx;
}

/* 分类导航样式 */
.category-nav {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  border-radius: 10rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 32rpx;
  color: #fff;
}

.category-name {
  font-size: 20rpx;
  color: #333;
  text-align: center;
}

/* 区块样式 */
.section {
  background-color: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 20rpx;
  color: #999;
}

/* 商品列表样式 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.goods-item {
  width: 48%;
  margin-bottom: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.goods-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.goods-info {
  padding: 15rpx;
}

.goods-name {
  font-size: 22rpx;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.tag {
  font-size: 16rpx;
  color: #666;
  background-color: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.goods-price-container {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.goods-price {
  font-size: 24rpx;
  font-weight: bold;
  color: #e64340;
  margin-right: 10rpx;
}

.goods-original-price {
  font-size: 18rpx;
  color: #999;
  text-decoration: line-through;
}

.goods-stock {
  font-size: 18rpx;
  color: #999;
}

/* 分类视图样式 */
.category-view {
  display: flex;
  height: calc(100vh - 150rpx);
  margin: 0 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  border: none;
}

/* 左侧分类栏 */
.category-left {
  width: 120rpx;
  background-color: #ffffff;
  overflow-y: auto;
  border-right: 2rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-left .category-item {
  width: 100%;
  padding: 24rpx 0;
  text-align: center;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 18rpx;
  color: #666;
  margin-bottom: 0;
  transition: all 0.3s ease;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
  padding-left: 0;
  padding-right: 0;
  min-height: 120rpx;
}

.category-left .category-item-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0 auto;
}

.category-left .category-item-icon::before {
  content: '';
  display: inline-block;
  height: 100%;
  vertical-align: middle;
}

.category-left .category-item:hover {
  background-color: #f9f9f9;
}

.category-left .category-item:hover .category-item-icon {
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.category-left .category-item.active {
  background-color: #fff0f0;
  color: #e64340;
  font-weight: 600;
}

.category-left .category-item.active .category-item-icon {
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(230, 67, 64, 0.3);
}

.category-left .category-item.active::after {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 60%;
  background-color: #e64340;
  border-radius: 0 2rpx 2rpx 0;
}

/* 右侧商品列表 */
.category-right {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  background-color: #f9f9f9;
}

/* 分类标题 */
.category-title-bar {
  padding: 0 0 16rpx 0;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding-left: 12rpx;
  border-left: 4rpx solid #e64340;
}

.category-goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.category-goods-item {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  position: relative;
}

.category-goods-item:hover {
  transform: translateY(-6rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.category-goods-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
  margin-right: 0;
  border-radius: 16rpx 16rpx 0 0;
}

.category-goods-info {
  padding: 16rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.category-goods-name {
  font-size: 22rpx;
  color: #333;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
  font-weight: 500;
}

.category-goods-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.category-goods-tags .tag {
  font-size: 14rpx;
  padding: 4rpx 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
}

.category-goods-price {
  font-size: 26rpx;
  font-weight: 600;
  color: #e64340;
  margin-top: auto;
}

/* 商品标签样式 */
.tag {
  font-size: 14rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}