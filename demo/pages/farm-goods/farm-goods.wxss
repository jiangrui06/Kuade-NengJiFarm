.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  gap: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
  justify-content: space-between;
}

.search-input-container {
  flex: 1;
  max-width: 500rpx;
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 60rpx;
  min-width: 0;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  margin-right: 16rpx;
}

.search-input-container:focus-within {
  background-color: #fff;
  border-color: #e64340;
  box-shadow: 0 0 0 4rpx rgba(230, 67, 64, 0.1);
}

.search-icon {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
  flex-shrink: 0;
  transition: color 0.3s ease;
}

.search-input-container:focus-within .search-icon {
  color: #e64340;
}

.search-input {
  flex: 1;
  font-size: 22rpx;
  background-color: transparent;
  border: none;
  outline: none;
  height: 100%;
  min-width: 0;
  color: #333;
}

.search-input::placeholder {
  color: #999;
  font-size: 20rpx;
}

.search-bar .button-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.search-btn {
  background-color: #e64340;
  color: #fff;
  padding: 0 28rpx;
  border-radius: 32rpx;
  font-size: 20rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(230, 67, 64, 0.3);
  transition: all 0.3s ease;
  flex-shrink: 0;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.search-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(230, 67, 64, 0.4);
  background-color: #d53a37;
}

.search-btn:active {
  transform: translateY(0);
  box-shadow: 0 2rpx 8rpx rgba(230, 67, 64, 0.3);
}

.category-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #e64340;
  border-radius: 32rpx;
  padding: 0 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(230, 67, 64, 0.3);
  transition: all 0.3s ease;
  white-space: nowrap;
  flex-shrink: 0;
  height: 60rpx;
  position: relative;
  overflow: hidden;
}

.category-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(230, 67, 64, 0.4);
  background-color: #d53a37;
}

.category-btn:active {
  transform: translateY(0);
  box-shadow: 0 2rpx 8rpx rgba(230, 67, 64, 0.3);
}

.category-btn .category-icon {
  font-size: 22rpx;
  color: #fff;
  margin-right: 10rpx;
}

.category-btn text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

/* 添加按钮点击效果 */
.search-btn::before,
.category-btn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.search-btn:active::before,
.category-btn:active::before {
  width: 300rpx;
  height: 300rpx;
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .search-bar {
    padding: 12rpx 16rpx;
    gap: 12rpx;
  }
  
  .search-input-container {
    padding: 0 20rpx;
    height: 56rpx;
  }
  
  .search-btn,
  .category-btn {
    padding: 0 24rpx;
    height: 56rpx;
    font-size: 18rpx;
  }
  
  .category-btn .category-icon {
    font-size: 20rpx;
    margin-right: 8rpx;
  }
}

/* 分类界面样式 */
.category-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  transition: opacity 0.3s ease-in-out;
}

.category-overlay[hidden] {
  opacity: 0;
  pointer-events: none;
}

.category-panel {
  width: 80%;
  max-height: 80%;
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background-color: #f9f9f9;
}

.category-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.category-list {
  padding: 20rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.category-list .category-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  width: 100%;
  margin-bottom: 0;
}

.category-list .category-item:last-child {
  border-bottom: none;
}

.category-item-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #fff;
}

.category-item-name {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

/* 轮播图样式 */
.swiper-container {
  width: 100%;
  height: 300rpx;
  margin-bottom: 20rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 加载更多样式 */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

/* 分类导航样式 */
.category-nav {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  border-radius: 10rpx;
  margin: 0 20rpx 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  font-size: 32rpx;
  color: #fff;
}

.category-name {
  font-size: 20rpx;
  color: #333;
  text-align: center;
}

/* 区块样式 */
.section {
  background-color: #fff;
  margin: 0 10rpx 20rpx;
  border-radius: 12rpx;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 20rpx;
  color: #999;
}

/* 商品容器样式 */
.goods-container {
  padding: 0 24rpx 24rpx 24rpx;
  max-height: 1000rpx;
  overflow-y: auto;
}

/* 商品列表样式 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
}

/* 商品项样式 */
.goods-container .goods-list .farm-goods-item {
  width: 48%;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  min-height: 450rpx;
  border: 1rpx solid #e0e0e0;
}

.goods-container .goods-list .farm-goods-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  background-color: #fff;
}

/* 商品图片样式 */
.farm-goods-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
  display: block;
  border-radius: 12rpx 12rpx 0 0;
}

/* 商品信息样式 */
.farm-goods-info {
  padding: 16rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* 商品名称样式 */
.farm-goods-name {
  font-size: 22rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.3;
  font-weight: 500;
  min-height: 60rpx;
  color: #333;
}

/* 商品标签样式 */
.farm-goods-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

/* 标签样式 */
.tag {
  font-size: 18rpx;
  padding: 3rpx 10rpx;
  border-radius: 6rpx;
  margin-right: 6rpx;
  margin-bottom: 6rpx;
  background-color: #f0f0f0;
  color: #666;
}

/* 商品价格容器样式 */
.farm-goods-price-container {
  margin-bottom: 4rpx;
  display: flex;
  align-items: baseline;
}

/* 商品价格样式 */
.farm-goods-price {
  color: #e64340;
  font-size: 26rpx;
  font-weight: 600;
}

/* 商品原价样式 */
.farm-goods-original-price {
  color: #999;
  font-size: 16rpx;
  text-decoration: line-through;
  margin-left: 6rpx;
}

/* 商品库存样式 */
.farm-goods-stock {
  font-size: 16rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 分类视图样式 */
.category-view {
  display: flex;
  height: calc(100vh - 150rpx);
  margin: 0 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  border: none;
}

/* 左侧分类栏 */
.category-left {
  width: 120rpx;
  background-color: #ffffff;
  overflow-y: auto;
  border-right: 2rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40rpx;
}

.category-left .category-item {
  width: 100%;
  padding: 24rpx 0;
  text-align: center;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 18rpx;
  color: #666;
  margin-bottom: 0;
  transition: all 0.3s ease;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
  padding-left: 0;
  padding-right: 0;
  min-height: 120rpx;
}

.category-left .category-item-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0 auto;
}

.category-left .category-item-icon::before {
  content: '';
  display: inline-block;
  height: 100%;
  vertical-align: middle;
}

.category-left .category-item:hover {
  background-color: #f9f9f9;
}

.category-left .category-item:hover .category-item-icon {
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.category-left .category-item.active {
  background-color: #fff0f0;
  color: #e64340;
  font-weight: 600;
}

.category-left .category-item.active .category-item-icon {
  transform: scale(1.1);
  box-shadow: 0 4rpx 12rpx rgba(230, 67, 64, 0.3);
}

.category-left .category-item.active::after {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 60%;
  background-color: #e64340;
  border-radius: 0 2rpx 2rpx 0;
}

/* 右侧商品列表 */
.category-right {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  background-color: #f9f9f9;
}

/* 分类标题 */
.category-title-bar {
  padding: 0 0 16rpx 0;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.category-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding-left: 12rpx;
  border-left: 4rpx solid #e64340;
}

.category-goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.category-goods-item {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  position: relative;
}

.category-goods-item:hover {
  transform: translateY(-6rpx);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.category-goods-image {
  width: 100%;
  height: 190rpx;
  object-fit: cover;
  margin-right: 0;
  border-radius: 12rpx 12rpx 0 0;
}

.category-goods-info {
  padding: 12rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.category-goods-name {
  font-size: 20rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.3;
  font-weight: 500;
  height: 56rpx;
}

.category-goods-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
  height: 32rpx;
  overflow: hidden;
}

.category-goods-tags .tag {
  font-size: 12rpx;
  padding: 3rpx 10rpx;
  margin-right: 6rpx;
  margin-bottom: 6rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 10rpx;
}

.category-goods-price {
  font-size: 24rpx;
  font-weight: 600;
  color: #e64340;
  margin-top: auto;
  align-self: flex-start;
}



/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}



/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}