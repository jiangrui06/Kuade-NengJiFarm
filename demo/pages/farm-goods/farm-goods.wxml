<view class="container" bindscrolltolower="onReachBottom">
  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input-container">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品" />
    </view>
    <view class="button-group">
      <view class="search-btn" bindtap="search">搜索</view>
      <view class="category-btn" bindtap="toggleCategory">
        <text class="category-icon">📂</text>
        <text>商品分类</text>
      </view>
    </view>
  </view>
  
  <!-- 分类界面 -->
  <view class="category-overlay" wx:if="{{showCategory}}">
    <view class="category-panel">
      <view class="category-header">
        <view class="category-title">农场商品分类</view>
        <view class="close-btn" bindtap="toggleCategory">✕</view>
      </view>
      <view class="category-list">
        <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}">
          <view class="category-item-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
          <view class="category-item-name">{{item.name}}</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 轮播图 -->
  <view class="swiper-container">
    <swiper indicator-dots="true" autoplay="true" interval="3000" duration="1000" circular="true">
      <swiper-item wx:for="{{swiperList}}" wx:key="id">
        <image src="{{item.image}}" class="swiper-image" mode="aspectFill" lazy-load="true" />
      </swiper-item>
    </swiper>
  </view>
  
 
  
  <!-- 今日优选 -->
  <view class="section" wx:if="{{!showCategoryView}}">
    <view class="section-header">
      <view class="section-title">今日优选</view>
      <view class="section-more" bindtap="viewMore">查看更多</view>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{todayGoods}}" wx:key="id" bindtap="viewGoodsDetail" data-id="{{item.id}}">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill" lazy-load="true" />
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-tags">
            <view class="tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</view>
          </view>
          <view class="goods-price-container">
            <view class="goods-price">¥{{item.price}}</view>
            <view class="goods-original-price">¥{{item.originalPrice}}</view>
          </view>
          <view class="goods-stock">还剩{{item.stock}}份</view>
        </view>
      </view>
    </view>
  </view>
 
  
  <!-- 分类商品 -->
  <view class="category-view" wx:if="{{showCategoryView}}">
    <view class="category-left">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}" class="{{currentCategory === item.id ? 'active' : ''}}">
        <view class="category-item-icon" style="background-color: {{item.color}}">{{item.icon}}</view>
        <view class="category-item-name">{{item.name}}</view>
      </view>
    </view>
    <view class="category-right">
      <!-- 分类标题 -->
      <view class="category-title-bar">
        <view class="category-title">{{getCurrentCategoryName()}}</view>
      </view>
      <view class="category-goods-list">
        <view class="category-goods-item" wx:for="{{currentCategoryGoods}}" wx:key="id" bindtap="viewGoodsDetail" data-id="{{item.id}}">
          <image class="category-goods-image" src="{{item.image}}" mode="aspectFill" lazy-load="true" />
          <view class="category-goods-info">
            <view class="category-goods-name">{{item.name}}</view>
            <view class="category-goods-tags">
              <view class="tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</view>
            </view>
            <view class="category-goods-price">¥{{item.price}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 加载更多 -->
  <view class="loading-more" wx:if="{{loadingMore}}">
    <text>加载中...</text>
  </view>
</view>