.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 活动图片 */
.activity-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

/* 活动信息 */
.activity-info {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.activity-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
}

.activity-date {
  font-size: 24rpx;
  color: #666;
}

.activity-description {
  font-size: 24rpx;
  color: #666;
  line-height: 40rpx;
}

/* 活动详情 */
.activity-details {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #e64340;
  padding-left: 20rpx;
}

.detail-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.detail-label {
  width: 150rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  line-height: 40rpx;
}

/* 活动图片展示 */
.activity-gallery {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.gallery-list {
  padding-bottom: 15rpx;
}

.gallery-item {
  width: 100%;
  margin-bottom: 15rpx;
  position: relative;
  overflow: hidden;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.gallery-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.gallery-image {
  width: 100%;
  height: 500rpx;
  object-fit: contain;
  transition: all 0.3s ease;
}

.gallery-item:hover .gallery-image {
  transform: scale(1.02);
}

.image-loading {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.8);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
  color: #666;
}

/* 底部按钮 */
.bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.contact-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border: 2rpx solid #e64340;
  color: #e64340;
  border-radius: 40rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.register-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #e64340;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

/* 响应式调整 */
@media screen and (max-width: 375px) {
  .detail-label {
    width: 120rpx;
  }
}