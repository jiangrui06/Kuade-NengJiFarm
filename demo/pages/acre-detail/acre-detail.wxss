.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.swiper-container {
  width: 100%;
  height: 400rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.acre-info {
  flex: 1;
  background-color: #fff;
  margin: 20rpx;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.name-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.acre-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.acre-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #e64340;
}

.divider {
  height: 2rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

.acre-description {
  margin-bottom: 20rpx;
}

.desc-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.purchase-process {
  margin-top: 20rpx;
}

.process-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.process-steps {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.step-number {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #1890ff;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.step-text {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

.bottom-button {
  padding: 20rpx;
  background-color: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.confirm-button {
  background-color: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 28rpx;
  font-weight: bold;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-button:hover {
  background-color: #40a9ff;
}

.confirm-button:active {
  background-color: #096dd9;
}