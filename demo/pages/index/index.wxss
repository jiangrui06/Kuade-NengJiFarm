/* ─────────────────────────────────────────
   首页样式 - 能记农场
   色系：稻田黄 #D4A76A | 丝苗米白 #FAF6F0
   ───────────────────────────────────────── */

/* 搜索框样式 */
.search-container {
  display: flex;
  padding: 24rpx 32rpx;
  background-color: #fff;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #FAF6F0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background-color: #FAF6F0;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333;
  border: none;
}

.search-input::placeholder {
  color: #B8A98E;
}

.search-btn {
  height: 72rpx;
  padding: 0 32rpx;
  background-color: #D4A76A;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  font-weight: 500;
}

/* 轮播图样式 */
.swiper-container {
  padding: 24rpx;
}

.swiper-item {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 视频播放器样式 */
.video-section {
  margin-bottom: 24rpx;
}

.video-container {
  background-color: #fff;
  overflow: hidden;
  position: relative;
}

.video-player {
  width: 100%;
  height: 420rpx;
  object-fit: cover;
}

/* 视频标题和描述 */
.video-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  color: #fff;
  padding: 40rpx 24rpx 24rpx;
}

.video-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.video-description {
  font-size: 24rpx;
  opacity: 0.9;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 功能按钮样式 */
.function-buttons {
  display: flex;
  background-color: #fff;
  padding: 32rpx 0;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.08);
}

.function-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.function-btn-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 40rpx;
  background-color: #FAF6F0;
  transition: all 0.3s ease;
}

.function-btn:active .function-btn-icon {
  transform: scale(0.95);
}

.function-btn-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 标题样式 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-title text:first-child {
  display: flex;
  align-items: center;
}

.section-title text:first-child::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background-color: #D4A76A;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

/* 查看更多样式 */
.more {
  font-size: 24rpx;
  color: #999;
  display: flex;
  align-items: center;
}

.more::after {
  content: '›';
  margin-left: 4rpx;
  font-size: 28rpx;
}

/* 项目列表样式 */
.project-list-small {
  margin: 0 24rpx 24rpx;
  display: flex;
  gap: 20rpx;
}

.project-item-small {
  width: calc(50% - 10rpx);
  background-color: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.08);
}

.project-image-small {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  object-fit: cover;
  margin-bottom: 16rpx;
  background-color: #FAF6F0;
}

.project-info-small {
  display: flex;
  flex-direction: column;
}

.project-title-small {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-description-small {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.project-price-small {
  color: #D4A76A;
  font-size: 32rpx;
  font-weight: 600;
}

.project-price-small::before {
  content: '¥';
  font-size: 24rpx;
}

/* 商品列表样式 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin: 0 24rpx 24rpx;
}

/* 商品项样式 */
.goods-item {
  width: calc(50% - 10rpx);
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.08);
  transition: all 0.3s ease;
}

.goods-item:active {
  transform: scale(0.98);
}

/* 商品图片样式 */
.goods-image {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
  background-color: #FAF6F0;
}

/* 商品信息样式 */
.goods-info {
  padding: 20rpx;
}

/* 商品名称样式 */
.goods-name {
  font-size: 28rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: #333;
  line-height: 1.4;
}

/* 商品标签样式 */
.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

/* 标签样式 */
.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background-color: #FAF6F0;
  color: #D4A76A;
}

/* 商品价格样式 */
.goods-price {
  color: #D4A76A;
  font-size: 32rpx;
  font-weight: 600;
}

.goods-price::before {
  content: '¥';
  font-size: 24rpx;
  margin-right: 2rpx;
}

/* 商品原价样式 */
.goods-original-price {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
  font-weight: 400;
}

/* 商品库存样式 */
.goods-stock {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 加载更多样式 */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 32rpx;
}
