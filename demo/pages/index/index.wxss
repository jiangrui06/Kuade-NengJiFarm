/* 搜索框样式 */
.search-container {
  display: flex;
  padding: 10px 15px;
  background-color: #fff;
  align-items: center;
  margin-bottom: 10px;
}

.search-input {
  flex: 1;
  height: 36px;
  background-color: #f5f5f5;
  border-radius: 18px;
  padding: 0 15px;
  font-size: 14px;
}

.search-btn {
  margin-left: 10px;
  height: 36px;
  padding: 0 15px;
  background-color: #e64340;
  color: #fff;
  border-radius: 18px;
  font-size: 14px;
  line-height: 36px;
}

/* 轮播图样式 */
.swiper-container {
  margin-bottom: 15px;
  padding: 0 15px;
}

.swiper-item {
  width: 100%;
  height: 180px;
  border-radius: 8px;
  overflow: hidden;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 功能按钮样式 */
.function-buttons {
  display: flex;
  background-color: #fff;
  padding: 15px 0;
  margin: 0 15px 15px 15px;
  border-radius: 8px;
}

.function-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.function-btn-icon {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 5px;
  font-size: 24px;
  color: #fff;
  text-align: center;
  line-height: 48px;
  padding: 0;
}

.function-btn-text {
  font-size: 12px;
  margin-top: 5px;
}

/* 项目列表样式 */
.project-list-small {
  margin: 0 15px 15px 15px;
  display: flex;
  justify-content: space-between;
}

.project-item-small {
  width: 48%;
  background-color: #fff;
  border-radius: 8px;
  padding: 10px;
  display: flex;
  flex-direction: column;
}

.project-image-small {
  width: 100%;
  height: 100px;
  border-radius: 8px;
  object-fit: cover;
  margin-bottom: 8px;
}

.project-info-small {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.project-title-small {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 3px;
}

.project-description-small {
  font-size: 10px;
  color: #666;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.project-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.project-price-small {
  color: #e64340;
  font-size: 16px;
  font-weight: 600;
}

/* 购买按钮样式 */
.buy-btn-small {
  background-color: #4CAF50;
  color: #fff;
  border: none;
  padding: 4px 12px;
  border-radius: 16px;
  font-size: 12px;
  font-weight: 600;
  box-shadow: 0 2px 4px rgba(76, 175, 80, 0.3);
  transition: all 0.3s ease;
}

.buy-btn-small:active {
  background-color: #388E3C;
  transform: translateY(2px);
  box-shadow: 0 1px 2px rgba(76, 175, 80, 0.3);
  transition: all 0.3s ease;
}

/* 商品列表样式 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin: 0 15px 20px 15px;
}

/* 商品项样式 */
.goods-item {
  width: 48%;
  background-color: #fff;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 15px;
}

/* 商品图片样式 */
.goods-image {
  width: 100%;
  height: 150px;
  object-fit: cover;
}

/* 商品信息样式 */
.goods-info {
  padding: 10px;
}

/* 商品名称样式 */
.goods-name {
  font-size: 14px;
  margin-bottom: 5px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 商品标签样式 */
.goods-tags {
  display: flex;
  margin-bottom: 5px;
}

/* 标签样式 */
.tag {
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 4px;
  margin-right: 5px;
  background-color: #f0f0f0;
  color: #666;
}

/* 商品价格样式 */
.goods-price {
  color: #e64340;
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 5px;
}

/* 商品原价样式 */
.goods-original-price {
  color: #999;
  font-size: 12px;
  text-decoration: line-through;
  margin-left: 5px;
}

/* 商品库存样式 */
.goods-stock {
  font-size: 12px;
  color: #999;
}

/* 标题样式 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px;
  font-size: 16px;
  font-weight: 600;
}

/* 查看更多样式 */
.more {
  font-size: 12px;
  color: #999;
}