<!-- 搜索框 -->
<view class="search-container" bindtap="navigateToSearch">
  <input class="search-input" placeholder="请输入内容查找" disabled />
  <view class="search-btn">搜索</view>
</view>

<view class="container">
  <!-- 轮播图 -->
  <view class="swiper-container">
    <swiper indicator-dots="true" autoplay="true" interval="3000" duration="1000" circular="true">
      <swiper-item class="swiper-item" wx:for="{{swiperList}}" wx:key="id" bindtap="navigateToFarmIntro">
        <image class="swiper-image" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

   <!-- 视频播放器 -->
   <view class="video-section" wx:if="{{videos.length > 0}}">
    <view class="video-container">
      <video 
        class="video-player"
        src="{{videos[0].videoUrl}}"
        poster="{{videos[0].coverImage && videos[0].coverImage.startsWith('http') ? videos[0].coverImage : ''}}"
        controls="true"
        autoplay="false"
        loop="false"
        muted="false"
        objectFit="cover"
        show-center-play-btn="true"
        enable-progress-gesture="true"
        show-play-btn="true"
        show-fullscreen-btn="true"
        enable-playback-rate="true"
        bindfullscreenchange="onFullscreenChange">
      </video>
    </view>
  </view>


  <!-- 功能按钮 -->
  <view class="function-buttons">
    <view class="function-btn" bindtap="navigateToAcre">
      <view class="function-btn-icon" style="background-color: #D4A574;">🌾</view>
      <view class="function-btn-text">认购一亩田</view>
    </view>
    <view class="function-btn" bindtap="navigateToFarmGoods">
      <view class="function-btn-icon" style="background-color: #D4A574;">🍅</view>
      <view class="function-btn-text">农场优选</view>
    </view>
    <view class="function-btn" bindtap="navigateToOrder">
      <view class="function-btn-icon" style="background-color: #D4A574;">🍽️</view>
      <view class="function-btn-text">点餐</view>
    </view>
    <view class="function-btn" bindtap="navigateToActivity">
      <view class="function-btn-icon" style="background-color: #D4A574;">🎉</view>
      <view class="function-btn-text">活动中心</view>
    </view>
  </view>

  <!-- 认购一亩田 -->
  <view class="section-title">
    <text>认购一亩田</text>
    <text class="more" bindtap="navigateToAcre">查看更多</text>
  </view>
  <view class="project-list-small">
    <view class="project-item-small" wx:for="{{acreProjects}}" wx:key="id" bindtap="navigateToAcreDetail" data-id="{{item.id}}">
      <image class="project-image-small" src="{{item.image}}" mode="aspectFill" />
      <view class="project-tag">限量认购</view>
      <view class="project-info-small">
        <view class="project-title-small">{{item.name}}</view>
        <view class="project-description-small">{{item.description}}</view>
        <view class="project-price-row">
          <view class="project-price-small">
            {{item.price}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 农场优选 -->
  <view class="section-title">
    <text>农场优选</text>
    <text class="more" bindtap="navigateToFarmGoods">查看更多</text>
  </view>
  <view class="goods-list">
    <view class="goods-item" wx:for="{{farmGoods}}" wx:key="id" bindtap="navigateToGoodsDetail" data-id="{{item.id}}">
      <image class="goods-image" src="{{item.image}}" mode="aspectFill" />
      <view class="goods-info">
        <view class="goods-name">{{item.name}}</view>
        <view class="goods-tags">
          <view class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index">{{tag}}</view>
        </view>
        <view class="goods-price">¥{{item.price}}<text class="goods-original-price">¥{{item.originalPrice}}</text></view>
        <view class="goods-stock {{item.stock === 0 ? 'stock-out' : item.stock < 10 ? 'stock-low' : ''}}">{{item.stock === 0 ? '已售罄' : '还剩' + item.stock + '份'}}</view>
      </view>
    </view>
  </view>

  <!-- 热销菜品 -->
  <view class="section-title">
    <text>热销菜品</text>
    <text class="more" bindtap="navigateToOrder">查看更多</text>
  </view>
  <view class="goods-list">
    <view class="goods-item" wx:for="{{hotDishes}}" wx:key="id" bindtap="navigateToOrderFoodsDetail" data-id="{{item.id}}">
      <image class="goods-image" src="{{item.image}}" mode="aspectFill" />
      <view class="goods-info">
        <view class="goods-name">{{item.name}}</view>
        <view class="goods-tags">
          <view class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index">{{tag}}</view>
        </view>
        <view class="goods-price">¥{{item.price}}</view>
      </view>
    </view>
  </view>
  

</view>