  <view class="goods-list">
    <view class="goods-item">
      <image class="goods-image" src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=fresh%20bell%20peppers&image_size=square" />
      <view class="goods-info">
        <view class="goods-name">甜腻玉米500g</view>
        <view class="goods-tags">
          <view class="tag">软糯香甜</view>
          <view class="tag">颗粒饱满</view>
