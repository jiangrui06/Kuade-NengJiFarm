<view class="container">
  <view class="dish-image-container">
    <image class="dish-image" src="{{dish.image}}" />
  </view>

  <view class="dish-info">
    <view class="dish-price">￥{{dish.price}}</view>
    <view class="dish-name">{{dish.name}}</view>
   
    <view class="dish-description">
      {{dish.description}}
    </view>



    <view class="service-info">
      <view class="service-item">
        <text class="service-label">服务</text>
        <text class="service-text">新鲜现做</text>
      </view>
    </view>
  </view>

  <view class="spec-info">
    <view class="spec-title">菜品信息</view>
    <view class="spec-item">
      <view class="spec-label">主要食材</view>
      <view class="spec-value">{{dish.ingredients}}</view>
    </view>
    <view class="spec-item">
      <view class="spec-label">烹饪时间</view>
      <view class="spec-value">{{dish.cookingTime}}</view>
    </view>
  </view>

  <view class="dish-display-image">
    <image class="display-image" src="{{dish.detailImage}}" />
  </view>

  <view class="dish-detail-images">
    <image class="detail-image" src="{{dish.detailImage}}" />
  </view>

  <view class="bottom-bar">
    <view class="cart-icon" bindtap="goToCart">
      <text class="cart-text">🛒</text>
      <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
    </view>
    <button class="add-to-cart-btn" bindtap="addToCart">加入购物车</button>
    <button class="buy-now-btn" bindtap="buyNow">立即购买</button>
  </view>
</view>
