<view class="container">
  <!-- 会员中心头部 -->
  <view class="member-header" bindtap="editProfile">
    <view class="member-info">
      <image class="member-avatar" src="{{userInfo.avatar}}" />
      <view class="member-details">
        <view class="member-name">{{userInfo.nickname}}</view>
        <view class="member-email" wx:if="{{userInfo.email}}">{{userInfo.email}}</view>
      </view>
    </view>
    <view class="member-actions">
      <image class="action-icon" src="https://img.icons8.com/ios-glyphs/24/ffffff/chat.png" />
      <image class="action-icon" src="https://img.icons8.com/ios-glyphs/24/ffffff/settings.png" />
    </view>
  </view>
  
  <!-- 我的订单 -->
  <view class="order-section">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <text class="section-more" bindtap="navigateToOrders" data-tab="all">全部订单 ></text>
    </view>
    <view class="order-states">
      <view class="order-state" bindtap="navigateToOrders" data-tab="pending">
        <image class="state-icon" src="https://img.icons8.com/ios-glyphs/24/666666/wallet.png" />
        <text class="state-text">待付款</text>
        <view class="state-badge" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</view>
      </view>
      <view class="order-state" bindtap="navigateToOrders" data-tab="paid">
        <image class="state-icon" src="https://img.icons8.com/ios-glyphs/24/666666/truck.png" />
        <text class="state-text">待发货</text>
        <view class="state-badge" wx:if="{{orderCounts.paid > 0}}">{{orderCounts.paid}}</view>
      </view>
      <view class="order-state" bindtap="navigateToOrders" data-tab="shipping">
        <image class="state-icon" src="https://img.icons8.com/ios-glyphs/24/666666/delivery.png" />
        <text class="state-text">待收货</text>
        <view class="state-badge" wx:if="{{orderCounts.shipping > 0}}">{{orderCounts.shipping}}</view>
      </view>
      <view class="order-state" bindtap="navigateToOrders" data-tab="refund">
        <image class="state-icon" src="https://img.icons8.com/ios-glyphs/24/666666/return.png" />
        <text class="state-text">售后</text>
        <view class="state-badge" wx:if="{{orderCounts.refund > 0}}">{{orderCounts.refund}}</view>
      </view>
    </view>
  </view>
  
  <!-- 推荐商品 -->
  <view class="recommend-section">
    <image class="recommend-image" src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=grilled%20skewers%20and%20vegetables&image_size=landscape_16_9" />
  </view>
  
  <!-- 功能列表 -->
  <view class="function-section">
    <view class="function-item" bindtap="navigateToAddress">
      <image class="function-icon" src="https://img.icons8.com/ios-glyphs/24/666666/map-marker.png" />
      <text class="function-text">收货地址</text>
      <image class="function-arrow" src="https://img.icons8.com/ios-glyphs/24/999999/chevron-right.png" />
    </view>
    <view class="function-item" bindtap="navigateToPayment">
      <image class="function-icon" src="https://img.icons8.com/ios-glyphs/24/666666/paypal.png" />
      <text class="function-text">支付信息</text>
      <image class="function-arrow" src="https://img.icons8.com/ios-glyphs/24/999999/chevron-right.png" />
    </view>
    <view class="function-item" bindtap="navigateToFavorites">
      <image class="function-icon" src="https://img.icons8.com/ios-glyphs/24/666666/like.png" />
      <text class="function-text">商品收藏</text>
      <image class="function-arrow" src="https://img.icons8.com/ios-glyphs/24/999999/chevron-right.png" />
    </view>
    <view class="function-item" bindtap="navigateToService">
      <image class="function-icon" src="https://img.icons8.com/ios-glyphs/24/666666/headset.png" />
      <text class="function-text">客服中心</text>
      <image class="function-arrow" src="https://img.icons8.com/ios-glyphs/24/999999/chevron-right.png" />
    </view>
    <view class="function-item" bindtap="navigateToFeedback">
      <image class="function-icon" src="https://img.icons8.com/ios-glyphs/24/666666/feedback.png" />
      <text class="function-text">意见反馈</text>
      <image class="function-arrow" src="https://img.icons8.com/ios-glyphs/24/999999/chevron-right.png" />
    </view>
  </view>
</view>