.container {
  padding: 0;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 会员中心头部 */
.member-header {
  background-color: #2196F3;
  padding: 30px 15px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #fff;
  position: relative;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.member-header:active {
  background-color: #1976D2;
}

.member-info {
  display: flex;
  align-items: center;
}

.member-avatar {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  margin-right: 15px;
  border: 2px solid #fff;
}

.member-details {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 5px;
}

.member-email {
  font-size: 12px;
  opacity: 0.8;
}

.member-level {
  font-size: 12px;
  opacity: 0.8;
}

.member-actions {
  display: flex;
  align-items: center;
}

.action-icon {
  width: 24px;
  height: 24px;
  margin-left: 15px;
}

/* 通用 section 样式 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px;
  background-color: #fff;
  border-bottom: 1px solid #f0f0f0;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
}

.section-more {
  font-size: 12px;
  color: #999;
}

/* 我的订单 */
.order-section {
  background-color: #fff;
  margin: 15px 0;
  border-radius: 8px;
  overflow: hidden;
}

.order-states {
  display: flex;
  padding: 15px;
  justify-content: space-around;
}

.order-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.state-icon {
  width: 24px;
  height: 24px;
  margin-bottom: 5px;
}

.state-text {
  font-size: 12px;
  color: #666;
}

.state-badge {
  position: absolute;
  top: -5px;
  right: -5px;
  background-color: #e64340;
  color: #fff;
  font-size: 10px;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 我的权益 */
.benefits-section {
  background-color: #fff;
  margin: 15px 0;
  border-radius: 8px;
  overflow: hidden;
}

.benefits-list {
  display: flex;
  padding: 15px;
  justify-content: space-around;
}

.benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.benefit-value {
  font-size: 18px;
  font-weight: 600;
  color: #e64340;
  margin-bottom: 5px;
}

.benefit-label {
  font-size: 12px;
  color: #666;
}

/* 推荐商品 */
.recommend-section {
  padding: 0 15px;
  margin: 15px 0;
}

.recommend-image {
  width: 100%;
  border-radius: 8px;
  height: 120px;
  object-fit: cover;
}

/* 功能列表 */
.function-section {
  background-color: #fff;
  margin: 15px 0;
  border-radius: 8px;
  overflow: hidden;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
}

.function-item:last-child {
  border-bottom: none;
}

.function-icon {
  width: 24px;
  height: 24px;
  margin-right: 15px;
}

.function-text {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.function-arrow {
  width: 24px;
  height: 24px;
  opacity: 0.5;
}