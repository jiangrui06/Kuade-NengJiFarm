<!--pages/buy/buy.wxml-->
<view class="container">
  <!-- 头部导航 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="header-title">选择支付方式</text>
    <view class="header-right"></view>
  </view>

  <!-- 金额信息 -->
  <view class="amount-section" wx:if="{{paymentInfo}}">
    <view class="amount-container">
      <text class="amount">¥{{paymentInfo.actualAmount}}</text>
    </view>
    <view class="order-amount-container">
      <text class="order-amount">订单金额：¥{{paymentInfo.totalAmount}}</text>
    </view>
  </view>

  <!-- 客户信息 -->
  <view class="info-section" wx:if="{{paymentInfo && paymentInfo.userInfo}}">
    <view class="info-item">
      <text class="info-label">客户信息</text>
      <text class="info-value">{{paymentInfo.userInfo.name}}（{{paymentInfo.userInfo.phone}}）</text>
    </view>
  </view>

  <!-- 地址信息 -->
  <view class="info-section" wx:if="{{paymentInfo && paymentInfo.address}}">
    <view class="info-item">
      <text class="info-label">收货地址</text>
      <text class="info-value">{{paymentInfo.address.name}} {{paymentInfo.address.phone}}\n{{paymentInfo.address.province}}{{paymentInfo.address.city}}{{paymentInfo.address.district}}{{paymentInfo.address.address}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section" wx:if="{{paymentMethods.length > 0}}">
    <view class="payment-item" wx:for="{{paymentMethods}}" wx:key="id" bindtap="selectPayment" data-index="{{index}}">
      <view class="payment-icon">
        <text class="icon">{{index === 0 ? '💚' : '💳'}}</text>
      </view>
      <view class="payment-info">
        <text class="payment-name">{{item.name}}</text>
        <text class="payment-desc">{{item.description}}</text>
      </view>
      <view class="payment-radio {{selectedPayment === index ? 'checked' : ''}}" bindtap="selectPayment" data-index="{{index}}">
        <view class="radio-inner {{selectedPayment === index ? 'checked' : ''}}"></view>
      </view>
    </view>
  </view>

  <!-- 确认收款按钮 -->
  <view class="confirm-btn" bindtap="confirmPayment">
    <text class="confirm-btn-text">确认支付</text>
  </view>
</view>