<!--pages/buy/buy.wxml-->
<view class="container">
  <!-- 头部导航 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="header-title">选择支付方式</text>
    <view class="header-right"></view>
  </view>

  <!-- 金额信息 -->
  <view class="amount-section">
    <view class="amount-container">
      <text class="amount">¥200.0</text>
    </view>
    <view class="order-amount-container">
      <text class="order-amount">订单金额：¥1000.00</text>
    </view>
  </view>

  <!-- 客户信息 -->
  <view class="info-section">
    <view class="info-item">
      <text class="info-label">客户信息</text>
      <text class="info-value">张女士（188****8888）</text>
    </view>
  </view>

  <!-- 优惠信息 -->
  <view class="discount-section">
    <view class="discount-item">
      <text class="discount-label">优惠</text>
      <view class="discount-value">
        <text class="discount-tag">收益优惠</text>
        <text class="discount-amount">本单优惠 ¥800.00</text>
      </view>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section">
    <view class="payment-item" bindtap="selectPayment" data-index="0">
      <view class="payment-icon">
        <text class="icon">💚</text>
      </view>
      <view class="payment-info">
        <text class="payment-name">微信支付</text>
        <text class="payment-desc">推荐使用微信支付，安全快捷</text>
      </view>
      <view class="payment-radio {{selectedPayment === 0 ? 'checked' : ''}}" bindtap="selectPayment" data-index="0">
        <view class="radio-inner {{selectedPayment === 0 ? 'checked' : ''}}"></view>
      </view>
    </view>
  </view>

  <!-- 确认收款按钮 -->
  <view class="confirm-btn" bindtap="confirmPayment">
    <text class="confirm-btn-text">确认支付</text>
  </view>
</view>