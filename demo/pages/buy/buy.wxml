<!--pages/buy/buy.wxml-->
<view class="container">
  <!-- 头部导航 -->
  <view class="header">
    <view class="header-left"></view>
    <text class="header-title">选择支付方式</text>
    <view class="header-right"></view>
  </view>

  <!-- 金额信息 -->
  <view class="amount-section">
    <view class="amount-container">
      <text class="amount">¥200.0</text>
    </view>
    <view class="order-amount-container">
      <text class="order-amount">订单金额：¥1000.00</text>
    </view>
  </view>

  <!-- 客户信息 -->
  <view class="info-section">
    <view class="info-item">
      <text class="info-label">客户信息</text>
      <text class="info-value">张女士（188****8888）</text>
    </view>
  </view>

  <!-- 优惠信息 -->
  <view class="discount-section">
    <view class="discount-item">
      <text class="discount-label">优惠</text>
      <view class="discount-value">
        <text class="discount-tag">收益优惠</text>
        <text class="discount-amount">本单优惠 ¥800.00</text>
      </view>
    </view>
  </view>

  <!-- 支付方式列表 -->
  <view class="payment-section">
    <view class="payment-item" bindtap="selectPayment" data-index="0">
      <view class="payment-icon">
        <image src="/images/qianbao.png" mode="aspectFill"></image>
      </view>
      <view class="payment-info">
        <text class="payment-name">钱包余额支付</text>
        <text class="payment-desc">可用余额 ¥12000.00</text>
      </view>
      <view class="payment-radio {{selectedPayment === 0 ? 'checked' : ''}}" bindtap="selectPayment" data-index="0">
        <view class="radio-inner {{selectedPayment === 0 ? 'checked' : ''}}"></view>
      </view>
    </view>

    <view class="payment-item" bindtap="selectPayment" data-index="1">
      <view class="payment-icon">
        <image src="/images/weixin.png" mode="aspectFill"></image>
      </view>
      <view class="payment-info">
        <text class="payment-name">微信支付</text>
      </view>
      <view class="payment-radio {{selectedPayment === 1 ? 'checked' : ''}}" bindtap="selectPayment" data-index="1">
        <view class="radio-inner {{selectedPayment === 1 ? 'checked' : ''}}"></view>
      </view>
    </view>

    <view class="payment-item" bindtap="selectPayment" data-index="2">
      <view class="payment-icon">
        <image src="/images/zhifu.png" mode="aspectFill"></image>
      </view>
      <view class="payment-info">
        <text class="payment-name">支付宝</text>
      </view>
      <view class="payment-radio {{selectedPayment === 2 ? 'checked' : ''}}" bindtap="selectPayment" data-index="2">
        <view class="radio-inner {{selectedPayment === 2 ? 'checked' : ''}}"></view>
      </view>
    </view>

    <view class="payment-item" bindtap="selectPayment" data-index="3">
      <view class="payment-icon">
        <image src="/images/zj.png" mode="aspectFill"></image>
      </view>
      <view class="payment-info">
        <text class="payment-name">银行卡</text>
      </view>
      <view class="payment-radio {{selectedPayment === 3 ? 'checked' : ''}}" bindtap="selectPayment" data-index="3">
        <view class="radio-inner {{selectedPayment === 3 ? 'checked' : ''}}"></view>
      </view>
    </view>

    <view class="payment-item" bindtap="selectPayment" data-index="4">
      <view class="payment-icon">
        <image src="/images/qita.png" mode="aspectFill"></image>
      </view>
      <view class="payment-info">
        <text class="payment-name">其它</text>
      </view>
      <view class="payment-radio {{selectedPayment === 4 ? 'checked' : ''}}" bindtap="selectPayment" data-index="4">
        <view class="radio-inner {{selectedPayment === 4 ? 'checked' : ''}}"></view>
      </view>
    </view>
  </view>

  <!-- 确认收款按钮 -->
  <view class="confirm-btn" bindtap="confirmPayment">
    <text class="confirm-btn-text">确认支付</text>
  </view>
</view>