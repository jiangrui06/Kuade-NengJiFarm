/* pages/buy/buy.wxss */
.container {
    background: #f5f5f5;
    min-height: 100vh;
    padding-bottom: 40rpx;
  }
  
  /* 头部导航 */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20rpx 30rpx;
    background: #fff;
    border-bottom: 1rpx solid #eee;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }
  
  .back-btn {
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .back-icon {
    font-size: 36rpx;
    color: #333;
  }
  
  .header-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
  }
  
  .header-left {
    width: 60rpx;
  }
  
  .header-right {
    width: 60rpx;
  }
  
  /* 金额信息 */
  .amount-section {
    background: #fff;
    padding: 60rpx 30rpx 40rpx;
    margin-top: 100rpx;
    text-align: center;
    border-radius: 0 0 16rpx 16rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  }
  
  .amount-container {
    margin-bottom: 20rpx;
  }
  
  .amount {
    font-size: 80rpx;
    font-weight: bold;
    color: #333;
    line-height: 1;
  }
  
  .order-amount-container {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .order-amount {
    font-size: 28rpx;
    color: #666;
    white-space: nowrap;
  }
  
  /* 信息区域 */
  .info-section {
    background: #fff;
    margin: 20rpx 30rpx;
    padding: 30rpx;
    border-radius: 12rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  }
  
  .info-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .info-label {
    font-size: 28rpx;
    color: #666;
    font-weight: 500;
  }
  
  .info-value {
    font-size: 28rpx;
    color: #333;
    font-weight: 500;
    text-align: right;
    line-height: 1.4;
    flex: 1;
    margin-left: 20rpx;
  }
  
  /* 优惠信息 */
  .discount-section {
    background: #fff;
    margin: 0 30rpx 20rpx;
    padding: 30rpx;
    border-radius: 12rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  }
  
  .discount-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .discount-label {
    font-size: 28rpx;
    color: #666;
    font-weight: 500;
  }
  
  .discount-value {
    display: flex;
    align-items: center;
  }
  
  .discount-tag {
    font-size: 20rpx;
    color: #ff4757;
    background: #fff0f0;
    padding: 6rpx 16rpx;
    border-radius: 8rpx;
    margin-right: 16rpx;
    font-weight: 500;
  }
  
  .discount-amount {
    font-size: 28rpx;
    color: #ff4757;
    font-weight: bold;
    text-shadow: 0 1rpx 2rpx rgba(255,71,87,0.3);
  }
  
  /* 支付方式 */
  .payment-section {
    background: #fff;
    margin: 0 30rpx 20rpx;
    border-radius: 12rpx;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
    padding: 30rpx;
  }
  
  .payment-item {
    display: flex;
    align-items: center;
    padding: 24rpx;
    transition: all 0.3s ease;
    border-radius: 12rpx;
    background: linear-gradient(135deg, #f8fff9 0%, #e6f7f0 100%);
    border: 2rpx solid #e6f7f0;
  }
  
  .payment-item:active {
    background: #e6f7f0;
    transform: translateY(-2rpx);
    box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
  }
  
  .payment-icon {
    width: 80rpx;
    height: 80rpx;
    margin-right: 24rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #07c160 0%, #05a650 100%);
    border-radius: 16rpx;
    box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
    flex-shrink: 0;
  }
  
  .payment-icon image {
    width: 100%;
    height: 100%;
  }
  
  .icon {
    font-size: 48rpx;
    color: #fff;
  }
  
  .payment-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  
  .payment-name {
    font-size: 36rpx;
    color: #333;
    font-weight: bold;
    margin-bottom: 4rpx;
  }
  
  .payment-desc {
    font-size: 24rpx;
    color: #666;
    line-height: 1.4;
  }
  
  .payment-radio {
    width: 48rpx;
    height: 48rpx;
    border: 3rpx solid #ddd;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    cursor: pointer;
    z-index: 1;
    flex-shrink: 0;
  }
  
  .payment-radio.checked {
    border-color: #07c160;
  }
  
  .radio-inner {
    width: 28rpx;
    height: 28rpx;
    border-radius: 50%;
    background: transparent;
    transition: all 0.3s ease;
  }
  
  .radio-inner.checked {
    background: #07c160;
    transform: scale(1.1);
  }
  
  .payment-item {
    cursor: pointer;
    user-select: none;
    position: relative;
    z-index: 0;
    -webkit-tap-highlight-color: transparent;
    tap-highlight-color: transparent;
  }
  
  .payment-radio {
    -webkit-tap-highlight-color: transparent;
    tap-highlight-color: transparent;
  }
  
  .payment-item:hover .payment-icon {
    transform: scale(1.05);
  }
  
  /* 确认收款按钮 */
  .confirm-btn {
    margin: 40rpx 30rpx;
    background: linear-gradient(135deg, #07c160 0%, #05a650 100%);
    padding: 30rpx;
    text-align: center;
    box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
    border-radius: 16rpx;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  
  .confirm-btn::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      to bottom right,
      rgba(255, 255, 255, 0.3) 0%,
      rgba(255, 255, 255, 0) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: rotate(45deg);
    animation: shine 3s infinite;
  }
  
  .confirm-btn:active {
    transform: translateY(2rpx);
    box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.3);
  }
  
  .confirm-btn-text {
    font-size: 32rpx;
    color: #fff;
    font-weight: bold;
    position: relative;
    z-index: 1;
  }
  
  @keyframes shine {
    0% {
      transform: translateX(-100%) rotate(45deg);
    }
    100% {
      transform: translateX(100%) rotate(45deg);
    }
  }