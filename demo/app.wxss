/* 全局样式 - 能记农场 */

/* 重置样式 */
page, view, text, image, button, input, textarea, navigator, swiper, swiper-item {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* 页面基础样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #F5F5F5;
  color: #333333;
  line-height: 1.5;
}

/* 容器样式 */
.container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 通用按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
  -webkit-tap-highlight-color: transparent;
}

.btn-primary {
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #FFFFFF;
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.15);
}

.btn-secondary {
  background: linear-gradient(135deg, #FAF6F0 0%, #F5F0E6 100%);
  color: #D4A76A;
  border: 2rpx solid #D4A76A;
}

.btn-secondary:active {
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #FFFFFF;
  transform: scale(0.95);
}

/* 通用标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 24rpx;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  height: 36rpx;
  line-height: 36rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

/* 通用卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
  padding: 24rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s ease;
}

.card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.15);
}

/* 通用图片样式 */
.image {
  width: 100%;
  object-fit: cover;
  border-radius: 8rpx;
  background-color: #FAF6F0;
}

/* 通用文本样式 */
.text-primary {
  color: #333333;
}

.text-secondary {
  color: #666666;
}

.text-tertiary {
  color: #999999;
}

.text-primary-color {
  color: #D4A76A;
}

.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.font-medium {
  font-weight: 500;
}

/* 通用间距样式 */
.mt-sm {
  margin-top: 8rpx;
}

.mt-md {
  margin-top: 16rpx;
}

.mt-lg {
  margin-top: 24rpx;
}

.mb-sm {
  margin-bottom: 8rpx;
}

.mb-md {
  margin-bottom: 16rpx;
}

.mb-lg {
  margin-bottom: 24rpx;
}

.mx-auto {
  margin-left: auto;
  margin-right: auto;
}

/* 通用布局样式 */
.flex {
  display: flex;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.items-center {
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 通用阴影样式 */
.shadow-sm {
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
}

.shadow-md {
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.15);
}

.shadow-lg {
  box-shadow: 0 12rpx 32rpx rgba(212, 167, 106, 0.2);
}

/* 通用圆角样式 */
.rounded-sm {
  border-radius: 8rpx;
}

.rounded-md {
  border-radius: 16rpx;
}

.rounded-lg {
  border-radius: 24rpx;
}

/* 通用动画样式 */
.transition {
  transition: all 0.3s ease;
}

/* 加载状态样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 空状态样式 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 24rpx;
  color: #999999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  color: #999999;
}

/* 错误状态样式 */
.error {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 24rpx;
  color: #E64340;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .section-title {
    font-size: 32rpx;
    height: 32rpx;
    line-height: 32rpx;
  }
  
  .card {
    padding: 16rpx;
  }
  
  .btn {
    font-size: 26rpx;
    padding: 14rpx 28rpx;
  }
}
