/* pages/buy/buy.wxss */

/* 全局样式 */
.container {
    background-color: #fff;
    min-height: 100vh;
    padding-bottom: 120rpx;
  }
  
  
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100rpx;
    background-color: #fff;
    padding: 0 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  
  .header-left {
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }
  
  .header-title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
  }
  
  .header-right {
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  
  /* 配送方式 */
  .delivery-section {
    background-color: #fff;
    margin-top: 20rpx;
    padding: 0 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .delivery-options {
    display: flex;
    justify-content: space-between;
    height: 100rpx;
    align-items: center;
  }
  
  .delivery-option {
    padding: 12rpx 30rpx;
    border-radius: 30rpx;
    font-size: 28rpx;
    font-weight: 400;
    transition: all 0.3s ease;
    min-width: 180rpx;
    text-align: center;
  }
  
  .delivery-option.active {
    background-color: #07c160;
    color: #fff;
  }
  
  .delivery-option:not(.active) {
    background-color: #f5f5f5;
    color: #666;
  }
  
  /* 收货地址 */
  .address-section {
    background-color: #fff;
    margin-top: 20rpx;
    padding: 30rpx;
    display: flex;
    align-items: center;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .address-icon {
    font-size: 36rpx;
    margin-right: 20rpx;
    color: #666;
  }
  
  .address-title {
    flex: 1;
    font-size: 32rpx;
    color: #333;
    font-weight: 500;
  }
  
  .address-arrow {
    font-size: 36rpx;
    color: #999;
  }
  
  /* 支付方式 */
  .payment-section {
    background-color: #fff;
    margin-top: 20rpx;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
    border-left: none;
  }
  
  .section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
    border-left: none !important;
    padding-left: 0 !important;
    background: none !important;
    position: relative !important;
  }
  
  .section-title::before {
    display: none !important;
  }
  
  .payment-item {
    display: flex;
    align-items: center;
    height: 80rpx;
    margin-bottom: 20rpx;
  }
  
  .payment-item:last-child {
    margin-bottom: 0;
  }
  
  .payment-icon {
    margin-right: 20rpx;
  }
  
  .icon {
    font-size: 48rpx;
  }
  
  .payment-info {
    flex: 1;
  }
  
  .payment-name {
    font-size: 32rpx;
    color: #333;
    font-weight: 500;
  }
  
  .payment-radio {
    width: 36rpx;
    height: 36rpx;
    border: 2rpx solid #ddd;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .radio-inner {
    width: 24rpx;
    height: 24rpx;
    border-radius: 50%;
    background-color: transparent;
    transition: all 0.3s ease;
  }
  
  .radio-inner.checked {
    background-color: #07c160;
  }
  
  /* 合计 */
  .total-section {
    background-color: #fff;
    margin-top: 20rpx;
    padding: 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .total-label {
    font-size: 32rpx;
    color: #333;
    font-weight: 500;
  }
  
  .total-price {
    font-size: 36rpx;
    font-weight: bold;
    color: #e64340;
  }
  
  /* 地址表单 */
  .address-form {
    background-color: #fff;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .form-item {
    display: flex;
    align-items: center;
    margin-bottom: 30rpx;
  }
  
  .form-item:last-child {
    margin-bottom: 0;
  }
  
  .form-label {
    width: 150rpx;
    font-size: 32rpx;
    color: #333;
    font-weight: 500;
  }
  
  .form-input {
    flex: 1;
    height: 80rpx;
    font-size: 32rpx;
    color: #333;
    border-bottom: 1rpx solid #f0f0f0;
    padding: 0 20rpx;
  }
  
  .address-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 40rpx;
    gap: 30rpx;
  }
  
  .cancel-btn {
    padding: 15rpx 40rpx;
    border: 1rpx solid #ddd;
    border-radius: 30rpx;
    font-size: 28rpx;
    color: #666;
  }
  
  .save-btn {
    padding: 15rpx 40rpx;
    background-color: #07c160;
    border-radius: 30rpx;
    font-size: 28rpx;
    color: #fff;
  }
  
  /* 获取位置按钮 */
  .location-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20rpx;
    background-color: #f5f5f5;
    border-radius: 10rpx;
    margin-top: 10rpx;
    margin-bottom: 20rpx;
  }
  
  .location-icon {
    font-size: 32rpx;
    margin-right: 10rpx;
    color: #07c160;
  }
  
  .location-text {
    font-size: 32rpx;
    color: #333;
    font-weight: 500;
  }
  
  /* 取货时间选项 */
  .pickup-time-options {
    flex: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 15rpx;
  }
  
  .pickup-time-item {
    padding: 12rpx 20rpx;
    border: 1rpx solid #ddd;
    border-radius: 20rpx;
    font-size: 28rpx;
    color: #666;
    text-align: center;
    min-width: 180rpx;
  }
  
  .pickup-time-item.active {
    background-color: #07c160;
    color: #fff;
    border-color: #07c160;
  }
  
  /* 商品列表 */
  .product-section {
    background-color: #fff;
    margin-top: 20rpx;
    padding: 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .product-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx 0;
    border-bottom: 1rpx solid #f0f0f0;
  }
  
  .product-item:last-child {
    border-bottom: none;
  }
  
  .product-info {
    flex: 1;
  }
  
  .product-name {
    font-size: 32rpx;
    color: #333;
    margin-bottom: 10rpx;
    display: block;
  }
  
  .product-price {
    font-size: 32rpx;
    font-weight: bold;
    color: #e64340;
  }
  
  .product-quantity {
    font-size: 32rpx;
    color: #666;
  }
  
  /* 提交订单按钮 */
  .submit-btn {
    position: fixed;
    bottom: 80rpx;
    left: 30rpx;
    right: 30rpx;
    height: 90rpx;
    background-color: #07c160;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 45rpx;
    box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
    z-index: 99;
  }
  
  .submit-btn-text {
    font-size: 36rpx;
    font-weight: bold;
    color: #fff;
  }
  