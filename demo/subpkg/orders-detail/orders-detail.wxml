<view class="container">


  <!-- 订单状态 -->
  <view class="order-status-section">
    <view class="status-text">{{order.isActivityOrder || order.isAcreOrder ? (order.status === 'pending' ? '待支付' : order.status === 'cancelled' ? '已取消' : '已支付') : order.statusText}}</view>
    <!-- 活动订单二维码 -->
    <view wx:if="{{order.isActivityOrder && order.status !== 'pending' && order.status !== 'cancelled'}}">
      <view class="qrcode-section">
        <view class="qrcode-title">活动二维码</view>
        <image class="qrcode-image" src="{{order.qrcode}}" mode="aspectFit" />
        <view class="qrcode-hint">请保存二维码，活动现场出示</view>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 订单详情 -->
  <view wx:else class="order-detail">
    <!-- 收货地址（非活动订单和非认购一亩订单显示） -->
    <view wx:if="{{!order.isActivityOrder && !order.isAcreOrder}}" class="address-section">
      <view class="section-title">收货地址</view>
      <view class="address-info">
        <view class="address-name">{{order.shippingAddress.name}}</view>
        <view class="address-phone">{{order.shippingAddress.phone}}</view>
        <view class="address-detail">{{order.shippingAddress.address}}</view>
      </view>
    </view>

    <!-- 订单信息 -->
    <view class="order-info-section">
      <view class="section-title">订单信息</view>
      <view class="info-item">
        <view class="info-label">订单号</view>
        <view class="info-value">{{order.id}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">下单时间</view>
        <view class="info-value">{{order.createTime}}</view>
      </view>
      <view wx:if="{{order.paymentTime}}" class="info-item">
        <view class="info-label">支付时间</view>
        <view class="info-value">{{order.paymentTime}}</view>
      </view>
      <view wx:if="{{order.shippingTime}}" class="info-item">
        <view class="info-label">发货时间</view>
        <view class="info-value">{{order.shippingTime}}</view>
      </view>
      <view wx:if="{{order.completeTime}}" class="info-item">
        <view class="info-label">完成时间</view>
        <view class="info-value">{{order.completeTime}}</view>
      </view>
      <view wx:if="{{order.paymentMethod}}" class="info-item">
        <view class="info-label">支付方式</view>
        <view class="info-value">{{order.paymentMethod}}</view>
      </view>
      <view wx:if="{{order.transactionId}}" class="info-item">
        <view class="info-label">交易流水号</view>
        <view class="info-value">{{order.transactionId}}</view>
      </view>
    </view>

    <!-- 商品列表 -->
    <view class="goods-section">
      <view class="section-title">商品信息</view>
      <view class="goods-list">
        <view class="goods-item" wx:for="{{order.items}}" wx:key="id">
          <image class="goods-image" src="{{item.image}}" />
          <view class="goods-info">
            <view class="goods-name">{{item.name}}</view>
            <view class="goods-price">￥{{item.price}} × {{item.quantity}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 价格信息 -->
    <view class="price-section">
      <view class="price-item">
        <view class="price-label">商品单价</view>
        <view class="price-value" wx:for="{{order.items}}" wx:key="id">￥{{item.price}}</view>
      </view>
      <view class="price-item total">
        <view class="price-label">订单总价</view>
        <view class="price-value total-price">￥{{order.totalPrice}}</view>
      </view>
    </view>

    <!-- 操作按钮 -->
  <view class="action-section">
    <button wx:if="{{order.status === 'pending'}}" class="action-btn primary-btn" bindtap="payOrder">去支付</button>
    <button wx:if="{{order.status === 'pending'}}" class="action-btn secondary-btn" bindtap="cancelOrder">取消订单</button>
    <!-- 非活动订单和非认购一亩订单显示发货相关按钮 -->
    <button wx:if="{{!order.isActivityOrder && !order.isAcreOrder && order.status === 'paid'}}" class="action-btn secondary-btn" bindtap="markShipping">模拟发货</button>
    <button wx:if="{{order.status === 'paid' || order.status === 'shipping'}}" class="action-btn primary-btn" bindtap="applyRefund">申请退款</button>
    <button wx:if="{{!order.isActivityOrder && !order.isAcreOrder && order.status === 'shipping'}}" class="action-btn secondary-btn" bindtap="confirmReceipt">确认收货</button>
  </view>
  </view>
</view>
