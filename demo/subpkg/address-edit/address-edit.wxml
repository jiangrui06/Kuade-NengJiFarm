<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="header-left"></view>
    <view class="header-title">{{addressId ? '编辑地址' : '新增地址'}}</view>
    <view class="header-right" bindtap="saveAddress">
      <text class="save-btn">保存</text>
    </view>
  </view>
  
  <!-- 表单内容 -->
  <view class="form-content">
    <!-- 收货人 -->
    <view class="form-item">
      <view class="form-label">收货人</view>
      <input class="form-input" value="{{formData.name}}" data-field="name" bindinput="onInputChange" placeholder="请输入收货人姓名" />
    </view>
    
    <!-- 手机号码 -->
    <view class="form-item">
      <view class="form-label">手机号码</view>
      <input class="form-input" value="{{formData.phone}}" data-field="phone" bindinput="onInputChange" placeholder="请输入手机号码" type="number" />
    </view>
    
    <!-- 所在地区 -->
    <view class="form-item" bindtap="chooseRegion">
      <view class="form-label">所在地区</view>
      <view class="region-select">
        <text class="region-text">{{formData.province}}{{formData.city}}{{formData.district}}</text>
        <text class="region-arrow">></text>
      </view>
    </view>
    
    <!-- 详细地址 -->
    <view class="form-item">
      <view class="form-label">详细地址</view>
      <textarea class="form-textarea" value="{{formData.detail}}" data-field="detail" bindinput="onInputChange" placeholder="请输入详细地址" />
    </view>
    
    <!-- 设为默认地址 -->
    <view class="form-item checkbox-item" bindtap="toggleDefault">
      <view class="form-label">设为默认地址</view>
      <view class="checkbox-container">
        <view class="checkbox {{formData.isDefault ? 'checked' : ''}}">
          <text wx:if="{{formData.isDefault}}" class="checkbox-icon">✓</text>
        </view>
      </view>
    </view>
  </view>
</view>