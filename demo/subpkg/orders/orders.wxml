<view class="container">
  <!-- 标签栏 -->
  <view class="tab-bar">
    <scroll-view scroll-x enable-flex scroll-into-view="{{scrollToView}}" scroll-with-animation>
      <view class="tab-list">
        <view 
          id="tab-{{item.key}}"
          class="tab-item {{activeTab === item.key ? 'active' : ''}}"
          wx:for="{{tabs}}" 
          wx:key="key"
          bindtap="switchTab"
          data-tab="{{item.key}}"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 订单列表 -->
    <block wx:else>
      <!-- 有订单的情况 -->
      <block wx:if="{{orders.length > 0}}">
        <view class="order-card" wx:for="{{orders}}" wx:key="id">
          <view class="order-header">
            <view class="order-top">
              <view class="order-type" wx:if="{{item.type}}">
                <text class="type-tag" wx:if="{{item.type === 'food'}}">点餐</text>
                <text class="type-tag" wx:elif="{{item.type === 'acre'}}">认购</text>
                <text class="type-tag" wx:elif="{{item.type === 'activity'}}">活动</text>
                <text class="type-tag" wx:elif="{{item.type === 'cart'}}">购物车</text>
              </view>
              <view class="order-id">订单号：{{item.id}}</view>
            </view>
            <view class="order-status">{{item.statusText}}</view>
          </view>
          
          <view class="order-content">
            <view class="order-items">
              <view class="order-item-row" wx:for="{{item.items}}" wx:for-item="goods" wx:key="index">
                <image class="item-image" src="{{goods.image}}" />
                <view class="item-info">
                  <view class="item-name">{{goods.name}}</view>
                  <view class="item-price">￥{{goods.price}} × {{goods.quantity}}</view>
                </view>
              </view>
            </view>
            
            <view class="order-footer">
              <view class="order-total">
                <text>共{{item.items.length}}件商品</text>
                <text class="total-price">合计：￥{{item.totalPrice}}</text>
              </view>
              
              <view class="order-actions">
                <button 
                  wx:if="{{item.status === 'pending'}}"
                  class="action-btn primary-btn"
                  bindtap="payOrder"
                  data-order-id="{{item.id}}"
                >
                  去支付
                </button>
                <button 
                  wx:if="{{item.status === 'pending'}}"
                  class="action-btn delete-btn"
                  bindtap="deleteOrder"
                  data-order-id="{{item.id}}"
                >
                  删除
                </button>
                <button 
                  wx:else
                  class="action-btn secondary-btn"
                  bindtap="viewOrderDetail"
                  data-order-id="{{item.id}}"
                >
                  查看详情
                </button>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 无订单的情况 -->
      <block wx:else>
        <view class="empty-order">
          <view class="empty-icon">
            <text class="icon">📋</text>
          </view>
          <view class="empty-text">您当前没有订单呢</view>
          <view class="empty-hint">去逛逛农场美食吧</view>
        </view>
      </block>
    </block>
  </view>
</view>
