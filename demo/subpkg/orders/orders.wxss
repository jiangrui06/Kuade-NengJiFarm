.container {
  background-color: #f8f5e9;
  min-height: 100vh;
}

/* 标签栏 */
.tab-bar {
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 99;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.tab-list {
  display: flex;
  padding: 0 5rpx;
}

.tab-item {
  padding: 18rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  position: relative;
  white-space: nowrap;
  transition: all 0.3s ease;
  text-align: center;
  margin: 0 8rpx;
  border-radius: 40rpx;
  min-width: 130rpx;
  font-weight: 500;
}

.tab-item.active {
  color: #fff;
  font-weight: 600;
  background-color: #d4a76a;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.4);
  transform: translateY(-2rpx);
}

.tab-item.active::after {
  display: none;
}

@keyframes slideIn {
  from {
    width: 0;
    left: 50%;
  }
  to {
    width: 60%;
    left: 20%;
  }
}

/* 订单列表 */
.order-list {
  padding: 15rpx;
  min-height: calc(100vh - 80rpx);
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top: 4rpx solid #d4a76a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 订单卡片 */
.order-card {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 1rpx solid #f5f5f5;
}

.order-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
}

.order-header {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  background-color: #f8f9fa;
}

.order-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.order-type {
  display: flex;
  align-items: center;
}

.type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-right: 10rpx;
  font-weight: 500;
}

.type-tag:nth-child(1) {
  background-color: #e8f4fd;
  color: #3498db;
}

.type-tag:nth-child(2) {
  background-color: #e8f5e8;
  color: #27ae60;
}

.type-tag:nth-child(3) {
  background-color: #fef5e7;
  color: #e67e22;
}

.type-tag:nth-child(4) {
  background-color: #f4e8f9;
  color: #9b59b6;
}

.order-id {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.order-status {
  font-size: 26rpx;
  color: #d4a76a;
  font-weight: 600;
  text-align: right;
}

.order-content {
  padding: 24rpx;
}

.order-items {
  margin-bottom: 20rpx;
}

.order-item-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f9f9f9;
}

.order-item-row:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  object-fit: cover;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
  line-height: 1.4;
}

.item-price {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.order-footer {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
  margin-top: 8rpx;
}

.order-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f9f9f9;
}

.order-total text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.total-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #d4a76a;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 36rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
  transition: all 0.3s ease;
  min-width: 130rpx;
  text-align: center;
  font-weight: 500;
}

.action-btn:active {
  transform: scale(0.95);
}

.primary-btn {
  background-color: #d4a76a;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.4);
}

.primary-btn:active {
  background-color: #c4975a;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.3);
}

.secondary-btn {
  background-color: #f8f9fa;
  color: #666;
  border: 1rpx solid #e0e0e0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.secondary-btn:active {
  background-color: #e8e8e8;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.delete-btn {
  background-color: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.1);
}

.delete-btn:active {
  background-color: #fff2f0;
  box-shadow: 0 1rpx 4rpx rgba(255, 77, 79, 0.2);
}

/* 无订单状态 */
.empty-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 250rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 40rpx;
  opacity: 0.4;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: #bbb;
}

/* 响应式调整 */
@media screen and (max-width: 375px) {
  .tab-item {
    padding: 16rpx 20rpx;
    font-size: 24rpx;
    min-width: 110rpx;
    margin: 0 3rpx;
  }
  
  .order-list {
    padding: 15rpx;
  }
  
  .order-header {
    padding: 16rpx;
  }
  
  .order-content {
    padding: 16rpx;
  }
  
  .item-image {
    width: 90rpx;
    height: 90rpx;
    margin-right: 16rpx;
  }
  
  .item-name {
    font-size: 26rpx;
  }
  
  .action-btn {
    padding: 10rpx 28rpx;
    font-size: 22rpx;
  }
}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  .container {
    background-color: #1a1a1a;
  }
  
  .tab-bar {
    background-color: #2a2a2a;
    border-bottom-color: #3a3a3a;
  }
  
  .tab-item {
    color: #ccc;
  }
  
  .tab-item.active {
    background-color: #d4a76a;
    color: #fff;
  }
  
  .order-card {
    background-color: #2a2a2a;
    box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
  }
  
  .order-header {
    background-color: #333;
    border-bottom-color: #444;
  }
  
  .order-id {
    color: #ccc;
  }
  
  .item-name {
    color: #eee;
  }
  
  .item-price {
    color: #aaa;
  }
  
  .order-total text {
    color: #ccc;
  }
  
  .total-price {
    color: #eee;
  }
  
  .secondary-btn {
    background-color: #444;
    color: #ccc;
    border-color: #555;
  }
  
  .empty-text {
    color: #888;
  }
  
  .empty-hint {
    color: #666;
  }
}
