<view class="page">
  <swiper
    class="detail-swiper"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    circular="{{true}}"
    interval="3000"
    duration="500"
  >
    <!-- 第一个轮播项显示视频 -->
    <swiper-item>
      <video
        class="detail-swiper-video"
        src="{{acreDetail.videoUrl}}"
        autoplay="{{true}}"
        loop="{{true}}"
        muted="{{true}}"
        controls="{{false}}"
        object-fit="cover"
      />
    </swiper-item>
    <!-- 其他轮播项显示图片 -->
    <block wx:for="{{swiperList}}" wx:key="id">
      <swiper-item>
        <image
          class="detail-swiper-image"
          src="{{item.image}}"
          mode="aspectFill"
        />
      </swiper-item>
    </block>
  </swiper>

  <view class="detail-card">
    <view class="detail-title">{{acreDetail.name}}</view>
    <view class="detail-price">{{acreDetail.price}}</view>
    <view class="detail-desc">{{acreDetail.description}}</view>
    
    <!-- 购买统计信息 -->
    <view class="purchase-stats">
      <view class="stat-item">
        <view class="stat-label">剩余亩数</view>
        <view class="stat-value">{{acreDetail.remainingAcres || 50}} 亩</view>
      </view>
      <view class="stat-item">
        <view class="stat-label">已售亩数</view>
        <view class="stat-value">{{acreDetail.soldAcres || 0}} 亩</view>
      </view>
    </view>
    
    <!-- 已卖完提示 -->
    <view wx:if="{{acreDetail.remainingAcres <= 0}}" class="sold-out">
      已卖完
    </view>
  </view>

  <!-- 例子图片和介绍 -->
  <view class="example-section">
    <view class="section-title">农场示例</view>
    <!-- 底部图片列表 - 垂直排列成长图 -->
    <view class="example-images-vertical" wx:if="{{acreDetail.bottomImages && acreDetail.bottomImages.length > 0}}"><block wx:for="{{acreDetail.bottomImages}}" wx:key="index"><image src="{{item}}" mode="aspectFill" style="display: block; width: 100%; height: 250rpx;" /></block></view>
  </view>

  <view class="bottom-bar">
    <button class="service-btn" bindtap="contactService">
      联系客服
    </button>
    <button 
      class="buy-btn" 
      bindtap="confirmPurchase"
      disabled="{{acreDetail.remainingAcres <= 0}}"
    >
      {{acreDetail.remainingAcres <= 0 ? '已卖完' : '立即购买'}}
    </button>
  </view>
</view>
