.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 轮播图样式 */
.swiper-container {
  width: 100%;
  height: 320rpx;
  padding: 20rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.12);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin: 0 32rpx 24rpx;
  position: relative;
  padding-left: 24rpx;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  height: 36rpx;
  line-height: 36rpx;
}

.title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

/* 项目列表样式 */
.acre-list {
  padding: 0 24rpx 32rpx;
}

.acre-item {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.15);
  display: flex;
  gap: 24rpx;
  transition: all 0.3s ease;
  position: relative;
}

.acre-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(212, 167, 106, 0.16);
}

/* 项目图片 */
.acre-image {
  width: 220rpx;
  height: 160rpx;
  border-radius: 12rpx;
  object-fit: cover;
  background-color: #FAF6F0;
  transition: transform 0.3s ease;
}

.acre-item:active .acre-image {
  transform: scale(1.02);
}

/* 项目信息 */
.acre-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16rpx;
}

.acre-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.acre-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  flex: 1;
}

/* 价格和按钮容器 */
.price-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #FAF6F0;
}

.acre-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #D4A76A;
  display: flex;
  align-items: baseline;
}

.acre-price::before {
  content: '¥';
  font-size: 24rpx;
  margin-right: 4rpx;
  font-weight: 600;
}

/* 购买按钮 */
.buy-button {
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  height: 64rpx;
  line-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  transition: all 0.3s ease;
  -webkit-tap-highlight-color: transparent;
}

.buy-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.2);
}

/* 标签样式 */
.acre-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  z-index: 10;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .swiper-container {
    height: 280rpx;
  }
  
  .title {
    font-size: 32rpx;
    height: 32rpx;
    line-height: 32rpx;
    margin: 0 24rpx 20rpx;
  }
  
  .acre-list {
    padding: 0 20rpx 24rpx;
  }
  
  .acre-item {
    padding: 20rpx;
    margin-bottom: 20rpx;
  }
  
  .acre-image {
    width: 200rpx;
    height: 140rpx;
  }
  
  .acre-name {
    font-size: 28rpx;
  }
  
  .acre-desc {
    font-size: 22rpx;
  }
  
  .buy-button {
    font-size: 22rpx;
    padding: 10rpx 20rpx;
    height: 56rpx;
    line-height: 56rpx;
  }
}
