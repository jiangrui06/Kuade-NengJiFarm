<view class="container">
  <!-- 页面头部 -->
  <view class="header">
    <view class="header-right" bindtap="addAddress">
      <text class="add-btn">新增</text>
    </view>
  </view>

  <!-- 获取当前位置按钮 -->
  <view class="location-section">
    <view class="location-btn" bindtap="getLocation" disabled="{{locating}}">
      <text class="location-icon">📍</text>
      <text class="location-text">{{locating ? '定位中...' : '获取当前位置'}}</text>
    </view>
  </view>
  
  <!-- 地址列表 -->
  <view class="address-list">
    <view wx:for="{{addressList}}" wx:key="id" class="address-item" bindtap="selectAddress" data-id="{{item.id}}">
      <view class="address-info">
        <view class="address-header">
          <text class="address-name">{{item.name}}</text>
          <text class="address-phone">{{item.phone}}</text>
          <view wx:if="{{item.isDefault}}" class="default-tag">默认</view>
        </view>
        <view class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail}}</view>
      </view>
      <view class="address-actions">
        <image class="action-icon" src="https://img.icons8.com/ios-glyphs/24/999999/edit.png" bindtap="editAddress" data-id="{{item.id}}" />
        <image class="action-icon" src="https://img.icons8.com/ios-glyphs/24/999999/trash.png" bindtap="deleteAddress" data-id="{{item.id}}" />
      </view>
    </view>
    
    <!-- 空地址提示 -->
    <view wx:if="{{addressList.length === 0}}" class="empty-address">
      <image class="empty-icon" src="https://img.icons8.com/ios-glyphs/64/999999/map-marker.png" />
      <text class="empty-text">暂无收货地址</text>
      <view class="add-first-btn" bindtap="addAddress">
        <text class="add-first-btn-text">添加收货地址</text>
      </view>
    </view>
  </view>
  
  <!-- 添加地址按钮 -->
  <view wx:if="{{addressList.length > 0}}" class="add-address-btn" bindtap="addAddress">
    <image class="add-icon" src="https://img.icons8.com/ios-glyphs/24/ffffff/plus.png" />
    <text class="add-address-text">添加收货地址</text>
  </view>
</view>