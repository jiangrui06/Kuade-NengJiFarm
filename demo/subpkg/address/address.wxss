.container {
  padding: 0;
  background-color: #f8f5e9;
  min-height: 100vh;
}

/* 页面头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  width: 80rpx;
}

.back-icon {
  font-size: 32rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.header-right {
  width: 80rpx;
  text-align: right;
}

.add-btn {
  font-size: 28rpx;
  color: #d4a76a;
  font-weight: 500;
}

/* 获取当前位置按钮 */
.location-section {
  padding: 20rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.location-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: linear-gradient(135deg, #d4a76a 0%, #c99a5a 100%);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  transition: all 0.3s ease;
}

.location-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(212, 167, 106, 0.2);
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* 地址列表 */
.address-list {
  padding: 20rpx;
  margin-bottom: 120rpx;
}

/* 地址项 */
.address-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background-color: #fff;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.address-info {
  flex: 1;
  margin-right: 20rpx;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.default-tag {
  font-size: 20rpx;
  color: #d4a76a;
  border: 1rpx solid #d4a76a;
  border-radius: 4rpx;
  padding: 2rpx 10rpx;
}

.address-detail {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 地址操作 */
.address-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-icon {
  width: 24rpx;
  height: 24rpx;
}

/* 空地址提示 */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  background-color: #fff;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.empty-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.add-first-btn {
  width: 240rpx;
  height: 60rpx;
  background-color: #d4a76a;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-first-btn-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 添加地址按钮 */
.add-address-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #d4a76a;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.add-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 10rpx;
}

.add-address-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}
