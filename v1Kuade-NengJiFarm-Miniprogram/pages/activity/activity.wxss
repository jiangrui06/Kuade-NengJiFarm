/* ============================================
   活动页 - 田园风
   ============================================ */

@import "../../styles/farm-theme.wxss";

page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: #7CB342;
  --rice-green-light: #9CCC65;
  --rice-green-pale: #C5E1A5;
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-danger: #D4765E;
  --rice-danger-light: #E0937E;
  --rice-warm: #F5E6D3;

  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%);
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;

  display: flex;
  flex-direction: column;
}

/* ===== 底部稻田梯田 ===== */
.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: -10%; right: -10%; height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 麦穗装饰 ===== */
.wheat-stalk { background: var(--wheat-deco) center/contain no-repeat; }

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: var(--rice-text-light);
  letter-spacing: 6rpx;
  font-weight: 400;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative; z-index: 1;
  padding: 0 0 130rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 搜索栏 ===== */
.search-section {
  position: relative; z-index: 1;
  padding: 16rpx 0 8rpx;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 76rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 24rpx var(--rice-shadow-strong);
  border: 1rpx solid rgba(232,200,122,0.12);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 100%;
  background: transparent;
  border: none;
  color: var(--rice-text);
}

.search-placeholder {
  color: var(--rice-text-light);
  font-size: 24rpx;
}

.search-btn {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* ===== 区块样式 ===== */
.section-block {
  position: relative;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);

}

.section-block::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

.anim-section {
  opacity: 0; animation: sectionFadeIn 0.6s ease-out forwards;
}
.anim-section:nth-child(2) { animation-delay: 0.1s; }
.anim-section:nth-child(3) { animation-delay: 0.2s; }

/* ===== 区块标题栏 ===== */
.section-title-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 24rpx 0;
  position: relative; z-index: 1;
}

.section-title-wheat {
  width: 28rpx; height: 36rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; opacity: 0.25;
  animation: wheatSway 3s ease-in-out infinite;
}

.section-title-bar-inner {
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #8BC34A, #7CB342);
  border-radius: 3rpx;
  flex-shrink: 0;
}

.section-title-text {
  font-size: 28rpx; font-weight: 700;
  color: var(--rice-text); letter-spacing: 2rpx;
  white-space: nowrap;
}

.section-title-more {
  font-size: 22rpx;
  color: var(--rice-green);
  font-weight: 500;
  white-space: nowrap;
}

/* ===== 麦穗分隔 ===== */
.section-wheat-scatter {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 0 8rpx;
  opacity: 0.15;
  position: relative; z-index: 1;
}

.scatter-wheat {
  width: 24rpx; height: 32rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block;
  animation: scatterFloat 3s ease-in-out infinite;
}

@keyframes scatterFloat {
  0%, 100% { transform: translateY(0) rotate(-3deg); opacity: 0.15; }
  25% { transform: translateY(-6rpx) rotate(3deg); opacity: 0.35; }
  50% { transform: translateY(-12rpx) rotate(-5deg); opacity: 0.45; }
  75% { transform: translateY(-4rpx) rotate(4deg); opacity: 0.25; }
}

/* ===== 分类标签 ===== */
.tabs-wrap {
  padding: 20rpx 24rpx;
  position: relative; z-index: 1;
}

.tabs-scroll {
  display: flex;
  white-space: nowrap;
  padding: 8rpx 0;
}

.tab-item {
  display: inline-flex;
  padding: 16rpx 36rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  background: var(--rice-paper);
  border-radius: 40rpx;
  transition: all 0.3s;
  font-weight: 500;
}

.tab-item.active {
  background: linear-gradient(135deg, #8BC34A, #7CB342);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 6rpx 24rpx rgba(124, 179, 66, 0.35);
}

/* ===== 活动列表 ===== */
.activity-list {
  padding: 24rpx;
  position: relative; z-index: 1;
}

.activity-card {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 28rpx;

  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx var(--rice-shadow);
  transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  border: 1rpx solid rgba(232, 200, 122, 0.12);
  position: relative;
}

.activity-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.activity-card:active {
  transform: translateY(-8rpx);
  box-shadow: 0 16rpx 48rpx var(--rice-shadow-strong);
}

.activity-image-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;

}

.activity-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s;
}

.activity-card:active .activity-image {
  transform: scale(1.05);
}

.activity-price-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(196, 149, 60, 0.4);
}

.activity-info {
  padding: 24rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--rice-text);
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.activity-meta {
  display: flex;
  gap: 24rpx;
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.activity-date, .activity-location {
  display: flex;
  align-items: center;
}

/* ===== 加载/结束 ===== */
.load-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 48rpx;
  position: relative; z-index: 1;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.load-end-deco {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.deco-line {
  width: 60rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--rice-straw));
}

.deco-line:last-child {
  background: linear-gradient(90deg, var(--rice-straw), transparent);
}

.deco-icon {
  width: 34rpx;
  height: 46rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block;
  opacity: 0.25;
}

.load-end-text {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  background: linear-gradient(180deg, rgba(245,240,230,0.4) 0%, rgba(124,179,66,0.06) 40%, rgba(124,179,66,0.12) 100%);
  border-top: 1rpx solid rgba(232,200,122,0.1);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: #6B8E23;
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.5;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

/* ===== 动画 ===== */
@keyframes sectionFadeIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
