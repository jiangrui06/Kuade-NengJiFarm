/* ─────────────────────────────────────────
   活动页样式 - 稻田时光农场
   色系：稻田黄 #D4A76A | 丝苗米白 #FAF6F0
   ───────────────────────────────────────── */

.container {
  min-height: 100vh;
  background-color: #FAF6F0;
}

/* 搜索框样式 */
.search-container {
  display: flex;
  padding: 24rpx 32rpx;
  background-color: #fff;
  align-items: center;
  gap: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background-color: #FAF6F0;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  border: none;
}

.search-input::placeholder {
  color: #B8A98E;
}

.search-btn {
  height: 72rpx;
  padding: 0 32rpx;
  background-color: #D4A76A;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  font-weight: 500;
}

/* 选项卡样式 */
.tabs {
  display: flex;
  background-color: #fff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #FAF6F0;
}

.tab {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s ease;
}

.tab.active {
  color: #D4A76A;
  font-weight: 600;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background-color: #D4A76A;
  border-radius: 2rpx;
}

/* 活动列表样式 */
.activity-list {
  padding: 24rpx;
}

.activity-item {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.08);
}

.activity-image {
  width: 100%;
  height: 360rpx;
  object-fit: cover;
  background-color: #FAF6F0;
}

.activity-info {
  padding: 24rpx;
}

.activity-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #333;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
}

.activity-price {
  color: #D4A76A;
  font-weight: 600;
}

.activity-date {
  color: #999;
}

.activity-validity {
  font-size: 22rpx;
  color: #D4A76A;
  margin-top: 8rpx;
}
