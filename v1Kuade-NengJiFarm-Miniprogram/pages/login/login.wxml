<view class="login-page">

  <!-- 背景层 -->
  <view class="bg-layer">
    <image
      class="bg-image"
      src="{{bgImage}}"
      mode="aspectFill"
      lazy-load
      bindload="onBgImageLoad"
      binderror="onBgImageError"
    />
    <view class="bg-mask"></view>
    <view class="bg-brand-mask"></view>
    <view class="bg-card-mask"></view>
  </view>

  <!-- 装饰粒子 -->
  <view class="login-particles">
    <view class="lp lp-grain" style="left:10%;animation-delay:0s;"></view>
    <text class="lp" style="left:30%;animation-delay:0.8s;">🍃</text>
    <view class="lp lp-grain" style="left:55%;animation-delay:1.6s;"></view>
    <text class="lp" style="left:78%;animation-delay:0.4s;">✨</text>
    <view class="lp lp-grain" style="left:90%;animation-delay:2s;"></view>
  </view>

  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;"></view>

  <!-- 返回按钮 -->
  <view class="nav-back" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 品牌区 -->
  <view class="brand-area">
    <view class="brand-logo-wrap">
      <view class="brand-logo"></view>
    </view>
    <text class="brand-name">稻田时光农场</text>
    <text class="brand-slogan">回归自然 · 享受生活</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <button
      class="phone-login-btn {{isLogging ? 'phone-login-disabled' : ''}}"
      open-type="getPhoneNumber"
      bind:getphonenumber="onGetPhoneNumber"
      loading="{{isLogging}}">
      <text class="login-btn-text">{{isLogging ? '登录中...' : '微信一键登录'}}</text>
    </button>
    <view class="security-hint" wx:if="{{!isLogging}}">
      <text class="hint-text">🔒 微信安全认证 · 信息加密保护</text>
    </view>
    <view class="login-mask" wx:if="{{isLogging}}" catchtap="preventLoginClick"></view>
  </view>

  <!-- 底部协议 -->
  <view class="login-footer">
    <text class="agreement">登录即代表同意</text>
    <text class="agreement-link" bindtap="viewAgreement">《用户协议》</text>
    <text class="agreement">和</text>
    <text class="agreement-link" bindtap="viewPrivacy">《隐私政策》</text>
  </view>
</view>
