<view class="login-page">
  <!-- 稻田加载动画 -->
  <farm-loading show="{{isLogging}}" text="登录中..."></farm-loading>

  <!-- 背景层 -->
  <view class="bg-layer">
    <image wx:if="{{bgImage}}"
      class="bg-image"
      src="{{bgImage}}"
      mode="aspectFill"
      lazy-load
      bindload="onBgImageLoad"
      binderror="onBgImageError"
    />
    <view class="bg-fallback" wx:else></view>
    <view class="bg-mask"></view>
    <view class="bg-card-mask"></view>
  </view>

  <!-- 自定义导航栏 -->
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;"></view>

  <!-- 返回按钮 -->
  <view class="nav-back" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 品牌区 -->
  <view class="brand-area">
    <text class="brand-name">稻田时光农场</text>
    <text class="brand-slogan">回归自然 · 享受生活</text>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <button
      wx:if="{{agreed && !isLogging}}"
      class="phone-login-btn"
      open-type="getPhoneNumber"
      bind:getphonenumber="onGetPhoneNumber">
      <view class="login-btn-content">
        <text class="login-btn-text">手机号快捷登录</text>
      </view>
    </button>
    <button
      wx:elif="{{isLogging}}"
      class="phone-login-btn phone-login-disabled"
      disabled>
      <view class="login-btn-content">
        <view class="login-spinner"></view>
        <text class="login-btn-text">登录中...</text>
      </view>
    </button>
    <button
      wx:else
      class="phone-login-btn"
      bindtap="showAgreementToast">
      <view class="login-btn-content">
        <text class="login-btn-text">手机号快捷登录</text>
      </view>
    </button>
    <view class="security-hint">
      <text class="hint-icon">⬡</text>
      <text class="hint-text">信息加密保护 · 安全可靠</text>
    </view>
  </view>

  <!-- 底部协议 -->
  <view class="login-footer">
    <view class="agreement-checkbox" bindtap="toggleAgreed">
      <view class="checkbox-circle {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}" class="checkbox-check">✓</text>
      </view>
    </view>
    <text class="agreement">登录即代表同意</text>
    <text class="agreement-link" bindtap="viewPrivacy">《隐私政策》</text>
  </view>
</view>
