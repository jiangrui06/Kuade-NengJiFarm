/* ===================== 配色变量 =====================
   稻田黄: #D4A76A (主色/按钮)
   丝苗米白: #FDF8EE (底色)
   深稻色: #8B6914 (品牌名/深色文字/强调)
   金棕: #B8894E (链接/副标题)
   ===================== */

/* 自定义导航栏（仅状态栏占位） */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: transparent;
  height: 0;
}

/* 页面容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 56rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background-color: #FDF8EE;
}

/* 背景层 */
.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
}

.bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    170deg,
    rgba(212, 167, 106, 0.15) 0%,
    rgba(253, 248, 238, 0.8) 45%,
    #FDF8EE 85%,
    #FDF8EE 100%
  );
}

/* ===== 品牌区 ===== */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
  position: relative;
  z-index: 2;
}

/* Logo 外圈 */
.brand-logo-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(212, 167, 106, 0.18), rgba(184, 137, 78, 0.08));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(212, 167, 106, 0.25);
}

.brand-logo {
  font-size: 64rpx;
}

.brand-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #8B6914;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.brand-slogan {
  font-size: 24rpx;
  color: #A07D3C;
  letter-spacing: 4rpx;
  font-weight: 500;
}

/* ===== 登录卡片 ===== */
.login-card {
  width: 100%;
  max-width: 580rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow:
    0 8rpx 32rpx rgba(139, 105, 20, 0.10),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  z-index: 2;
  /* 卡片顶部金色细线装饰 */
  border-top: 5rpx solid transparent;
  border-image: linear-gradient(90deg, transparent, #D4A76A, transparent) 1;
}

/* 一键登录按钮 */
.phone-login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C49648 50%, #BA8C35 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 6rpx 20rpx rgba(212, 167, 106, 0.38),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.15);
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  position: relative;
  overflow: hidden;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 3rpx 12rpx rgba(212, 167, 106, 0.28);
}

.phone-login-btn[disabled] {
  opacity: 0.6;
}

.phone-login-disabled {
  opacity: 0.55 !important;
  background: linear-gradient(135deg, #D0B085 0%, #C4A075 100%) !important;
  box-shadow: none !important;
}

.login-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  border-radius: 48rpx;
  background-color: transparent;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 6rpx;
}

/* 安全提示 */
.security-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
}

.hint-icon {
  font-size: 18rpx;
  margin-right: 6rpx;
}

.hint-text {
  font-size: 19rpx;
  color: #999;
  letter-spacing: 1rpx;
}

/* ===== 底部协议 ===== */
.login-footer {
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #777;
  width: 100%;
  text-align: center;
  flex-wrap: wrap;
  gap: 6rpx;
  line-height: 1.8;
  position: relative;
  z-index: 2;
}

.agreement {
  color: #888;
}

.agreement-link {
  color: #B8894E;
  margin: 0 2rpx;
  font-weight: 600;
}

.agreement-link:active {
  opacity: 0.7;
}

/* ===== 员工登录入口 ===== */
.staff-login-section {
  margin-top: 40rpx;
  position: relative;
  z-index: 2;
}

.staff-login-btn {
  font-size: 26rpx;
  color: #B8894E;
  text-decoration: underline;
  font-weight: 500;
}

.staff-login-btn:active {
  opacity: 0.7;
}
