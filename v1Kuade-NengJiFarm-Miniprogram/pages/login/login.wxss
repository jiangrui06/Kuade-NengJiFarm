.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: transparent;
  height: 0;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 48rpx;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #FDF8EE 0%, #F8EED5 100%);
}

.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
  opacity: 0.3;
}

.bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at 50% 0%, rgba(212, 167, 106, 0.25) 0%, rgba(253, 248, 238, 0.9) 40%, #FDF8EE 100%);
}

.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 88rpx;
  position: relative;
  z-index: 2;
  animation: fadeInUp 0.8s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.brand-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #8B6914;
  letter-spacing: 12rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(139, 105, 20, 0.15);
}

.brand-slogan {
  font-size: 26rpx;
  color: #A07D3C;
  letter-spacing: 6rpx;
  font-weight: 500;
  opacity: 0.9;
}

.login-card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20rpx);
  border-radius: 36rpx;
  padding: 56rpx 48rpx 48rpx;
  box-shadow:
    0 16rpx 48rpx rgba(139, 105, 20, 0.15),
    0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 2;
  border: 2rpx solid rgba(212, 167, 106, 0.15);
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

.login-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 6rpx;
  background: linear-gradient(90deg, transparent, #D4A76A, transparent);
  border-radius: 3rpx;
}

.phone-login-btn {
  width: 100%;
  height: 104rpx;
  background: linear-gradient(135deg, #E8B878 0%, #D4A76A 25%, #C99A58 75%, #BA8C35 100%);
  border-radius: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 10rpx 28rpx rgba(212, 167, 106, 0.45),
    0 4rpx 12rpx rgba(139, 105, 20, 0.2),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.3);
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% { left: -100%; }
  20% { left: 100%; }
  100% { left: 100%; }
}

.phone-login-btn:active {
  transform: scale(0.96);
  box-shadow: 0 6rpx 18rpx rgba(212, 167, 106, 0.35);
}

.phone-login-btn[disabled] {
  opacity: 0.6;
}

.phone-login-disabled {
  opacity: 0.55 !important;
  background: linear-gradient(135deg, #D0B085 0%, #C4A075 100%) !important;
  box-shadow: none !important;
}

.login-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  border-radius: 52rpx;
  background-color: transparent;
}

.login-btn-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.security-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  padding: 16rpx 24rpx;
  background: rgba(212, 167, 106, 0.08);
  border-radius: 24rpx;
}

.hint-text {
  font-size: 22rpx;
  color: #8B6914;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.login-footer {
  margin-top: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #777;
  width: 100%;
  text-align: center;
  flex-wrap: wrap;
  gap: 8rpx;
  line-height: 1.8;
  position: relative;
  z-index: 2;
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.agreement {
  color: #888;
}

.agreement-link {
  color: #B8894E;
  margin: 0 4rpx;
  font-weight: 600;
  padding: 4rpx 8rpx;
  border-radius: 8rpx;
  background: rgba(184, 137, 78, 0.08);
}

.agreement-link:active {
  opacity: 0.7;
  background: rgba(184, 137, 78, 0.15);
}

.staff-login-fab {
  position: fixed;
  right: 30rpx;
  bottom: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, rgba(44, 62, 80, 0.15) 0%, rgba(26, 37, 47, 0.2) 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(44, 62, 80, 0.1);
  z-index: 100;
  transition: all 0.3s ease;
}

.staff-login-fab:active {
  background: linear-gradient(135deg, rgba(44, 62, 80, 0.25) 0%, rgba(26, 37, 47, 0.3) 100%);
}

.fab-text {
  font-size: 22rpx;
  color: rgba(44, 62, 80, 0.4);
  font-weight: 600;
  letter-spacing: 1rpx;
}
