/* ============================================
   登录页 - 稻田风 · 高级版
   ============================================ */

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 56rpx;
  position: relative;
  overflow: hidden;
  background: var(--rice-cream);
}

/* ===== 导航栏 ===== */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: transparent;
  height: 0;
}

.nav-back {
  position: fixed;
  top: 88rpx;
  left: 24rpx;
  z-index: 1000;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border: 2rpx solid rgba(196,149,60,0.4);
  box-shadow: 0 4rpx 20rpx var(--rice-shadow), inset 0 1rpx 0 rgba(255,255,255,0.6);
  transition: all 0.2s;
}

.nav-back:active {
  background: rgba(196,149,60,0.2);
  transform: scale(0.92);
}

.back-icon {
  font-size: 44rpx;
  color: var(--rice-gold);
  line-height: 1;
  margin-top: -6rpx;
  font-weight: 500;
}

/* ===== 背景 ===== */
.bg-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.bg-image {
  width: 100%;
  height: 100%;
  animation: fadeInBg 1.5s ease-out;
}

/* 背景图加载失败时的纯色渐变替代 */
.bg-fallback {
  width: 100%;
  height: 100%;
  background:
    radial-gradient(ellipse at 50% 30%, rgba(230,184,119,0.3) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 70%, rgba(124,179,66,0.15) 0%, transparent 50%),
    radial-gradient(ellipse at 20% 80%, rgba(196,149,60,0.1) 0%, transparent 50%),
    linear-gradient(180deg, #FDF5E6 0%, #FCF0DC 30%, #FAEBD5 60%, #F5E6D3 100%);
  animation: fadeInBg 1.5s ease-out;
}

@keyframes fadeInBg {
  from { opacity: 0; transform: scale(1.05); }
  to { opacity: 1; transform: scale(1); }
}

.bg-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at 50% 40%,
    rgba(255,255,255,0.5) 0%,
    rgba(255,255,255,0.3) 30%,
    rgba(253,248,238,0.6) 60%,
    rgba(248,238,213,0.8) 100%);
}

.bg-card-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 55%;
  background: linear-gradient(0deg,
    rgba(255,255,255,0.9) 0%,
    rgba(255,255,255,0.6) 35%,
    rgba(255,255,255,0.3) 65%,
    transparent 100%);
  z-index: 1;
}

/* ===== 装饰粒子 ===== */
.login-particles {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 60%;
  z-index: 1;
  pointer-events: none;
}

.lp {
  position: absolute;
  font-size: 36rpx;
  animation: loginParticle 5s ease-in-out infinite;
  opacity: 0;
}

.lp-grain {
  display: inline-block;
  width: 28rpx;
  height: 40rpx;
  font-size: 0;
}

@keyframes loginParticle {
  0% { transform: translateY(20%) scale(0) rotate(0deg); opacity: 0; }
  15% { opacity: 0.6; }
  75% { opacity: 0.4; }
  100% { transform: translateY(-400%) scale(1.2) rotate(40deg); opacity: 0; }
}

/* ===== 品牌区 ===== */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
  position: relative;
  z-index: 2;
  animation: fadeInUp 0.8s ease-out;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--rice-green-deep);
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.brand-slogan {
  font-size: 24rpx;
  color: var(--rice-text-secondary);
  letter-spacing: 6rpx;
  font-weight: 500;
}

/* ===== 登录卡片 ===== */
.login-card {
  width: 100%;
  max-width: 580rpx;
  background: var(--rice-paper);
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 12rpx 48rpx rgba(139,105,20,0.12), 0 2rpx 8rpx var(--rice-shadow);
  position: relative;
  z-index: 2;
  border-top: 4rpx solid var(--rice-gold-light);
  animation: fadeInUp 0.8s ease-out 0.3s both;
}

.phone-login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, var(--rice-green) 0%, var(--rice-green-deep) 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(91,140,62,0.35);
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  position: relative;
  overflow: hidden;
  transition: all 0.3s;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(91,140,62,0.25);
}

.phone-login-disabled {
  opacity: 0.7 !important;
  background: linear-gradient(135deg, var(--rice-green-mist), var(--rice-green-light)) !important;
  box-shadow: none !important;
}

.login-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.login-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
}

/* ===== 安全提示 ===== */
.security-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 28rpx;
  gap: 8rpx;
}

.hint-icon {
  font-size: 16rpx;
  color: var(--rice-gold);
  opacity: 0.6;
}

.hint-text {
  font-size: 20rpx;
  color: var(--rice-text-light);
  letter-spacing: 1rpx;
}

/* ===== 底部协议 ===== */
.login-footer {
  margin-top: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 4rpx;
  position: relative;
  z-index: 2;
  animation: fadeInUp 0.8s ease-out 0.6s both;
}

.agreement-checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx;
  margin-right: 4rpx;
}

.checkbox-circle {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid var(--rice-text-light);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  background: transparent;
}

.checkbox-circle.checked {
  background: var(--rice-green);
  border-color: var(--rice-green);
}

.checkbox-check {
  font-size: 18rpx;
  color: #fff;
  font-weight: 700;
  line-height: 1;
}

.agreement {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.agreement-link {
  font-size: 22rpx;
  color: var(--rice-gold);
  font-weight: 500;
}

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
