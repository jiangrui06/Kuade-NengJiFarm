/* ============================================
   个人中心 - 稻田风 · 高级版
   ============================================ */

@import "../../styles/farm-theme.wxss";

page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: var(--rice-gold);
  --rice-green-light: var(--rice-gold-light);
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-danger: #D4765E;
  --rice-danger-light: #E0937E;
  --rice-warm: #F5E6D3;
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%);
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
}

/* ===== 底部稻田梯田 ===== */
.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 520rpx;
  background:
    radial-gradient(ellipse 40% 40% at 18% 62%, rgba(91,140,62,0.2) 0%, rgba(91,140,62,0.08) 45%, transparent 100%),
    radial-gradient(ellipse 35% 35% at 35% 58%, rgba(107,142,68,0.18) 0%, rgba(107,142,68,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 50% 45% at 58% 60%, rgba(91,140,62,0.16) 0%, rgba(91,140,62,0.07) 45%, transparent 100%),
    radial-gradient(ellipse 30% 40% at 78% 63%, rgba(120,160,75,0.15) 0%, rgba(120,160,75,0.05) 45%, transparent 100%),
    radial-gradient(ellipse 25% 35% at 92% 66%, rgba(91,140,62,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 120% 30% at 25% 76%, rgba(110,160,70,0.18) 0%, transparent 100%),
    radial-gradient(ellipse 100% 25% at 60% 74%, rgba(120,170,80,0.15) 0%, transparent 100%),
    radial-gradient(ellipse 80% 20% at 45% 80%, rgba(130,180,85,0.1) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light);
  letter-spacing: 6rpx; font-weight: 400;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative; z-index: 1;
  padding: 0 0 130rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 稻穗装饰 ===== */
.wheat-stalk {
  background: var(--wheat-deco) center/contain no-repeat;
}

/* ===== 未登录 ===== */
.login-hero {
  position: relative;
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.login-hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, var(--rice-green) 0%, var(--rice-green-deep) 40%, var(--rice-text) 100%);
}

.login-hero-bg::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(0deg, var(--rice-cream) 0%, transparent 100%);
}

.login-hero-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.login-avatar-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: 4rpx solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.login-avatar-icon {
  font-size: 72rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 48rpx;
}

.login-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 32rpx rgba(196, 149, 60, 0.4);
  letter-spacing: 4rpx;
}

.login-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.login-deco {
  position: absolute;
  bottom: 60rpx;
  display: flex;
  gap: 40rpx;
  z-index: 2;
}

.login-deco-item {
  width: 36rpx;
  height: 52rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  animation: loginFloat 3s ease-in-out infinite;
  opacity: 0.4;
  display: inline-block;
}

@keyframes loginFloat {
  0%, 100% { transform: translateY(0); opacity: 0.3; }
  50% { transform: translateY(-16rpx); opacity: 0.6; }
}

/* ===== 会员卡片 ===== */
.profile-card {
  margin: 0;
  border-radius: 28rpx;
  overflow: hidden;
  position: relative;
}

/* 各卡片不同色调和装饰 */
.card-member {
  background: linear-gradient(135deg, #FDF5E6 0%, #FCF0DC 40%, #FAEBD5 100%);
  box-shadow: 0 8rpx 32rpx var(--rice-shadow), 0 1rpx 0 0 rgba(255,248,235,0.5) inset;
  border: 1rpx solid rgba(232, 200, 122, 0.3);
}
.card-member::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(232,200,122,0.08) 0%, transparent 8%),
    radial-gradient(2px 2px at 20% 30%, rgba(196, 149, 60, 0.06) 0%, transparent 100%),
    radial-gradient(2px 2px at 70% 60%, rgba(232, 200, 122, 0.05) 0%, transparent 100%);
  pointer-events: none;
}

.card-orders {
  background: linear-gradient(160deg, #FDF7EC 0%, #FCF2E0 50%, #FAECD8 100%);
  box-shadow: 0 8rpx 32rpx var(--rice-shadow), 0 1rpx 0 0 rgba(255,248,235,0.5) inset;
  border: 1rpx solid rgba(232, 200, 122, 0.2);
}
.card-orders::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(270deg, rgba(232,200,122,0.06) 0%, transparent 8%),
    radial-gradient(2px 2px at 35% 40%, rgba(196, 149, 60, 0.05) 0%, transparent 100%),
    radial-gradient(2px 2px at 80% 70%, rgba(232, 200, 122, 0.04) 0%, transparent 100%);
  pointer-events: none;
}

.card-functions {
  background: linear-gradient(140deg, #FDF6E8 0%, #FCF0DC 50%, #FBEAD2 100%);
  box-shadow: 0 8rpx 32rpx var(--rice-shadow), 0 1rpx 0 0 rgba(255,248,235,0.5) inset;
  border: 1rpx solid rgba(232, 200, 122, 0.25);
}
.card-functions::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(232,200,122,0.05) 0%, transparent 6%),
    linear-gradient(270deg, rgba(232,200,122,0.05) 0%, transparent 6%),
    radial-gradient(2px 2px at 50% 25%, rgba(196, 149, 60, 0.05) 0%, transparent 100%),
    radial-gradient(2px 2px at 30% 75%, rgba(232, 200, 122, 0.04) 0%, transparent 100%);
  pointer-events: none;
}

.profile-card-flat {
  overflow: visible;
  background: transparent;
  box-shadow: none;
  border: none;
}

.profile-card-flat::before {
  display: none;
}

/* ===== 区块容器 ===== */
.section-block {
  margin-top: 24rpx;
}

.anim-section {
  animation: sectionFadeIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.section-block:nth-child(1) { animation-delay: 0.05s; }
.section-block:nth-child(2) { animation-delay: 0.15s; }
.section-block:nth-child(3) { animation-delay: 0.25s; }
.section-block:nth-child(4) { animation-delay: 0.35s; }
.section-block:nth-child(5) { animation-delay: 0.45s; }

@keyframes sectionFadeIn {
  from { opacity: 0; transform: translateY(40rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* ===== 四角麦穗装饰（首页轮播风格） ===== */
.section-with-corners {
  position: relative;
}

.module-corner {
  position: absolute;
  width: 220rpx;
  height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none;
  z-index: 3;
  opacity: 0.9;
  animation: moduleCornerSway 4s ease-in-out infinite;
}
.module-corner-tl { top: -200rpx; left: -110rpx; transform: rotate(135deg); }
.module-corner-tr { top: -200rpx; right: -110rpx; transform: rotate(-135deg); }
.module-corner-bl { bottom: -200rpx; left: -110rpx; transform: rotate(45deg); }
.module-corner-br { bottom: -200rpx; right: -110rpx; transform: rotate(-45deg); }
.module-corner-tr,
.module-corner-br { animation-delay: 0.5s; }

@keyframes moduleCornerSway {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.8; }
}

/* ===== 对角双角（首页功能入口风格） ===== */
.feature-nav-wheat {
  position: absolute;
  width: 220rpx;
  height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none;
  opacity: 0.85;
  animation: featureWheat 3s ease-in-out infinite;
}
.feature-nav-wheat-tl { top: -100rpx; left: -100rpx; transform: rotate(135deg); }
.feature-nav-wheat-br { bottom: -100rpx; right: -100rpx; transform: rotate(-45deg); }

@keyframes featureWheat {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.65; }
}

/* ===== 麦穗分隔 ===== */
.section-wheat-scatter {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 4rpx 0;
  opacity: 0.2;
}

.scatter-wheat {
  width: 30rpx;
  height: 42rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block;
  animation: scatterFloat 3s ease-in-out infinite;
}

@keyframes scatterFloat {
  0%, 100% { transform: translateY(0) rotate(-3deg); opacity: 0.15; }
  25% { transform: translateY(-6rpx) rotate(3deg); opacity: 0.35; }
  50% { transform: translateY(-12rpx) rotate(-5deg); opacity: 0.45; }
  75% { transform: translateY(-4rpx) rotate(4deg); opacity: 0.25; }
}

/* ===== 区块标题麦穗（首页标题栏风格） ===== */
.section-title-wheat {
  width: 36rpx;
  height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block;
  animation: wheatBounce 3s ease-in-out infinite;
  opacity: 0.3;
  flex-shrink: 0;
}

.section-title-bar-inner {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
  margin-right: 4rpx;
  flex-shrink: 0;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  letter-spacing: 2rpx;
  flex: 1;
}

@keyframes wheatBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  30% { transform: translateY(-8rpx) rotate(3deg); }
  60% { transform: translateY(-3rpx) rotate(7deg); }
  80% { transform: translateY(-6rpx) rotate(-2deg); }
}
.profile-card-inner {
  position: relative; z-index: 1;
  padding: 32rpx 28rpx;
}

.profile-avatar-row {
  display: flex;
  align-items: center;
}

.avatar-btn {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 28rpx 0 0;
  border: none;
  background: transparent;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: none;
}

.profile-avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.1);
  display: block;
}

.profile-name-area {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.profile-name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--rice-text);
  margin-bottom: 6rpx;
}

.profile-role {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.profile-card-hd {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 28rpx 28rpx 0;
  position: relative; z-index: 1;
}

.profile-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  padding-left: 16rpx;
  border-left: 6rpx solid var(--rice-gold);
}

.profile-card-more {
  font-size: 24rpx;
  color: var(--rice-text-light);
  padding: 8rpx 16rpx;
  background: var(--rice-paper);
  border-radius: 20rpx;
}

/* ===== 订单状态 ===== */
.order-states {
  display: flex;
  padding: 32rpx 16rpx;
  justify-content: space-around;
  position: relative; z-index: 1;
}

.order-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 16rpx;
}

/* 新图标外框 - 圆角方形 */
.state-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 2rpx solid rgba(196, 149, 60, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(196, 149, 60, 0.15);
  transition: all 0.2s;
  overflow: hidden;
}

.state-icon-box image {
  width: 96rpx;
  height: 96rpx;
  display: block;
}

.order-state:active .state-icon-box {
  transform: scale(0.95);
  box-shadow: 0 6rpx 20rpx rgba(196, 149, 60, 0.25);
}

/* 各订单状态的彩色边框 */
.state-icon-box-pending {
  border-color: rgba(196, 149, 60, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(196, 149, 60, 0.15);
}

.state-icon-box-paid {
  border-color: rgba(124, 179, 66, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(124, 179, 66, 0.12);
}

.state-icon-box-shipping {
  border-color: rgba(157, 192, 200, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(157, 192, 200, 0.12);
}

/* "全部" 文字样式 */
.state-icon-box-all {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-color: rgba(196, 149, 60, 0.3);
}

.state-icon-all-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 700;
}

.state-text {
  font-size: 24rpx;
  color: var(--rice-text-secondary);
  font-weight: 500;
}

/* ===== 推荐 ===== */
.recommend-img {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx var(--rice-shadow);
  display: block;
}

/* ===== 功能列表 ===== */
.function-list {
  padding: 8rpx 0;
  position: relative; z-index: 1;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 30rpx 32rpx;
  border-bottom: 1rpx solid var(--rice-paper);
  transition: background 0.2s;
}

.function-item:last-child {
  border-bottom: none;
}

.function-item:active {
  background: var(--rice-warm);
}

.function-btn {
  display: flex !important;
  align-items: center;
  justify-content: flex-start !important;
  text-align: left !important;
  padding: 30rpx 32rpx !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
  border-radius: 0 !important;
  width: 100%;
  box-sizing: border-box;
  line-height: 1 !important;
  border-bottom: 1rpx solid var(--rice-paper) !important;
}

.function-btn::after {
  border: none !important;
  display: none !important;
}

.function-btn:active {
  background: var(--rice-warm) !important;
}

/* 功能列表图标外框 */
.func-icon-wrap {
  margin-right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: 14rpx;
  border: 2rpx solid rgba(196, 149, 60, 0.15);
  flex-shrink: 0;
  overflow: hidden;
}

.func-icon-wrap image {
  width: 56rpx;
  height: 56rpx;
  display: block;
}

/* 农场图标 */
.func-icon-wrap-farm {
  background: transparent;
  border-color: rgba(124, 179, 66, 0.3);
}

/* 核销图标 */
.func-icon-wrap-verify {
  background: transparent;
  border-color: rgba(230, 184, 119, 0.35);
}

/* 退出登录 */
.func-icon-wrap-logout {
  background: transparent;
  border-color: rgba(212, 118, 94, 0.3);
}

.func-icon-text {
  font-size: 22rpx;
  color: var(--rice-danger);
  font-weight: 600;
}

.func-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--rice-text);
  font-weight: 500;
}

.func-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.func-subtext {
  font-size: 22rpx;
  color: var(--rice-gold);
}

.func-arrow {
  font-size: 32rpx;
  color: var(--rice-text-light);
  opacity: 0.3;
  flex-shrink: 0;
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  background: linear-gradient(180deg, rgba(245,240,230,0.4) 0%, rgba(124,179,66,0.1) 40%, rgba(124,179,66,0.18) 100%);
  border-top: 1rpx solid rgba(232,200,122,0.15);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.7;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }
