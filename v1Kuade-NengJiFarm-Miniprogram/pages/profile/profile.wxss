/* ─────────────────────────────────────────
   个人中心样式 - 稻田时光农场
   色系：稻田黄 #D4A76A | 丝苗米白 #FAF6F0
   ───────────────────────────────────────── */

/* ===== 全局 ===== */
.container {
  min-height: 100vh;
  background-color: #FAF6F0;
}

/* ===== 会员中心头部 ===== */
.member-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 56rpx 40rpx 48rpx;
  background: linear-gradient(145deg, #D4A76A 0%, #B8915A 60%, #A07D4A 100%);
  position: relative;
  overflow: hidden;
}

/* 头部装饰光晕 */
.member-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.member-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: 20%;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.member-info {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 1;
}

.avatar-button {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0 28rpx 0 0;
  border: none;
  background: transparent;
  line-height: 1;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-button::after {
  border: none;
}

.member-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255, 255, 255, 0.4);
  background-color: rgba(255, 255, 255, 0.15);
  display: block;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.member-details {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
  color: #fff;
  letter-spacing: 1rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.member-email {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.5rpx;
}

.member-actions {
  position: relative;
  z-index: 1;
  padding: 12rpx;
}

.member-actions .action-icon {
  width: 48rpx;
  height: 48rpx;
  padding: 10rpx;
  background-color: rgba(255, 255, 255, 0.18);
  border-radius: 50%;
  box-sizing: border-box;
  backdrop-filter: blur(4rpx);
  -webkit-backdrop-filter: blur(4rpx);
  transition: background-color 0.25s;
}

.member-actions .action-icon:active {
  background-color: rgba(255, 255, 255, 0.32);
}

/* ===== 通用 section 样式 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 0;
  background-color: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2a2a2a;
  display: flex;
  align-items: center;
  letter-spacing: 0.5rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #D4A76A, #C99A5A);
  border-radius: 3rpx;
  margin-right: 14rpx;
}

.section-more {
  font-size: 24rpx;
  color: #aaa;
  letter-spacing: 0.3rpx;
}

/* ===== 我的订单 ===== */
.order-section {
  background-color: #fff;
  margin: 20rpx 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(212, 167, 106, 0.08);
}

.order-states {
  display: flex;
  padding: 36rpx 8rpx 32rpx;
  justify-content: space-around;
}

.order-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  flex: 1;
  /* 扩大热区 */
  padding: 12rpx 8rpx;
}

.state-icon-container {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.2s ease;
}

.order-state:active .state-icon-container {
  transform: scale(0.88);
}

.state-icon-container.pending {
  background: linear-gradient(135deg, #ff6b6b, #ee5a6f);
  box-shadow: 0 6rpx 20rpx rgba(238, 90, 111, 0.3);
}

.state-icon-container.paid {
  background: linear-gradient(135deg, #4ecdc4, #45b7d1);
  box-shadow: 0 6rpx 20rpx rgba(69, 183, 209, 0.3);
}

.state-icon-container.shipping {
  background: linear-gradient(135deg, #45b7d1, #4361ee);
  box-shadow: 0 6rpx 20rpx rgba(67, 97, 238, 0.3);
}

.state-icon-container.all {
  background: linear-gradient(135deg, #D4A76A, #C99A5A);
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.3);
}

.state-icon-text {
  font-size: 36rpx;
  line-height: 1;
}

.state-text {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.state-badge {
  position: absolute;
  top: 4rpx;
  right: 50%;
  transform: translateX(50%);
  background-color: #ff4d4f;
  color: #fff;
  font-size: 18rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* ===== 推荐商品 ===== */
.recommend-section {
  padding: 0 24rpx;
  margin: 8rpx 0 20rpx;
}

.recommend-image {
  width: 100%;
  border-radius: 16rpx;
  height: 180rpx;
  object-fit: cover;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

/* ===== 功能列表 ===== */
.function-section {
  background-color: #fff;
  margin: 0 24rpx 32rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(212, 167, 106, 0.08);
}

/* 通用列表项 */
.function-item {
  display: flex;
  align-items: center;
  padding: 30rpx 32rpx;
  border-bottom: 1rpx solid #f0ebe4;
  transition: background-color 0.2s ease;
  background: #fff;
}

/* 清除最后一个列表项的下边框 */
.function-item:last-child,
.function-item-btn:last-child {
  border-bottom: none;
}

.function-item:active {
  background-color: #faf6f0;
}

.function-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 24rpx;
  padding: 8rpx;
  background-color: #faf6f0;
  border-radius: 12rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.function-text {
  flex: 1;
  font-size: 28rpx;
  color: #2a2a2a;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

/* 核销券类：主标题 + 副标题容器 */
.function-text-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.function-subtext {
  font-size: 22rpx;
  color: #D4A76A;
  margin-top: 4rpx;
}

.function-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
  flex-shrink: 0;
}

/* 客服 button 项 — 彻底重置 button 样式 */
.function-item-btn {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 30rpx 32rpx !important;
  margin: 0 !important;
  border: none !important;
  background: #fff !important;
  border-radius: 0 !important;
  width: 100%;
  box-sizing: border-box;
  line-height: 1 !important;
  border-bottom: 1rpx solid #f0ebe4;
  font-size: 0;
}

.function-item-btn::after {
  border: none !important;
  display: none !important;
}

.function-item-btn:active {
  background-color: #faf6f0 !important;
}

.function-item-btn .function-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 24rpx;
  padding: 8rpx;
  background-color: #faf6f0;
  border-radius: 12rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  display: block;
}

.function-item-btn .function-text {
  flex: 1;
  font-size: 28rpx;
  color: #2a2a2a;
  font-weight: 500;
  letter-spacing: 0.3rpx;
  line-height: 1;
  text-align: left;
  display: block;
}

.function-item-btn .function-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.3;
  flex-shrink: 0;
  display: block;
}

/* 移除内部容器，直接在 button 内布局 */
.function-item-inner {
  display: contents;
}

/* 员工核销入口 */
.staff-entry {
  background-color: #fffbf0 !important;
}

.staff-badge {
  font-size: 20rpx;
  color: #fff;
  background-color: #D4A76A;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

/* ===== 员工专属样式 ===== */
.staff-profile-content {
  padding: 20rpx 24rpx 40rpx;
}

/* 快捷入口 */
.staff-quick-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.staff-action-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(212, 167, 106, 0.1);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.staff-action-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 12rpx rgba(212, 167, 106, 0.15);
}

.action-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-wrap.verify {
  background: linear-gradient(135deg, #D4A76A, #C99A5A);
  box-shadow: 0 6rpx 16rpx rgba(212, 167, 106, 0.35);
}

.action-icon-wrap.history {
  background: linear-gradient(135deg, #4ecdc4, #45b7d1);
  box-shadow: 0 6rpx 16rpx rgba(69, 183, 209, 0.3);
}

.action-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.action-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2a2a2a;
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 22rpx;
  color: #aaa;
}

/* 员工信息卡 */
.staff-info-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(212, 167, 106, 0.08);
  margin-bottom: 40rpx;
}

.info-card-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0ebe4;
}

.info-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2a2a2a;
  display: flex;
  align-items: center;
}

.info-card-title::before {
  content: '';
  width: 6rpx;
  height: 26rpx;
  background: linear-gradient(180deg, #D4A76A, #C99A5A);
  border-radius: 3rpx;
  margin-right: 14rpx;
}

.info-card-body {
  padding: 8rpx 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f5f1ec;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #888;
}

.info-value-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.info-value {
  font-size: 26rpx;
  color: #2a2a2a;
  font-weight: 500;
}

.role-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.staff-role-tag {
  color: #fff;
  background: linear-gradient(135deg, #D4A76A, #C99A5A);
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.status-dot.online {
  background-color: #52c41a;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.5);
}

/* 退出登录按钮 */
.staff-logout-wrap {
  padding: 0 0 40rpx;
}

.staff-logout-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  border: 2rpx solid #f0ebe4;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #ff4d4f;
  font-weight: 500;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.06);
}

.staff-logout-btn::after {
  border: none;
}

.staff-logout-btn:active {
  background: #fef2f2;
  border-color: #ffccc7;
}

/* ===== 未登录提示 ===== */
.login-prompt {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
  padding: 40rpx;
}

.login-prompt-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 80rpx 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(212, 167, 106, 0.08);
  width: 100%;
  box-sizing: border-box;
}

.login-prompt-avatar {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.login-prompt-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2a2a2a;
  margin-bottom: 16rpx;
}

.login-prompt-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.login-prompt-btn {
  width: 80%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(145deg, #D4A76A, #C99A5A);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.35);
}

.login-prompt-btn::after {
  border: none;
}

.login-prompt-btn:active {
  opacity: 0.9;
}
