<wxs module="filters" src="filters.wxs" />
<view class="page-wrap {{showModal || showSeparateSettleModal ? 'fixed' : ''}}">

  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>

  <!-- ===== 四角麦穗装饰 ===== -->
   <image class="wheat-corner-tl" src="/images/615.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/615.png" mode="aspectFit"/>

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/2072.png" mode="aspectFit"/>
    <text class="header-title">购物车</text>
    <image class="header-bar-wheat-right" src="/images/2072.png" mode="aspectFit"/>
    <text class="header-subtitle">稻田好物，满载而归</text>
  </view>

  <!-- ===== 主内容区 ===== -->
  <view class="main-content">

    <!-- 共享购物车模式 -->
    <view class="shared-cart-banner" wx:if="{{isSharedMode}}">
      <text class="shared-cart-icon">📤</text>
      <view class="shared-cart-info">
        <text class="shared-cart-title">好友分享的购物车</text>
        <text class="shared-cart-count">共 {{sharedCartItems.length}} 件商品</text>
      </view>
    </view>

    <!-- 共享购物车商品 -->
    <view wx:if="{{isSharedMode && sharedCartItems.length > 0}}">
      <view class="cart-item" wx:for="{{sharedCartItems}}" wx:key="_cartKey">
        <image class="cart-item-img" src="{{item.image || 'https://api.nengjifarm.com/api/file/image/default.png'}}" mode="aspectFill" />
        <view class="cart-item-info">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-price">¥{{filters.price(item.price)}}</text>
        </view>
        <view class="cart-item-qty">×{{item.count}}</view>
      </view>
    </view>

    <!-- 共享模式操作 -->
    <view class="shared-actions" wx:if="{{isSharedMode}}">
      <view class="btn btn-gold w-full" bindtap="addSharedToCart">加入我的购物车</view>
      <view class="btn btn-ghost w-full mt-sm" bindtap="exitSharedMode">查看自己的购物车</view>
    </view>

    <!-- 空购物车 -->
    <view class="empty-cart-wrap" wx:if="{{cartList.length === 0 && !isSharedMode}}">
      <view class="empty-cart-icon">🛒</view>
      <text class="empty-cart-title">购物车空空的</text>
      <text class="empty-cart-desc">快去稻田里挑选好物吧~</text>
      <view class="btn btn-gold mt-lg" bindtap="navigateToFarmGoods">去逛逛</view>
    </view>

    <!-- ===== 购物车内容 ===== -->
    <view wx:if="{{cartList.length > 0 && !isSharedMode}}" class="cart-content">
      <!-- 全选栏 -->
      <view class="cart-toolbar">
        <view class="select-all" bindtap="handleSelectAll">
          <view class="checkbox-circle {{selectAll ? 'checked' : ''}}">
            <text wx:if="{{selectAll}}">✓</text>
          </view>
          <text>全选</text>
        </view>
        <view class="toolbar-actions">
          <text class="toolbar-action" bindtap="handleClearCart">清空</text>
        </view>
      </view>

      <!-- 点餐区域 -->
      <view class="region-card" wx:if="{{regions.food.items.length > 0}}">
        <view class="region-header" bindtap="toggleRegionSelect" data-region="food">
          <view class="region-left">
            <view class="checkbox-circle {{regions.food.selected ? 'checked' : ''}}">
              <text wx:if="{{regions.food.selected}}">✓</text>
            </view>
            <text class="region-name">{{regions.food.name}}</text>
            <text class="region-count">({{regions.food.items.length}}件)</text>
          </view>
          <view class="region-right" catchtap="goToOrder">
            <text class="table-badge" wx:if="{{tableNumber}}">桌号 {{tableNumber}}</text>
            <text class="table-select-link" wx:else>选桌号 →</text>
          </view>
        </view>
        <view class="region-items">
          <view class="cart-item-row" wx:for="{{regions.food.items}}" wx:key="_cartKey">
            <view class="checkbox-circle {{item.checked ? 'checked' : ''}}" catchtap="toggleSelect" data-id="{{item.id}}" data-type="{{item.type}}">
              <text wx:if="{{item.checked}}">✓</text>
            </view>
            <image class="cart-item-img" src="{{item.image}}" mode="aspectFill" bindtap="goToDetail" data-id="{{item.id}}" data-type="{{item.type}}" data-is-farm-good="{{item.isFarmGood}}" />
            <view class="cart-item-info">
              <text class="cart-item-name">{{item.name}}</text>
              <text class="cart-item-tag">{{item.tag}}</text>
              <text class="cart-item-price">¥{{filters.price(item.price)}}</text>
              <text class="cart-item-stock" wx:if="{{item.stock}}">仅剩{{item.stock}}件</text>
            </view>
            <view class="cart-item-ctrl">
              <view class="qty-btn" catchtap="handleMinus" data-id="{{item.id}}" data-type="{{item.type}}">−</view>
              <input class="qty-input" type="number" value="{{item.count}}" data-id="{{item.id}}" data-type="{{item.type}}" bindinput="handleQuantityInput" bindblur="handleQuantityBlur" />
              <view class="qty-btn" catchtap="handlePlus" data-id="{{item.id}}" data-type="{{item.type}}">+</view>
            </view>
            <view class="item-del" catchtap="handleRemoveItem" data-id="{{item.id}}" data-type="{{item.type}}">✕</view>
          </view>
        </view>
      </view>

      <!-- 商品区域 -->
      <view class="region-card" wx:if="{{regions.goods.items.length > 0}}">
        <view class="region-header" bindtap="toggleRegionSelect" data-region="goods">
          <view class="region-left">
            <view class="checkbox-circle {{regions.goods.selected ? 'checked' : ''}}">
              <text wx:if="{{regions.goods.selected}}">✓</text>
            </view>
            <text class="region-name">{{regions.goods.name}}</text>
            <text class="region-count">({{regions.goods.items.length}}件)</text>
          </view>
        </view>
        <view class="region-items">
          <view class="cart-item-row" wx:for="{{regions.goods.items}}" wx:key="_cartKey">
            <view class="checkbox-circle {{item.checked ? 'checked' : ''}}" catchtap="toggleSelect" data-id="{{item.id}}" data-type="{{item.type}}">
              <text wx:if="{{item.checked}}">✓</text>
            </view>
            <image class="cart-item-img" src="{{item.image}}" mode="aspectFill" bindtap="goToDetail" data-id="{{item.id}}" data-type="{{item.type}}" data-is-farm-good="{{item.isFarmGood}}" />
            <view class="cart-item-info">
              <text class="cart-item-name">{{item.name}}</text>
              <text class="cart-item-tag">{{item.tag}}</text>
              <text class="cart-item-price">¥{{filters.price(item.price)}}</text>
              <text class="cart-item-stock" wx:if="{{item.stock}}">仅剩{{item.stock}}件</text>
            </view>
            <view class="cart-item-ctrl">
              <view class="qty-btn" catchtap="handleMinus" data-id="{{item.id}}" data-type="{{item.type}}">−</view>
              <input class="qty-input" type="number" value="{{item.count}}" data-id="{{item.id}}" data-type="{{item.type}}" bindinput="handleQuantityInput" bindblur="handleQuantityBlur" />
              <view class="qty-btn" catchtap="handlePlus" data-id="{{item.id}}" data-type="{{item.type}}">+</view>
            </view>
            <view class="item-del" catchtap="handleRemoveItem" data-id="{{item.id}}" data-type="{{item.type}}">✕</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ===== 底部装饰 ===== -->
    <view class="footer-decoration">
      <image class="footer-wheat footer-wheat-bl" src="/images/615.png" mode="aspectFit"/>
      <image class="footer-wheat footer-wheat-br" src="/images/615.png" mode="aspectFit"/>
      <view class="footer-rice">
        <image class="footer-rice-text" src="/images/2072.png" mode="aspectFit" />
      </view>
      <view class="footer-wheat-row">
        <image class="footer-wheat-left" src="/images/2072.png" mode="aspectFit"/>
        <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
        <image class="footer-wheat-right" src="/images/2072.png" mode="aspectFit"/>
      </view>
      <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
    </view>
  </view>

  <!-- ===== 底部结算栏 ===== -->
  <view class="cart-bottom-bar" wx:if="{{!showModal && !showSeparateSettleModal && !isSharedMode && cartList.length > 0}}">
    <view class="bar-left">
      <text class="bar-total-label">合计</text>
      <text class="bar-total-price">¥{{filters.price(totalPrice)}}</text>
    </view>
    <view class="bar-settle {{canSettle ? 'active' : 'disabled'}}" bindtap="handleSettle">
      <text>{{selectedCount > 0 ? '结算(' + selectedCount + ')' : '结算'}}</text>
    </view>
  </view>

  <!-- ===== 分别结算弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{showSeparateSettleModal}}" bindtap="handleCloseSeparateSettleModal"></view>
  <view class="modal-content" wx:if="{{showSeparateSettleModal}}">
    <view class="modal-header">
      <text class="modal-title">分别结算</text>
      <view class="modal-close" bindtap="handleCloseSeparateSettleModal">✕</view>
    </view>
    <view class="modal-body">
      <view class="settle-section" wx:if="{{regions.food.hasChecked}}">
        <view class="settle-section-hd">
          <text class="settle-section-name">{{regions.food.name}}</text>
          <text class="settle-section-tag">堂食</text>
        </view>
        <view class="settle-section-preview">
          <image class="preview-img" wx:for="{{regions.food.previewImages}}" wx:key="index" src="{{item}}" mode="aspectFill" />
          <view class="preview-more" wx:if="{{regions.food.moreCount > 0}}">+{{regions.food.moreCount}}</view>
        </view>
        <text class="settle-section-desc">{{regions.food.checkedItemNames.join('、')}}</text>
        <view class="settle-section-ft">
          <text class="settle-price">¥{{filters.price(regions.food.totalPrice)}}</text>
          <view class="btn btn-gold btn-sm" bindtap="settleFood">结算</view>
        </view>
      </view>
      <view class="settle-section" wx:if="{{regions.goods.hasChecked}}">
        <view class="settle-section-hd">
          <text class="settle-section-name">{{regions.goods.name}}</text>
          <text class="settle-section-tag">配送</text>
        </view>
        <view class="settle-section-preview">
          <image class="preview-img" wx:for="{{regions.goods.previewImages}}" wx:key="index" src="{{item}}" mode="aspectFill" />
          <view class="preview-more" wx:if="{{regions.goods.moreCount > 0}}">+{{regions.goods.moreCount}}</view>
        </view>
        <text class="settle-section-desc">{{regions.goods.checkedItemNames.join('、')}}</text>
        <view class="settle-section-ft">
          <text class="settle-price">¥{{filters.price(regions.goods.totalPrice)}}</text>
          <view class="btn btn-gold btn-sm" bindtap="settleGoods">结算</view>
        </view>
      </view>
    </view>
  </view>
</view>
