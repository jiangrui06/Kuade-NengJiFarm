/* ============================================
   购物车页 - 稻田风 · 高级版
   ============================================ */

@import "../../styles/farm-theme.wxss";

page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: var(--rice-gold);
  --rice-green-light: var(--rice-gold-light);
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-danger: #D4765E;
  --rice-danger-light: #E0937E;
  --rice-warm: #F5E6D3;

  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%);
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;

  display: flex;
  flex-direction: column;
}

.page-wrap.fixed {

  height: 100vh;
}

/* ===== 底部稻田梯田 ===== */
.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: -10%; right: -10%; height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light);
  letter-spacing: 6rpx; font-weight: 400;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative; z-index: 1;
  display: flex;
  flex-direction: column;
  flex: 1;
  padding: 0 0 130rpx;
}

/* ===== 稻穗装饰 ===== */
.wheat-stalk {
  background: var(--wheat-deco) center/contain no-repeat;
}

/* ===== 共享购物车 ===== */
.shared-cart-banner {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(232, 200, 122, 0.12), rgba(245, 222, 160, 0.08));
  border-radius: 24rpx;
  border: 1rpx solid rgba(232, 200, 122, 0.25);
  gap: 16rpx;
}

.shared-cart-icon {
  font-size: 48rpx;
}

.shared-cart-info {
  flex: 1;
}

.shared-cart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--rice-text);
}

.shared-cart-count {
  font-size: 22rpx;
  color: var(--rice-text-light);
  margin-top: 4rpx;
}

.shared-actions {
  margin-top: 24rpx;
}

/* ===== 空购物车 ===== */
.empty-cart-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 60rpx 40rpx;
}

.empty-cart-icon {
  width: 120rpx;
  height: 120rpx;
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
  position: relative;
  top: -40rpx;
  left: -20rpx;
}

.empty-cart-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--rice-text);
  margin-bottom: 8rpx;
}

.empty-cart-desc {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

/* ===== 工具栏 ===== */
.cart-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  margin: 16rpx 0;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx var(--rice-shadow);
  border: 1rpx solid rgba(232, 200, 122, 0.08);
}

.select-all {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-size: 26rpx;
  color: var(--rice-text-secondary);
}

.toolbar-actions {
  display: flex;
  gap: 16rpx;
}

.toolbar-action {
  font-size: 22rpx;
  color: var(--rice-text-light);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--rice-straw);
}

.toolbar-action:active {
  background: var(--rice-paper);
}

/* ===== 复选框 ===== */
.checkbox-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--rice-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  flex-shrink: 0;
}

.checkbox-circle.checked {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-color: var(--rice-gold);
}

.checkbox-circle text {
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
}

/* ===== 区域卡片 ===== */
.region-card {
  margin: 0 0 20rpx;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;

  box-shadow: 0 8rpx 32rpx var(--rice-shadow);
  border: 1rpx solid rgba(232, 200, 122, 0.12);
  position: relative;
}

.region-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.region-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--rice-cream);
  border-bottom: 1rpx solid var(--rice-paper);
}

.region-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.region-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--rice-text);
}

.region-count {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.region-right {
  display: flex;
  align-items: center;
}

.table-badge {
  font-size: 22rpx;
  color: var(--rice-gold);
  padding: 6rpx 16rpx;
  background: rgba(196, 149, 60, 0.1);
  border-radius: 20rpx;
  font-weight: 500;
}

.table-select-link {
  font-size: 24rpx;
  color: var(--rice-gold);
  font-weight: 500;
  padding: 6rpx 16rpx;
  background: rgba(196, 149, 60, 0.08);
  border-radius: 20rpx;
}

/* ===== 购物车项 ===== */
.cart-item-row {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid var(--rice-paper);
  position: relative;
  gap: 16rpx;
}

.cart-item-row:last-child {
  border-bottom: none;
}

.cart-item-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: var(--rice-paper);
  flex-shrink: 0;
}

.cart-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.cart-item-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--rice-text);
  line-height: 1.4;
}

.cart-item-tag {
  font-size: 20rpx;
  color: var(--rice-gold);
  padding: 2rpx 10rpx;
  background: rgba(196, 149, 60, 0.08);
  border-radius: 4rpx;
  display: inline-block;
  align-self: flex-start;
}

.cart-item-price {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--rice-gold);
}

.cart-item-stock {
  font-size: 18rpx;
  color: var(--rice-text-light);
}

.cart-item-ctrl {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--rice-paper);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--rice-gold);
  font-weight: 600;
  transition: all 0.2s;
}

.qty-btn:active {
  background: var(--rice-gold);
  color: #fff;
}

.qty-input {
  width: 60rpx;
  height: 52rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--rice-text);
  background: var(--rice-paper);
  border-radius: 8rpx;
  border: 1rpx solid var(--rice-straw);
}

.cart-item-qty {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--rice-gold);
  padding: 0 24rpx;
}

.item-del {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--rice-paper);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--rice-text-light);
}

.item-del:active {
  background: rgba(212, 118, 94, 0.15);
  color: var(--rice-danger);
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  background: linear-gradient(180deg, rgba(245,240,230,0.4) 0%, rgba(124,179,66,0.1) 40%, rgba(124,179,66,0.18) 100%);
  border-top: 1rpx solid rgba(232,200,122,0.15);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.7;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

/* ===== 底部结算栏 ===== */
.cart-bottom-bar {
  position: fixed;
  bottom: calc(260rpx + env(safe-area-inset-bottom));
  left: 24rpx;
  right: 24rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx 0 32rpx;
  box-shadow: 0 8rpx 40rpx var(--rice-shadow-heavy);
  z-index: 100;
  border: 1rpx solid rgba(232, 200, 122, 0.1);
}

.bar-left {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.bar-total-label {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.bar-total-price {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--rice-gold);
}

.bar-settle {
  padding: 18rpx 44rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.bar-settle.active {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  box-shadow: 0 6rpx 24rpx rgba(196, 149, 60, 0.35);
}

.bar-settle.active:active {
  transform: scale(0.95);
}

.bar-settle.disabled {
  background: var(--rice-straw);
  color: var(--rice-text-light);
}

/* ===== 分别结算弹窗 ===== */
.settle-section {
  background: var(--rice-paper);
  border-radius: 20rpx;
  margin-bottom: 20rpx;

}

.settle-section-hd {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 12rpx;
  border-bottom: 1rpx solid var(--rice-straw);
}

.settle-section-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--rice-text);
}

.settle-section-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  font-weight: 500;
}

.settle-section-preview {
  display: flex;
  padding: 16rpx 24rpx;
  gap: 8rpx;
}

.preview-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #fff;
}

.preview-more {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: var(--rice-paper);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.settle-section-desc {
  font-size: 22rpx;
  color: var(--rice-text-secondary);
  padding: 0 24rpx 16rpx;
  line-height: 1.4;
}

.settle-section-ft {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
}

.settle-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-gold);
}

/* ===== 动画 ===== */
@keyframes gentleFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
