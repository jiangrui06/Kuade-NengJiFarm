/* ============================================
   首页 - 稻田风 · 轻复古田园版
   主色：#FAF5EB · 主题色：#E6B877 · 文字：#5C3D2E · 点缀：#7CB342
   ============================================ */

/* ===== 首页覆写色彩体系 ===== */
page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: var(--rice-gold);
  --rice-green-light: var(--rice-gold-light);
  --rice-text: #5C3D2E;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  background:
    /* 夕阳暖晕 */
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    /* 远处青山轮廓 */
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    /* 天空渐变 - 暖米色系 */
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

/* ===== 页面容器 ===== */
.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
}

/* ===== 太阳动画（增强） ===== */
.bg-sun {
  position: fixed;
  top: 50rpx;
  right: 50rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background:
    /* 核心光球 */
    radial-gradient(circle at 50% 50%, #FFF8E1 0%, #FFE082 15%, #FFD54F 30%, rgba(255, 200, 50, 0.6) 50%, transparent 70%),
    /* 外层光晕 */
    radial-gradient(circle at 50% 50%, rgba(255, 220, 100, 0.2) 0%, rgba(255, 200, 80, 0.08) 50%, transparent 70%);
  pointer-events: none;
  z-index: 0;
  animation: sunPulse 5s ease-in-out infinite;
}

.bg-sun::after {
  content: '';
  position: absolute;
  top: -40rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, transparent 35%, rgba(255, 220, 100, 0.12) 45%, transparent 55%),
    radial-gradient(circle at 50% 50%, transparent 30%, rgba(255, 200, 80, 0.08) 42%, transparent 58%);
  animation: sunCorona 6s ease-in-out infinite;
}

@keyframes sunPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; box-shadow: 0 0 30rpx rgba(255, 200, 50, 0.2); }
  50% { transform: scale(1.12); opacity: 1; box-shadow: 0 0 60rpx rgba(255, 200, 50, 0.4), 0 0 120rpx rgba(255, 200, 50, 0.15); }
}

@keyframes sunCorona {
  0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.6; }
  50% { transform: scale(1.2) rotate(180deg); opacity: 1; }
}

/* ===== 云朵动画（增强） ===== */
.bg-cloud {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  animation: cloudDrift 20s linear infinite;
}

.bg-cloud::before {
  content: '';
  position: absolute;
  border-radius: 50%;
  background:
    radial-gradient(ellipse 100% 100% at 50% 50%, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.1) 60%, transparent 100%);
}

.bg-cloud-1 {
  width: 320rpx;
  height: 80rpx;
  top: 70rpx;
  left: -360rpx;
  animation-duration: 32s;
}
.bg-cloud-1::before {
  width: 260rpx;
  height: 90rpx;
  top: -30rpx;
  left: 20rpx;
  background:
    radial-gradient(ellipse 100% 100% at 30% 50%, rgba(255, 255, 255, 0.2) 0%, transparent 60%),
    radial-gradient(ellipse 100% 100% at 70% 50%, rgba(255, 255, 255, 0.15) 0%, transparent 60%);
}
.bg-cloud-1::after {
  content: '';
  position: absolute;
  width: 180rpx;
  height: 60rpx;
  top: -20rpx;
  left: 60rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse 100% 100% at 50% 50%, rgba(255, 255, 255, 0.12) 0%, transparent 70%);
}

.bg-cloud-2 {
  width: 240rpx;
  height: 55rpx;
  top: 140rpx;
  left: -280rpx;
  animation-duration: 26s;
  animation-delay: 5s;
}
.bg-cloud-2::before {
  width: 200rpx;
  height: 60rpx;
  top: -20rpx;
  left: 10rpx;
}

.bg-cloud-3 {
  width: 180rpx;
  height: 40rpx;
  top: 40rpx;
  left: -220rpx;
  animation-duration: 20s;
  animation-delay: 11s;
}
.bg-cloud-3::before {
  width: 150rpx;
  height: 45rpx;
  top: -15rpx;
  left: 5rpx;
}

@keyframes cloudDrift {
  0% { transform: translateX(0) translateY(0); opacity: 0; }
  4% { opacity: 1; }
  45% { transform: translateX(50vw) translateY(-10rpx); }
  90% { opacity: 1; }
  100% { transform: translateX(150vw) translateY(0); opacity: 0; }
}

/* ===== 飞鸟动画（增强） ===== */
.bg-bird {
  position: fixed;
  width: 44rpx;
  height: 18rpx;
  top: 160rpx;
  left: -80rpx;
  pointer-events: none;
  z-index: 0;
  animation: birdFly 14s ease-in-out infinite;
}

.bg-bird::before,
.bg-bird::after {
  content: '';
  position: absolute;
  width: 18rpx;
  height: 8rpx;
  background: rgba(80, 60, 40, 0.15);
  border-radius: 60% 40% 50% 50%;
  animation: wingFlap 0.3s ease-in-out infinite;
}

.bg-bird::before {
  left: 0;
  transform: rotate(-18deg);
  transform-origin: right center;
}
.bg-bird::after {
  right: 0;
  transform: rotate(18deg);
  transform-origin: left center;
}

.bg-bird-2 {
  top: 210rpx;
  animation-duration: 18s;
  animation-delay: 6s;
  transform: scale(0.65);
}

.bg-bird-3 {
  top: 130rpx;
  animation-duration: 22s;
  animation-delay: 13s;
  transform: scale(0.5);
}

@keyframes birdFly {
  0% { transform: translateX(0) translateY(0); opacity: 0; }
  3% { opacity: 1; }
  30% { transform: translateX(30vw) translateY(-15rpx); }
  60% { transform: translateX(65vw) translateY(10rpx); }
  85% { opacity: 1; }
  100% { transform: translateX(140vw) translateY(-5rpx); opacity: 0; }
}

@keyframes wingFlap {
  0%, 100% { transform: rotate(-20deg) scaleY(1); }
  50% { transform: rotate(-30deg) scaleY(0.5); }
}

.bg-bird-2::before,
.bg-bird-2::after {
  animation-duration: 0.25s;
}
.bg-bird-3::before,
.bg-bird-3::after {
  animation-duration: 0.35s;
}

/* ===== 蝴蝶动画（新增） ===== */
.bg-butterfly {
  position: fixed;
  width: 24rpx;
  height: 16rpx;
  top: 260rpx;
  left: -40rpx;
  pointer-events: none;
  z-index: 0;
  animation: butterflyFly 25s ease-in-out infinite;
}

.bg-butterfly::before,
.bg-butterfly::after {
  content: '';
  position: absolute;
  width: 16rpx;
  height: 10rpx;
  border-radius: 50% 50% 0 50%;
  background: linear-gradient(135deg, #E8A87C 0%, #D4866B 40%, #C4705A 100%);
  opacity: 0.55;
  animation: wingFlapButterfly 0.15s ease-in-out infinite;
}

.bg-butterfly::before {
  left: 0;
  transform-origin: right center;
}
.bg-butterfly::after {
  right: 0;
  transform-origin: left center;
  border-radius: 50% 50% 50% 0;
}

.bg-butterfly-2 {
  top: 320rpx;
  animation-duration: 30s;
  animation-delay: 10s;
  transform: scale(0.7);
}

@keyframes butterflyFly {
  0% { transform: translateX(0) translateY(0) rotate(0deg); opacity: 0; }
  5% { opacity: 0.8; }
  15% { transform: translateX(20vw) translateY(-30rpx) rotate(5deg); }
  30% { transform: translateX(35vw) translateY(20rpx) rotate(-8deg); }
  50% { transform: translateX(55vw) translateY(-40rpx) rotate(10deg); }
  70% { transform: translateX(75vw) translateY(15rpx) rotate(-5deg); }
  90% { transform: translateX(90vw) translateY(-20rpx) rotate(3deg); opacity: 0.6; }
  100% { transform: translateX(110vw) translateY(0) rotate(0deg); opacity: 0; }
}

@keyframes wingFlapButterfly {
  0%, 100% { transform: scaleY(1) rotate(-10deg); }
  50% { transform: scaleY(0.3) rotate(-20deg); }
}

.bg-butterfly-2::before,
.bg-butterfly-2::after {
  animation-duration: 0.18s;
}

/* ===== 漂浮稻粒（增强） ===== */
.bg-float-grain {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  animation: grainFloat 7s ease-in-out infinite;
}

.bg-float-grain::after {
  content: '';
  position: absolute;
  top: -2rpx;
  left: -2rpx;
  width: calc(100% + 4rpx);
  height: calc(100% + 4rpx);
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(255, 240, 180, 0.3) 0%, transparent 70%);
  animation: grainGlow 2s ease-in-out infinite alternate;
}

.bg-grain-lg {
  width: 12rpx;
  height: 18rpx;
  background: linear-gradient(180deg, rgba(232, 200, 122, 0.6), rgba(196, 149, 60, 0.45));
}

.bg-grain-md {
  width: 8rpx;
  height: 14rpx;
  background: linear-gradient(180deg, rgba(232, 200, 122, 0.5), rgba(196, 149, 60, 0.35));
}

.bg-grain-sm {
  width: 5rpx;
  height: 10rpx;
  background: rgba(196, 149, 60, 0.35);
}

@keyframes grainFloat {
  0% { transform: translateY(0) rotate(0deg) scale(1); opacity: 0; }
  8% { opacity: 0.8; }
  40% { transform: translateY(-40rpx) rotate(25deg) scale(1.15); opacity: 0.6; }
  70% { opacity: 0.4; }
  100% { transform: translateY(-90rpx) rotate(55deg) scale(0.4); opacity: 0; }
}

@keyframes grainGlow {
  0% { opacity: 0.3; }
  100% { opacity: 0.8; }
}

/* ===== 萤火虫 / 光点粒子（新增） ===== */
.bg-firefly {
  position: fixed;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
  background:
    radial-gradient(circle at 50% 50%, rgba(255, 255, 200, 0.8) 0%, rgba(255, 230, 150, 0.25) 40%, transparent 70%);
  animation: fireflyFloat 8s ease-in-out infinite;
}

.bg-firefly::after {
  content: '';
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 50%, rgba(255, 240, 180, 0.12) 0%, transparent 70%);
  animation: fireflyGlow 2s ease-in-out infinite alternate;
}

@keyframes fireflyFloat {
  0% { transform: translate(0, 0); opacity: 0; }
  15% { opacity: 0.6; }
  30% { transform: translate(15rpx, -25rpx); opacity: 0.8; }
  50% { transform: translate(-10rpx, -45rpx); opacity: 0.4; }
  70% { transform: translate(20rpx, -30rpx); opacity: 0.7; }
  85% { opacity: 0.3; }
  100% { transform: translate(-5rpx, -60rpx); opacity: 0; }
}

@keyframes fireflyGlow {
  0% { transform: scale(1); opacity: 0.5; }
  100% { transform: scale(2); opacity: 1; }
}

/* ===== 金色花粉 / 尘埃粒子（新增） ===== */
.bg-pollen {
  position: fixed;
  width: 3rpx;
  height: 3rpx;
  border-radius: 50%;
  background: rgba(255, 220, 120, 0.35);
  pointer-events: none;
  z-index: 0;
  animation: pollenDrift 12s ease-in-out infinite;
}

@keyframes pollenDrift {
  0% { transform: translate(0, 0) scale(1); opacity: 0; }
  10% { opacity: 0.6; }
  40% { transform: translate(25rpx, -20rpx) scale(1.3); opacity: 0.5; }
  70% { transform: translate(-15rpx, -40rpx) scale(0.8); opacity: 0.35; }
  100% { transform: translate(30rpx, -70rpx) scale(0.5); opacity: 0; }
}

/* 底部稻田梯田 · 远山 + 水田（豪华版） */
.page-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: -10%;
  right: -10%;
  height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}



/* 光晕氛围 + 散射稻谷颗粒（增强版） */
.page-wrap::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background:

    linear-gradient(155deg, transparent 20%, rgba(255,220,150,0.1) 42%, transparent 65%);
  pointer-events: none; z-index: 0;
  opacity: 0.9;
  animation: moduleCornerSway 4s ease-in-out infinite;
}
/* 所有稻穗朝向模块中心，形成聚拢感 */
.module-corner-tl { top: -200rpx; left: -110rpx; transform: rotate(135deg); }
.module-corner-tr { top: -200rpx; right: -110rpx; transform: rotate(-135deg); }
.module-corner-bl { bottom: -200rpx; left: -110rpx; transform: rotate(45deg); }
.module-corner-br { bottom: -200rpx; right: -110rpx; transform: rotate(-45deg); }

.module-corner-tr,
.module-corner-br { animation-delay: 0.5s; }

/* 视频区：右上+右下，完全在模块外紧贴边缘 */
.video-section .module-corner-tr { top: -410rpx; right: -20rpx; }
.video-section .module-corner-br { bottom: -410rpx; right: -20rpx; }

@keyframes moduleCornerSway {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 0.8; }
}

.swiper-wrapper::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24rpx;
  border: 1rpx solid rgba(232, 200, 122, 0.15);
  pointer-events: none;
  z-index: 2;
}

.swiper-item {
  width: 100%;
  height: 320rpx;
  position: relative;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.swiper-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40%;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.35) 0%, transparent 100%);
  z-index: 1;
}

.swiper-caption {
  position: absolute;
  bottom: 20rpx;
  left: 24rpx;
  right: 24rpx;
  z-index: 2;
}

.swiper-caption-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.3);
}

/* ============================================
   顶部标题栏
   ============================================ */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}


.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light);
  letter-spacing: 6rpx; font-weight: 400;
}

@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}

/* ============================================
   搜索区
   ============================================ */
.search-section {
  padding: 0;
  margin: 16rpx 0;
  position: relative;
  z-index: 20;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: linear-gradient(135deg, #FAF5EB, #FDF5E6);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 24rpx rgba(92, 61, 46, 0.08),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(230, 184, 119, 0.25);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 56rpx;
  background: transparent;
  border: none;
  outline: none;
  color: var(--rice-text);
}

.search-placeholder {
  color: var(--rice-text-light);
  font-size: 24rpx;
}

.search-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 14rpx 28rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(230, 184, 119, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(230, 184, 119, 0.3);
  transition: all 0.3s;
  flex-shrink: 0;
}

.search-btn:active {
  transform: scale(0.94);
  box-shadow: 0 2rpx 8rpx rgba(230, 184, 119, 0.2);
}

/* ============================================
   主内容区
   ============================================ */
.main-content {
  padding: 0 0 130rpx;
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.section-block {
  margin-top: 24rpx;
}

.section-with-corners {
  position: relative;
}

/* ---- 麦穗点缀分隔 ---- */
.section-wheat-scatter {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 8rpx 0 4rpx;
  opacity: 0.2;
}

.scatter-wheat {
  width: 30rpx;
  height: 42rpx;
  display: inline-block;
  animation: scatterFloat 3s ease-in-out infinite;
}

@keyframes scatterFloat {
  0%, 100% { transform: translateY(0) rotate(-3deg); opacity: 0.15; }
  25% { transform: translateY(-6rpx) rotate(3deg); opacity: 0.35; }
  50% { transform: translateY(-12rpx) rotate(-5deg); opacity: 0.45; }
  75% { transform: translateY(-4rpx) rotate(4deg); opacity: 0.25; }
}

/* ---- 区块入场动画 ---- */
.anim-section {
  animation: sectionFadeIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

.section-block:nth-child(1) { animation-delay: 0.05s; }
.section-block:nth-child(2) { animation-delay: 0.15s; }
.section-block:nth-child(3) { animation-delay: 0.25s; }
.section-block:nth-child(4) { animation-delay: 0.35s; }
.section-block:nth-child(5) { animation-delay: 0.45s; }

@keyframes sectionFadeIn {
  from { opacity: 0; transform: translateY(40rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* ============================================
   轮播图容器
   ============================================ */
.swiper-wrapper {
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx var(--rice-shadow);
  position: relative;
}

/* ===== 模块四角麦穗装饰 ===== */
.module-corner {
  position: absolute;
  width: 220rpx;
  height: 400rpx;
  pointer-events: none;
  z-index: 3;
  opacity: 0.9;
  animation: moduleCornerSway 4s ease-in-out infinite;
}

/* ============================================
   视频卡片
   ============================================ */
.video-card {
  background: linear-gradient(135deg, #FEFCF7 0%, #FDF5E6 50%, #FCF0D8 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx var(--rice-shadow);
  border: 1rpx solid rgba(232, 200, 122, 0.15);
  position: relative;
}

.video-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.03) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 60% 70%, rgba(232, 200, 122, 0.03) 0%, transparent 100%);
  pointer-events: none;
}

.video-label {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 12rpx;
}

.video-label-icon {
  font-size: 28rpx;
}

.video-label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--rice-green-deep);
}

.video-container {
  display: flex;
  flex-direction: column;
}

.video-player {
  width: 100%;
  height: 340rpx;
  background-color: #1a1a1a;
}

/* ============================================
   功能入口（新图标风格 - 虚线边框 + 方形图标）
   ============================================ */
.feature-nav-container {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  padding: 32rpx 16rpx;
  background: linear-gradient(135deg, rgba(254,252,247,0.8) 0%, rgba(253,245,230,0.6) 100%);
  border-radius: 24rpx;
  border: 2rpx dashed var(--rice-straw);
  box-shadow: 0 4rpx 20rpx var(--rice-shadow);
  position: relative;
  overflow: hidden;
}

.feature-nav-container::before {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(232, 200, 122, 0.08);
  pointer-events: none;
}

/* 功能入口四角麦穗 */
/* 功能入口四角麦穗 — 左上+右下，朝内聚拢 */
.feature-nav-wheat {
  position: absolute;
  width: 220rpx;
  height: 400rpx;
  pointer-events: none;
  opacity: 0.85;
  animation: featureWheat 3s ease-in-out infinite;
}

.feature-nav-wheat-tl { top: -100rpx; left: -100rpx; transform: rotate(135deg); }
.feature-nav-wheat-br { bottom: -100rpx; right: -100rpx; transform: rotate(-45deg); }

@keyframes featureWheat {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.65; }
}

.feature-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

/* 新图标外框 - 圆角方形，与图标风格统一 */
.feature-icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 2rpx solid rgba(196, 149, 60, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(196, 149, 60, 0.15);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
}

/* 各功能入口统一金色边框 */
.feature-icon-box-farm,
.feature-icon-box-food,
.feature-icon-box-activity,
.feature-icon-box-points {
  border-color: rgba(196, 149, 60, 0.35);
  box-shadow: 0 4rpx 16rpx rgba(196, 149, 60, 0.15);
}

.feature-nav-item:active .feature-icon-box {
  transform: scale(1.08);
  box-shadow: 0 8rpx 28rpx rgba(196, 149, 60, 0.25);
  border-color: rgba(196, 149, 60, 0.5);
}

/* 图标图片本身 */
.feature-icon-img {
  width: 96rpx;
  height: 96rpx;
  display: block;
}

.feature-nav-label {
  font-size: 22rpx;
  color: var(--rice-text-secondary);
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* ============================================
   区块标题栏
   ============================================ */
.section-title-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
  gap: 10rpx;
}

.section-title-wheat {
  width: 36rpx;
  height: 54rpx;
  display: inline-block;
  animation: wheatBounce 3s ease-in-out infinite;
  opacity: 0.3;
}

.section-title-bar-inner {
  width: 6rpx;
  height: 28rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
  margin-right: 4rpx;
  flex-shrink: 0;
}

.section-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  letter-spacing: 2rpx;
  flex: 1;
}

@keyframes wheatBounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  30% { transform: translateY(-8rpx) rotate(3deg); }
  60% { transform: translateY(-3rpx) rotate(7deg); }
  80% { transform: translateY(-6rpx) rotate(-2deg); }
}

.section-title-more {
  font-size: 22rpx;
  color: var(--rice-text-light);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--rice-straw);
  transition: all 0.2s;
}

.section-title-more:active {
  background: var(--rice-paper);
  color: var(--rice-gold);
  border-color: var(--rice-gold-light);
}

/* ============================================
   商品网格
   ============================================ */
.product-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.product-card {
  background: linear-gradient(135deg, #FAF5EB 0%, #FDF5E6 50%, #FCF0DC 100%);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx var(--rice-shadow);
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  border: 1rpx solid rgba(230, 184, 119, 0.15);
  animation: cardFloatIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  position: relative;
}

.product-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(255,255,255,0) 40%, rgba(255,255,240,0.05) 50%, rgba(255,255,255,0) 60%);
  animation: cardShimmer 4s ease-in-out infinite;
  pointer-events: none;
}

@keyframes cardShimmer {
  0%, 100% { opacity: 0; transform: translateX(-100%); }
  30% { opacity: 1; }
  60% { opacity: 0; transform: translateX(100%); }
}

.product-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 15% 20%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.product-card:nth-child(1) { animation-delay: 0.05s; }
.product-card:nth-child(2) { animation-delay: 0.1s; }
.product-card:nth-child(3) { animation-delay: 0.15s; }
.product-card:nth-child(4) { animation-delay: 0.2s; }

@keyframes cardFloatIn {
  from { opacity: 0; transform: translateY(30rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.product-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx var(--rice-shadow-strong);
}

.product-image-wrap {
  position: relative;
  width: 100%;
  height: 280rpx;
  overflow: hidden;
  background: var(--rice-warm);
}

/* 商品图片四角麦穗装饰 */

.product-image {
  width: 100%;
  height: 100%;
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.product-card:active .product-image {
  transform: scale(1.06);
}

.product-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 4rpx 14rpx;
  background: linear-gradient(135deg, var(--rice-green), var(--rice-green-deep));
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(61, 90, 30, 0.3);
}

.product-tag.hot-tag {
  background: linear-gradient(135deg, var(--rice-danger), var(--rice-danger-light));
  box-shadow: 0 4rpx 12rpx rgba(212, 118, 94, 0.3);
}

.product-info {
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--rice-text);
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}

.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.product-tag-item {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  background: var(--rice-paper);
  color: var(--rice-text-secondary);
  font-weight: 500;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 6rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid var(--rice-paper);
}

.product-price {
  color: var(--rice-gold);
  font-size: 32rpx;
  font-weight: 700;
}

.product-stock {
  font-size: 20rpx;
  font-weight: 500;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  color: var(--rice-text-secondary);
  background: var(--rice-paper);
}

.product-stock.stock-low {
  color: var(--rice-gold);
  background: rgba(196, 149, 60, 0.1);
}

.product-stock.stock-out {
  color: #fff;
  background: linear-gradient(135deg, var(--rice-danger), var(--rice-danger-light));
}

.product-sales {
  font-size: 20rpx;
  font-weight: 500;
  color: var(--rice-text-light);
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  background: var(--rice-paper);
}

/* ============================================
   分隔装饰
   ============================================ */
.section-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 40rpx;
  gap: 20rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--rice-straw), transparent);
}

.divider-icon {
  width: 42rpx;
  height: 54rpx;
  display: inline-block;
  animation: gentleFloat 3s ease-in-out infinite;
}

/* ============================================
   底部装饰
   ============================================ */
.footer-decoration {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx 30rpx;
  position: relative;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
}

.footer-rice {
  margin-bottom: 16rpx;
}

.footer-rice {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.footer-rice-text {
  width: 42rpx;
  height: 54rpx;
  display: inline-block;
  animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.footer-wheat-left,
.footer-wheat-right {
  width: 36rpx;
  height: 48rpx;
  display: inline-block;
  animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.25;
}

.footer-wheat-right {
  animation-delay: 0.6s;
}

.footer-wheat-sep {
  font-size: 14rpx;
  color: var(--rice-straw);
}

.footer-wheat-center {
  font-size: 24rpx;
  color: var(--rice-text-secondary);
  letter-spacing: 3rpx;
  font-weight: 500;
}

.footer-text {
  font-size: 20rpx;
  color: var(--rice-text-light);
  letter-spacing: 4rpx;
}

/* 底部装饰 — 左右下角麦穗，半覆盖渐变背景 */
.footer-wheat {
  position: absolute;
  width: 220rpx;
  height: 400rpx;
  pointer-events: none;
  opacity: 0.7;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

/* ============================================
   动画合集
   ============================================ */
@keyframes gentleFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  30% { transform: translateY(-12rpx) rotate(-2deg); }
  60% { transform: translateY(-6rpx) rotate(2deg); }
  80% { transform: translateY(-10rpx) rotate(-1deg); }
}
