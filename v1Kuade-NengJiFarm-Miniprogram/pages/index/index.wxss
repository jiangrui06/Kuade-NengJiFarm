/* 首页样式 - 稻田时光农场 */

/* ===== 员工核销入口卡片 ===== */
.staff-verify-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FFF8E6, #FFF1D0);
  border-radius: 20rpx;
  border: 2rpx solid #D4A76A;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.2);
}

.staff-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.staff-card-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.15);
}

.staff-card-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.staff-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #8B6914;
}

.staff-card-desc {
  font-size: 22rpx;
  color: #B8973E;
}

.staff-card-arrow {
  font-size: 40rpx;
  color: #D4A76A;
  font-weight: 300;
}

/* 搜索框样式 */
.search-container {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  gap: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  background-color: #f8f8f8;
  border: none;
  outline: none;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 32rpx;
  color: #333;
}

.search-input::placeholder {
  color: #999;
  font-size: 24rpx;
}

.search-btn {
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  transition: all 0.3s ease;
}

.search-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.2);
}

/* 视频播放器样式 */
.video-section {
  margin: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
}

.video-container {
  display: flex;
  flex-direction: column;
}

.video-player {
  width: 100%;
  height: 320rpx;
  background-color: #000;
}

.video-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.video-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.video-description {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 轮播图样式 */
.swiper-container {
  padding: 20rpx;
}

.swiper-item {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.12);
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 功能按钮样式 */
.function-buttons {
  display: flex;
  background-color: #fff;
  padding: 32rpx 0;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
}

.function-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.function-btn-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 40rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.3);
  transition: all 0.3s ease;
}

.function-btn:active .function-btn-icon {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.2);
}

.function-btn-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  font-weight: 500;
}

/* 标题样式 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  margin-top: 16rpx;
  position: relative;
}

/* 移除全局 ::before 伪元素的影响 */
.section-title::before {
  display: none;
}

.section-title text:first-child {
  position: relative;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  padding-left: 24rpx;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  height: 36rpx;
  line-height: 36rpx;
}

/* 标题左侧装饰条 - 渐变效果 */
.section-title text:first-child::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

/* 查看更多样式 */
.more {
  font-size: 26rpx;
  color: #999;
  display: flex;
  align-items: center;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #FAF6F0 0%, #F5F0E6 100%);
  border-radius: 28rpx;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.1);
  font-weight: 500;
}

.more:active {
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
}

.more::after {
  content: '›';
  margin-left: 6rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: transform 0.3s ease;
}

.more:active::after {
  transform: translateX(4rpx);
}

/* 项目列表样式 */
.project-list-small {
  margin: 0 24rpx 32rpx;
  display: flex;
  gap: 24rpx;
}

.project-item-small {
  width: calc(50% - 12rpx);
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(212, 167, 106, 0.15);
  transition: all 0.3s ease;
  position: relative;
  display: flex;
  flex-direction: column;
}

.project-item-small:active {
  transform: translateY(-8rpx);
  box-shadow: 0 12rpx 32rpx rgba(212, 167, 106, 0.2);
}

.project-image-small {
  width: 100%;
  height: 320rpx;
  object-fit: cover;
  background-color: #FAF6F0;
  border-bottom: 2rpx solid #FAF6F0;
  transition: transform 0.3s ease;
}

.project-item-small:active .project-image-small {
  transform: scale(1.02);
}

.project-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  z-index: 10;
}

.project-info-small {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex: 1;
  justify-content: space-between;
}

.project-title-small {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.project-description-small {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  flex: 1;
}

.project-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #FAF6F0;
}

.project-price-small {
  color: #D4A76A;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: baseline;
}

.project-price-unit {
  font-size: 20rpx;
  color: #999;
  margin-left: 6rpx;
  font-weight: 500;
}

.project-button {
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
}

.project-button:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.2);
}

/* 商品列表样式 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.goods-item {
  width: 48%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.08);
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.goods-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(212, 167, 106, 0.16);
}

.goods-image {
  width: 100%;
  height: 320rpx;
  object-fit: cover;
  background-color: #FAF6F0;
  transition: transform 0.3s ease;
}

.goods-item:active .goods-image {
  transform: scale(1.02);
}

.goods-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
}

.goods-name {
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: #333;
  line-height: 1.4;
  font-weight: 600;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.tag {
  font-size: 18rpx;
  padding: 3rpx 10rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #FAF6F0 0%, #F5F0E6 100%);
  color: #D4A76A;
  font-weight: 500;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
}

.goods-price {
  color: #D4A76A;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: baseline;
}

.goods-original-price {
  color: #999;
  font-size: 22rpx;
  text-decoration: line-through;
  margin-left: 6rpx;
}

.goods-sales {
  font-size: 20rpx;
  font-weight: 500;
  color: #B8A98E;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

/* 库存显示样式 */
.goods-stock {
  font-size: 20rpx;
  font-weight: 500;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

/* 库存充足 */
.goods-stock {
  color: #666;
}

/* 库存紧张（少于10份） */
.goods-stock.stock-low {
  color: #D4A76A;
}

/* 库存为0 */
.goods-stock.stock-out {
  color: #FF4444;
}

/* 热销标签 */
.goods-hot-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF4444 100%);
  color: #fff;
  flex-shrink: 0;
}

/* 添加到购物车按钮 */
.add-cart-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4A76A 0%, #C99A5A 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(212, 167, 106, 0.4);
  transition: all 0.3s ease;
  z-index: 10;
}

.add-cart-btn:active:not(.disabled) {
  transform: scale(0.9);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.3);
}

/* 售罄状态 */
.add-cart-btn.disabled {
  background: linear-gradient(135deg, #D9D9D9 0%, #BFBFBF 100%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  font-size: 22rpx;
  cursor: not-allowed;
}

.goods-item {
  position: relative;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .swiper-item {
    height: 280rpx;
  }
  
  .project-image-small,
  .goods-image {
    height: 280rpx;
  }
  
  .section-title text:first-child {
    font-size: 32rpx;
  }
  
  .project-title-small {
    font-size: 28rpx;
  }
  
  .project-info-small {
    padding: 20rpx;
  }
  
  .goods-info {
    padding: 16rpx;
  }
}
