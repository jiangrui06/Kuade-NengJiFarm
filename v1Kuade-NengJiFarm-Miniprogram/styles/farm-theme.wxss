/* ============================================
   稻田农场 · 全局主题装饰层
   所有页面共享的背景装饰和动画
   ============================================ */

/* ===== 太阳 ===== */
.bg-sun {
  position: fixed;
  top: 50rpx;
  right: 50rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, #FFF8E1 0%, #FFE082 15%, #FFD54F 30%, rgba(255, 200, 50, 0.6) 50%, transparent 70%),
    radial-gradient(circle at 50% 50%, rgba(255, 220, 100, 0.2) 0%, rgba(255, 200, 80, 0.08) 50%, transparent 70%);
  pointer-events: none;
  z-index: 0;
  animation: sunPulse 5s ease-in-out infinite;
}
.bg-sun::after {
  content: '';
  position: absolute;
  top: -40rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, transparent 35%, rgba(255, 220, 100, 0.12) 45%, transparent 55%),
    radial-gradient(circle at 50% 50%, transparent 30%, rgba(255, 200, 80, 0.08) 42%, transparent 58%);
  animation: sunCorona 6s ease-in-out infinite;
}

/* ===== 云朵 ===== */
.bg-cloud {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  animation: cloudDrift 20s linear infinite;
}
.bg-cloud::before {
  content: '';
  position: absolute;
  border-radius: 50%;
  background:
    radial-gradient(ellipse 100% 100% at 50% 50%, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.1) 60%, transparent 100%);
}
.bg-cloud-1 { width: 320rpx; height: 80rpx; top: 70rpx; left: -360rpx; animation-duration: 32s; }
.bg-cloud-1::before { width: 260rpx; height: 90rpx; top: -30rpx; left: 20rpx; background: radial-gradient(ellipse 100% 100% at 30% 50%, rgba(255, 255, 255, 0.2) 0%, transparent 60%), radial-gradient(ellipse 100% 100% at 70% 50%, rgba(255, 255, 255, 0.15) 0%, transparent 60%); }
.bg-cloud-1::after { content: ''; position: absolute; width: 180rpx; height: 60rpx; top: -20rpx; left: 60rpx; border-radius: 50%; background: radial-gradient(ellipse 100% 100% at 50% 50%, rgba(255, 255, 255, 0.12) 0%, transparent 70%); }
.bg-cloud-2 { width: 240rpx; height: 55rpx; top: 140rpx; left: -280rpx; animation-duration: 26s; animation-delay: 5s; }
.bg-cloud-2::before { width: 200rpx; height: 60rpx; top: -20rpx; left: 10rpx; }
.bg-cloud-3 { width: 180rpx; height: 40rpx; top: 40rpx; left: -220rpx; animation-duration: 20s; animation-delay: 11s; }
.bg-cloud-3::before { width: 150rpx; height: 45rpx; top: -15rpx; left: 5rpx; }

/* ===== 飞鸟 ===== */
.bg-bird {
  position: fixed; width: 44rpx; height: 18rpx; top: 160rpx; left: -80rpx; pointer-events: none; z-index: 0;
  animation: birdFly 14s ease-in-out infinite;
}
.bg-bird::before, .bg-bird::after { content: ''; position: absolute; width: 18rpx; height: 8rpx; background: rgba(80, 60, 40, 0.15); border-radius: 60% 40% 50% 50%; animation: wingFlap 0.3s ease-in-out infinite; }
.bg-bird::before { left: 0; transform: rotate(-18deg); transform-origin: right center; }
.bg-bird::after { right: 0; transform: rotate(18deg); transform-origin: left center; }
.bg-bird-2 { top: 210rpx; animation-duration: 18s; animation-delay: 6s; transform: scale(0.65); }
.bg-bird-3 { top: 130rpx; animation-duration: 22s; animation-delay: 13s; transform: scale(0.5); }

/* ===== 蝴蝶 ===== */
.bg-butterfly {
  position: fixed; width: 24rpx; height: 16rpx; top: 260rpx; left: -40rpx; pointer-events: none; z-index: 0;
  animation: butterflyFly 25s ease-in-out infinite;
}
.bg-butterfly::before, .bg-butterfly::after { content: ''; position: absolute; width: 16rpx; height: 10rpx; border-radius: 50% 50% 0 50%; background: linear-gradient(135deg, #E8A87C 0%, #D4866B 40%, #C4705A 100%); opacity: 0.55; animation: wingFlapButterfly 0.15s ease-in-out infinite; }
.bg-butterfly::before { left: 0; transform-origin: right center; }
.bg-butterfly::after { right: 0; transform-origin: left center; border-radius: 50% 50% 50% 0; }
.bg-butterfly-2 { top: 320rpx; animation-duration: 30s; animation-delay: 10s; transform: scale(0.7); }

/* ===== 漂浮谷粒 ===== */
.bg-float-grain { position: fixed; border-radius: 50%; pointer-events: none; z-index: 0; will-change: transform, opacity; animation: grainFloat 7s ease-in-out infinite; }
.bg-float-grain::after { content: ''; position: absolute; top: -2rpx; left: -2rpx; width: calc(100% + 4rpx); height: calc(100% + 4rpx); border-radius: 50%; background: radial-gradient(circle at 50% 50%, rgba(255, 240, 180, 0.3) 0%, transparent 70%); animation: grainGlow 2s ease-in-out infinite alternate; }
.bg-grain-lg { width: 12rpx; height: 18rpx; background: linear-gradient(180deg, rgba(232, 200, 122, 0.6), rgba(196, 149, 60, 0.45)); }
.bg-grain-md { width: 8rpx; height: 14rpx; background: linear-gradient(180deg, rgba(232, 200, 122, 0.5), rgba(196, 149, 60, 0.35)); }
.bg-grain-sm { width: 5rpx; height: 10rpx; background: rgba(196, 149, 60, 0.35); }

/* ===== 萤火虫 ===== */
.bg-firefly { position: fixed; width: 6rpx; height: 6rpx; border-radius: 50%; pointer-events: none; z-index: 0; will-change: transform, opacity; background: radial-gradient(circle at 50% 50%, rgba(255, 255, 200, 0.8) 0%, rgba(255, 230, 150, 0.25) 40%, transparent 70%); animation: fireflyFloat 8s ease-in-out infinite; }
.bg-firefly::after { content: ''; position: absolute; top: -8rpx; left: -8rpx; width: 22rpx; height: 22rpx; border-radius: 50%; background: radial-gradient(circle at 50% 50%, rgba(255, 240, 180, 0.12) 0%, transparent 70%); animation: fireflyGlow 2s ease-in-out infinite alternate; }

/* ===== 花粉 ===== */
.bg-pollen { position: fixed; width: 3rpx; height: 3rpx; border-radius: 50%; background: rgba(255, 220, 120, 0.35); pointer-events: none; z-index: 0; will-change: transform, opacity; animation: pollenDrift 12s ease-in-out infinite; }

/* ===== 光斑闪烁 ===== */
.bg-shimmer { position: fixed; border-radius: 50%; pointer-events: none; z-index: 0; will-change: transform, opacity; animation: shimmerPulse 3s ease-in-out infinite; }
.bg-shimmer::after { content: ''; position: absolute; top: -6rpx; left: -6rpx; width: calc(100% + 12rpx); height: calc(100% + 12rpx); border-radius: 50%; background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.08) 0%, transparent 70%); animation: shimmerRing 2s ease-in-out infinite alternate; }
.shimmer-lg { width: 18rpx; height: 18rpx; background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.45) 0%, rgba(255, 240, 200, 0.2) 40%, transparent 70%); }
.shimmer-md { width: 12rpx; height: 12rpx; background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.35) 0%, transparent 60%); }
.shimmer-sm { width: 8rpx; height: 8rpx; background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.25) 0%, transparent 60%); }

/* ===== 稻田梯田背景 ===== */
