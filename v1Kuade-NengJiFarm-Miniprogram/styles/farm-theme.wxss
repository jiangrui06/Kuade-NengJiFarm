/* ===== 稻穗装饰边框 ===== */
.wheat-border-left, .wheat-border-right {
  position: fixed; top: 0; bottom: 0; width: 28rpx; z-index: 999; pointer-events: none;
  display: flex; flex-direction: column; align-items: center; justify-content: space-around;
  padding: 60rpx 0 120rpx; opacity: 0.12; will-change: transform;
}
.wheat-border-left { left: 0; }
.wheat-border-right { right: 0; }
.wheat-stalk { width: 24rpx; height: 36rpx; display: block; will-change: transform; animation: stalkSway 3s ease-in-out infinite; transform-origin: bottom center; }

/* ===== 稻田背景 (给容器加相对定位) ===== */
.page-container {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

/* ============================================
   动画合集
   ============================================ */
@keyframes sunPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; box-shadow: 0 0 30rpx rgba(255, 200, 50, 0.2); }
  50% { transform: scale(1.12); opacity: 1; box-shadow: 0 0 60rpx rgba(255, 200, 50, 0.4), 0 0 120rpx rgba(255, 200, 50, 0.15); }
}
@keyframes sunCorona { 0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.6; } 50% { transform: scale(1.2) rotate(180deg); opacity: 1; } }
@keyframes cloudDrift { 0% { transform: translateX(0) translateY(0); opacity: 0; } 4% { opacity: 1; } 45% { transform: translateX(50vw) translateY(-10rpx); } 90% { opacity: 1; } 100% { transform: translateX(150vw) translateY(0); opacity: 0; } }
@keyframes birdFly { 0% { transform: translateX(0) translateY(0); opacity: 0; } 3% { opacity: 1; } 30% { transform: translateX(30vw) translateY(-15rpx); } 60% { transform: translateX(65vw) translateY(10rpx); } 85% { opacity: 1; } 100% { transform: translateX(140vw) translateY(-5rpx); opacity: 0; } }
@keyframes wingFlap { 0%, 100% { transform: rotate(-20deg) scaleY(1); } 50% { transform: rotate(-30deg) scaleY(0.5); } }
.bg-bird-2::before, .bg-bird-2::after { animation-duration: 0.25s; }
.bg-bird-3::before, .bg-bird-3::after { animation-duration: 0.35s; }
@keyframes butterflyFly { 0% { transform: translateX(0) translateY(0) rotate(0deg); opacity: 0; } 5% { opacity: 0.8; } 15% { transform: translateX(20vw) translateY(-30rpx) rotate(5deg); } 30% { transform: translateX(35vw) translateY(20rpx) rotate(-8deg); } 50% { transform: translateX(55vw) translateY(-40rpx) rotate(10deg); } 70% { transform: translateX(75vw) translateY(15rpx) rotate(-5deg); } 90% { transform: translateX(90vw) translateY(-20rpx) rotate(3deg); opacity: 0.6; } 100% { transform: translateX(110vw) translateY(0) rotate(0deg); opacity: 0; } }
@keyframes wingFlapButterfly { 0%, 100% { transform: scaleY(1) rotate(-10deg); } 50% { transform: scaleY(0.3) rotate(-20deg); } }
.bg-butterfly-2::before, .bg-butterfly-2::after { animation-duration: 0.18s; }
@keyframes grainFloat { 0% { transform: translateY(0) rotate(0deg) scale(1); opacity: 0; } 8% { opacity: 0.8; } 40% { transform: translateY(-40rpx) rotate(25deg) scale(1.15); opacity: 0.6; } 70% { opacity: 0.4; } 100% { transform: translateY(-90rpx) rotate(55deg) scale(0.4); opacity: 0; } }
@keyframes grainGlow { 0% { opacity: 0.3; } 100% { opacity: 0.8; } }
@keyframes fireflyFloat { 0% { transform: translate(0, 0); opacity: 0; } 15% { opacity: 0.6; } 30% { transform: translate(15rpx, -25rpx); opacity: 0.8; } 50% { transform: translate(-10rpx, -45rpx); opacity: 0.4; } 70% { transform: translate(20rpx, -30rpx); opacity: 0.7; } 85% { opacity: 0.3; } 100% { transform: translate(-5rpx, -60rpx); opacity: 0; } }
@keyframes fireflyGlow { 0% { transform: scale(1); opacity: 0.5; } 100% { transform: scale(2); opacity: 1; } }
@keyframes pollenDrift { 0% { transform: translate(0, 0) scale(1); opacity: 0; } 10% { opacity: 0.6; } 40% { transform: translate(25rpx, -20rpx) scale(1.3); opacity: 0.5; } 70% { transform: translate(-15rpx, -40rpx) scale(0.8); opacity: 0.35; } 100% { transform: translate(30rpx, -70rpx) scale(0.5); opacity: 0; } }
@keyframes shimmerPulse { 0%, 100% { transform: scale(0.3); opacity: 0; } 20% { opacity: 0.7; } 40% { transform: scale(1.4); opacity: 1; } 60% { opacity: 0.5; } 80% { opacity: 0.2; } }
@keyframes shimmerRing { 0% { transform: scale(1); opacity: 0.2; } 100% { transform: scale(1.5); opacity: 0.5; } }
@keyframes terraceGlow { 0%, 100% { opacity: 0.9; } 25% { opacity: 1; } 50% { opacity: 0.7; } 75% { opacity: 0.85; } }
@keyframes stalkSway { 0%, 100% { transform: rotate(-3deg) scaleY(1); } 25% { transform: rotate(-1deg) scaleY(1.02); } 50% { transform: rotate(3deg) scaleY(0.98); } 75% { transform: rotate(1deg) scaleY(1.01); } }
