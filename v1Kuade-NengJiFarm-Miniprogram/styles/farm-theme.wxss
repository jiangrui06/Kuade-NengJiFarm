  pointer-events: none;
  z-index: 0;
  animation: terraceGlow 8s ease-in-out infinite;
}
.page-terrace::after {
  content: '';
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background:
    linear-gradient(155deg, transparent 20%, rgba(255, 220, 150, 0.12) 42%, rgba(255, 210, 140, 0.08) 48%, transparent 65%),
