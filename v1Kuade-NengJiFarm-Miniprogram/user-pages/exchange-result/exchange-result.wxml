<view class="page-wrap">

  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>

  <!-- ===== 四角麦穗装饰 ===== -->
   <image class="wheat-corner-tl" src="/images/615.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/615.png" mode="aspectFit"/>

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/2072.png" mode="aspectFit"/>
    <text class="header-title">兑换结果</text>
    <image class="header-bar-wheat-right" src="/images/2072.png" mode="aspectFit"/>
    <text class="header-subtitle">兑换处理状态</text>
  </view>

  <view class="main-content">
  <!-- 稻田GIF加载动画 -->
  <farm-loading show="{{loading}}" text="加载中..."></farm-loading>

  <block wx:if="{{!loading}}">

    <!-- ====== 状态卡片（含二维码） ====== -->
    <view class="status-card">
      <view class="status-card-inner">

        <!-- 状态信息（已核销时隐藏，由下方已核销区域替代） -->
        <view class="status-card-info" wx:if="{{status !== 'verified'}}">
          <view class="status-card-icon">✓</view>
          <view class="status-card-main">
            <text wx:if="{{status === 'verified'}}">已兑换</text>
            <text wx:elif="{{status === 'cancelled'}}">已取消</text>
            <text wx:else>兑换成功</text>
          </view>
          <view class="status-card-sub" wx:if="{{status === 'verified'}}">感谢使用</view>
          <view class="status-card-sub" wx:else>到店出示此码核销</view>
        </view>

        <!-- 二维码区域（已核销时不展示） -->
        <block wx:if="{{qrcodeUrl && status !== 'verified' && status !== 'cancelled'}}">
          <view class="qrcode-divider"></view>
          <view class="qrcode-area">
            <view class="qrcode-title">核销二维码</view>
            <image class="qrcode-img" src="{{qrcodeUrl}}" mode="aspectFit" />
            <view class="qrcode-tip">出示给工作人员扫描核销</view>
            <view class="qrcode-btn" bindtap="saveQrcode">保存二维码</view>
          </view>
        </block>

        <!-- 已核销 -->
        <block wx:elif="{{status === 'verified'}}">
          <view class="qrcode-divider"></view>
          <view class="verified-area">
            <view class="verified-badge">已核销</view>
            <view class="verified-time" wx:if="{{verifyTime}}">核销时间：{{verifyTime}}</view>
          </view>
        </block>

      </view>
    </view>

    <!-- ====== 商品信息卡片 ====== -->
    <view class="card">
      <view class="card-title">
        <view class="card-title-left">
          <view class="card-title-bar"></view>
          <text class="card-title-text">商品信息</text>
        </view>
      </view>
      <view class="card-body goods-body">
        <image class="goods-img" src="{{goodsImage}}" mode="aspectFill" />
        <view class="goods-info">
          <text class="goods-name">{{goodsName}}</text>
          <text class="goods-points">消耗 <text class="points-num">{{pointsSpent}}</text> 积分</text>
          <text class="goods-time" wx:if="{{exchangeTime}}">兑换时间：{{exchangeTime}}</text>
        </view>
      </view>
    </view>

    <!-- ====== 订单信息卡片 ====== -->
    <view class="card">
      <view class="card-title">
        <view class="card-title-left">
          <view class="card-title-bar"></view>
          <text class="card-title-text">订单信息</text>
        </view>
      </view>
      <view class="card-body rows">
        <view class="row">
          <text class="row-lbl">兑换单号</text>
          <text class="row-val row-val-sm">{{orderNo}}</text>
        </view>
        <view class="row" wx:if="{{pointsRemaining > 0}}">
          <text class="row-lbl">剩余积分</text>
          <text class="row-val row-points">{{pointsRemaining}}</text>
        </view>
        <view class="row" wx:if="{{exchangeTime}}">
          <text class="row-lbl">兑换时间</text>
          <text class="row-val">{{exchangeTime}}</text>
        </view>
        <view class="row" wx:if="{{status === 'verified' && verifyTime}}">
          <text class="row-lbl">核销时间</text>
          <text class="row-val">{{verifyTime}}</text>
        </view>
      </view>
    </view>

  <!-- ====== 底部操作栏 ====== -->
  <view class="bottom-bar" wx:if="{{!loading}}">
    <button wx:if="{{status === 'pending'}}" class="btn btn-ghost" bindtap="cancelExchange">取消兑换</button>
    <button class="btn btn-primary" bindtap="goBack">返回</button>
  </view>
    <!-- ===== 底部装饰 ===== -->
    <view class="footer-decoration">
      <image class="footer-wheat footer-wheat-bl" src="/images/615.png" mode="aspectFit"/>
      <image class="footer-wheat footer-wheat-br" src="/images/615.png" mode="aspectFit"/>
      <view class="footer-rice">
        <image class="footer-rice-text" src="/images/2072.png" mode="aspectFit" />
      </view>
      <view class="footer-wheat-row">
        <image class="footer-wheat-left" src="/images/2072.png" mode="aspectFit"/>
        <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
        <image class="footer-wheat-right" src="/images/2072.png" mode="aspectFit"/>
      </view>
      <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
    </view>

  </block>
  </view>
</view>
