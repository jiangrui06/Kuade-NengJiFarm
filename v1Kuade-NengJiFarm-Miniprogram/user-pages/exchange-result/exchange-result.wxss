@import "../../styles/farm-theme.wxss";

.wheat-stalk { background: var(--wheat-deco) center/contain no-repeat; }

/* 兑换结果 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding-bottom: 40rpx;
  display: flex;
  flex-direction: column;
}

.page-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}



/* ===== 主内容区 ===== */
.main-content {
  padding: 0 0 0px;
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: var(--rice-text-light);
  letter-spacing: 6rpx;
  font-weight: 400;
}

@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  background: linear-gradient(180deg, rgba(245,240,230,0.4) 0%, rgba(124,179,66,0.08) 40%, rgba(124,179,66,0.15) 100%);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.6;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  30% { transform: translateY(-12rpx) rotate(-2deg); }
  60% { transform: translateY(-6rpx) rotate(2deg); }
  80% { transform: translateY(-10rpx) rotate(-1deg); }
}

/* ====== 加载中 ====== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-ring {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--rice-paper);
  border-top-color: var(--rice-gold);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: var(--rice-text-light);
}

/* ====== 状态卡片 ====== */
.status-card {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  padding: 44rpx 32rpx 36rpx;
  position: relative;
  overflow: hidden;
}

.status-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.status-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 48rpx;
  right: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  border-radius: 0 0 4rpx 4rpx;
}

.status-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.status-card-info {
  text-align: center;
}

.status-card-icon {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  font-size: 42rpx;
  font-weight: 700;
  margin: 0 auto 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(196,149,60,0.3);
}

.status-card-main {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--rice-text);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.status-card-sub {
  font-size: 26rpx;
  color: var(--rice-text-light);
  letter-spacing: 1rpx;
}

/* ====== 二维码 ====== */
.qrcode-divider {
  height: 1rpx;
  background: var(--rice-straw);
  margin: 28rpx 0 24rpx;
  width: 100%;
}

.qrcode-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.qrcode-title {
  font-size: 26rpx;
  color: var(--rice-text-light);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.qrcode-img {
  width: 280rpx;
  height: 280rpx;
  border-radius: 20rpx;
  background: #fff;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--rice-shadow);
}

.qrcode-tip {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}

.qrcode-btn {
  font-size: 26rpx;
  color: var(--rice-gold);
  background: var(--rice-paper);
  border-radius: 36rpx;
  padding: 16rpx 48rpx;
  font-weight: 600;
  border: 1rpx solid rgba(196,149,60,0.15);
  transition: all 0.2s;
}

.qrcode-btn:active {
  transform: scale(0.96);
  background: rgba(196,149,60,0.08);
}

/* ====== 已核销 ====== */
.verified-area {
  text-align: center;
  padding: 4rpx 0;
}

.verified-badge {
  font-size: 28rpx;
  color: var(--rice-green);
  font-weight: 600;
  background: rgba(124,179,66,0.1);
  padding: 8rpx 36rpx;
  border-radius: 28rpx;
  display: inline-block;
  letter-spacing: 2rpx;
}

.verified-time {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-top: 16rpx;
}

/* ====== 通用卡片 ====== */
.card {
  margin: 20rpx 24rpx 0;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  animation: fadeInUp 0.5s ease-out both;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--rice-paper);
}

.card-title-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.card-title-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
}

.card-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  letter-spacing: 1rpx;
}

/* ====== 商品信息 ====== */
.goods-body {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 20rpx;
}

.goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: var(--rice-paper);
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--rice-text);
}

.goods-points {
  font-size: 26rpx;
  color: var(--rice-text-light);
}

.points-num {
  color: var(--rice-gold);
  font-weight: 600;
}

.goods-time {
  font-size: 23rpx;
  color: var(--rice-straw);
}

/* ====== 订单信息行 ====== */
.rows { padding: 8rpx 0 4rpx; }

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 32rpx;
  border-bottom: 1rpx solid var(--rice-paper);
}

.row:last-child { border-bottom: none; }

.row-lbl {
  font-size: 26rpx;
  color: var(--rice-text-light);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.row-val {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.row-val-sm {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.row-points {
  color: var(--rice-gold);
  font-weight: 600;
}

/* ====== 底部操作栏 ====== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 16rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 30rpx var(--rice-shadow);
  border-top: 1rpx solid rgba(232,200,122,0.1);
}

.btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  letter-spacing: 1rpx;
  margin: 0;
  padding: 0;
  text-align: center;
  transition: all 0.2s;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.3);
  flex: 1.2;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-ghost {
  background: var(--rice-paper);
  color: var(--rice-text-secondary);
}

.btn-ghost:active {
  background: var(--rice-straw);
}

/* ====== 动画 ====== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
