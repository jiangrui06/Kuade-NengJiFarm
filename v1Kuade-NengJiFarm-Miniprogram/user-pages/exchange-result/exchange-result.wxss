.container {
  background-color: #f2ede6;
  min-height: 100vh;
  padding-bottom: 220rpx;
}

/* ====== 加载中 ====== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-ring {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #ece4d8;
  border-top-color: #c99a5a;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: #c0b8ad;
}

/* ====== 状态 Banner ====== */
.status-banner {
  background: linear-gradient(135deg, #c99a5a 0%, #e0b878 60%, #d4a96a 100%);
  padding: 80rpx 40rpx 44rpx;
  position: relative;
  overflow: hidden;
}

.status-banner::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.status-banner::before {
  content: '';
  position: absolute;
  left: -60rpx;
  bottom: -80rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.status-banner-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.status-info {
  text-align: center;
}

.status-icon {
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  margin: 0 auto 16rpx;
}

.status-main-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.15);
}

.status-sub-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
}

/* 二维码区域（在 Banner 内） */
.qrcode-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.25);
  margin: 28rpx 0 24rpx;
  width: 100%;
}

.qrcode-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.qrcode-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.qrcode-img {
  width: 280rpx;
  height: 280rpx;
  border-radius: 20rpx;
  background: #fff;
  padding: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.verify-code {
  font-size: 28rpx;
  color: #fff;
  letter-spacing: 6rpx;
  margin-top: 16rpx;
  font-weight: 600;
  background: rgba(255,255,255,0.15);
  padding: 6rpx 24rpx;
  border-radius: 8rpx;
}

.qrcode-tip {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}

.qrcode-btn {
  font-size: 28rpx;
  color: #c99a5a;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 56rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.qrcode-btn:active {
  opacity: 0.85;
}

/* 已核销区域 */
.verified-area {
  text-align: center;
  padding: 8rpx 0;
}

.verified-badge {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 40rpx;
  border-radius: 32rpx;
  display: inline-block;
  letter-spacing: 2rpx;
}

.verified-time {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 16rpx;
}

/* ====== 通用卡片 ====== */
.card {
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(160, 130, 90, 0.07);
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f5f1eb;
}

.card-title-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.card-title-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #c99a5a, #e0c080);
}

.card-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

/* ====== 商品信息 ====== */
.goods-body {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  gap: 20rpx;
}

.goods-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #f5f0e8;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.goods-points {
  font-size: 26rpx;
  color: #999;
}

.points-num {
  color: #c99a5a;
  font-weight: 600;
}

.goods-time {
  font-size: 23rpx;
  color: #bbb;
}

/* ====== 订单信息行 ====== */
.rows {
  padding: 8rpx 0 4rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 32rpx;
  border-bottom: 1rpx solid #f8f4ee;
}

.row:last-child {
  border-bottom: none;
}

.row-lbl {
  font-size: 26rpx;
  color: #aaa;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.row-val {
  font-size: 26rpx;
  color: #444;
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.row-val-sm {
  font-size: 24rpx;
  color: #888;
}

.row-points {
  color: #c99a5a;
  font-weight: 600;
}

/* ====== 底部操作栏 ====== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -2rpx 24rpx rgba(160, 130, 90, 0.10);
  backdrop-filter: blur(10px);
}

.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  letter-spacing: 1rpx;
  margin: 0;
  padding: 0;
  text-align: center;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #d4a55a, #c99a5a);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 20rpx rgba(201, 154, 90, 0.35);
  flex: 1.2;
}

.btn-primary:active {
  background: linear-gradient(135deg, #b88a4a, #a87a3a);
  transform: scale(0.97);
}

.btn-ghost {
  background: #f7f3ed;
  color: #888;
  border: none;
}

.btn-ghost:active {
  background: #ece8e0;
}
