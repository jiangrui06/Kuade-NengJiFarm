@import "../../styles/farm-theme.wxss";

/* 支付页面 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--rice-cream) 0%, var(--rice-warm) 30%, var(--rice-cream) 100%);
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

.status-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 32rpx;
  box-shadow: 0 16rpx 56rpx var(--rice-shadow-strong);
  border: 1rpx solid rgba(232,200,122,0.08);
  width: 100%;
  max-width: 560rpx;
  animation: fadeInUp 0.6s ease-out;
  position: relative;
}

.status-container::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.loading-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--rice-green), var(--rice-green-light));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 32rpx rgba(91,140,62,0.3);
}

.failed-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--rice-danger), var(--rice-danger-light));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 32rpx rgba(230,67,64,0.3);
}

.status-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--rice-text);
  margin-bottom: 12rpx;
}

.fail-detail {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-bottom: 16rpx;
  text-align: center;
}

.price {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--rice-gold);
  margin-bottom: 48rpx;
  letter-spacing: 2rpx;
}

.view-order-btn,
.retry-btn,
.complete-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  border: none;
  text-align: center;
  transition: all 0.2s;
}

.view-order-btn::after,
.retry-btn::after,
.complete-btn::after { border: none; }

.view-order-btn:active,
.retry-btn:active,
.complete-btn:active { transform: scale(0.96); }

.view-order-btn,
.complete-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.3);
}

.retry-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.3);
}

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
