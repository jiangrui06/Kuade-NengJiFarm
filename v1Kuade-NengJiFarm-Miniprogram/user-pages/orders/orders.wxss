@import "../../styles/farm-theme.wxss";

.wheat-stalk { background: var(--wheat-deco) center/contain no-repeat; }

/* 我的订单 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding-bottom: 40rpx;
  display: flex;
  flex-direction: column;
}

.page-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background:
    radial-gradient(ellipse 40% 40% at 18% 62%, rgba(91, 140, 62, 0.2) 0%, rgba(91, 140, 62, 0.08) 45%, transparent 100%),
    radial-gradient(ellipse 35% 35% at 35% 58%, rgba(107, 142, 68, 0.18) 0%, rgba(107, 142, 68, 0.06) 45%, transparent 100%),
    radial-gradient(ellipse 50% 45% at 58% 60%, rgba(91, 140, 62, 0.16) 0%, rgba(91, 140, 62, 0.07) 45%, transparent 100%),
    radial-gradient(ellipse 30% 40% at 78% 63%, rgba(120, 160, 75, 0.15) 0%, rgba(120, 160, 75, 0.05) 45%, transparent 100%),
    radial-gradient(ellipse 25% 35% at 92% 66%, rgba(91, 140, 62, 0.14) 0%, transparent 100%),
    radial-gradient(ellipse 120% 30% at 25% 76%, rgba(110, 160, 70, 0.18) 0%, transparent 100%),
    radial-gradient(ellipse 100% 25% at 60% 74%, rgba(120, 170, 80, 0.15) 0%, transparent 100%),
    radial-gradient(ellipse 90% 30% at 85% 77%, rgba(110, 160, 70, 0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 25% at 15% 82%, rgba(100, 150, 60, 0.18) 0%, transparent 100%),
    radial-gradient(ellipse 120% 22% at 45% 80%, rgba(110, 155, 70, 0.15) 0%, transparent 100%),
    radial-gradient(ellipse 100% 30% at 75% 83%, rgba(100, 150, 60, 0.16) 0%, transparent 100%),
    radial-gradient(ellipse 80% 25% at 92% 84%, rgba(110, 155, 70, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 150% 22% at 30% 88%, rgba(196, 149, 60, 0.22) 0%, transparent 100%),
    radial-gradient(ellipse 130% 18% at 65% 90%, rgba(180, 135, 50, 0.18) 0%, transparent 100%),
    radial-gradient(ellipse 100% 25% at 90% 89%, rgba(196, 149, 60, 0.16) 0%, transparent 100%),
    radial-gradient(2px 2px at 12% 78%, rgba(255, 255, 255, 0.25) 0%, transparent 100%),
    radial-gradient(2px 2px at 28% 73%, rgba(255, 255, 255, 0.18) 0%, transparent 100%),
    radial-gradient(2px 2px at 42% 82%, rgba(255, 255, 255, 0.22) 0%, transparent 100%),
    radial-gradient(2px 2px at 55% 76%, rgba(255, 240, 200, 0.2) 0%, transparent 100%),
    radial-gradient(2px 2px at 65% 85%, rgba(255, 255, 255, 0.25) 0%, transparent 100%),
    radial-gradient(2px 2px at 78% 79%, rgba(255, 240, 200, 0.18) 0%, transparent 100%),
    radial-gradient(2px 2px at 88% 84%, rgba(255, 255, 255, 0.2) 0%, transparent 100%),
    radial-gradient(2px 2px at 95% 75%, rgba(255, 255, 255, 0.15) 0%, transparent 100%),
    radial-gradient(ellipse 160% 20% at 50% 100%, rgba(196, 149, 60, 0.12) 0%, transparent 100%);
  pointer-events: none;
  z-index: 0;
  animation: terraceGlow 8s ease-in-out infinite;
}

@keyframes terraceGlow {
  0%, 100% { opacity: 0.9; }
  25% { opacity: 1; }
  50% { opacity: 0.7; }
  75% { opacity: 0.85; }
}

/* ===== 主内容区 ===== */
.main-content {
  padding: 0 0 0px;
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: var(--rice-text-light);
  letter-spacing: 6rpx;
  font-weight: 400;
}

@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  background: linear-gradient(180deg, rgba(245,240,230,0.4) 0%, rgba(124,179,66,0.08) 40%, rgba(124,179,66,0.15) 100%);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.6;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  30% { transform: translateY(-12rpx) rotate(-2deg); }
  60% { transform: translateY(-6rpx) rotate(2deg); }
  80% { transform: translateY(-10rpx) rotate(-1deg); }
}

/* ===== 搜索栏 ===== */
.search-bar {
  position: relative; z-index: 1;
  padding: 16rpx 24rpx 8rpx;
}

.search-box {
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 76rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 24rpx var(--rice-shadow-strong);
  border: 1rpx solid rgba(232,200,122,0.12);
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 100%;
  background: transparent;
  border: none;
  color: var(--rice-text);
}

.search-input::placeholder {
  color: var(--rice-text-light);
  font-size: 24rpx;
}

.search-btn {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 600;
  transition: all 0.2s;
  margin-left: 16rpx;
}

.search-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* ===== 状态标签栏 ===== */
.tab-bar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 998;
  border-bottom: 1rpx solid var(--rice-paper);
}

.tab-list {
  display: flex;
  padding: 0 16rpx;
}

.tab-item {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--rice-text-secondary);
  white-space: nowrap;
  margin-right: 32rpx;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--rice-green);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: linear-gradient(90deg, var(--rice-green), var(--rice-green-light));
  border-radius: 2rpx;
}

/* ===== 订单类型标签栏 ===== */
.type-tab-bar {
  background: var(--rice-cream);
  padding: 8rpx 0;
  position: sticky;
  top: 88rpx;
  z-index: 997;
  border-bottom: 1rpx solid var(--rice-straw);
}

.type-tab-list {
  display: flex;
  padding: 0 16rpx;
}

.type-tab-item {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: var(--rice-text-secondary);
  white-space: nowrap;
  margin-right: 16rpx;
  border-radius: 24rpx;
  background: #fff;
  transition: all 0.3s;
  border: 1rpx solid var(--rice-straw);
}

.type-tab-item.active {
  background: linear-gradient(135deg, var(--rice-green), var(--rice-green-deep));
  color: #fff;
  font-weight: 600;
  border-color: transparent;
}

/* ===== 订单列表 ===== */
.order-list {
  padding: 20rpx 20rpx 24rpx;
}

/* ===== 加载中 ===== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--rice-paper);
  border-top: 4rpx solid var(--rice-gold);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--rice-text-light);
}

/* ===== 订单卡片 ===== */
.order-card {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  overflow: hidden;
  border: 1rpx solid rgba(232,200,122,0.12);
  animation: fadeInUp 0.5s ease-out both;
  position: relative;
}

.order-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.order-header {
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--rice-paper);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.order-type-id {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.order-id-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.table-badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 4rpx;
}

.table-badge-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--rice-gold);
  letter-spacing: 1rpx;
}

.order-id {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.order-status-text {
  margin-left: auto;
  flex-shrink: 0;
}

.status-tag {
  font-size: 24rpx;
  font-weight: 600;
}

.status-pending   { color: var(--rice-gold); }
.status-paid      { color: var(--rice-green); }
.status-shipping  { color: var(--rice-water); }
.status-completed { color: var(--rice-green); }
.status-cancelled { color: var(--rice-text-light); }
.status-refunding { color: var(--rice-danger); }
.status-refunded  { color: var(--rice-text-light); }
.status-verify_pending { color: var(--rice-gold); }
.status-verified       { color: var(--rice-green); }

.order-type {
  display: flex;
  align-items: center;
}

.type-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  background: var(--rice-paper);
  color: var(--rice-text-secondary);
}

.delivery-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.pickup-tag {
  background: rgba(196,149,60,0.1);
  color: var(--rice-gold);
  border: 1rpx solid rgba(196,149,60,0.2);
}

.express-tag {
  background: rgba(91,140,62,0.1);
  color: var(--rice-green);
  border: 1rpx solid rgba(91,140,62,0.25);
}

/* ===== 订单内容 ===== */
.order-content {
  padding: 20rpx 24rpx;
}

.order-items {
  margin-bottom: 20rpx;
}

.order-item-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--rice-paper);
}

.order-item-row:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.item-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: var(--rice-paper);
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: var(--rice-text);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
}

/* ===== 订单底部 ===== */
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--rice-paper);
}

.order-total {
  display: flex;
  flex-direction: column;
}

.order-total text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.total-price {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  margin-top: 4rpx;
}

.points-badge {
  font-size: 22rpx;
  color: var(--rice-green);
  background: rgba(91,140,62,0.1);
  display: inline-block;
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
  margin-top: 6rpx;
  align-self: flex-start;
  font-weight: 500;
}

.list-state-badge {
  font-size: 26rpx;
  font-weight: 700;
  display: inline-block;
  margin-top: 6rpx;
  align-self: flex-start;
}

.state-completed { color: var(--rice-green); }
.state-refunded { color: var(--rice-danger); }

.order-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  border: none;
  min-width: 120rpx;
  text-align: center;
  line-height: 1.5;
  transition: all 0.2s;
}

.action-btn::after { border: none; }

.action-btn:active { transform: scale(0.95); }

.primary-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
}

.secondary-btn {
  background: var(--rice-paper);
  color: var(--rice-text-secondary);
}

.delete-btn {
  background: rgba(212,118,94,0.08);
  color: var(--rice-danger);
}

.danger-btn {
  background: rgba(212,118,94,0.08);
  color: var(--rice-danger);
  border: 1rpx solid rgba(212,118,94,0.2);
}

.cancel-btn {
  background: rgba(212,118,94,0.08);
  color: var(--rice-danger);
}

.pay-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
}

/* ===== 空状态 ===== */
.empty-order {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--rice-text-light);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--rice-gold);
  font-weight: 500;
}

/* ===== 更多提示 ===== */
.more-items-hint {
  padding: 16rpx 0;
  text-align: center;
  background: var(--rice-paper);
  border-radius: 12rpx;
  margin-top: 8rpx;
}

.more-items-hint text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

/* ===== 分页 ===== */
.pagination-bar {
  padding: 24rpx 0 60rpx;
  text-align: center;
}

.pagination-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.pagination-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid var(--rice-straw);
  min-width: 120rpx;
  justify-content: center;
  transition: all 0.2s;
}

.pagination-btn:active { background: var(--rice-paper); }

.pagination-btn.disabled {
  opacity: 0.35;
  background: var(--rice-paper);
  border-color: var(--rice-straw);
}

.pagination-arrow {
  font-size: 32rpx;
  color: var(--rice-gold);
  font-weight: 300;
  line-height: 1;
}

.pagination-btn.disabled .pagination-arrow { color: var(--rice-text-light); }

.pagination-btn-text {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
}

.pagination-btn.disabled .pagination-btn-text { color: var(--rice-text-light); }

.pagination-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 0 8rpx;
}

.pagination-page {
  font-size: 26rpx;
  color: var(--rice-gold);
  font-weight: 600;
}

.pagination-divider {
  font-size: 24rpx;
  color: var(--rice-straw);
}

.pagination-total {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

/* ===== 加载更多 ===== */
.load-more-bar {
  padding: 40rpx 0 80rpx;
  text-align: center;
  min-height: 120rpx;
}

.loading-more-hint,
.no-more-hint,
.pull-hint {
  padding: 16rpx 0;
}

.loading-more-text,
.pull-text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.no-more-text {
  font-size: 24rpx;
  color: var(--rice-straw);
}

/* ===== 退款弹窗 ===== */
.other-reason-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(44,24,16,0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.other-reason-dialog {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 80rpx var(--rice-shadow-heavy);
  animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.other-reason-header {
  padding: 36rpx 30rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--rice-text);
  text-align: center;
}

.other-reason-textarea {
  width: calc(100% - 60rpx);
  min-height: 240rpx;
  max-height: 500rpx;
  margin: 28rpx 30rpx;
  padding: 20rpx;
  background: var(--rice-paper);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--rice-text);
  line-height: 1.6;
  box-sizing: border-box;
}

.other-reason-footer {
  display: flex;
  border-top: 2rpx solid var(--rice-paper);
}

.other-reason-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  font-size: 30rpx;
  background: #fff;
}

.other-reason-btn.cancel-btn {
  color: var(--rice-text-secondary);
  border-right: 2rpx solid var(--rice-paper);
}

.other-reason-btn.confirm-btn {
  color: var(--rice-danger);
  font-weight: 500;
}

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { transform: scale(0.85); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
