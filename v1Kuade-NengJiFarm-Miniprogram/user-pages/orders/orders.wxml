<view class="page-wrap">
  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>
  <view class="bg-shimmer shimmer-lg" style="left:18%;bottom:18%;animation-delay:0s"></view>
  <view class="bg-shimmer shimmer-sm" style="left:50%;bottom:14%;animation-delay:2.8s"></view>
  <view class="bg-shimmer shimmer-md" style="left:82%;bottom:16%;animation-delay:3.6s"></view>

  <!-- ===== 稻穗装饰边框 ===== -->
  <view class="wheat-border-left">
    <image wx:for="{{8}}" wx:for-index="i" wx:key="i" class="wheat-stalk" src="/images/wheat-reference.png" mode="aspectFit" style="animation-delay: {{i * 0.35}}s"/>
  </view>
  <view class="wheat-border-right">
    <image wx:for="{{8}}" wx:for-index="i" wx:key="i" class="wheat-stalk" src="/images/wheat-reference.png" mode="aspectFit" style="animation-delay: {{i * 0.28}}s"/>
  </view>

  <!-- ===== 四角麦穗装饰 ===== -->
  <image class="wheat-corner-tl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-br" src="/images/wheat-reference.png" mode="aspectFit"/>

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-title">我的订单</text>
    <image class="header-bar-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-subtitle">查看所有订单状态</text>
  </view>

  <view class="main-content">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon"></text>
      <input class="search-input" placeholder="搜索订单号或订单类型" value="{{searchKeyword}}" bindinput="onSearchInput" />
      <view class="search-btn" bindtap="searchOrders">搜索</view>
    </view>
  </view>

  <!-- 状态标签栏 -->
  <view class="tab-bar">
    <scroll-view scroll-x enable-flex scroll-into-view="{{scrollToView}}" scroll-with-animation>
      <view class="tab-list">
        <view
          id="tab-{{item.key}}"
          class="tab-item {{activeTab === item.key ? 'active' : ''}}"
          wx:for="{{statusTabs}}"
          wx:key="key"
          bindtap="switchTab"
          data-tab="{{item.key}}"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>


  <!-- 订单类型标签栏 -->
  <view class="type-tab-bar" wx:if="{{!searchKeyword || !searching}}">
    <scroll-view scroll-x enable-flex scroll-with-animation>
      <view class="type-tab-list">
        <view
          class="type-tab-item {{activeTypeTab === item.key ? 'active' : ''}}"
          wx:for="{{typeTabs}}"
          wx:key="key"
          bindtap="switchTypeTab"
          data-type-tab="{{item.key}}"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 订单列表（使用原生页面滚动，支持 pull-down-refresh） -->
  <view class="order-list">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loading">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 订单列表 -->
    <block wx:else>
      <!-- 搜索无结果的情况 -->
      <block wx:if="{{noSearchResult}}">
        <view class="empty-order">
          <view class="empty-icon">
            <text class="icon">🔍</text>
          </view>
          <view class="empty-text">未找到相关订单</view>
          <view class="empty-hint">试试其他关键词吧</view>
        </view>
      </block>

      <!-- 有订单的情况 -->
      <block wx:elif="{{orders.length > 0}}">
        <view class="order-card" wx:for="{{orders}}" wx:key="id">
          <view class="order-header" bindtap="viewOrderDetail" data-order-id="{{item.id}}">
            <view class="order-top">
              <view class="order-type-id">
                <view class="order-type" wx:if="{{item.type}}">
                  <text class="type-tag">{{item.typeText}}</text>
                  <text wx:if="{{item.isPickupOrder}}" class="delivery-tag pickup-tag">自取</text>
                  <text wx:elif="{{item.deliveryMethod === 'express' && item.type === 'goods'}}" class="delivery-tag express-tag">快递</text>
                </view>
                <view class="order-id-wrap">
                  <view class="table-badge" wx:if="{{item.type === 'food' && item.tableNo}}">
                    <text class="table-badge-text">{{item.tableNo}}</text>
                  </view>
                  <view class="order-id">{{item.orderNumber}}</view>
                </view>
              </view>
              <view class="order-status-text" wx:if="{{item.statusText}}">
                <text class="status-tag status-{{item.status}}">{{item.statusText}}</text>
              </view>
            </view>
          </view>
          
          <view class="order-content">
            <view class="order-items" bindtap="viewOrderDetail" data-order-id="{{item.id}}">
              <view class="order-item-row" wx:for="{{item.items}}" wx:for-item="goods" wx:key="index" wx:if="{{index < 2}}">
                <image class="item-image" src="{{goods.image}}" />
                <view class="item-info">
                  <view class="item-name">{{goods.name}}</view>
                  <view class="item-price">￥{{goods.price}} × {{goods.quantity}}</view>
                </view>
              </view>
              <view class="more-items-hint" wx:if="{{item.items.length > 2}}">
                <text>还有 {{item.items.length - 2}} 件商品，点击查看详情</text>
              </view>
            </view>
            
            <view class="order-footer">
              <view class="order-total" bindtap="viewOrderDetail" data-order-id="{{item.id}}">
                <text>共{{item.items.length}}件商品</text>
                <text class="total-price">合计：￥{{item.totalPrice}}</text>
                  <text wx:if="{{item.earnedPoints > 0}}" class="points-badge">+{{item.earnedPoints}}积分</text>
                  <text wx:if="{{item.status === 'completed' || item.status === 'verified'}}" class="list-state-badge state-completed">+¥{{item.totalPrice}}</text>
                  <text wx:elif="{{item.status === 'refunded'}}" class="list-state-badge state-refunded">-¥{{item.totalPrice}}</text>
              </view>

              <view class="order-actions">
                <button
                  wx:if="{{item.status === 'pending' || item.status === 'pending_payment'}}"
                  class="action-btn cancel-btn"
                  catchtap="cancelOrder"
                  data-order-id="{{item.id}}"
                >
                  取消订单
                </button>
                <button
                  wx:if="{{item.status === 'pending' || item.status === 'pending_payment'}}"
                  class="action-btn pay-btn"
                  catchtap="payOrder"
                  data-order-id="{{item.id}}"
                >
                  去支付
                </button>
                <!-- 可申请退款：已付款/配送中/已下单/待核销，且无退款记录 -->
                <button
                  wx:if="{{!item.hasRefund && (item.status === 'paid' || item.status === 'shipping' || item.status === 'ordered' || item.status === 'verify_pending')}}"
                  class="action-btn secondary-btn"
                  catchtap="applyRefund"
                  data-order-id="{{item.id}}"
                >
                  申请退款
                </button>
                <!-- 已取消 -->
                <button
                  wx:if="{{item.status === 'cancelled'}}"
                  class="action-btn secondary-btn"
                  catchtap="viewOrderDetail"
                  data-order-id="{{item.id}}"
                >
                  查看详情
                </button>
                <!-- 已完成等其他状态 -->
                <button
                  wx:if="{{item.status !== 'pending' && item.status !== 'cancelled' && item.status !== 'paid' && item.status !== 'shipping' && item.status !== 'ordered' && item.status !== 'verify_pending'}}"
                  class="action-btn secondary-btn"
                  catchtap="viewOrderDetail"
                  data-order-id="{{item.id}}"
                >
                  查看详情
                </button>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 无订单的情况 -->
      <block wx:else>
        <view class="empty-order" bindtap="goToShop">
          <view class="empty-icon">
            <text class="icon">📋</text>
          </view>
          <view class="empty-text">您当前没有订单呢</view>
          <view class="empty-hint">去逛逛农场美食吧 →</view>
        </view>
      </block>
    </block>

    <!-- 加载更多提示 -->
    <view wx:if="{{orders.length > 0 && !searchKeyword}}" class="load-more-bar">
      <view wx:if="{{loadingMore}}" class="loading-more-hint">
        <text class="loading-more-text">加载中...</text>
      </view>
      <view wx:elif="{{!hasMore}}" class="no-more-hint">
        <text class="no-more-text">没有更多订单了</text>
      </view>
      <view wx:else class="pull-hint">
        <text class="pull-text">上拉加载更多</text>
      </view>
    </view>
  </view>

  <!-- 其他原因输入弹窗 -->
  <view wx:if="{{showOtherReasonInput}}" class="other-reason-overlay" bindtap="onOverlayTap">
    <view class="other-reason-dialog" catchtap="">
      <view class="other-reason-header">请输入退款原因</view>
      <textarea
        class="other-reason-textarea"
        value="{{otherReasonText}}"
        bindinput="onOtherReasonInput"
        placeholder="请详细描述您的退款原因..."
        maxlength="500"
        auto-height
      />
      <view class="other-reason-footer">
        <view class="other-reason-btn cancel-btn" bindtap="cancelOtherReason">取消</view>
        <view class="other-reason-btn confirm-btn" bindtap="confirmOtherReason">确认提交</view>
      </view>
    </view>
  </view>
    <!-- ===== 底部装饰 ===== -->
    <view class="footer-decoration">
      <image class="footer-wheat footer-wheat-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
      <image class="footer-wheat footer-wheat-br" src="/images/wheat-reference.png" mode="aspectFit"/>
      <view class="footer-rice">
        <view class="footer-rice-text"></view>
      </view>
      <view class="footer-wheat-row">
        <image class="footer-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
        <text class="footer-wheat-sep">·</text>
        <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
        <text class="footer-wheat-sep">·</text>
        <image class="footer-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
      </view>
      <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
    </view>
  </view>
</view>
