@import "../../styles/farm-theme.wxss";

/* 认购一亩田 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.container {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: linear-gradient(180deg, var(--rice-cream) 0%, var(--rice-warm) 30%, var(--rice-cream) 100%);
}

/* ===== 轮播图 ===== */
.swiper-container {
  width: 100%;
  height: 320rpx;
  padding: 20rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx var(--rice-shadow);
}

/* ===== 标题 ===== */
.title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--rice-text);
  margin: 0 32rpx 24rpx;
  position: relative;
  padding-left: 24rpx;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
}

.title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--rice-gold) 0%, var(--rice-gold-light) 100%);
  border-radius: 4rpx;
}

/* ===== 项目列表 ===== */
.acre-list {
  padding: 0 24rpx 32rpx;
}

.acre-item {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  display: flex;
  gap: 24rpx;
  transition: all 0.3s;
  position: relative;
  border: 1rpx solid rgba(232,200,122,0.08);
  animation: fadeInUp 0.5s ease-out both;
}

.acre-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.acre-item:active {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 40rpx var(--rice-shadow-strong);
}

/* ===== 项目图片 ===== */
.acre-image {
  width: 220rpx;
  height: 160rpx;
  border-radius: 16rpx;
  object-fit: cover;
  background: var(--rice-paper);
  flex-shrink: 0;
}

/* ===== 标签 ===== */
.acre-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(196,149,60,0.3);
  z-index: 10;
}

/* ===== 项目信息 ===== */
.acre-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16rpx;
}

.acre-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.acre-desc {
  font-size: 24rpx;
  color: var(--rice-text-secondary);
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  flex: 1;
}

.price-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--rice-paper);
}

.acre-price {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--rice-gold);
}

.buy-button {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 14rpx 32rpx;
  font-size: 24rpx;
  font-weight: 700;
  height: 64rpx;
  line-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(196,149,60,0.3);
  transition: all 0.2s;
}

.buy-button::after { border: none; }

.buy-button:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.sold-out-text {
  background: var(--rice-paper);
  color: var(--rice-text-light);
  border: none;
  border-radius: 20rpx;
  padding: 14rpx 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  height: 64rpx;
  line-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
