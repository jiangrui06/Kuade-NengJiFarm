<farm-loading show="{{loading}}" text="加载中..."></farm-loading>
<block wx:if="{{!loading}}">
<view class="page-wrap">
  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>

  <!-- ===== 四角麦穗装饰 ===== -->
   <image class="wheat-corner-tl" src="/images/615.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/615.png" mode="aspectFit"/>

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/2072.png" mode="aspectFit"/>
    <text class="header-title">收货地址</text>
    <image class="header-bar-wheat-right" src="/images/2072.png" mode="aspectFit"/>
    <text class="header-subtitle">管理您的收货地址</text>
  </view>

  <view class="main-content">

  <!-- 地址列表 -->
  <view class="address-list">
    <view wx:for="{{addressList}}" wx:key="id" class="address-item" bindtap="selectAddress" data-id="{{item.id}}">
      <view class="address-info">
        <view class="address-header">
          <text class="address-name">{{item.name}}</text>
          <text class="address-phone">{{item.phone}}</text>
          <view wx:if="{{item.isDefault}}" class="default-tag">默认</view>
        </view>
        <view class="address-detail">{{item.address}} {{item.detail}}</view>
      </view>
      <view class="address-actions">
        <image class="action-icon" src="https://img.icons8.com/ios-glyphs/32/999999/edit.png" catchtap="editAddress" data-id="{{item.id}}" />
        <image class="action-icon" src="https://img.icons8.com/ios-glyphs/32/999999/trash.png" catchtap="deleteAddress" data-id="{{item.id}}" />
      </view>
    </view>

    <!-- 空地址提示 -->
    <view wx:if="{{addressList.length === 0}}" class="empty-address">
      <view class="empty-icon">📍</view>
      <text class="empty-text">暂无收货地址</text>
      <view class="add-first-btn" bindtap="addAddress">
        <text class="add-first-btn-text">添加收货地址</text>
      </view>
    </view>
  </view>

  <!-- 添加地址按钮 -->
  <view wx:if="{{addressList.length > 0}}" class="add-btn-bar" bindtap="addAddress">
    <text class="add-icon">+</text>
    <text class="add-address-text">添加收货地址</text>
  </view>

  <!-- ===== 底部装饰 ===== -->
  <view class="footer-decoration">
    <image class="footer-wheat footer-wheat-bl" src="/images/615.png" mode="aspectFit"/>
    <image class="footer-wheat footer-wheat-br" src="/images/615.png" mode="aspectFit"/>
    <view class="footer-rice">
      <image class="footer-rice-text" src="/images/2072.png" mode="aspectFit" />
    </view>
    <view class="footer-wheat-row">
      <image class="footer-wheat-left" src="/images/2072.png" mode="aspectFit"/>
      <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
      <image class="footer-wheat-right" src="/images/2072.png" mode="aspectFit"/>
    </view>
    <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
  </view>
</view>
</view>
</block>
