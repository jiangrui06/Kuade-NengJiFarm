@import "../../styles/farm-theme.wxss";

/* 收货地址 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: -10%;
  right: -10%;
  height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-wrap: wrap; justify-content: center; align-items: center;
  gap: 12rpx; padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left,
.header-bar-wheat-right {
  width: 48rpx;
  height: 64rpx;
  display: inline-block;
  animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.5;
}

.header-bar-wheat-left {
  transform: rotate(-15deg);
}

.header-bar-wheat-right {
  transform: rotate(15deg);
  animation-delay: 0.6s;
}

.header-title {
  font-size: 38rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
  text-shadow: none;
  position: relative;
}

.header-title::after {
  content: '';
  display: block;
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0;
  border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: var(--rice-text-light);
  letter-spacing: 6rpx;
  width: 100%; text-align: center;
  font-weight: 400;
  width: 100%; text-align: center;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative;
  z-index: 10;
  padding: 0 0 0px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 地址列表 ===== */
.address-list {
  padding: 24rpx 0;
  position: relative;
  z-index: 2;
}

/* ===== 地址项 ===== */
.address-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  transition: all 0.3s;
  animation: fadeInUp 0.5s ease-out both;
  position: relative;
  overflow: hidden;
}

.address-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.address-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx var(--rice-shadow-strong);
}

.address-info {
  flex: 1;
  margin-right: 20rpx;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  flex-wrap: wrap;
  gap: 12rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--rice-text);
}

.address-phone {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
}

.default-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.address-detail {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  line-height: 1.6;
  word-break: break-all;
}

/* ===== 地址操作 ===== */
.address-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  flex-shrink: 0;
}

.action-icon {
  width: 40rpx;
  height: 40rpx;
  transition: all 0.2s;
  padding: 6rpx;
  border-radius: 8rpx;
}

.action-icon:active {
  background: var(--rice-paper);
  transform: scale(1.1);
}

/* ===== 空地址提示 ===== */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  position: relative;
}

.empty-address::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: var(--rice-text-light);
  margin-bottom: 32rpx;
}

.add-first-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-radius: 40rpx;
  padding: 18rpx 56rpx;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.25);
  transition: all 0.2s;
}

.add-first-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.add-first-btn-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== 添加地址按钮 ===== */
.add-btn-bar {
  margin: 20rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.25);
  border-radius: 48rpx;
  transition: all 0.2s;
}

.add-btn-bar:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
  margin-right: 12rpx;
}

.add-address-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== 选择的地址信息 ===== */
.chosen-address {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  margin: 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  padding: 28rpx;
  border-left: 6rpx solid var(--rice-gold);
  position: relative;
}

.chosen-address::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.chosen-address-header {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chosen-address-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--rice-text);
}

.chosen-address-badge {
  font-size: 20rpx;
  color: var(--rice-gold);
  background: rgba(196,149,60,0.1);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.chosen-address-info { padding-top: 8rpx; }

.chosen-address-header-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.chosen-address-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--rice-text);
  margin-right: 16rpx;
}

.chosen-address-phone {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
}

.chosen-address-detail {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  line-height: 1.6;
  word-break: break-all;
  padding-left: 16rpx;
  border-left: 2rpx solid var(--rice-paper);
}

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx 30rpx;
  position: relative;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  min-height: 160rpx;
  width: 100%;
}

.footer-rice {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.footer-rice-text {
  width: 42rpx;
  height: 54rpx;
  display: inline-block;
  animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.footer-wheat-left,
.footer-wheat-right {
  width: 36rpx;
  height: 48rpx;
  display: inline-block;
  animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.45;
}

.footer-wheat-right {
  animation-delay: 0.6s;
}


.footer-wheat-center {
  font-size: 24rpx;
  color: var(--rice-text-secondary);
  letter-spacing: 3rpx;
  font-weight: 500;
}

.footer-text {
  font-size: 20rpx;
  color: var(--rice-text-light);
  letter-spacing: 4rpx;
}

.footer-wheat {
  position: absolute;
  width: 220rpx;
  height: 400rpx;
  pointer-events: none;
  opacity: 0.9;
}

.footer-wheat-bl { bottom: -70rpx; left: -30rpx; transform: scaleX(-1) rotate(-20deg); }
.footer-wheat-br { bottom: -70rpx; right: -30rpx; transform: rotate(-20deg); }

/* ===== 麦穗摇摆动画 ===== */
@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  30% { transform: translateY(-12rpx) rotate(-2deg); }
  60% { transform: translateY(-6rpx) rotate(2deg); }
  80% { transform: translateY(-10rpx) rotate(-1deg); }
}
