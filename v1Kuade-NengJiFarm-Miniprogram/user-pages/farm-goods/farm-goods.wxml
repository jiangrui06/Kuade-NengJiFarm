<view class="page-wrap">

  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>
  <view class="bg-shimmer shimmer-lg" style="left:18%;bottom:18%;animation-delay:0s"></view>
  <view class="bg-shimmer shimmer-sm" style="left:50%;bottom:14%;animation-delay:2.8s"></view>
  <view class="bg-shimmer shimmer-md" style="left:82%;bottom:16%;animation-delay:3.6s"></view>

  <!-- ===== 稻穗装饰边框 ===== -->
  <view class="wheat-border-left">
    <image wx:for="{{8}}" wx:for-index="i" wx:key="i" class="wheat-stalk" src="/images/wheat-reference.png" mode="aspectFit" style="animation-delay: {{i * 0.35}}s"/>
  </view>
  <view class="wheat-border-right">
    <image wx:for="{{8}}" wx:for-index="i" wx:key="i" class="wheat-stalk" src="/images/wheat-reference.png" mode="aspectFit" style="animation-delay: {{i * 0.28}}s"/>
  </view>

  <!-- ===== 四角麦穗装饰 ===== -->
  <image class="wheat-corner-tl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-br" src="/images/wheat-reference.png" mode="aspectFit"/>

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-title">农场优选</text>
    <image class="header-bar-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-subtitle">有机时令，从田间到餐桌</text>
  </view>

  <!-- ===== 主内容区 ===== -->
  <view class="main-content">

    <!-- ===== 搜索栏 ===== -->
    <view class="section-block anim-section">
      <view class="search-section-fg">
        <view class="search-box-fg">
          <text class="search-icon">🔍</text>
          <input class="search-input-fg" placeholder="搜索商品..." bindinput="onSearchInput" value="{{searchKeyword}}" />
        </view>
        <view class="filter-btn-fg" bindtap="showFilterDrawer">
          <text>☰</text>
        </view>
      </view>
    </view>

    <!-- ===== 分类 ===== -->
    <view class="section-block anim-section">
      <view class="section-title-bar">
        <image class="section-title-wheat" src="/images/wheat-reference.png" mode="aspectFit"/>
        <view class="section-title-bar-inner"></view>
        <text class="section-title-text">商品分类</text>
      </view>
      <view class="category-scroll-wrap">
        <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="category-chip {{currentCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="selectCategory" data-id="{{item.id}}">{{item.name}}</view>
        </scroll-view>
      </view>
    </view>

    <!-- ===== 商品列表 ===== -->
    <view class="section-block anim-section">
      <view class="goods-section">
        <view class="goods-list-fg">
          <view class="goods-card-fg" wx:for="{{currentCategoryGoods}}" wx:key="*this" bindtap="viewGoodsDetail" data-id="{{item.id}}">
            <view class="goods-card-img-wrap">
              <image class="goods-card-img" src="{{item.image}}" mode="aspectFill" lazy-load />
              <view class="goods-card-badge" wx:if="{{item.tags && item.tags.length > 0}}">{{item.tags[0]}}</view>
            </view>
            <view class="goods-card-info">
              <text class="goods-card-name">{{item.name}}</text>
              <view class="goods-card-tags">
                <text class="goods-card-tag" wx:for="{{item.tags}}" wx:key="index" wx:for-item="tag" wx:if="{{index > 0}}">{{tag}}</text>
              </view>
              <view class="goods-card-bottom">
                <text class="goods-card-price">¥{{item.price}}</text>
                <text class="goods-card-stock">余{{item.stock}}份</text>
              </view>
              <view class="goods-card-actions" catchtap="stopPropagation">
                <view class="qty-ctrl">
                  <view class="qty-btn-sm" bindtap="decreaseQuantity" data-id="{{item.id}}">−</view>
                  <input class="qty-input-sm" type="text" pattern="[0-9]*" value="{{cart[item.id] ? cart[item.id].quantity : 0}}" bindtap="stopPropagation" bindblur="onQuantityInput" bindconfirm="onQuantityInput" data-id="{{item.id}}" />
                  <view class="qty-btn-sm qty-add" bindtap="increaseQuantity" data-id="{{item.id}}">+</view>
                </view>
              </view>
            </view>
          </view>
        </view>

        <!-- ===== 加载/结束 ===== -->
        <view class="loading-more" wx:if="{{loadingMore}}">
          <text class="loading-more-text">加载中...</text>
        </view>
        <view class="loading-more" wx:elif="{{allLoaded && currentCategoryGoods.length > 0}}">
          <text class="loading-more-text muted">— 已全部加载 —</text>
        </view>

        <!-- ===== 底部装饰 ===== -->
        <view class="footer-decoration" wx:if="{{currentCategoryGoods.length > 0}}">
          <image class="footer-wheat footer-wheat-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
          <image class="footer-wheat footer-wheat-br" src="/images/wheat-reference.png" mode="aspectFit"/>
        </view>
      </view>
    </view>

  </view>

  <!-- ===== 购物车按钮 ===== -->
  <view class="cart-fab" bindtap="goToCart">
    <text class="cart-fab-icon">🛒</text>
    <view class="cart-fab-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
  </view>

  <!-- ===== 价格筛选抽屉 ===== -->
  <view class="modal-overlay" wx:if="{{showFilterDrawer}}" bindtap="hideFilterDrawer"></view>
  <view class="filter-panel" wx:if="{{showFilterDrawer}}">
    <view class="filter-header">
      <text class="filter-title">价格筛选</text>
      <view class="modal-close" bindtap="hideFilterDrawer">✕</view>
    </view>
    <view class="filter-body">
      <view class="price-range">
        <view class="price-input-group">
          <text class="price-label">最低</text>
          <input class="price-input" type="digit" placeholder="0" value="{{minPrice}}" bindinput="onMinPriceInput" />
        </view>
        <text class="price-sep">—</text>
        <view class="price-input-group">
          <text class="price-label">最高</text>
          <input class="price-input" type="digit" placeholder="9999" value="{{maxPrice}}" bindinput="onMaxPriceInput" />
        </view>
      </view>
      <view class="filter-actions">
        <view class="btn btn-ghost btn-sm" bindtap="resetFilter">重置</view>
        <view class="btn btn-gold btn-sm" bindtap="applyFilter">确定</view>
      </view>
    </view>
  </view>
</view>
