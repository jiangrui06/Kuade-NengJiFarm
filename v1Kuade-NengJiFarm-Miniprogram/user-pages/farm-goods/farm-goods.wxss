/* ============================================
   农场优选 - 稻田风 · 首页同款
   ============================================ */

/* ===== 覆写色彩体系 ===== */
page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: var(--rice-gold);
  --rice-green-light: var(--rice-gold-light);
  --rice-text: #5C3D2E;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

/* ===== 页面容器 ===== */
.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
}

/* ============================================
   背景动画元素
   ============================================ */

.bg-sun {
  position: fixed;
  top: 50rpx;
  right: 50rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, #FFF8E1 0%, #FFE082 15%, #FFD54F 30%, rgba(255, 200, 50, 0.6) 50%, transparent 70%),
    radial-gradient(circle at 50% 50%, rgba(255, 220, 100, 0.2) 0%, rgba(255, 200, 80, 0.08) 50%, transparent 70%);
  pointer-events: none;
  z-index: 0;
  animation: sunPulse 5s ease-in-out infinite;
}

.bg-sun::after {
  content: '';
  position: absolute;
  top: -40rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, transparent 35%, rgba(255, 220, 100, 0.12) 45%, transparent 55%),
    radial-gradient(circle at 50% 50%, transparent 30%, rgba(255, 200, 80, 0.08) 42%, transparent 58%);
  animation: sunCorona 6s ease-in-out infinite;
}

.bg-cloud {
  position: fixed;
  pointer-events: none;
  z-index: 0;
  animation: cloudDrift 20s linear infinite;
}
.bg-cloud::before {
  content: '';
  position: absolute;
  border-radius: 50%;
  background:
    radial-gradient(ellipse 100% 100% at 50% 50%, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.1) 60%, transparent 100%);
}
.bg-cloud-1 { width: 320rpx; height: 80rpx; top: 70rpx; left: -360rpx; animation-duration: 32s; }
.bg-cloud-1::before { width: 260rpx; height: 90rpx; top: -30rpx; left: 20rpx; background: radial-gradient(ellipse 100% 100% at 30% 50%, rgba(255, 255, 255, 0.2) 0%, transparent 60%), radial-gradient(ellipse 100% 100% at 70% 50%, rgba(255, 255, 255, 0.15) 0%, transparent 60%); }
.bg-cloud-1::after { content: ''; position: absolute; width: 180rpx; height: 60rpx; top: -20rpx; left: 60rpx; border-radius: 50%; background: radial-gradient(ellipse 100% 100% at 50% 50%, rgba(255, 255, 255, 0.12) 0%, transparent 70%); }
.bg-cloud-2 { width: 240rpx; height: 55rpx; top: 140rpx; left: -280rpx; animation-duration: 26s; animation-delay: 5s; }
.bg-cloud-2::before { width: 200rpx; height: 60rpx; top: -20rpx; left: 10rpx; }
.bg-cloud-3 { width: 180rpx; height: 40rpx; top: 40rpx; left: -220rpx; animation-duration: 20s; animation-delay: 11s; }
.bg-cloud-3::before { width: 150rpx; height: 45rpx; top: -15rpx; left: 5rpx; }

.bg-bird {
  position: fixed; width: 44rpx; height: 18rpx; top: 160rpx; left: -80rpx; pointer-events: none; z-index: 0;
  animation: birdFly 14s ease-in-out infinite;
}
.bg-bird::before, .bg-bird::after { content: ''; position: absolute; width: 18rpx; height: 8rpx; background: rgba(80, 60, 40, 0.15); border-radius: 60% 40% 50% 50%; animation: wingFlap 0.3s ease-in-out infinite; }
.bg-bird::before { left: 0; transform: rotate(-18deg); transform-origin: right center; }
.bg-bird::after { right: 0; transform: rotate(18deg); transform-origin: left center; }
.bg-bird-2 { top: 210rpx; animation-duration: 18s; animation-delay: 6s; transform: scale(0.65); }
.bg-bird-3 { top: 130rpx; animation-duration: 22s; animation-delay: 13s; transform: scale(0.5); }

.bg-butterfly {
  position: fixed; width: 24rpx; height: 16rpx; top: 260rpx; left: -40rpx; pointer-events: none; z-index: 0;
  animation: butterflyFly 25s ease-in-out infinite;
}
.bg-butterfly::before, .bg-butterfly::after { content: ''; position: absolute; width: 16rpx; height: 10rpx; border-radius: 50% 50% 0 50%; background: linear-gradient(135deg, #E8A87C 0%, #D4866B 40%, #C4705A 100%); opacity: 0.55; animation: wingFlapButterfly 0.15s ease-in-out infinite; }
.bg-butterfly::before { left: 0; transform-origin: right center; }
.bg-butterfly::after { right: 0; transform-origin: left center; border-radius: 50% 50% 50% 0; }
.bg-butterfly-2 { top: 320rpx; animation-duration: 30s; animation-delay: 10s; transform: scale(0.7); }

.bg-float-grain { position: fixed; border-radius: 50%; pointer-events: none; z-index: 0; animation: grainFloat 7s ease-in-out infinite; }
.bg-float-grain::after { content: ''; position: absolute; top: -2rpx; left: -2rpx; width: calc(100% + 4rpx); height: calc(100% + 4rpx); border-radius: 50%; background: radial-gradient(circle at 50% 50%, rgba(255, 240, 180, 0.3) 0%, transparent 70%); animation: grainGlow 2s ease-in-out infinite alternate; }
.bg-grain-lg { width: 12rpx; height: 18rpx; background: linear-gradient(180deg, rgba(232, 200, 122, 0.6), rgba(196, 149, 60, 0.45)); }
.bg-grain-md { width: 8rpx; height: 14rpx; background: linear-gradient(180deg, rgba(232, 200, 122, 0.5), rgba(196, 149, 60, 0.35)); }
.bg-grain-sm { width: 5rpx; height: 10rpx; background: rgba(196, 149, 60, 0.35); }

.bg-firefly { position: fixed; width: 6rpx; height: 6rpx; border-radius: 50%; pointer-events: none; z-index: 0; background: radial-gradient(circle at 50% 50%, rgba(255, 255, 200, 0.8) 0%, rgba(255, 230, 150, 0.25) 40%, transparent 70%); animation: fireflyFloat 8s ease-in-out infinite; }
.bg-firefly::after { content: ''; position: absolute; top: -8rpx; left: -8rpx; width: 22rpx; height: 22rpx; border-radius: 50%; background: radial-gradient(circle at 50% 50%, rgba(255, 240, 180, 0.12) 0%, transparent 70%); animation: fireflyGlow 2s ease-in-out infinite alternate; }

.bg-pollen { position: fixed; width: 3rpx; height: 3rpx; border-radius: 50%; background: rgba(255, 220, 120, 0.35); pointer-events: none; z-index: 0; animation: pollenDrift 12s ease-in-out infinite; }


/* ===== 稻田梯田背景 ===== */
.page-wrap::before {
  content: '';
  position: absolute; bottom: 0; left: -10%; right: -10%; height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

.page-wrap::after {
  content: '';
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background:

    linear-gradient(155deg, transparent 20%, rgba(255,220,150,0.1) 42%, transparent 65%);
  pointer-events: none; z-index: 0;
}
/* ===== 顶部标题栏 ===== */
.header-bar {
  text-align: center; padding: 40rpx 20rpx 8rpx; position: relative;
  display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 16rpx;
}
.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.5;
}
.header-bar-wheat-right { animation-delay: 0.6s; }
.header-title { font-size: 48rpx; font-weight: 800; color: var(--rice-text); letter-spacing: 6rpx; display: inline-block; text-shadow: 0 2rpx 8rpx rgba(196, 149, 60, 0.15); }
.header-subtitle { font-size: 22rpx; color: var(--rice-text-light); letter-spacing: 4rpx; display: block; margin-top: 8rpx; width: 100%; text-align: center; }

/* ===== 主内容区 ===== */
.main-content { padding: 0 0 100rpx; position: relative; z-index: 10; flex: 1; display: flex; flex-direction: column; }
.section-block { margin-top: 24rpx; }

.anim-section { animation: sectionFadeIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
.section-block:nth-child(1) { animation-delay: 0.05s; }
.section-block:nth-child(2) { animation-delay: 0.15s; }
.section-block:nth-child(3) { animation-delay: 0.25s; }
.section-block:nth-child(4) { animation-delay: 0.35s; }

/* ===== 区块标题栏 ===== */
.section-title-bar {
  display: flex; align-items: center; margin-bottom: 20rpx; padding: 0 4rpx; gap: 10rpx;
}
.section-title-wheat {
  width: 36rpx; height: 54rpx;
  display: inline-block; animation: wheatBounce 3s ease-in-out infinite; opacity: 0.5;
}
.section-title-bar-inner { width: 6rpx; height: 28rpx; border-radius: 3rpx; background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light)); margin-right: 4rpx; flex-shrink: 0; }
.section-title-text { font-size: 30rpx; font-weight: 700; color: var(--rice-text); letter-spacing: 2rpx; flex: 1; }

/* ===== 搜索栏 ===== */
.search-section-fg {
  display: flex; align-items: center; gap: 16rpx; position: relative; z-index: 10;
}
.search-box-fg {
  flex: 1; display: flex; align-items: center; height: 76rpx; padding: 0 24rpx;
  background: linear-gradient(135deg, #FAF5EB, #FDF5E6);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 24rpx rgba(92, 61, 46, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  border: 1rpx solid rgba(230, 184, 119, 0.25);
}
.search-icon { font-size: 28rpx; margin-right: 16rpx; }
.search-input-fg { flex: 1; font-size: 26rpx; height: 100%; background: transparent; border: none; color: var(--rice-text); }
.search-input-fg::placeholder { color: var(--rice-text-light); font-size: 24rpx; }
.filter-btn-fg {
  width: 76rpx; height: 76rpx;
  background: linear-gradient(135deg, #FAF5EB, #FDF5E6);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: var(--rice-text);
  box-shadow: 0 4rpx 24rpx rgba(92, 61, 46, 0.08);
  border: 1rpx solid rgba(230, 184, 119, 0.25);
}
.filter-btn-fg:active { transform: scale(0.9); }

/* ===== 分类 ===== */
.category-scroll-wrap { margin-top: -15rpx; padding-bottom: 20rpx; }
.category-scroll { display: flex; white-space: nowrap; padding: 8rpx 0; }
.category-chip {
  display: inline-flex; padding: 14rpx 32rpx; margin-right: 16rpx; font-size: 24rpx;
  color: var(--rice-text-secondary); background: linear-gradient(135deg, #FEFCF7, #FEF8EE);
  border-radius: 36rpx; transition: all 0.3s; font-weight: 500;
  border: 1rpx solid rgba(232,200,122,0.12);
  box-shadow: 0 4rpx 12rpx var(--rice-shadow);
}
.category-chip.active {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff; font-weight: 600;
  box-shadow: 0 6rpx 24rpx rgba(196, 149, 60, 0.35);
  border-color: transparent;
}

/* ===== 商品列表 ===== */
.goods-section { margin-top: 20rpx; }
.goods-list-fg { display: flex; flex-direction: column; gap: 20rpx; }
.goods-card-fg {
  display: flex;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx; overflow: hidden;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  transition: all 0.3s;
  border: 1rpx solid rgba(232, 200, 122, 0.12);
  position: relative;
}
.goods-card-fg::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}
.goods-card-fg:active { transform: translateY(-4rpx); box-shadow: 0 12rpx 40rpx var(--rice-shadow-strong); }
.goods-card-img-wrap { position: relative; width: 220rpx; height: 220rpx; flex-shrink: 0; }
.goods-card-img { width: 100%; height: 100%; }
.goods-card-badge {
  position: absolute; top: 12rpx; left: 12rpx; padding: 4rpx 14rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff; font-size: 18rpx; font-weight: 600; border-radius: 20rpx;
}
.goods-card-info { flex: 1; padding: 20rpx; display: flex; flex-direction: column; gap: 6rpx; }
.goods-card-name { font-size: 28rpx; font-weight: 600; color: var(--rice-text); line-height: 1.3; }
.goods-card-tags { display: flex; gap: 6rpx; flex-wrap: wrap; }
.goods-card-tag { font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 4rpx; background: var(--rice-paper); color: var(--rice-text-secondary); }
.goods-card-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: auto; }
.goods-card-price { font-size: 32rpx; font-weight: 700; color: var(--rice-gold); }
.goods-card-stock { font-size: 20rpx; color: var(--rice-text-light); }
.goods-card-actions { margin-top: 8rpx; }
.qty-ctrl { display: flex; align-items: center; justify-content: flex-end; gap: 8rpx; }
.qty-btn-sm { width: 52rpx; height: 52rpx; border-radius: 50%; background: var(--rice-paper); display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: var(--rice-gold); font-weight: 600; transition: all 0.2s; }
.qty-btn-sm:active { background: var(--rice-gold); color: #fff; }
.qty-add { background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light)); color: #fff; }
.qty-add:active { opacity: 0.9; }
.qty-input-sm { width: 60rpx; height: 48rpx; text-align: center; font-size: 24rpx; font-weight: 600; color: var(--rice-text); background: var(--rice-paper); border-radius: 8rpx; border: 1rpx solid var(--rice-straw); }

/* ===== 加载/结束 ===== */
.loading-more { display: flex; justify-content: center; padding: 24rpx 0 48rpx; }
.loading-more-text { font-size: 24rpx; color: var(--rice-text-light); }
.loading-more-text.muted { color: var(--rice-text-light); opacity: 0.5; }

/* ===== 购物车FAB ===== */
.cart-fab {
  position: fixed; bottom: calc(160rpx + env(safe-area-inset-bottom)); left: 32rpx;
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(196, 149, 60, 0.4);
  z-index: 999;
}
.cart-fab:active { transform: scale(0.9); }
.cart-fab-icon { font-size: 44rpx; }
.cart-fab-badge {
  position: absolute; top: -4rpx; right: -4rpx; min-width: 36rpx; height: 36rpx; border-radius: 18rpx;
  background: #fff; color: var(--rice-gold); font-size: 20rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx var(--rice-shadow);
}

/* ===== 筛选面板 ===== */
.filter-panel {
  position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 85%; max-width: 600rpx;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 100%);
  border-radius: 32rpx; padding: 32rpx; z-index: 10000;
  box-shadow: 0 32rpx 80rpx var(--rice-shadow-heavy);
  animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  border: 1rpx solid rgba(232, 200, 122, 0.08);
}
.filter-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.filter-title { font-size: 32rpx; font-weight: 700; color: var(--rice-text); }
.filter-body { display: flex; flex-direction: column; gap: 32rpx; }
.price-range { display: flex; align-items: center; gap: 16rpx; }
.price-input-group { flex: 1; display: flex; align-items: center; padding: 12rpx 16rpx; background: var(--rice-paper); border-radius: 16rpx; gap: 8rpx; }
.price-label { font-size: 22rpx; color: var(--rice-text-light); white-space: nowrap; }
.price-input { flex: 1; font-size: 26rpx; background: transparent; border: none; color: var(--rice-text); }
.price-sep { font-size: 24rpx; color: var(--rice-text-light); }
.filter-actions { display: flex; gap: 16rpx; }
.filter-actions .btn { flex: 1; }

/* ===== 分隔装饰 ===== */
.section-divider { display: flex; align-items: center; justify-content: center; padding: 32rpx 40rpx; gap: 20rpx; }
.divider-line { flex: 1; height: 1rpx; background: linear-gradient(90deg, transparent, var(--rice-straw), transparent); }

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center; position: relative;
  min-height: 200rpx;
  margin-top: auto;
  width: 100%;
}
.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  pointer-events: none; opacity: 0.9;
}
.footer-wheat-bl { bottom: -70rpx; left: -30rpx; transform: scaleX(-1) rotate(-20deg); }
.footer-wheat-br { bottom: -70rpx; right: -30rpx; transform: rotate(-20deg); }

/* ============================================
   动画合集
   ============================================ */
@keyframes sunPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; box-shadow: 0 0 30rpx rgba(255, 200, 50, 0.2); }
  50% { transform: scale(1.12); opacity: 1; box-shadow: 0 0 60rpx rgba(255, 200, 50, 0.4), 0 0 120rpx rgba(255, 200, 50, 0.15); }
}
@keyframes sunCorona { 0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.6; } 50% { transform: scale(1.2) rotate(180deg); opacity: 1; } }
@keyframes cloudDrift { 0% { transform: translateX(0) translateY(0); opacity: 0; } 4% { opacity: 1; } 45% { transform: translateX(50vw) translateY(-10rpx); } 90% { opacity: 1; } 100% { transform: translateX(150vw) translateY(0); opacity: 0; } }
@keyframes birdFly { 0% { transform: translateX(0) translateY(0); opacity: 0; } 3% { opacity: 1; } 30% { transform: translateX(30vw) translateY(-15rpx); } 60% { transform: translateX(65vw) translateY(10rpx); } 85% { opacity: 1; } 100% { transform: translateX(140vw) translateY(-5rpx); opacity: 0; } }
@keyframes wingFlap { 0%, 100% { transform: rotate(-20deg) scaleY(1); } 50% { transform: rotate(-30deg) scaleY(0.5); } }
.bg-bird-2::before, .bg-bird-2::after { animation-duration: 0.25s; }
.bg-bird-3::before, .bg-bird-3::after { animation-duration: 0.35s; }
@keyframes butterflyFly { 0% { transform: translateX(0) translateY(0) rotate(0deg); opacity: 0; } 5% { opacity: 0.8; } 15% { transform: translateX(20vw) translateY(-30rpx) rotate(5deg); } 30% { transform: translateX(35vw) translateY(20rpx) rotate(-8deg); } 50% { transform: translateX(55vw) translateY(-40rpx) rotate(10deg); } 70% { transform: translateX(75vw) translateY(15rpx) rotate(-5deg); } 90% { transform: translateX(90vw) translateY(-20rpx) rotate(3deg); opacity: 0.6; } 100% { transform: translateX(110vw) translateY(0) rotate(0deg); opacity: 0; } }
@keyframes wingFlapButterfly { 0%, 100% { transform: scaleY(1) rotate(-10deg); } 50% { transform: scaleY(0.3) rotate(-20deg); } }
.bg-butterfly-2::before, .bg-butterfly-2::after { animation-duration: 0.18s; }
@keyframes grainFloat { 0% { transform: translateY(0) rotate(0deg) scale(1); opacity: 0; } 8% { opacity: 0.8; } 40% { transform: translateY(-40rpx) rotate(25deg) scale(1.15); opacity: 0.6; } 70% { opacity: 0.4; } 100% { transform: translateY(-90rpx) rotate(55deg) scale(0.4); opacity: 0; } }
@keyframes grainGlow { 0% { opacity: 0.3; } 100% { opacity: 0.8; } }
@keyframes fireflyFloat { 0% { transform: translate(0, 0); opacity: 0; } 15% { opacity: 0.6; } 30% { transform: translate(15rpx, -25rpx); opacity: 0.8; } 50% { transform: translate(-10rpx, -45rpx); opacity: 0.4; } 70% { transform: translate(20rpx, -30rpx); opacity: 0.7; } 85% { opacity: 0.3; } 100% { transform: translate(-5rpx, -60rpx); opacity: 0; } }
@keyframes fireflyGlow { 0% { transform: scale(1); opacity: 0.5; } 100% { transform: scale(2); opacity: 1; } }
@keyframes pollenDrift { 0% { transform: translate(0, 0) scale(1); opacity: 0; } 10% { opacity: 0.6; } 40% { transform: translate(25rpx, -20rpx) scale(1.3); opacity: 0.5; } 70% { transform: translate(-15rpx, -40rpx) scale(0.8); opacity: 0.35; } 100% { transform: translate(30rpx, -70rpx) scale(0.5); opacity: 0; } }
@keyframes terraceGlow { 0%, 100% { opacity: 0.9; } 25% { opacity: 1; } 50% { opacity: 0.7; } 75% { opacity: 0.85; } }
@keyframes wheatSway { 0%, 100% { transform: rotate(-12deg) scaleX(1); } 25% { transform: rotate(-5deg) scaleX(1.05); } 50% { transform: rotate(12deg) scaleX(0.95); } 75% { transform: rotate(5deg) scaleX(1.02); } }
@keyframes wheatBounce { 0%, 100% { transform: translateY(0) rotate(-5deg); } 30% { transform: translateY(-8rpx) rotate(3deg); } 60% { transform: translateY(-3rpx) rotate(7deg); } 80% { transform: translateY(-6rpx) rotate(-2deg); } }
@keyframes sectionFadeIn { from { opacity: 0; transform: translateY(40rpx) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }
@keyframes gentleFloat { 0%, 100% { transform: translateY(0) rotate(0deg); } 30% { transform: translateY(-12rpx) rotate(-2deg); } 60% { transform: translateY(-6rpx) rotate(2deg); } 80% { transform: translateY(-10rpx) rotate(-1deg); } }
@keyframes scaleIn { from { transform: translate(-50%, -50%) scale(0.85); opacity: 0; } to { transform: translate(-50%, -50%) scale(1); opacity: 1; } }
