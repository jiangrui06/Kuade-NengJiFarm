/* ==============================================
  农场优选页面 - 修复闪白/闪烁 最终版
  直接复制全覆盖！
============================================== */
.container {
  background-color: #FAF6F0; /* 丝苗米白 */
  min-height: 100vh;
  /* 强制硬件加速，防止重绘闪白 */
  transform: translateZ(0);
  backface-visibility: hidden;
  perspective: 1000px;
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
  gap: 16rpx;
  border-bottom: 2rpx solid #f5f5f5;
  justify-content: space-between;
  transform: translateZ(0);
}

.search-input-container {
  flex: 1;
  max-width: 600rpx;
  display: flex;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 64rpx;
  min-width: 0;
  margin-right: 16rpx;
  transform: translateZ(0);
}

.search-input-container:focus-within {
  background-color: #fff;
  border-color: #e64340;
  box-shadow: 0 0 0 4rpx rgba(230, 67, 64, 0.1);
}

.search-icon {
  font-size: 28rpx;
  color: #999;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  background-color: transparent;
  border: none;
  outline: none;
  height: 100%;
  min-width: 0;
  color: #333;
}

.search-input::placeholder {
  color: #999;
  font-size: 24rpx;
}

.search-bar .button-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: transparent;
  border-radius: 50%;
  padding: 0;
  white-space: nowrap;
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  position: relative;
  overflow: hidden;
  transform: translateZ(0);
  -webkit-tap-highlight-color: transparent;
}

.filter-icon {
  font-size: 32rpx;
  color: #333;
}

.category-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  border-radius: 50%;
  padding: 0;
  white-space: nowrap;
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  position: relative;
  transform: translateZ(0);
  -webkit-tap-highlight-color: transparent;
}

.category-btn .category-icon {
  font-size: 32rpx;
  color: #333;
  margin-right: 0;
}

.category-btn .filter-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
}

.category-btn .filter-icon-image {
  width: 40rpx;
  height: 40rpx;
}

/* 分类类型选项 */
.category-tabs {
  display: flex;
  background-color: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  overflow-x: auto;
  white-space: nowrap;
  gap: 20rpx;
  /* 隐藏滚动条 */
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.category-tabs::-webkit-scrollbar {
  display: none;
}

.category-tab {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  transition: all 0.3s;
  flex-shrink: 0;
}

.category-tab.active {
  background-color: #D4A76A;
  color: #fff;
  font-weight: 600;
}

/* ==============================================
  分类弹窗 —— 修复闪白核心区
============================================== */
.category-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 强制硬件加速，彻底不闪 */
  transform: translateZ(0);
  backface-visibility: hidden;
  background-clip: padding-box;
  -webkit-tap-highlight-color: transparent;
}

/* 只用 wx:if 不要用 hidden + opacity，小程序必闪 */
.category-overlay.hidden {
  display: none !important;
}

.category-panel {
  width: 80%;
  max-height: 80%;
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  transform: translateZ(0);
  background: #fff !important;
}

.category-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background-color: #f9f9f9;
}

.category-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.category-list {
  padding: 20rpx;
  max-height: 500rpx;
  overflow-y: auto;
}

.category-list .category-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
  width: 100%;
  margin-bottom: 0;
}

.category-list .category-item:last-child {
  border-bottom: none;
}

.category-item-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #fff;
}

.category-item-name {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}

/* 轮播图 */
.swiper-container {
  width: 100%;
  height: 300rpx;
  margin-bottom: 20rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 区块 */
.section {
  background-color: #fff;
  margin: 20rpx 0;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transform: translateZ(0);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 20rpx;
  color: #999;
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goods-item {
  display: flex;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  min-height: 200rpx;
  width: 100%;
}

.goods-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.goods-image {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.4;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.goods-tags .tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
  background-color: #f0f0f0;
  color: #666;
}

.goods-price-container {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.goods-price {
  color: #D4A76A;
  font-size: 32rpx;
  font-weight: 600;
}

.goods-original-price {
  color: #999;
  font-size: 20rpx;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.goods-stock {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.goods-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #D4A76A;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

.quantity-btn:active {
  opacity: 0.8;
}

.quantity-display {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.quantity-input {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  background-color: transparent;
  border: none;
  outline: none;
  -webkit-appearance: none;
  appearance: none;
}



/* 加载更多 */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

.loading-more:last-child {
  color: #bbb;
  font-size: 22rpx;
}

/* 价格筛选抽屉 */
.filter-drawer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  touch-action: none;
  overflow: hidden;
}

.filter-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  cursor: pointer;
}

.filter-content {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  animation: fadeIn 0.3s ease-out;
  z-index: 10000;
  min-height: 400rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.9);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.filter-close {
  font-size: 40rpx;
  color: #999;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-body {
  padding: 0 16rpx;
}

.price-range {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.price-input-group {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
}

.price-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
}

.price-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  background-color: transparent;
  border: none;
  outline: none;
}

.price-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.price-separator {
  font-size: 32rpx;
  color: #999;
  margin: 0 24rpx;
}

.filter-buttons {
  display: flex;
  gap: 20rpx;
}

.filter-btn-reset,
.filter-btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.filter-btn-reset {
  background-color: #f5f5f5;
  color: #666;
}

.filter-btn-confirm {
  background-color: #D4A76A;
  color: #fff;
}

/* 购物车按钮 */
.cart-button {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #e64340;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(230, 67, 64, 0.4);
  z-index: 9999;
  /* 确保固定定位不受父元素影响 */
  transform: translateZ(0);
  -webkit-tap-highlight-color: transparent;
}

.cart-icon {
  font-size: 48rpx;
  color: #fff;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #fff;
  color: #e64340;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

