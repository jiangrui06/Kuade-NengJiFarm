@import "../../styles/farm-theme.wxss";

/* 积分商城 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%
    );
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-warm: #F5E6D3;
}

.wheat-stalk { background: var(--wheat-deco) center/contain no-repeat; }

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
}

.main-content { position: relative; z-index: 10; flex: 1; display: flex; flex-direction: column; }

.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: -10%; right: -10%; height: 520rpx;
  background:
    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light);
  letter-spacing: 6rpx; font-weight: 400;
}

/* ===== 积分头部 ===== */
.points-header {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  margin: 24rpx 0 0;
  padding: 0;
  border-radius: 24rpx;
  position: relative;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
}

.points-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.points-header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  position: relative;
  z-index: 1;
}

.points-balance {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.points-value {
  font-size: 72rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-gold-light) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 2rpx;
  line-height: 1.1;
}

.points-actions {
  display: flex;
  gap: 16rpx;
}

.points-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s;
  box-shadow: 0 4rpx 16rpx rgba(196,149,60,0.2);
}

.points-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.points-btn-icon {
  font-size: 32rpx;
}

.points-btn-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--rice-text-light);
}

/* ===== 商品列表 ===== */
.goods-list {
  padding: 24rpx 0;
}

.goods-card {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  animation: fadeInUp 0.5s ease-out both;
  position: relative;
}

.goods-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.goods-image {
  width: 100%;
  display: block;
}

.goods-info {
  padding: 24rpx;
}

.goods-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--rice-text);
  margin-bottom: 8rpx;
}

.goods-desc {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-bottom: 16rpx;
}

.goods-spec-tag {
  display: inline-block;
  background: rgba(196,149,60,0.1);
  color: var(--rice-gold);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  margin-right: 6rpx;
}

.goods-desc-text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-points {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.points-icon {
  font-size: 28rpx;
}

.points-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--rice-gold);
}

.points-unit {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.exchange-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  border: none;
  border-radius: 36rpx;
  padding: 14rpx 40rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  box-shadow: 0 4rpx 16rpx rgba(196,149,60,0.25);
  transition: all 0.2s;
}

.exchange-btn::after { border: none; }

.exchange-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.exchange-btn.disabled {
  background: var(--rice-straw);
  color: var(--rice-text-light);
  box-shadow: none;
}

/* ===== 加载更多（来自 orders 页面） ===== */
.load-more-bar {
  padding: 40rpx 0 20rpx;
  text-align: center;
  min-height: 60rpx;
}

.loading-more-hint,
.no-more-hint,
.pull-hint {
  padding: 16rpx 0;
}

.loading-more-text,
.pull-text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.no-more-text {
  font-size: 24rpx;
  color: var(--rice-straw);
}

/* ===== 懒加载 mini 稻田动画（来自 orders 页面） ===== */
.farm-mini-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.mini-wheat-group {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 12rpx;
  height: 48rpx;
}

.mini-wheat {
  width: 4rpx;
  background: linear-gradient(to top, #7CB342 0%, #AED581 50%, #C5E1A5 100%);
  border-radius: 2rpx;
  transform-origin: bottom center;
  position: relative;
}

.mini-wheat::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 14rpx;
  background: linear-gradient(to bottom, #E8C87A 0%, #D4A84B 50%, #B8923A 100%);
  border-radius: 6rpx 6rpx 3rpx 3rpx;
}

.mini-wheat::after {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 10rpx;
  background: radial-gradient(ellipse at center, #F5DEA0 0%, #E8C87A 60%, transparent 100%);
  border-radius: 50%;
  opacity: 0.5;
}

.mini-wheat:nth-child(1) {
  height: 32rpx;
  animation: miniWheatSway 1.8s ease-in-out infinite;
}

.mini-wheat:nth-child(2) {
  height: 44rpx;
  animation: miniWheatSway 1.5s ease-in-out infinite;
  animation-delay: 0.3s;
}

.mini-wheat:nth-child(3) {
  height: 36rpx;
  animation: miniWheatSway 1.6s ease-in-out infinite;
  animation-delay: 0.6s;
}

@keyframes miniWheatSway {
  0%, 100% { transform: rotate(-6deg); }
  50% { transform: rotate(6deg); }
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  border-top: 1rpx solid rgba(232,200,122,0.15);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.7;
}
.footer-wheat-bl { bottom: -0rpx; left: -30rpx; transform: rotate(60deg); }
.footer-wheat-br { bottom: -0rpx; right: -30rpx; transform: rotate(-60deg); }

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}
