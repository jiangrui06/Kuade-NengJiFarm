<view class="page-wrap">

  <!-- ===== 稻田背景动画层（豪华版） ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar header-bar-compact">
    <text class="header-title">农场点餐</text>
    <text class="header-subtitle">时令鲜材，匠心烹制</text>
  </view>

  <!-- ===== 主内容区 ===== -->
  <view class="main-content">

    <!-- ===== 商店信息条 ===== -->
    <view class="shop-header-bar">
      <view class="shop-bar-top">
        <view class="shop-bar-shop">
          <text class="shop-bar-icon">🌾</text>
          <text class="shop-bar-name">稻田时光 · 农场直购</text>
        </view>
        <view class="shop-bar-hours">🕐 00:00-23:59</view>
      </view>
      <view class="shop-bar-bottom">
        <view class="scan-btn" bindtap="testScanCode">📷 扫码点餐</view>
        <view class="table-select" bindtap="selectTable">
          <text class="table-label">🍽️</text>
          <text class="table-num">{{tableNumber ? tableNumber : '选桌台'}}</text>
          <text class="table-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- ===== 点餐主体（分类侧栏 + 商品列表） ===== -->
    <view class="section-block anim-section" style="margin-top: 0;">
      <view class="order-layout">
        <!-- 左侧分类 -->
        <view class="category-sidebar">
          <view class="category-sidebar-inner">
            <view class="category-side-item {{activeCategory === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCategory" data-category="{{item.id}}">
              <text class="category-side-text">{{item.name}}</text>
            </view>
          </view>
        </view>

        <!-- 右侧商品列表 -->
        <scroll-view class="goods-scroll" scroll-y scroll-top="{{goodsScrollTop}}" scroll-into-view="{{scrollIntoViewId}}" scroll-with-animation bounces="false" bindscroll="onScroll">

          <!-- ===== 稻田GIF加载动画 ===== -->
          <farm-loading show="{{loading}}" text="加载中..."></farm-loading>

          <block wx:if="{{!loading}}">
            <block wx:for="{{mergedGoodsList}}" wx:key="uniqueKey">
              <!-- 分类标题 -->
              <view wx:if="{{item.type === 'category'}}" id="category-{{item.id}}" class="goods-category-title">{{item.name}}</view>
              <!-- 商品 -->
              <view wx:else class="order-goods-item">
                <view class="order-goods-left">
                  <image class="order-goods-img" src="{{item.image}}" bindtap="navigateToGoodsDetail" data-id="{{item.id}}" />
                  <text class="order-goods-price">¥{{item.price}}</text>
                </view>
                <view class="order-goods-info">
                  <text class="order-goods-name" bindtap="navigateToGoodsDetail" data-id="{{item.id}}">{{item.name}}</text>
                  <view class="order-goods-sales">
                    <text>已售 {{item.sold}}</text>
                    <text class="order-goods-stock">仅剩 {{item.stock}}份</text>
                  </view>
                  <view class="order-goods-bottom">
                    <view class="order-qty-ctrl">
                      <view class="order-qty-btn" catchtap="decreaseQuantity" data-id="{{item.id}}" wx:if="{{cart[item.id] && cart[item.id].quantity > 0}}">−</view>
                      <input class="order-qty-input" type="text" pattern="[0-9]*" value="{{cart[item.id] ? cart[item.id].quantity : 0}}" wx:if="{{cart[item.id] && cart[item.id].quantity > 0}}" bindtap="stopPropagation" bindblur="onQuantityInput" bindconfirm="onQuantityInput" data-id="{{item.id}}" />
                      <view class="order-add-btn" catchtap="addToCart" data-id="{{item.id}}">+</view>
                    </view>
                  </view>
                </view>
              </view>
            </block>
            <!-- 触底加载哨兵 -->
            <view class="load-more-sentinel" wx:if="{{hasMoreMap[activeCategory]}}"></view>
            <view class="order-bottom-placeholder">
              <text>已经到底啦</text>
            </view>
          </block>
        </scroll-view>
      </view>
    </view>

  </view>

  <!-- ===== 底部结算栏 ===== -->
  <view class="order-bottom-bar">
    <view class="bar-cart-icon" bindtap="viewCart">
      <text class="bar-cart-emoji">🛒</text>
      <view class="bar-cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
    </view>
    <view class="bar-total">
      <text class="bar-total-price">¥{{totalPrice}}</text>
    </view>
    <view class="bar-checkout" bindtap="checkout">去结算</view>
  </view>

  <!-- ===== 客服按钮 ===== -->
  <button class="service-button" open-type="contact">
    <image class="service-icon" src="/images/icons/客服.png" />
  </button>

  <!-- ===== 桌台选择弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{showTableModal}}" bindtap="hideTableModal"></view>
  <view class="table-modal-panel" wx:if="{{showTableModal}}">
    <view class="table-modal-header">
      <text class="table-modal-title">选择桌台</text>
      <text class="modal-close" bindtap="hideTableModal">×</text>
    </view>
    <view class="table-modal-body">
      <view class="table-grid">
        <view wx:for="{{tableList}}" wx:key="id" class="table-grid-item {{tableNumber === item.id ? 'selected' : ''}}" bindtap="selectTableNumber" data-table-id="{{item.id}}">
          <text class="table-grid-num">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 购物车弹窗 ===== -->
  <view class="modal-overlay" wx:if="{{showCartModal}}" bindtap="hideCartModal"></view>
  <view class="cart-modal-panel" wx:if="{{showCartModal}}">
    <view class="cart-modal-header">
      <text class="cart-modal-title">🛒 购物车</text>
      <text class="modal-close" bindtap="hideCartModal">×</text>
    </view>
    <view class="cart-modal-body">
      <block wx:if="{{cartItems.length > 0}}">
        <view class="cart-modal-item" wx:for="{{cartItems}}" wx:key="*this" wx:for-index="idx">
          <image class="cart-modal-img" src="{{item.image}}" mode="aspectFill" />
          <view class="cart-modal-info">
            <text class="cart-modal-name">{{item.name}}</text>
            <text class="cart-modal-price">¥{{item.price}}</text>
          </view>
          <view class="cart-modal-qty">
            <view class="order-qty-btn" bindtap="decreaseQuantity" data-id="{{item.id}}">−</view>
            <input class="order-qty-input" type="text" pattern="[0-9]*" value="{{item.quantity}}" bindtap="stopPropagation" bindblur="onQuantityInput" bindconfirm="onQuantityInput" data-id="{{item.id}}" />
            <view class="order-qty-btn" bindtap="increaseQuantity" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="cart-modal-empty">购物车为空</view>
      </block>
    </view>
  </view>

</view>
