﻿﻿﻿﻿<!-- 商店信息 -->
<view class="shop-info">
  <view class="shop-header">
    <view class="shop-name">
      <text class="icon">📍</text>
      农场直购
    </view>
    <text class="shop-hours">00:00-23:59</text>
  </view>
  <view class="shop-info-row">
    <view class="table-info">
      <text class="table-label">桌台</text>
      <view class="table-selector" bindtap="selectTable">
        <text class="table-number-text">{{tableNumber ? tableNumber : '选择桌台'}}</text>
        <view class="table-arrow">
          <text>></text>
        </view>
      </view>
    </view>
    <view class="contact-buttons">
      <text class="scan-btn" bindtap="testScanCode">扫码绑桌</text>
    </view>
  </view>
</view>

<!-- 客服按钮 -->
<button class="service-button function-item function-item-btn" open-type="contact">
  <image class="service-icon" src="https://img.icons8.com/ios-glyphs/24/666666/headset.png" />
</button>

<!-- 桌台选择弹窗 -->
<view class="table-modal" wx:if="{{showTableModal}}">
  <view class="table-modal-content">
    <view class="table-modal-header">
      <text class="table-modal-title">选择桌台</text>
      <view class="table-modal-close" bindtap="hideTableModal">×</view>
    </view>
    <view class="table-modal-body">
      <view class="table-grid">
        <view
          wx:for="{{tableList}}"
          wx:key="id"
          class="table-item {{tableNumber === item.id ? 'selected' : ''}}"
          bindtap="selectTableNumber"
          data-table-id="{{item.id}}"
        >
          <text class="table-item-num">{{item.name}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<view class="content">
  <!-- 左侧分类 -->
  <view class="category-list">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-item {{activeCategory === item.id ? 'active' : ''}}"
      bindtap="switchCategory"
      data-category="{{item.id}}"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 右侧商品列表 -->
  <scroll-view
    class="goods-list"
    scroll-y
    scroll-into-view="{{scrollIntoViewId}}"
    scroll-with-animation
    enhanced
    bounces="false"
    bindscroll="onScroll"
  >
    <block wx:if="{{loading}}">
      <view class="loading">加载中...</view>
    </block>
    <block wx:else>
      <block wx:for="{{mergedGoodsList}}" wx:key="uniqueKey">
        <!-- 分类标题 -->
        <view
          wx:if="{{item.type === 'category'}}"
          id="category-{{item.id}}"
          class="category-tag"
        >
          {{item.name}}
        </view>
        <!-- 商品 -->
        <view wx:else class="goods-item">
          <view class="goods-image-container">
            <image class="goods-image" src="{{item.image}}" bindtap="navigateToGoodsDetail" data-id="{{item.id}}" />
            <view class="goods-price">￥{{item.price}}</view>
          </view>
          <view class="goods-info">
            <view class="goods-name" bindtap="navigateToGoodsDetail" data-id="{{item.id}}">{{item.name}}</view>
            <view class="goods-sales">
              <text class="sold">已售 {{item.sold}}</text>
              <text class="stock">仅剩 {{item.stock}}份</text>
            </view>
            <view class="goods-bottom">
              <view class="quantity-control">
                <view class="quantity-btn" catchtap="decreaseQuantity" data-id="{{item.id}}" wx:if="{{cart[item.id] && cart[item.id].quantity > 0}}">-</view>
                <input class="quantity-input" type="text" pattern="[0-9]*" value="{{cart[item.id] ? cart[item.id].quantity : 0}}" wx:if="{{cart[item.id] && cart[item.id].quantity > 0}}" bindtap="stopPropagation" bindblur="onQuantityInput" bindconfirm="onQuantityInput" data-id="{{item.id}}" />
                <view class="add-btn" catchtap="addToCart" data-id="{{item.id}}">+</view>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 底部加高占位 ← 解决最后3个分类无法置顶的核心！ -->
      <view class="bottom-placeholder">
        <text>已经到底啦</text>
      </view>
    </block>
  </scroll-view>
</view>

<!-- 底部结算栏 -->
<view class="bottom-bar">
  <view class="cart-icon" bindtap="viewCart">
    <text class="cart-text">🛒</text>
    <block wx:if="{{cartCount > 0}}">
      <view class="cart-badge">{{cartCount}}</view>
    </block>
  </view>
  <view class="total-price">
    <text>￥{{totalPrice}}</text>
  </view>
  <button class="checkout-btn" bindtap="checkout">去结算</button>
</view>

<!-- 购物车弹窗 -->
<view class="cart-modal" wx:if="{{showCartModal}}">
  <view class="cart-modal-overlay" bindtap="hideCartModal"></view>
  <view class="cart-modal-content">
    <view class="cart-modal-header">
      <text class="cart-modal-title">购物车</text>
      <view class="table-modal-close" bindtap="hideCartModal">×</view>
    </view>
    <view class="cart-modal-body">
      <block wx:if="{{cartItems.length > 0}}">
        <view wx:for="{{cartItems}}" wx:key="*this" wx:for-index="idx" class="cart-item">
          <image class="cart-item-image" src="{{item.image}}" mode="scaleToFill" />
          <view class="cart-item-info">
            <text class="cart-item-name">{{item.name}}</text>
            <text class="cart-item-price">￥{{item.price}}</text>
          </view>
          <view class="cart-item-quantity">
            <view class="quantity-btn" bindtap="decreaseQuantity" data-id="{{item.id}}">-</view>
            <input class="quantity-input" type="text" pattern="[0-9]*" value="{{item.quantity}}" bindtap="stopPropagation" bindblur="onQuantityInput" bindconfirm="onQuantityInput" data-id="{{item.id}}" />
            <view class="quantity-btn" bindtap="increaseQuantity" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </block>
      <block wx:else>
        <view class="empty">购物车为空</view>
      </block>
    </view>
  </view>
</view>