<view class="page">

  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>

  <!-- ===== 稻田GIF加载动画 ===== -->
  <farm-loading show="{{loading}}" text="加载中..."></farm-loading>

  <block wx:if="{{!loading}}">
  <!-- ===== 四角麦穗装饰 ===== -->
   <image class="wheat-corner-tl" src="/images/615.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/615.png" mode="aspectFit"/>

  <swiper
    class="detail-swiper"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    circular="{{true}}"
    interval="3000"
    duration="500"
  >
    <!-- 有视频时第一个轮播项显示视频 -->
    <swiper-item wx:if="{{hasVideo}}">
      <video
        class="detail-swiper-video"
        src="{{acreDetail.videoUrl}}"
        poster="{{acreDetail.coverImage && acreDetail.coverImage.startsWith('http') ? acreDetail.coverImage : (acreDetail.image && acreDetail.image.startsWith('http') ? acreDetail.image : '')}}"
        controls="true"
        autoplay="false"
        loop="false"
        muted="false"
        object-fit="cover"
        show-center-play-btn="true"
        enable-progress-gesture="true"
        show-play-btn="true"
        show-fullscreen-btn="true"
        enable-playback-rate="true"
        volume="1.0"
        show-mute-btn="true"
        show-volume-btn="true"
      />
    </swiper-item>
    <!-- 其他轮播项显示图片 -->
    <block wx:for="{{swiperList}}" wx:key="id">
      <swiper-item>
        <image
          class="detail-swiper-image"
          src="{{item.image}}"
          mode="aspectFill"
          bindtap="previewImage"
          data-url="{{item.image}}"
        />
      </swiper-item>
    </block>
  </swiper>

  <view class="detail-card">
    <view class="detail-title">{{acreDetail.name}}</view>
    <view class="detail-price">￥{{acreDetail.price}}</view>
    <view class="detail-desc">
      <text wx:if="{{acreDetail.spec}}" class="detail-spec">{{acreDetail.spec}}</text>
      <text>{{acreDetail.description}}</text>
    </view>
    
    <!-- 购买统计信息 -->
    <view class="purchase-stats">
      <view class="stat-item">
        <view class="stat-label">剩余亩数</view>
        <view class="stat-value">{{acreDetail.remainingAcres || 50}} 亩</view>
      </view>
      <view class="stat-item">
        <view class="stat-label">已售亩数</view>
        <view class="stat-value">{{acreDetail.soldAcres || 0}} 亩</view>
      </view>
    </view>
    
    <!-- 已卖完提示 -->
    <view wx:if="{{acreDetail.remainingAcres <= 0}}" class="sold-out">
      已卖完
    </view>
  </view>

  <!-- 农场示例（模仿活动图片显示） -->
  <view class="example-section">
    <view class="section-title">农场示例</view>
    <!-- 图片列表 - widthFix 自适应高度 -->
    <view class="example-images-vertical" wx:if="{{acreDetail.images && acreDetail.images.length > 0}}">
      <block wx:for="{{acreDetail.images}}" wx:key="index">
        <image src="{{item}}" mode="widthFix" bindtap="previewExampleImage" data-url="{{item}}" data-index="{{index}}" />
      </block>
    </view>
    <!-- 备用图片来源：bottomImages -->
    <view class="example-images-vertical" wx:elif="{{acreDetail.bottomImages && acreDetail.bottomImages.length > 0}}">
      <block wx:for="{{acreDetail.bottomImages}}" wx:key="index">
        <image src="{{item}}" mode="widthFix" bindtap="previewExampleImage" data-url="{{item}}" data-index="{{index}}" />
      </block>
    </view>
    <!-- 备用图片来源2 -->
    <view class="example-images-vertical" wx:elif="{{acreDetail.longExampleImages && acreDetail.longExampleImages.length > 0}}">
      <block wx:for="{{acreDetail.longExampleImages}}" wx:key="index">
        <image src="{{item}}" mode="widthFix" bindtap="previewExampleImage" data-url="{{item}}" data-index="{{index}}" />
      </block>
    </view>
    <!-- 备用图片来源3 -->
    <view class="example-images-vertical" wx:elif="{{acreDetail.longExampleImageList && acreDetail.longExampleImageList.length > 0}}">
      <block wx:for="{{acreDetail.longExampleImageList}}" wx:key="index">
        <image src="{{item}}" mode="widthFix" bindtap="previewExampleImage" data-url="{{item}}" data-index="{{index}}" />
      </block>
    </view>
    <!-- 单个示例图片 -->
    <view class="example-images-vertical" wx:elif="{{acreDetail.longExampleImage}}">
      <image src="{{acreDetail.longExampleImage}}" mode="widthFix" bindtap="previewExampleImage" data-url="{{acreDetail.longExampleImage}}" data-index="0" />
    </view>
    <!-- 无图片时的提示 -->
    <view class="no-images" wx:else>
      <text>暂无农场示例图片</text>
    </view>
  </view>

  <view class="bottom-bar">
    
    <button 
      class="buy-btn" 
      bindtap="confirmPurchase"
      disabled="{{acreDetail.remainingAcres <= 0}}"
    >
      {{acreDetail.remainingAcres <= 0 ? '已卖完' : '立即购买'}}
    </button>
  </view>

  <!-- 客服按钮 -->
  <button class="service-button function-item function-item-btn" open-type="contact">
    <image class="service-icon" src="/images/icons/客服.png" />
  </button>

  </block>
</view>
