@import "../../styles/farm-theme.wxss";

/* 认购一亩田详情 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.page {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  background: linear-gradient(180deg, var(--rice-cream) 0%, var(--rice-warm) 30%, var(--rice-cream) 100%);
  padding-bottom: 120rpx;
}

/* ===== 轮播 ===== */
.detail-swiper {
  width: 100%;
  height: 500rpx;
  background: var(--rice-paper);
}

.detail-swiper-image,
.detail-swiper-video {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

/* ===== 详情卡片 ===== */
.detail-card {
  margin: 20rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  animation: fadeInUp 0.5s ease-out;
  position: relative;
}

.detail-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--rice-text);
  margin-bottom: 16rpx;
  padding-left: 24rpx;
  position: relative;
}

.detail-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
  border-radius: 4rpx;
}

.detail-price {
  font-size: 40rpx;
  color: var(--rice-gold);
  font-weight: 800;
  margin-bottom: 16rpx;
  padding-left: 20rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  line-height: 1.8;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
}

.detail-spec {
  display: inline-block;
  background: rgba(196,149,60,0.1);
  color: var(--rice-gold);
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
  font-weight: 500;
}

/* ===== 购买统计 ===== */
.purchase-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-top: 2rpx solid var(--rice-paper);
  margin-top: 24rpx;
}

.stat-item {
  text-align: center;
  padding: 0 20rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--rice-gold);
}

/* ===== 已卖完提示 ===== */
.sold-out {
  margin-top: 24rpx;
  padding: 20rpx;
  background: rgba(212,118,94,0.08);
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--rice-danger);
  border: 1rpx solid rgba(212,118,94,0.2);
}

/* ===== 农场示例 ===== */
.example-section {
  margin: 20rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  margin-bottom: 140rpx;
  animation: fadeInUp 0.5s ease-out 0.1s both;
  position: relative;
}

.example-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 26rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
  border-radius: 3rpx;
}

.example-images-vertical {
  display: flex;
  flex-direction: column;
}

.example-images-vertical image {
  width: 100%;
  display: block;
}

/* ===== 无图片提示 ===== */
.no-images {
  text-align: center;
  padding: 60rpx 0;
  color: var(--rice-text-light);
  font-size: 26rpx;
  background: var(--rice-paper);
  border-radius: 12rpx;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(232,200,122,0.1);
  box-shadow: 0 -4rpx 30rpx var(--rice-shadow);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 20rpx;
  z-index: 100;
}

.buy-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  border-radius: 36rpx;
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.3);
  transition: all 0.2s;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.buy-btn::after { border: none; }

.buy-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.buy-btn:disabled {
  background: var(--rice-straw);
  color: var(--rice-text-light);
  box-shadow: none;
}

/* ===== 客服按钮 ===== */
.service-button {
  position: fixed;
  bottom: 200rpx;
  left: 24rpx;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(196,149,60,0.4);
  z-index: 9999;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: none;
}

.service-button::after { border: none; }
.service-button:active { transform: scale(0.9); }

.service-button .service-icon {
  width: 80rpx;
  height: 80rpx;
}

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
