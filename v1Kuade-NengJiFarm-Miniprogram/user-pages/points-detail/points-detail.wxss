@import "../../styles/farm-theme.wxss";

/* ===== 色彩体系（覆盖全局，与商品详情一致） ===== */
page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: var(--rice-gold);
  --rice-green-light: var(--rice-gold-light);
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-danger: #D4765E;
  --rice-danger-light: #E0937E;
  --rice-warm: #F5E6D3;

  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%);
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  width: 100%;
}

.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: -10%; right: -10%; height: 520rpx;
  background:
    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light);
  letter-spacing: 6rpx; font-weight: 400;
}

/* ===== 主内容区 ===== */
.main-content { padding: 0 2rpx; position: relative; z-index: 10; flex: 1; display: flex; flex-direction: column; }

.section-block { margin-top: 24rpx; }

.anim-section { animation: sectionFadeIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
.section-block:nth-child(1) { animation-delay: 0.05s; }
.section-block:nth-child(2) { animation-delay: 0.15s; }
.section-block:nth-child(3) { animation-delay: 0.25s; }

/* ===== 区块标题栏 ===== */
.section-title-bar {
  display: flex; align-items: center; margin-bottom: 20rpx; padding: 0 4rpx; gap: 10rpx;
}

.section-title-wheat {
  width: 36rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatBounce 3s ease-in-out infinite; opacity: 0.3;
}

.section-title-bar-inner {
  width: 6rpx; height: 28rpx; border-radius: 3rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
  margin-right: 4rpx; flex-shrink: 0;
}

.section-title-text {
  font-size: 30rpx; font-weight: 700; color: var(--rice-text);
  letter-spacing: 2rpx; flex: 1;
}

/* ===== 积分总览 ===== */
.points-header {
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-gold-light) 50%, var(--rice-gold-pale) 100%);
  padding: 48rpx 32rpx;
  text-align: center;
  border-radius: 24rpx;
  position: relative;

  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
}

.points-header::before {
  content: '';
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
}

.points-header::after {
  content: '';
  position: absolute;
  left: -80rpx;
  bottom: -100rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.points-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  position: relative;
  z-index: 1;
}

.points-value {
  font-size: 80rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
  position: relative;
  z-index: 1;
}

/* ===== 积分统计 ===== */
.points-stats {
  display: flex;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  padding: 24rpx 20rpx;
  margin: -20rpx 0 0;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  position: relative;
  z-index: 2;
}

.points-stats::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  letter-spacing: 1rpx;
}

.stat-num.earn { color: var(--rice-green); }
.stat-num.spend { color: var(--rice-gold); }

.stat-label {
  font-size: 22rpx;
  color: var(--rice-text-light);
  margin-top: 4rpx;
  display: block;
}

/* ===== 类型筛选 ===== */
.type-tab-bar {
  display: flex;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 16rpx;
  padding: 6rpx;
  box-shadow: 0 4rpx 16rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  position: relative;
}

.type-tab-bar::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  border-radius: 12rpx;
  transition: all 0.3s;
}

.type-tab.active {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  font-weight: 600;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 28rpx;
  color: var(--rice-text-light);
}

/* ===== 记录列表 ===== */
.records-list {
  padding: 0;
}

.record-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 16rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.06);
  transition: all 0.3s;
  position: relative;
}

.record-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.record-item:active {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 24rpx var(--rice-shadow-strong);
}

.record-left {
  margin-right: 16rpx;
}

.record-type {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.record-type.earn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
}

.record-type.spend {
  background: linear-gradient(135deg, var(--rice-paper), var(--rice-straw));
  color: var(--rice-text-light);
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-desc {
  font-size: 26rpx;
  color: var(--rice-text);
}

.record-time {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.record-right {
  text-align: right;
  margin-left: 16rpx;
}

.record-points {
  font-size: 30rpx;
  font-weight: 700;
  display: block;
}

.record-points.earn { color: var(--rice-green); }
.record-points.spend { color: var(--rice-gold); }

/* ===== 加载更多（来自 orders 页面） ===== */
.load-more-bar {
  padding: 40rpx 0 20rpx;
  text-align: center;
  min-height: 60rpx;
}

.loading-more-hint,
.no-more-hint,
.pull-hint {
  padding: 16rpx 0;
}

.loading-more-text,
.pull-text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.no-more-text {
  font-size: 24rpx;
  color: var(--rice-straw);
}

/* ===== 懒加载 mini 稻田动画（来自 orders 页面） ===== */
.farm-mini-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.mini-wheat-group {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 12rpx;
  height: 48rpx;
}

.mini-wheat {
  width: 4rpx;
  background: linear-gradient(to top, #7CB342 0%, #AED581 50%, #C5E1A5 100%);
  border-radius: 2rpx;
  transform-origin: bottom center;
  position: relative;
}

.mini-wheat::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 14rpx;
  background: linear-gradient(to bottom, #E8C87A 0%, #D4A84B 50%, #B8923A 100%);
  border-radius: 6rpx 6rpx 3rpx 3rpx;
}

.mini-wheat::after {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 10rpx;
  background: radial-gradient(ellipse at center, #F5DEA0 0%, #E8C87A 60%, transparent 100%);
  border-radius: 50%;
  opacity: 0.5;
}

.mini-wheat:nth-child(1) {
  height: 32rpx;
  animation: miniWheatSway 1.8s ease-in-out infinite;
}

.mini-wheat:nth-child(2) {
  height: 44rpx;
  animation: miniWheatSway 1.5s ease-in-out infinite;
  animation-delay: 0.3s;
}

.mini-wheat:nth-child(3) {
  height: 36rpx;
  animation: miniWheatSway 1.6s ease-in-out infinite;
  animation-delay: 0.6s;
}

@keyframes miniWheatSway {
  0%, 100% { transform: rotate(-6deg); }
  50% { transform: rotate(6deg); }
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  border-top: 1rpx solid rgba(232,200,122,0.15);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
  
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.7;
}
.footer-wheat-bl { bottom: -0rpx; left: -30rpx; transform: rotate(60deg); }
.footer-wheat-br { bottom: -0rpx; right: -30rpx; transform: rotate(-60deg); }

/* ===== 动画 ===== */
@keyframes sectionFadeIn {
  from { opacity: 0; transform: translateY(40rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}
