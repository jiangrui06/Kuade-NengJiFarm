<view class="page-wrap">

  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>
  <view class="bg-shimmer shimmer-lg" style="left:18%;bottom:18%;animation-delay:0s"></view>
  <view class="bg-shimmer shimmer-sm" style="left:50%;bottom:14%;animation-delay:2.8s"></view>
  <view class="bg-shimmer shimmer-md" style="left:82%;bottom:16%;animation-delay:3.6s"></view>

  <!-- ===== 稻穗装饰边框 ===== -->
  <view class="wheat-border-left">
    <image wx:for="{{8}}" wx:for-index="i" wx:key="i" class="wheat-stalk" src="/images/wheat-reference.png" mode="aspectFit" style="animation-delay: {{i * 0.35}}s"/>
  </view>
  <view class="wheat-border-right">
    <image wx:for="{{8}}" wx:for-index="i" wx:key="i" class="wheat-stalk" src="/images/wheat-reference.png" mode="aspectFit" style="animation-delay: {{i * 0.28}}s"/>
  </view>

  <!-- ===== 四角麦穗装饰 ===== -->
  <image class="wheat-corner-tl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-br" src="/images/wheat-reference.png" mode="aspectFit"/>

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-title">积分详情</text>
    <image class="header-bar-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-subtitle">每一分耕耘，都有收获</text>
  </view>

  <!-- ===== 主内容区 ===== -->
  <view class="main-content">

    <!-- ===== 积分总览 ===== -->
    <view class="section-block anim-section">
      <view class="points-header">
        <text class="points-label">当前积分</text>
        <text class="points-value">{{points}}</text>
      </view>
      <view class="points-stats">
        <view class="stat-item">
          <text class="stat-num earn">+{{todayEarned}}</text>
          <text class="stat-label">今日获得</text>
        </view>
        <view class="stat-item">
          <text class="stat-num earn">+{{earnedPoints}}</text>
          <text class="stat-label">累计获得</text>
        </view>
        <view class="stat-item">
          <text class="stat-num spend">-{{spentPoints}}</text>
          <text class="stat-label">累计消费</text>
        </view>
      </view>
    </view>

    <!-- ===== 类型筛选 ===== -->
    <view class="section-block anim-section">
      <view class="type-tab-bar">
        <view
          wx:for="{{typeTabs}}"
          wx:key="key"
          class="type-tab {{typeFilter === item.key ? 'active' : ''}}"
          bindtap="switchTypeTab"
          data-type="{{item.key}}">
          {{item.name}}
        </view>
      </view>
    </view>

    <!-- ===== 积分明细 ===== -->
    <view class="section-block anim-section">
      <view class="section-title-bar">
        <image class="section-title-wheat" src="/images/wheat-reference.png" mode="aspectFit"/>
        <view class="section-title-bar-inner"></view>
        <text class="section-title-text">积分明细</text>
      </view>

      <!-- 加载中 -->
      <view wx:if="{{loading}}" class="loading">加载中...</view>

      <!-- 空状态 -->
      <view wx:elif="{{records.length === 0}}" class="empty">暂无积分记录</view>

      <!-- 积分记录列表 -->
      <view wx:else class="records-list">
        <view wx:for="{{records}}" wx:key="id" class="record-item">
          <view class="record-left">
            <view class="record-type {{item.type === 'earn' ? 'earn' : 'spend'}}">
              {{item.type === 'earn' ? '+' : '-'}}
            </view>
          </view>
          <view class="record-info">
            <text class="record-desc">{{item.desc}}</text>
            <text class="record-time">{{item.time}}</text>
          </view>
          <view class="record-right">
            <text class="record-points {{item.type === 'earn' ? 'earn' : 'spend'}}">{{item.points}}</text>
          </view>
        </view>

        <!-- 加载更多 -->
        <view wx:if="{{hasMore && records.length > 0}}" class="load-more">上拉加载更多</view>
        <view wx:elif="{{!hasMore && records.length > 0}}" class="load-more no-more">没有更多了</view>
      </view>
    </view>

    <!-- ===== 底部装饰 ===== -->
    <view class="footer-decoration">
      <image class="footer-wheat footer-wheat-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
      <image class="footer-wheat footer-wheat-br" src="/images/wheat-reference.png" mode="aspectFit"/>
      <view class="footer-rice">
        <view class="footer-rice-text"></view>
      </view>
      <view class="footer-wheat-row">
        <image class="footer-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
        <text class="footer-wheat-sep">✦</text>
        <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
        <text class="footer-wheat-sep">✦</text>
        <image class="footer-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
      </view>
      <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
    </view>
  </view>
</view>
