<view class="container">
  <!-- ===== 四角麦穗装饰 ===== -->
  <image class="wheat-corner-tl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-br" src="/images/wheat-reference.png" mode="aspectFit"/>

  <!-- 搜索头部 -->
  <view class="search-header">
    <view class="search-box">
      <input class="search-input" placeholder="请输入商品名称" value="{{keyword}}" bindinput="onInputChange" />
      <view class="search-btn" bindtap="search">搜索</view>
    </view>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!searching && !hasResults && history.length > 0}}">
    <view class="history-header">
      <text class="history-title">搜索历史</text>
      <text class="clear-history" bindtap="clearHistory">清除</text>
    </view>
    <view class="history-tags">
      <view class="history-tag" wx:for="{{history}}" wx:key="index" bindtap="searchWithHistory" data-keyword="{{item}}">{{item}}</view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="search-results" wx:if="{{hasResults}}">
    <view class="results-header">
      <text>搜索 "{{keyword}}" 的结果</text>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{searchResults}}" wx:key="id" bindtap="navigateToDetail" data-id="{{item.id}}" data-type="{{item.type}}">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill" />
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-tags">
            <view class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="index">{{tag}}</view>
          </view>
          <view class="goods-price">￥{{item.price}}</view>
          <view class="goods-stock" wx:if="{{item.stock}}">还剩{{item.stock}}份</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 搜索中 -->
  <view class="searching" wx:if="{{searching}}">
    <text>搜索中...</text>
  </view>

  <!-- 无结果 -->
  <view class="no-results" wx:if="{{!searching && !hasResults && keyword}}">
    <view class="no-results-icon">🔍</view>
    <text class="no-results-text">没有相关的商品</text>
    <text class="no-results-hint">换个关键词试试吧</text>
  </view>

  <!-- 初始状态 -->
  <view class="no-results" wx:if="{{!searching && !hasResults && !keyword && history.length === 0}}">
    <view class="no-results-icon">🔍</view>
    <text class="no-results-text">搜索商品</text>
    <text class="no-results-hint">输入关键词开始搜索</text>
  </view>
</view>
