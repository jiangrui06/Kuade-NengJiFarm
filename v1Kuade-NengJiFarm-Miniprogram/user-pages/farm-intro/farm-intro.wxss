.container {
  padding: 0;
  margin: 0;
  height: 100vh;
  position: relative;
  overflow: auto;
  background-color: #f5f5f5;
}

/* 确保页面无默认边距 */
page {
  margin: 0;
  padding: 0;
  background-color: #f5f5f5;
}

/* 背景图 */
.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  object-fit: cover;
}

/* 内容容器 */
.content-wrapper {
  padding: 20rpx;
  min-height: 100vh;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  font-size: 24rpx;
  color: #999;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-top: 0;
  margin-bottom: 0;
  color: #333;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
}

.main-image-container {
  margin-bottom: 0;
  border-radius: 0;
  overflow: hidden;
  box-shadow: none;
}

.main-image {
  width: 100%;
  height: 400rpx;
  display: block;
  object-fit: cover;
}

.section {
  background-color: #ffffff;
  border-radius: 0;
  padding: 30rpx;
  margin-bottom: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #333;
  position: relative;
  padding-left: 20rpx;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  height: 32rpx;
  line-height: 32rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

.section-content {
  font-size: 26rpx;
  line-height: 44rpx;
  color: #555;
  text-align: justify;
}

/* 农场特色 */
.features-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 10rpx 0;
}

.feature-item {
  width: calc(33.33% - 14rpx);
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.feature-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
}

.feature-image {
  width: 100%;
  height: 200rpx;
  display: block;
}

.feature-name {
  padding: 16rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  font-weight: 500;
}

.feature-list {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.feature-item {
  flex: 1;
  text-align: center;
  margin: 0 10rpx;
}

.feature-image {
  width: 100%;
  height: 150rpx;
  border-radius: 8rpx;
  margin-bottom: 10rpx;
}

.feature-text {
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
}

.contact-info {
  margin-top: 10rpx;
}

.contact-item {
  font-size: 26rpx;
  margin-bottom: 16rpx;
  color: #555;
  display: flex;
  align-items: center;
}

.contact-label {
  font-weight: 600;
  color: #333;
  width: 100rpx;
  flex-shrink: 0;
}

.contact-value {
  flex: 1;
  word-break: break-all;
}

.contact-address {
  cursor: pointer;
}

.contact-address:active {
  opacity: 0.7;
}

.location-icon {
  font-size: 32rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
  padding: 8rpx;
}

/* 农场图片展示 */
.farm-images {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.farm-image {
  width: 48%;
  height: 200rpx;
  border-radius: 8rpx;
  object-fit: cover;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.farm-image:nth-child(2n+1) {
  margin-right: 4%;
}

/* 推荐图片 */
.recommend-section {
  margin: 20rpx 0;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.recommend-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

/* 技术支持水印 */
.footer-watermark {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx 60rpx;
  gap: 8rpx;
}

.watermark-line {
  font-size: 22rpx;
  color: #bbb;
  letter-spacing: 1rpx;
}