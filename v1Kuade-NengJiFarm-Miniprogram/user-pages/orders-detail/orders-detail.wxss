@import "../../styles/farm-theme.wxss";

.wheat-stalk { background: var(--wheat-deco) center/contain no-repeat; }

/* 订单详情 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding-bottom: 40rpx;
  display: flex;
  flex-direction: column;
}

.page-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}



/* ===== 主内容区 ===== */
.main-content {
  padding: 0 0 0px;
  position: relative;
  z-index: 10;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: var(--rice-text-light);
  letter-spacing: 6rpx;
  font-weight: 400;
}

@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.6;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  30% { transform: translateY(-12rpx) rotate(-2deg); }
  60% { transform: translateY(-6rpx) rotate(2deg); }
  80% { transform: translateY(-10rpx) rotate(-1deg); }
}

/* ===== 返回按钮 ===== */
.nav-back {
  position: fixed;
  top: 88rpx;
  left: 20rpx;
  z-index: 200;
  width: 72rpx;
  height: 72rpx;
  background: rgba(180,180,180,0.7);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.3);
  box-shadow: 0 4rpx 20rpx var(--rice-shadow);
}

.nav-back:active {
  background: rgba(160,160,160,0.85);
  transform: scale(0.94);
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  line-height: 1;
  margin-top: -4rpx;
  font-weight: 500;
}

/* ===== 状态卡片 ===== */
.status-card {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  margin: 24rpx 24rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  padding: 44rpx 32rpx 36rpx;
  position: relative;
  overflow: hidden;
}

.status-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.status-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 48rpx;
  right: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  border-radius: 0 0 4rpx 4rpx;
}

.status-card-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.status-card-info {
  text-align: center;
  width: 100%;
}

.status-card-main {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--rice-text);
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.status-card-sub {
  font-size: 26rpx;
  color: var(--rice-text-light);
  line-height: 1.6;
}

.countdown-inline {
  color: var(--rice-gold);
  font-weight: 700;
  font-size: 28rpx;
  background: var(--rice-paper);
  border-radius: 8rpx;
  padding: 0 8rpx;
}

/* ===== 二维码 ===== */
.qrcode-divider {
  height: 1rpx;
  background: var(--rice-straw);
  margin: 28rpx 0 24rpx;
  width: 100%;
  position: relative;
  z-index: 1;
}

.qrcode-area {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.qrcode-title {
  font-size: 26rpx;
  color: var(--rice-text-light);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.qrcode-img {
  width: 280rpx;
  height: 280rpx;
  border-radius: 20rpx;
  background: #fff;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx var(--rice-shadow);
}

.qrcode-tip {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}

.qrcode-btn {
  font-size: 26rpx;
  color: var(--rice-gold);
  background: var(--rice-paper);
  border-radius: 36rpx;
  padding: 16rpx 48rpx;
  font-weight: 600;
  border: 1rpx solid rgba(196,149,60,0.15);
  transition: all 0.2s;
}

.qrcode-btn:active {
  transform: scale(0.96);
  background: rgba(196,149,60,0.08);
}

/* ===== 通用卡片 ===== */
.card {
  margin: 20rpx 24rpx 0;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.12);
  animation: fadeInUp 0.5s ease-out both;
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--rice-paper);
}

.card-title-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.card-title-bar {
  width: 6rpx;
  height: 32rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
}

.card-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--rice-text);
  letter-spacing: 1rpx;
}

.card-title-arrow {
  font-size: 24rpx;
  color: var(--rice-gold);
  font-weight: 500;
  padding: 8rpx 0 8rpx 16rpx;
}

.card-title-arrow:active { opacity: 0.6; }

.card-title-sub {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.clickable-card:active {
  opacity: 0.88;
  transform: scale(0.99);
}

.card-body {
  padding: 28rpx 32rpx;
}

.card-body.rows {
  padding: 8rpx 0 4rpx;
}

/* ===== 物流信息 ===== */
.logistics-card-body {
  padding: 24rpx 32rpx;
}

.logistics-basic {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--rice-cream);
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--rice-straw);
}

.logistics-basic-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.logistics-basic-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.logistics-basic-company {
  font-size: 28rpx;
  color: var(--rice-text);
  font-weight: 600;
}

.logistics-basic-no {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.logistics-estimated {
  font-size: 24rpx;
  color: var(--rice-gold);
  font-weight: 500;
}

.logistics-basic-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 4rpx;
}

.logistics-status {
  font-size: 22rpx;
  color: var(--rice-green);
  background: rgba(91,140,62,0.1);
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
}

.logistics-phone {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

/* ===== 物流时间线 ===== */
.logistics-timeline {
  padding-left: 8rpx;
}

.logistics-timeline-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 32rpx;
  position: relative;
}

.logistics-timeline-item:last-child { padding-bottom: 0; }

.logistics-timeline-item::before {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 20rpx;
  bottom: 0;
  width: 2rpx;
  background: var(--rice-paper);
}

.logistics-timeline-item:last-child::before { display: none; }

.timeline-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: var(--rice-straw);
  flex-shrink: 0;
  margin-top: 4rpx;
  position: relative;
  z-index: 1;
}

.timeline-dot.active {
  background: var(--rice-gold);
  width: 22rpx;
  height: 22rpx;
  margin-top: 2rpx;
  box-shadow: 0 0 0 6rpx rgba(196,149,60,0.18);
}

.timeline-content {
  flex: 1;
  min-width: 0;
}

.timeline-desc {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  line-height: 1.5;
  margin-bottom: 6rpx;
}

.logistics-timeline-item.latest .timeline-desc {
  color: var(--rice-text);
  font-weight: 500;
}

.timeline-time {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

/* ===== 收货地址 ===== */
.addr-body {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 32rpx;
}

.addr-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: rgba(196,149,60,0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.addr-icon {
  font-size: 32rpx;
}

.addr-content {
  flex: 1;
  padding-top: 4rpx;
}

.addr-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.addr-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--rice-text);
}

.addr-phone {
  font-size: 26rpx;
  color: var(--rice-text-light);
}

.addr-detail {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  line-height: 1.7;
}

/* ===== 备注 ===== */
.remark-body {
  padding: 24rpx 32rpx;
  background: var(--rice-cream);
  border-radius: 0 0 24rpx 24rpx;
}

.remark-text {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  line-height: 1.6;
  word-break: break-word;
}

/* ===== 商品信息 ===== */
.goods-body {
  padding: 0 32rpx 8rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--rice-paper);
  gap: 20rpx;
}

.goods-item:last-child {
  border-bottom: none;
  padding-bottom: 20rpx;
}

.goods-item:first-child { padding-top: 20rpx; }

.goods-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: var(--rice-paper);
  flex-shrink: 0;
}

.goods-mid {
  flex: 1;
  min-width: 0;
}

.goods-name {
  font-size: 28rpx;
  color: var(--rice-text);
  font-weight: 500;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-qty {
  font-size: 24rpx;
  color: var(--rice-text-light);
  background: var(--rice-paper);
  padding: 2rpx 14rpx;
  border-radius: 20rpx;
  display: inline-block;
}

.goods-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  gap: 6rpx;
}

.goods-price {
  font-size: 30rpx;
  color: var(--rice-text);
  font-weight: 600;
}

.goods-subtotal {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

/* ===== 行（订单信息、价格明细） ===== */
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 32rpx;
  border-bottom: 1rpx solid var(--rice-paper);
}

.row:last-child { border-bottom: none; }

.row-lbl {
  font-size: 26rpx;
  color: var(--rice-text-light);
  flex-shrink: 0;
  margin-right: 16rpx;
}

.row-val {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  text-align: right;
  flex: 1;
  word-break: break-all;
}

.row-val-sm {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.row-total {
  padding: 28rpx 32rpx 24rpx;
  border-top: 1rpx dashed var(--rice-straw);
  margin-top: 4rpx;
  background: var(--rice-cream);
}

.row-total-lbl {
  font-size: 28rpx;
  color: var(--rice-text-secondary);
  font-weight: 600;
}

.row-total-right {
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.row-total-unit {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--rice-gold);
}

.row-total-val {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--rice-gold);
  line-height: 1;
}

/* ===== 退款进度 ===== */
.refund-card { margin: 24rpx 24rpx 0; }
.refund-body { padding: 8rpx 0; }

.refund-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--rice-paper);
}

.refund-row:last-child { border-bottom: none; }

.refund-label {
  color: var(--rice-text-light);
  font-size: 26rpx;
  flex-shrink: 0;
  width: 140rpx;
}

.refund-value {
  color: var(--rice-text-secondary);
  font-size: 26rpx;
  text-align: right;
  flex: 1;
  margin-left: 16rpx;
  word-break: break-all;
}

.refund-amount {
  color: var(--rice-danger);
  font-weight: 600;
  font-size: 30rpx;
}

.refund-status.pending,
.refund-status.approved,
.refund-status.processing { color: var(--rice-gold); }

.refund-status.completed { color: var(--rice-green); }

.refund-status.rejected,
.refund-status.failed { color: var(--rice-danger); }

.refund-status.cancelled { color: var(--rice-text-light); }

.refund-status.refunded { color: var(--rice-green); }

.refund-admin-reply {
  flex-direction: column;
  align-items: flex-start;
}

.refund-admin-reply .refund-value {
  margin-left: 0;
  margin-top: 8rpx;
  color: var(--rice-text-secondary);
  background: var(--rice-paper);
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.refund-row .refund-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
  justify-content: flex-end;
}

.refund-row .refund-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: var(--rice-paper);
}

/* ===== 有效期 ===== */
.validity-card { margin: 24rpx 24rpx 0; }

.validity-status {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.validity-status.valid { background: rgba(91,140,62,0.1); color: var(--rice-green); }
.validity-status.expired { background: rgba(212, 118, 94, 0.1); color: var(--rice-danger); }
.validity-status.pending { background: rgba(196, 149, 60, 0.1); color: var(--rice-gold); }

.validity-body { padding: 20rpx 32rpx 28rpx; }

.validity-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.validity-label {
  font-size: 26rpx;
  color: var(--rice-text-light);
}

.validity-value {
  font-size: 26rpx;
  color: var(--rice-text);
  font-weight: 500;
}

/* ===== 自取提示 ===== */
.pickup-tip-card { margin-top: 0; }
.pickup-tip-body { padding: 20rpx 24rpx; }
.pickup-tip-text {
  font-size: 26rpx;
  color: var(--rice-gold);
  line-height: 1.6;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 16rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 30rpx var(--rice-shadow);
  border-top: 1rpx solid rgba(232,200,122,0.1);
}

.btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  letter-spacing: 1rpx;
  margin: 0;
  padding: 0;
  text-align: center;
  transition: all 0.2s;
}

.btn::after { border: none; }

.btn-primary {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  font-weight: 700;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.3);
  flex: 1.2;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-danger {
  background: rgba(212, 118, 94, 0.08);
  color: var(--rice-danger);
  border: 1rpx solid rgba(212, 118, 94, 0.2);
}

.btn-danger:active { background: rgba(212, 118, 94, 0.15); }

.btn-ghost {
  background: var(--rice-paper);
  color: var(--rice-text-secondary);
}

.btn-ghost:active { background: var(--rice-straw); }

/* ===== 客服按钮 ===== */
.service-button {
  position: fixed;
  bottom: 200rpx;
  left: 24rpx;
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(196,149,60,0.4);
  z-index: 9999;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 1;
  border: none;
}

.service-button::after { border: none; }
.service-button:active { transform: scale(0.9); }

.service-icon {
  width: 80rpx;
  height: 80rpx;
}

/* ===== 加载 ===== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.loading-ring {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--rice-paper);
  border-top-color: var(--rice-gold);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: var(--rice-text-light);
}

/* ===== 退款弹窗 ===== */
.other-reason-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(44,24,16,0.45);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.other-reason-dialog {
  width: 85%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 80rpx var(--rice-shadow-heavy);
  animation: scaleIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.other-reason-header {
  padding: 36rpx 30rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--rice-text);
  text-align: center;
}

.other-reason-textarea {
  width: calc(100% - 60rpx);
  min-height: 240rpx;
  margin: 28rpx 30rpx;
  padding: 20rpx;
  background: var(--rice-paper);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: var(--rice-text);
  line-height: 1.6;
  box-sizing: border-box;
}

.other-reason-footer {
  display: flex;
  border-top: 2rpx solid var(--rice-paper);
}

.other-reason-btn {
  flex: 1;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  font-size: 30rpx;
  background: #fff;
}

.other-reason-btn.cancel-btn {
  color: var(--rice-text-secondary);
  border-right: 2rpx solid var(--rice-paper);
}

.other-reason-btn.confirm-btn {
  color: var(--rice-danger);
  font-weight: 500;
}

/* ===== 弹窗 ===== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44,24,16,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx;
  width: 86%;
  max-width: 640rpx;
  padding: 40rpx 36rpx 32rpx;
  box-shadow: 0 24rpx 80rpx var(--rice-shadow-heavy);
}

.modal-sm { max-width: 520rpx; }

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--rice-text);
  text-align: center;
  margin-bottom: 36rpx;
  letter-spacing: 2rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: var(--rice-text-light);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-actions .btn { flex: 1; }

/* ===== 动画 ===== */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { transform: scale(0.85); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
