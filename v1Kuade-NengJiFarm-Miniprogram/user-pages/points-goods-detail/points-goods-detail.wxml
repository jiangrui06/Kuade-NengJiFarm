<view class="page-wrap">

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-title">积分商品</text>
    <image class="header-bar-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-subtitle">积分兑换，好物带回家</text>
  </view>

  <!-- ===== 主内容区 ===== -->
  <view class="main-content">

    <!-- 稻田GIF加载动画 -->
    <farm-loading show="{{loading}}" text="加载中..."></farm-loading>

    <block wx:if="{{!loading}}">

      <!-- ===== 商品轮播 ===== -->
      <view class="section-block anim-section">
        <swiper
          class="detail-swiper"
          indicator-dots="{{true}}"
          autoplay="{{true}}"
          circular="{{true}}"
          interval="3000"
          duration="500"
        >
          <block wx:for="{{swiperList}}" wx:key="id">
            <swiper-item>
              <image
                class="detail-swiper-image"
                src="{{item.image}}"
                mode="aspectFill"
                bindtap="previewImage"
                data-url="{{item.image}}"
                data-group="swiper"
              />
            </swiper-item>
          </block>
        </swiper>
      </view>

      <!-- ===== 商品信息 ===== -->
      <view class="section-block anim-section">
        <view class="section-title-bar">
          <image class="section-title-wheat" src="/images/wheat-reference.png" mode="aspectFit"/>
          <view class="section-title-bar-inner"></view>
          <text class="section-title-text">商品信息</text>
        </view>
        <view class="goods-info">
          <view class="goods-points-row">
            <text class="points-label">积分</text>
            <text class="points-value">{{goods.points || goods.pointsPrice}}</text>
          </view>
          <view class="goods-name">{{goods.name}}</view>
          <view wx:if="{{goods.stock <= 0}}" class="stock-empty">库存不足</view>
          <view wx:elif="{{goods.stock <= 5}}" class="stock-low">仅剩 {{goods.stock}} 件</view>
          <view wx:else class="stock-info">还剩 {{goods.stock}} 份</view>
          <view class="goods-description">
            <text wx:if="{{goods.spec}}" class="goods-spec">{{goods.spec}}</text>
            <text wx:if="{{goods.description}}">{{goods.description}}</text>
          </view>
          <view class="user-points-row">
            <text class="user-points-label">我的积分：</text>
            <text class="user-points-value">{{userPoints}}</text>
          </view>
        </view>
      </view>

      <!-- ===== 商品实拍 ===== -->
      <view class="section-block anim-section" wx:if="{{goods.detailImages && goods.detailImages.length > 0}}">
        <view class="section-title-bar">
          <image class="section-title-wheat" src="/images/wheat-reference.png" mode="aspectFit"/>
          <view class="section-title-bar-inner"></view>
          <text class="section-title-text">商品实拍</text>
        </view>
        <view class="goods-detail-images">
          <view class="detail-image-container">
            <image wx:for="{{goods.detailImages}}" wx:key="*this" class="detail-image" src="{{item}}" mode="widthFix" bindtap="previewImage" data-url="{{item}}" data-group="detail" />
          </view>
        </view>
      </view>

    </block>

    <!-- ===== 底部装饰 ===== -->
    <view class="footer-decoration">
      <image class="footer-wheat footer-wheat-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
      <image class="footer-wheat footer-wheat-br" src="/images/wheat-reference.png" mode="aspectFit"/>
      <view class="footer-rice">
        <view class="footer-rice-text"></view>
      </view>
      <view class="footer-wheat-row">
        <image class="footer-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
        <text class="footer-wheat-sep">✦</text>
        <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
        <text class="footer-wheat-sep">✦</text>
        <image class="footer-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
      </view>
      <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
    </view>
  </view>

  <!-- ===== 底部操作栏 ===== -->
  <view class="bottom-bar">
    <view class="points-display">
      <text>所需积分：</text>
      <text class="points-needed">{{goods.points || goods.pointsPrice}}</text>
    </view>
    <button class="exchange-btn {{goods.stock <= 0 || userPoints < (goods.points || goods.pointsPrice) ? 'disabled' : ''}}"
      bindtap="exchangeNow">
      {{userPoints < (goods.points || goods.pointsPrice) ? '积分不足' : goods.stock <= 0 ? '已兑完' : '立即兑换'}}
    </button>
  </view>
</view>
