@import "../../styles/farm-theme.wxss";

/* ===== 色彩体系 ===== */
page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: var(--rice-gold);
  --rice-green-light: var(--rice-gold-light);
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-danger: #D4765E;
  --rice-danger-light: #E0937E;
  --rice-warm: #F5E6D3;

  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%);
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;

  display: flex;
  flex-direction: column;
}

/* ===== 底部稻田梯田 ===== */
.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: -10%; right: -10%; height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light);
  letter-spacing: 6rpx; font-weight: 400;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative; z-index: 1;
  padding: 0 0 100rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 加载 ===== */
.loading {
  text-align: center; padding: 120rpx;
  font-size: 26rpx; color: var(--rice-text-light);
}

/* ===== 区块容器 ===== */
.section-block {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
 position: relative;
}

.section-block::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

.anim-section {
  opacity: 0; animation: sectionFadeIn 0.6s ease-out forwards;
}
.anim-section:nth-child(2) { animation-delay: 0.1s; }
.anim-section:nth-child(3) { animation-delay: 0.2s; }

/* ===== 区块内边距 ===== */
.section-block > view:not(.section-title-bar):not(.detail-swiper),
.section-block > .goods-info,
.section-block > .goods-detail-images {
  position: relative; z-index: 1;
}

/* ===== 标题栏 ===== */
.section-title-bar {
  display: flex; align-items: center; gap: 12rpx;
  padding: 24rpx 24rpx 0; position: relative; z-index: 1;
}

.section-title-wheat {
  width: 28rpx; height: 36rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; opacity: 0.25;
  animation: wheatSway 3s ease-in-out infinite;
}

.section-title-bar-inner {
  flex: 1; height: 1rpx;
  background: linear-gradient(90deg, rgba(232,200,122,0.3), transparent);
}

.section-title-text {
  font-size: 28rpx; font-weight: 700;
  color: var(--rice-text-secondary); letter-spacing: 2rpx;
  white-space: nowrap;
}

/* ===== 轮播 ===== */
.detail-swiper {
  width: 100%; height: 500rpx;
  background: var(--rice-paper);
}

.detail-swiper-image {
  width: 100%; height: 100%; display: block; object-fit: cover;
}

/* ===== 商品信息 ===== */
.goods-info {
  padding: 24rpx; position: relative; z-index: 1;
}

.goods-points-row {
  display: flex; align-items: baseline; gap: 12rpx;
  margin-bottom: 12rpx;
}

.points-label {
  font-size: 26rpx; color: var(--rice-text-light); font-weight: 500;
}

.points-value {
  font-size: 48rpx; font-weight: 800;
  color: var(--rice-gold);
  text-shadow: 0 2rpx 8rpx rgba(196,149,60,0.15);
}

.goods-name {
  font-size: 30rpx; font-weight: 700;
  color: var(--rice-text); margin-bottom: 12rpx; line-height: 1.4;
}

.stock-empty {
  font-size: 24rpx; color: var(--rice-danger); margin-top: 6rpx; font-weight: 500;
}

.stock-low {
  font-size: 24rpx; color: var(--rice-gold); margin-top: 6rpx; font-weight: 500;
}

.stock-info {
  font-size: 24rpx; color: var(--rice-text-light); margin-top: 6rpx;
}

.goods-description {
  font-size: 26rpx; color: var(--rice-text-secondary);
  line-height: 1.6; margin: 12rpx 0 8rpx;
  padding: 16rpx; background: var(--rice-cream);
  border-radius: 12rpx;
}

.goods-spec {
  display: inline-block;
  background: linear-gradient(135deg, var(--rice-cream), var(--rice-paper));
  color: var(--rice-gold); padding: 4rpx 16rpx; border-radius: 6rpx;
  font-size: 22rpx; font-weight: 600; margin-right: 8rpx;
  border: 1rpx solid rgba(196,149,60,0.15);
}

.user-points-row {
  font-size: 24rpx; color: var(--rice-text-secondary);
  padding-top: 16rpx; border-top: 1rpx solid var(--rice-paper);
  display: flex; align-items: center; justify-content: flex-end; gap: 8rpx;
}

.user-points-label { color: var(--rice-text-light); }

.user-points-value {
  color: var(--rice-gold); font-weight: 700; font-size: 28rpx;
}

/* ===== 商品详情图 ===== */
.goods-detail-images {
  position: relative; z-index: 1;
}

.detail-image-container { width: 100%; display: flex; flex-direction: column; }

.detail-image {
  width: 100%; display: block; line-height: 0; font-size: 0;
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  background: linear-gradient(180deg, rgba(245,240,230,0.4) 0%, rgba(124,179,66,0.1) 40%, rgba(124,179,66,0.18) 100%);
  border-top: 1rpx solid rgba(232,200,122,0.15);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.7;
}
.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  height: 100rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 30rpx var(--rice-shadow);
  border-top: 1rpx solid rgba(232,200,122,0.1);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 28rpx; z-index: 100;
}

.points-display {
  font-size: 26rpx; color: var(--rice-text-secondary);
}

.points-needed {
  color: var(--rice-gold); font-size: 36rpx; font-weight: 800;
  text-shadow: 0 2rpx 8rpx rgba(196,149,60,0.12);
}

.exchange-btn {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff; border: none; border-radius: 36rpx;
  height: 72rpx; padding: 0 44rpx;
  font-size: 28rpx; font-weight: 700; line-height: 72rpx;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.3);
  transition: all 0.2s;
}

.exchange-btn::after { border: none; }

.exchange-btn:active { transform: scale(0.96); opacity: 0.9; }

.exchange-btn.disabled {
  background: var(--rice-straw); color: var(--rice-text-light); box-shadow: none;
}

/* ===== 动画 ===== */
@keyframes sectionFadeIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}
