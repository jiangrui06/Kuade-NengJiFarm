/* ===== 隐私政策页 - 稻田风 ===== */
page {
  background: var(--rice-cream);
}

.page-wrap {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===== 主内容区 ===== */
.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 10;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-wrap: wrap; justify-content: center; align-items: center;
  gap: 12rpx; padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.55;
}
.header-bar-wheat-left { transform: rotate(-15deg); }
.header-bar-wheat-right { transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, #E6B877 0%, #7CB342 50%, #E6B877 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, #E6B877, transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: var(--rice-text-light, #8B7355);
  letter-spacing: 6rpx;
  font-weight: 400;
  width: 100%; text-align: center;
}

/* ===== 内容滚动区 ===== */
.policy-scroll {
  flex: 1;
  padding: 0 24rpx;
  height: 0;
}

.policy-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(92, 61, 46, 0.08);
  margin-bottom: 24rpx;
}

.policy-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5C3D2E;
  text-align: center;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.policy-body {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.policy-text {
  font-size: 26rpx;
  color: #5C3D2E;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

.policy-heading {
  font-size: 28rpx;
  font-weight: 700;
  color: #5C3D2E;
  margin-top: 16rpx;
  margin-bottom: 4rpx;
  line-height: 1.6;
}

.policy-date {
  font-size: 24rpx;
  color: #8B7355;
  text-align: right;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E3D6C0;
}

/* ===== 底部按钮 ===== */
.bottom-btn-wrap {
  padding: 16rpx 24rpx calc(30rpx + env(safe-area-inset-bottom));
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #7CB342 0%, #558B2F 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 44rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(91, 140, 62, 0.35);
}

.btn-confirm:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center; position: relative;
  min-height: 200rpx;
  margin-top: auto;
  width: 100%;
}
.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  pointer-events: none; opacity: 0.9;
}
.footer-wheat-bl { bottom: -70rpx; left: -30rpx; transform: scaleX(-1) rotate(-20deg); }
.footer-wheat-br { bottom: -70rpx; right: -30rpx; transform: rotate(-20deg); }

/* ===== 动画 ===== */
@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}
