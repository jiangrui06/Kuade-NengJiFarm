<view class="page-wrap">

  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-title">菜品详情</text>
    <image class="header-bar-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-subtitle">时令鲜材，匠心烹制</text>
  </view>

  <!-- ===== 主内容区 ===== -->
  <view class="main-content">

    <!-- ===== 轮播 ===== -->
    <view class="section-block anim-section">
      <swiper
        class="detail-swiper"
        indicator-dots="{{true}}"
        autoplay="{{true}}"
        circular="{{true}}"
        interval="3000"
        duration="500"
      >
        <block wx:for="{{swiperList}}" wx:key="id">
          <swiper-item>
            <video wx:if="{{item.type === 'video'}}"
              class="detail-swiper-video"
              src="{{item.image}}"
              poster="{{item.image}}"
              controls="true"
              autoplay="false"
              loop="false"
              muted="false"
              object-fit="cover"
              show-center-play-btn="true"
              enable-progress-gesture="true"
              show-play-btn="true"
              show-fullscreen-btn="true"
              enable-playback-rate="true"
              volume="1.0"
              show-mute-btn="true"
            />
            <image wx:else
              class="detail-swiper-image"
              src="{{item.image}}"
              mode="scaleToFill"
              bindtap="previewSwiperImage"
              data-url="{{item.image}}"
            />
          </swiper-item>
        </block>
      </swiper>
    </view>

    <!-- ===== 菜品信息 ===== -->
    <view class="section-block anim-section">
      <view class="section-title-bar">
        <image class="section-title-wheat" src="/images/wheat-reference.png" mode="aspectFit"/>
        <view class="section-title-bar-inner"></view>
        <text class="section-title-text">菜品信息</text>
      </view>
      <view class="goods-info">
        <view class="price">￥{{goods.price}}</view>
        <view class="name">{{goods.name}}</view>
        <view class="desc" wx:if="{{goods.desc}}">{{goods.desc}}</view>
        <view class="sales-info">
          <text class="sold">已售 {{goods.sold || goods.sales || 0}}</text>
          <text class="stock">仅剩 {{goods.stock || 0}}份</text>
        </view>
      </view>
    </view>

    <!-- ===== 菜品实拍 ===== -->
    <view class="section-block anim-section" wx:if="{{goods.detailImages && goods.detailImages.length > 0}}">
      <view class="section-title-bar">
        <image class="section-title-wheat" src="/images/wheat-reference.png" mode="aspectFit"/>
        <view class="section-title-bar-inner"></view>
        <text class="section-title-text">菜品实拍</text>
      </view>
      <view class="goods-detail-images">
        <view class="detail-image-container">
          <image wx:for="{{goods.detailImages}}" wx:key="*this" class="detail-image" src="{{item}}" mode="widthFix" bindtap="previewDetailImages" data-url="{{item}}" />
        </view>
      </view>
    </view>

    <!-- ===== 底部装饰 ===== -->
    <view class="footer-decoration">
      <image class="footer-wheat footer-wheat-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
      <image class="footer-wheat footer-wheat-br" src="/images/wheat-reference.png" mode="aspectFit"/>
      <view class="footer-rice">
        <view class="footer-rice-text"></view>
      </view>
      <view class="footer-wheat-row">
        <image class="footer-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
        <text class="footer-wheat-sep">✦</text>
        <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
        <text class="footer-wheat-sep">✦</text>
        <image class="footer-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
      </view>
      <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
    </view>
  </view>

  <!-- ===== 底部操作栏 ===== -->
  <view class="bottom-bar">
    <view class="cart-icon" bindtap="viewCart">
      <text class="cart-text">🛒</text>
      <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
    </view>
    <view class="btn-container">
      <button class="add-cart-btn" bindtap="addToCart">加入购物车</button>
      <button class="buy-btn" bindtap="buyNow">立即购买</button>
    </view>
  </view>

  <!-- ===== 桌台提示浮窗 ===== -->
  <view class="table-modal" wx:if="{{showTableModal}}">
    <view class="table-modal-content">
      <view class="table-modal-title">提示</view>
      <view class="table-modal-message">您还没扫码绑定桌号，先绑定了再加入购物车点餐</view>
      <view class="table-modal-buttons">
        <view class="table-modal-button cancel" bindtap="closeTableModal">取消</view>
        <view class="table-modal-button confirm" bindtap="confirmTableModal">确定</view>
      </view>
    </view>
  </view>

  <!-- ===== 客服按钮 ===== -->
  <button class="service-button function-item function-item-btn" open-type="contact">
    <image class="service-icon" src="/images/icons/客服.png" />
  </button>
</view>
