<view class="container">
  <!-- 轮播图和视频 -->
  <swiper
    class="detail-swiper"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    circular="{{true}}"
    interval="3000"
    duration="500"
  >
    <block wx:for="{{swiperList}}" wx:key="id">
      <swiper-item>
        <video wx:if="{{item.type === 'video'}}"
          class="detail-swiper-video"
          src="{{item.image}}"
          poster="{{item.image}}"
          controls="true"
          autoplay="false"
          loop="false"
          muted="false"
          object-fit="cover"
          show-center-play-btn="true"
          enable-progress-gesture="true"
          show-play-btn="true"
          show-fullscreen-btn="true"
          enable-playback-rate="true"
          volume="1.0"
          show-mute-btn="true"
        />
        <image wx:else
          class="detail-swiper-image"
          src="{{item.image}}"
          mode="scaleToFill"
          bindtap="previewSwiperImage"
          data-url="{{item.image}}"
        />
      </swiper-item>
    </block>
  </swiper>

  <!-- 商品信息 -->
  <view class="goods-info">
    <view class="price">￥{{goods.price}}</view>
    <view class="name">{{goods.name}}</view>
    <view class="desc" wx:if="{{goods.desc}}">{{goods.desc}}</view>
    <view class="sales-info">
      <text class="sold">已售 {{goods.sold || goods.sales || 0}}</text>
      <text class="stock">仅剩 {{goods.stock || 0}}份</text>
    </view>
  </view>

  <!-- 规格图 -->
  <view class="goods-detail-images">
    <view class="detail-image-container">
      <image wx:for="{{goods.detailImages}}" wx:key="*this" class="detail-image" src="{{item}}" mode="widthFix" bindtap="previewDetailImages" data-url="{{item}}" />
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="cart-icon" bindtap="viewCart">
      <text class="cart-text">🛒</text>
      <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
    </view>
    <view class="btn-container">
      <button class="add-cart-btn" bindtap="addToCart">加入购物车</button>
      <button class="buy-btn" bindtap="buyNow">立即购买</button>
    </view>
  </view>

  <!-- 桌台提示浮窗 -->
  <view class="table-modal" wx:if="{{showTableModal}}">
    <view class="table-modal-content">
      <view class="table-modal-title">提示</view>
      <view class="table-modal-message">您还没扫码绑定桌号，先绑定了再加入购物车点餐</view>
      <view class="table-modal-buttons">
        <view class="table-modal-button cancel" bindtap="closeTableModal">取消</view>
        <view class="table-modal-button confirm" bindtap="confirmTableModal">确定</view>
      </view>
    </view>
  </view>

  <!-- 客服按钮 -->
  <button class="service-button function-item function-item-btn" open-type="contact">
    <image class="service-icon" src="https://img.icons8.com/ios-glyphs/24/666666/headset.png" />
  </button>
</view>
