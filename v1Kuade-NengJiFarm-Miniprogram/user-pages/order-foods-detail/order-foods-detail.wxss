@import "../../styles/farm-theme.wxss";

/* ===== 色彩体系（覆盖全局，与商品详情一致） ===== */
page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-green: var(--rice-gold);
  --rice-green-light: var(--rice-gold-light);
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-danger: #D4765E;
  --rice-danger-light: #E0937E;
  --rice-warm: #F5E6D3;

  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%);
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;

  display: flex;
  flex-direction: column;
}

/* ===== 底部稻田梯田 ===== */
.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: -10%; right: -10%; height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

.page-wrap::after {
  content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background:

    linear-gradient(155deg, transparent 20%, rgba(255,220,150,0.1) 42%, transparent 65%);
  pointer-events: none; z-index: 0;
}/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-wrap: wrap; justify-content: center; align-items: center;
  gap: 12rpx; padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.5;
}
.header-bar-wheat-left { transform: rotate(-15deg); }
.header-bar-wheat-right { transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light); width: 100%; text-align: center;
  letter-spacing: 6rpx; font-weight: 400;
  width: 100%; text-align: center;
}

/* ===== 主内容区 ===== */
.main-content { padding: 0 0 100rpx; position: relative; z-index: 10; flex: 1; display: flex; flex-direction: column; }

.section-block { margin-top: 24rpx; }

.anim-section { animation: sectionFadeIn 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both; }
.section-block:nth-child(1) { animation-delay: 0.05s; }
.section-block:nth-child(2) { animation-delay: 0.15s; }
.section-block:nth-child(3) { animation-delay: 0.25s; }

/* ===== 区块标题栏 ===== */
.section-title-bar {
  display: flex; align-items: center; margin-bottom: 20rpx; padding: 0 4rpx; gap: 10rpx;
}

.section-title-wheat {
  width: 36rpx; height: 54rpx;
  display: inline-block; animation: wheatBounce 3s ease-in-out infinite; opacity: 0.5;
}

.section-title-bar-inner {
  width: 6rpx; height: 28rpx; border-radius: 3rpx;
  background: linear-gradient(180deg, var(--rice-gold), var(--rice-gold-light));
  margin-right: 4rpx; flex-shrink: 0;
}

.section-title-text {
  font-size: 30rpx; font-weight: 700; color: var(--rice-text);
  letter-spacing: 2rpx; flex: 1;
}

/* ===== 轮播 ===== */
.detail-swiper {
  width: 100%; height: 500rpx; background: var(--rice-paper);
  position: relative; border-radius: 24rpx; overflow: hidden;
  box-shadow: 0 8rpx 32rpx var(--rice-shadow);
}

.detail-swiper-image { width: 100%; height: 100%; display: block; }

.detail-swiper-video { width: 100%; height: 100%; display: block; }

/* ===== 菜品信息卡 ===== */
.goods-info {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  padding: 28rpx; border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.12);
  position: relative;
}

.goods-info::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.price {
  font-size: 44rpx; font-weight: 800; color: var(--rice-gold);
  margin-bottom: 8rpx; letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(196,149,60,0.12);
}

.name {
  font-size: 30rpx; font-weight: 700; color: var(--rice-text);
  margin-bottom: 8rpx; line-height: 1.4;
}

.desc {
  font-size: 26rpx; color: var(--rice-text-secondary);
  line-height: 1.5; margin-bottom: 12rpx;
}

/* 销售信息 */
.sales-info {
  display: flex; justify-content: space-between;
  margin-top: 12rpx; padding-top: 16rpx;
  border-top: 1rpx solid var(--rice-paper);
}

.sold { font-size: 24rpx; color: var(--rice-text-light); }

.stock { font-size: 24rpx; color: var(--rice-text-light); }

/* ===== 菜品实拍图 ===== */
.goods-detail-images {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  border-radius: 24rpx; overflow: hidden;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.12);
  position: relative;
}

.goods-detail-images::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196,149,60,0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232,200,122,0.02) 0%, transparent 100%);
  pointer-events: none;
}

.detail-image-container { width: 100%; display: flex; flex-direction: column; }

.detail-image { width: 100%; display: block; }

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.45;
}

.footer-wheat-right { animation-delay: 0.6s; }


.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  pointer-events: none; opacity: 0.9;
}
.footer-wheat-bl { bottom: -70rpx; left: -30rpx; transform: scaleX(-1) rotate(-20deg); }
.footer-wheat-br { bottom: -70rpx; right: -30rpx; transform: rotate(-20deg); }

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx); -webkit-backdrop-filter: blur(20rpx);
  display: flex; align-items: center; padding: 0 24rpx;
  box-shadow: 0 -4rpx 30rpx var(--rice-shadow);
  z-index: 100; gap: 16rpx;
}

.cart-icon {
  position: relative; width: 72rpx; height: 72rpx; display: flex;
  align-items: center; justify-content: center; background: var(--rice-paper);
  border-radius: 50%; flex-shrink: 0;
}

.cart-text { font-size: 40rpx; }

.cart-badge {
  position: absolute; top: -4rpx; right: -4rpx; min-width: 32rpx; height: 32rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff; font-size: 18rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center; padding: 0 6rpx;
}

.btn-container { flex: 1; display: flex; gap: 16rpx; }

.add-cart-btn {
  flex: 1; height: 72rpx; background: transparent; color: var(--rice-gold);
  border: 2rpx solid var(--rice-gold); border-radius: 36rpx;
  font-size: 26rpx; font-weight: 600; display: flex; align-items: center;
  justify-content: center; padding: 0; line-height: 1; transition: all 0.2s;
}

.add-cart-btn::after { border: none; }
.add-cart-btn:active { background: rgba(196,149,60,0.08); transform: scale(0.96); }

.buy-btn {
  flex: 1; height: 72rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff; border: none; border-radius: 36rpx; font-size: 26rpx;
  font-weight: 700; display: flex; align-items: center; justify-content: center;
  padding: 0; line-height: 1;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.3); transition: all 0.2s;
}

.buy-btn::after { border: none; }
.buy-btn:active { transform: scale(0.96); opacity: 0.9; }

/* ===== 桌台提示浮窗 ===== */
.table-modal {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(44, 24, 16, 0.5);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000; animation: fadeIn 0.25s ease-out;
}

.table-modal-content {
  width: 80%; max-width: 500rpx; background: #fff;
  border-radius: 28rpx; padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx var(--rice-shadow-strong);
  animation: scaleIn 0.3s ease-out;
}

.table-modal-title {
  font-size: 34rpx; font-weight: 700; color: var(--rice-text);
  text-align: center; margin-bottom: 16rpx;
}

.table-modal-message {
  font-size: 28rpx; color: var(--rice-text-secondary);
  text-align: center; margin-bottom: 36rpx; line-height: 1.6;
}

.table-modal-buttons { display: flex; gap: 20rpx; }

.table-modal-button {
  flex: 1; height: 80rpx; border-radius: 40rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; font-weight: 700;
}

.table-modal-button::after { border: none; }

.table-modal-button.cancel {
  background: var(--rice-paper); color: var(--rice-text-secondary);
}
.table-modal-button.cancel:active { background: var(--rice-straw); }

.table-modal-button.confirm {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff; box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.25);
}
.table-modal-button.confirm:active { opacity: 0.9; }

/* ===== 客服按钮 ===== */
.service-button {
  position: fixed; bottom: 140rpx; left: 24rpx; width: 88rpx; height: 88rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(196,149,60,0.4); z-index: 99;
  padding: 0; margin: 0; line-height: 1; border: none;
}

.service-button::after { border: none; }
.service-button:active { transform: scale(0.9); }

.service-button .service-icon {
  width: 80rpx; height: 80rpx;
}

/* ===== 动画 ===== */
@keyframes sectionFadeIn {
  from { opacity: 0; transform: translateY(40rpx) scale(0.97); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}
