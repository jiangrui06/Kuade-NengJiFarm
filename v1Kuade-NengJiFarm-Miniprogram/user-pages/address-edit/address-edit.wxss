@import "../../styles/farm-theme.wxss";

/* 编辑地址 - 稻田风 · 高级版 */
page {
  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%,
      #FCF0DC 12%,
      #FAEBD5 25%,
      #F9E6CE 38%,
      #F7E0C5 50%,
      #F5DABC 62%,
      #F2D4B3 75%,
      #EFCEAA 88%,
      #ECC8A1 100%
    );
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx;

  display: flex;
  flex-direction: column;
}

.page-wrap::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: -10%;
  right: -10%;
  height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

.wheat-stalk {
  background: var(--wheat-deco) center/contain no-repeat;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 24rpx 16rpx;
  position: relative;
  z-index: 1;
}

.header-bar-wheat-left,
.header-bar-wheat-right {
  width: 48rpx;
  height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block;
  animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3;
  position: absolute;
  top: 26rpx;
}

.header-bar-wheat-left {
  left: 40rpx;
  transform: rotate(-15deg);
}

.header-bar-wheat-right {
  right: 40rpx;
  transform: rotate(15deg);
  animation-delay: 0.6s;
}

.header-title {
  font-size: 38rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
  text-shadow: none;
  position: relative;
}

.header-title::after {
  content: '';
  display: block;
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0;
  border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx;
  color: var(--rice-text-light);
  letter-spacing: 6rpx;
  font-weight: 400;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative;
  z-index: 10;
  padding: 0 0 100rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 表单内容 ===== */
.form-content {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 50%, #FDF3E4 100%);
  margin: -10rpx 20rpx 0;
  border-radius: 24rpx;

  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.08);
  position: relative;
  z-index: 2;
}

.form-content::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

/* 金色顶边 */
.form-content::after {
  content: '';
  position: absolute;
  top: 0;
  left: 48rpx;
  right: 48rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  z-index: 1;
}

/* ===== 表单项 ===== */
.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid var(--rice-paper);
  transition: all 0.3s;
}

.form-item:last-child { border-bottom: none; }

.form-item:active { background: var(--rice-cream); }

.form-label {
  font-size: 28rpx;
  color: var(--rice-text);
  width: 150rpx;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--rice-text-secondary);
  text-align: right;
  padding-right: 20rpx;
  height: 48rpx;
  line-height: 48rpx;
  border: none;
  outline: none;
  background: transparent;
}

.form-input::placeholder {
  color: var(--rice-text-light);
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: var(--rice-text-secondary);
  min-height: 140rpx;
  padding: 16rpx 20rpx 16rpx 0;
  text-align: right;
  line-height: 1.5;
  border: none;
  outline: none;
  background: transparent;
  resize: none;
}

.form-textarea::placeholder {
  color: var(--rice-text-light);
}

/* ===== 手机号容器 ===== */
.phone-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.phone-input {
  flex: 1;
  text-align: right;
}

.get-phone-btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
  border: none;
  white-space: nowrap;
  line-height: 1.5;
  font-weight: 500;
  transition: all 0.2s;
  box-shadow: 0 2rpx 12rpx rgba(196,149,60,0.2);
}

.get-phone-btn::after { border: none; }

.get-phone-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* ===== 地区选择 ===== */
.region-select {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 48rpx;
  line-height: 48rpx;
}

.region-text {
  font-size: 28rpx;
  color: var(--rice-text-secondary);
  margin-right: 12rpx;
  text-align: right;
  flex: 1;

  text-overflow: ellipsis;
  white-space: nowrap;
}

.region-arrow {
  font-size: 36rpx;
  color: var(--rice-text-light);
  font-weight: 300;
}

/* ===== 复选框 ===== */
.checkbox-container {
  padding-right: 20rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid var(--rice-straw);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  background: #fff;
}

.checkbox.checked {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  border-color: var(--rice-gold);
}

.checkbox-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

/* ===== 保存按钮 ===== */
.save-btn-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx 20rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  transition: all 0.2s;
}

.save-btn-inner {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-gold-light));
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.25);
  border-radius: 40rpx;
}

.save-btn-inner:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.save-btn-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx 30rpx;
  position: relative;
  background: linear-gradient(180deg, transparent 0%, rgba(124, 179, 66, 0.06) 40%, rgba(124, 179, 66, 0.1) 100%);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
}

.footer-rice {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.footer-rice-text {
  width: 42rpx;
  height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block;
  animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.footer-wheat-left,
.footer-wheat-right {
  width: 36rpx;
  height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block;
  animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.25;
}

.footer-wheat-right {
  animation-delay: 0.6s;
}

.footer-wheat-sep {
  font-size: 14rpx;
  color: var(--rice-straw);
}

.footer-wheat-center {
  font-size: 24rpx;
  color: var(--rice-text-secondary);
  letter-spacing: 3rpx;
  font-weight: 500;
}

.footer-text {
  font-size: 20rpx;
  color: var(--rice-text-light);
  letter-spacing: 4rpx;
}

.footer-wheat {
  position: absolute;
  width: 220rpx;
  height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none;
  opacity: 0.7;
}

.footer-wheat-bl { bottom: -80rpx; left: -60rpx; transform: rotate(45deg); }
.footer-wheat-br { bottom: -80rpx; right: -60rpx; transform: rotate(-45deg); }

/* ===== 麦穗摇摆动画 ===== */
@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
  75% { transform: rotate(5deg) scaleX(1.02); }
}

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  30% { transform: translateY(-12rpx) rotate(-2deg); }
  60% { transform: translateY(-6rpx) rotate(2deg); }
  80% { transform: translateY(-10rpx) rotate(-1deg); }
}
