<view class="page-wrap">
  <!-- ===== 顶部标题栏 ===== -->
  <view class="header-bar">
    <image class="header-bar-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-title">{{addressId ? '编辑地址' : '新增地址'}}</text>
    <image class="header-bar-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
    <text class="header-subtitle">填写收货信息</text>
  </view>

  <view class="main-content">

  <!-- 表单内容 -->
  <view class="form-content">
    <!-- 收货人 -->
    <view class="form-item">
      <view class="form-label">收货人</view>
      <input class="form-input" value="{{formData.name}}" data-field="name" bindinput="onInputChange" placeholder="请输入收货人姓名" />
    </view>

    <!-- 手机号码 -->
    <view class="form-item phone-item">
      <view class="form-label">手机号码</view>
      <view class="phone-container">
        <input class="form-input phone-input" value="{{formData.phone}}" data-field="phone" bindinput="onInputChange" placeholder="请输入手机号" type="number" />
        <button class="get-phone-btn" open-type="getPhoneNumber" bind:getphonenumber="onGetPhoneNumber">
          获取手机号
        </button>
      </view>
    </view>

    <!-- 所在地区 -->
    <view class="form-item" bindtap="chooseRegion">
      <view class="form-label">所在地区</view>
      <view class="region-select">
        <text class="region-text">{{formData.address}}</text>
        <text class="region-arrow">›</text>
      </view>
    </view>

    <!-- 详细地址 -->
    <view class="form-item">
      <view class="form-label">详细地址</view>
      <textarea class="form-textarea" value="{{formData.detail}}" data-field="detail" bindinput="onInputChange" placeholder="请输入详细地址" />
    </view>

    <!-- 设为默认地址 -->
    <view class="form-item checkbox-item" bindtap="toggleDefault">
      <view class="form-label">设为默认地址</view>
      <view class="checkbox-container">
        <view class="checkbox {{formData.isDefault ? 'checked' : ''}}">
          <text wx:if="{{formData.isDefault}}" class="checkbox-icon">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-btn-bar" bindtap="saveAddress">
    <view class="save-btn-inner">
      <text class="save-btn-text">保存</text>
    </view>
  </view>

  <!-- ===== 底部装饰 ===== -->
  <view class="footer-decoration">
    <image class="footer-wheat footer-wheat-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
    <image class="footer-wheat footer-wheat-br" src="/images/wheat-reference.png" mode="aspectFit"/>
    <view class="footer-rice">
      <view class="footer-rice-text"></view>
    </view>
    <view class="footer-wheat-row">
      <image class="footer-wheat-left" src="/images/wheat-reference.png" mode="aspectFit"/>
      <text class="footer-wheat-sep">·</text>
      <text class="footer-wheat-center">稻田时光农场 · 自然之味</text>
      <text class="footer-wheat-sep">·</text>
      <image class="footer-wheat-right" src="/images/wheat-reference.png" mode="aspectFit"/>
    </view>
    <text class="footer-text">从田间到餐桌 · 每一口都是自然的味道</text>
  </view>
  </view>
</view>
