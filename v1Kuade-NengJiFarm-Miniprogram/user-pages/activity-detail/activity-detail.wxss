.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 头部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  background-color: #fff;
  padding: 0 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.header-left::before {
  content: '←';
  font-size: 40rpx;
  color: #333;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  width: 60rpx;
}

/* 活动图片 → 改为轮播 */
.activity-swiper {
  width: 100%;
  height: 400rpx;
}

.activity-swiper-image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.activity-swiper-video {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

/* 兼容旧样式（保留以防其他地方引用） */
.activity-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

/* 活动信息 */
.activity-info {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.activity-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.activity-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.activity-price {
  font-size: 28rpx;
  color: #e64340;
  font-weight: bold;
}

.activity-date {
  font-size: 24rpx;
  color: #666;
}

.activity-description {
  font-size: 24rpx;
  color: #666;
  line-height: 40rpx;
}

/* 活动详情 */
.activity-details {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 24rpx;
  letter-spacing: 3rpx;
  display: flex;
  align-items: center;
  height: 36rpx;
  line-height: 36rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

.detail-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.detail-label {
  width: 150rpx;
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  line-height: 40rpx;
}

.detail-value.highlight {
  color: #e64340;
  font-weight: bold;
}

.detail-value.success {
  color: #52c41a;
  font-weight: bold;
}

/* 活动图片展示 */
.activity-gallery {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

/* 农场示例图片：widthFix 模式下不设固定 height */
.example-images-vertical {
  display: flex;
  flex-direction: column;
  gap: 0rpx;
}

.example-images-vertical image {
  width: 100%;
  display: block;
  border-radius: 8rpx;
  background-color: #f0f0f0;
  margin: 0;
  padding: 0;
  cursor: pointer;
}





/* 底部按钮 */
.bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.contact-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border: 2rpx solid #e64340;
  color: #e64340;
  border-radius: 40rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  background-color: #fff;
}

.register-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #e64340;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

/* 响应式调整 */
@media screen and (max-width: 375px) {
  .detail-label {
    width: 120rpx;
  }
}

/* 二维码页面 */
.qrcode-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.qrcode-content {
  width: 80%;
  max-width: 500rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.qrcode-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.qrcode-subtitle {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.qrcode-image {
  width: 300rpx;
  height: 300rpx;
  margin: 0 auto 40rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.qrcode-image image {
  width: 100%;
  height: 100%;
}

.qrcode-hint {
  margin-bottom: 40rpx;
  text-align: left;
}

.qrcode-hint text {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.back-btn {
  width: 100%;
  background-color: #e64340;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(230, 67, 64, 0.3);
  border: none;
  padding: 0;
  margin: 0;
}

.back-btn::after {
  border: none;
}

/* 客服按钮 */
.service-button {
  position: fixed;
  bottom: 160rpx;
  left: 20rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #e64340;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(230, 67, 64, 0.4);
  z-index: 9999;
  transform: translateZ(0);
  -webkit-tap-highlight-color: transparent;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: none;
}

.service-button::after {
  border: none;
}

.service-button .service-icon {
  width: 50rpx;
  height: 50rpx;
  filter: invert(100%) sepia(0%) saturate(0%) hue-rotate(90deg) brightness(200%) contrast(100%);
}