.container {
  padding: 16rpx;
  min-height: 100vh;
  background-color: #FAF6F0;
  padding-top: 32rpx;
  position: relative;
  margin-top: 0;
  padding-bottom: 140rpx;
}

/* 桌号显示 */
.table-number-display {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.1);
  z-index: 10;
  margin-bottom: 20rpx;
}

.table-number-display .table-label {
  font-weight: bold;
  margin-right: 8rpx;
}

.table-number-display .table-value {
  font-weight: bold;
  color: #D4A76A;
}

.table-number-display .table-value.placeholder {
  color: #999;
  font-weight: normal;
}

.table-number-display .arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #999;
}

/* 地址区域 */
.address-section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.1);
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.address-header .section-title {
  margin: 0;
  padding-left: 0;
}

.address-header .section-title::before {
  display: none;
}

.select-more-address {
  font-size: 24rpx;
  color: #D4A76A;
}

.address-list {
  margin-bottom: 0;
}

.no-address {
  text-align: center;
  padding: 20rpx 0;
}

.no-address-text {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.add-address-btn {
  background-color: #D4A76A !important;
  color: #fff !important;
  border: none !important;
  border-radius: 24rpx !important;
  padding: 16rpx 40rpx !important;
  font-size: 26rpx !important;
  font-weight: 500 !important;
  margin-top: 8rpx !important;
  line-height: 1.5 !important;
}

.address-item {
  background-color: #FAF6F0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
}

.address-item:last-child {
  margin-bottom: 0;
}

.address-item.active {
  border-color: #D4A76A;
  background-color: #FFFDF8;
}

.address-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.address-top-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.default-tag {
  font-size: 18rpx;
  color: #fff;
  background-color: #D4A76A;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  margin-left: 12rpx;
}

.address-phone {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.address-detail {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  word-break: break-all;
}

.address-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  margin-left: 16rpx;
  min-width: 100rpx;
}

.address-check-container {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #D4A76A;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.address-item.active .address-check-container {
  background-color: #D4A76A;
}

.address-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #D4A76A;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.edit-address-btn {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 24rpx;
  background-color: #fff;
  margin-top: 8rpx;
  transition: all 0.3s ease;
}

.edit-address-btn:active {
  background-color: #FAF6F0;
}

/* 桌台选择弹窗 */
.table-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.table-modal-content {
  background: white;
  width: 80%;
  border-radius: 16rpx;
  overflow: hidden;
}

.table-modal-header {
  padding: 32rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: bold;
}

.table-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.table-modal-close {
  font-size: 48rpx;
  color: #999;
  cursor: pointer;
}

.table-modal-body {
  padding: 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.table-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.table-item {
  padding: 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333;
  cursor: pointer;
  transition: all 0.3s ease;
}

.table-item:active {
  transform: scale(0.95);
}

.table-item.selected {
  background: #D4A76A;
  color: white;
  border-color: #D4A76A;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin: 0 0 20rpx 0;
  color: #333;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #D4A76A 0%, #E8C69A 50%, #D4A76A 100%);
  border-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
  margin-right: 0;
}

/* 订单商品列表 */
.order-items {
  background-color: white;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.item-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.item-quantity {
  font-size: 28rpx;
  color: #666;
}

/* 支付方式 */
.payment-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-item.selected {
  background-color: #f0f9ff;
}

.payment-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.payment-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.payment-check {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: #1890ff;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 订单汇总 */
.order-summary {
  background-color: white;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 120rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.total-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 24rpx;
  z-index: 100;
}

.total-info {
  font-size: 28rpx;
  color: #333;
}

.confirm-btn {
  background-color: #D4A76A;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  line-height: 1.5;
}

.confirm-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.confirm-btn[disabled] {
  background-color: #ccc;
  color: #999;
  box-shadow: none;
  pointer-events: none;
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  background-color: white;
  padding: 48rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #333;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
