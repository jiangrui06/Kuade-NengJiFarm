<!-- 确认订单页面 -->
<view class="container">

  <!-- ===== 稻田背景动画层 ===== -->
  <view class="bg-sun"></view>
  <view class="bg-cloud bg-cloud-1"></view>
  <view class="bg-cloud bg-cloud-2"></view>
  <view class="bg-cloud bg-cloud-3"></view>
  <view class="bg-bird"></view>
  <view class="bg-bird bg-bird-2"></view>
  <view class="bg-bird bg-bird-3"></view>
  <view class="bg-butterfly"></view>
  <view class="bg-butterfly bg-butterfly-2"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:5%;top:20%;animation-delay:0s"></view>
  <view class="bg-float-grain bg-grain-sm" style="left:28%;top:15%;animation-delay:3s"></view>
  <view class="bg-float-grain bg-grain-md" style="left:52%;top:12%;animation-delay:2.2s"></view>
  <view class="bg-float-grain bg-grain-lg" style="left:75%;top:40%;animation-delay:1.2s"></view>
  <view class="bg-firefly" style="left:8%;top:55%;animation-delay:0s;animation-duration:7s"></view>
  <view class="bg-firefly" style="left:42%;top:50%;animation-delay:3s;animation-duration:8s"></view>
  <view class="bg-firefly" style="left:78%;top:52%;animation-delay:2s;animation-duration:7.5s"></view>
  <view class="bg-pollen" style="left:12%;top:28%;animation-delay:0s;animation-duration:11s"></view>
  <view class="bg-pollen" style="left:48%;top:35%;animation-delay:4s;animation-duration:10s"></view>
  <view class="bg-pollen" style="left:80%;top:38%;animation-delay:1.5s;animation-duration:14s"></view>

  <!-- 稻田加载动画 -->
  <farm-loading show="{{loading}}" text="加载中..."></farm-loading>

  <!-- ===== 四角麦穗装饰 ===== -->
   <image class="wheat-corner-tl" src="/images/615.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/615.png" mode="aspectFit"/>
  <!-- 点餐显示桌号，商品显示地址 -->
  <view wx:if="{{orderType === 'food'}}" class="table-number-display" bindtap="showTableModal">
    <text class="table-label">桌号：</text>
    <text class="table-value {{tableNumber ? '' : 'placeholder'}}">{{tableNumber ? tableNumber : '请选择'}}</text>
    <text class="arrow">▼</text>
  </view>

  <!-- 配送方式选择（商品订单） -->
  <view wx:if="{{orderType === 'goods'}}" class="delivery-method-section">
    <view class="section-title">配送方式</view>
    <view class="delivery-methods">
      <view
        wx:for="{{deliveryMethods}}"
        wx:key="id"
        class="delivery-method-item {{deliveryMethod === item.id ? 'selected' : ''}}"
        bindtap="selectDeliveryMethod"
        data-method="{{item.id}}">
        <view class="delivery-method-radio">
          <view class="radio-circle {{deliveryMethod === item.id ? 'checked' : ''}}">
            <text wx:if="{{deliveryMethod === item.id}}">✓</text>
          </view>
        </view>
        <view class="delivery-method-info">
          <text class="delivery-method-name">{{item.name}}</text>
          <text class="delivery-method-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 收货地址（仅快递配送时显示） -->
  <view wx:if="{{orderType === 'goods' && deliveryMethod === 'express'}}" class="address-section" bindtap="goToAddress">
    <view class="address-header">
      <text class="section-title">收货地址</text>
      <text class="address-arrow">〉</text>
    </view>
    <view wx:if="{{defaultAddress}}" class="address-card">
      <view class="address-card-top">
        <text class="address-name">{{defaultAddress.name}}</text>
        <text class="address-phone">{{defaultAddress.phone}}</text>
        <text wx:if="{{defaultAddress.isDefault}}" class="default-tag">默认</text>
      </view>
      <text class="address-detail-text">{{defaultAddress.detail}}</text>
    </view>
    <view wx:else class="no-address">
      <text class="no-address-text">请选择收货地址</text>
    </view>
  </view>

  <!-- 订单商品列表 -->
  <view class="order-items">
    <view class="section-title">商品信息</view>
    <view wx:for="{{orderInfo.items}}" wx:key="id" class="order-item">
      <image class="item-image" src="{{item.image}}" />
      <view class="item-info">
        <view class="item-name">{{item.name}}</view>
        <view class="item-price">￥{{item.price}}</view>
      </view>
      <view class="item-quantity">x{{item.quantity}}</view>
    </view>
  </view>

  <!-- 订单备注 -->
  <view class="remark-section" wx:if="{{orderType === 'food'}}">
    <view class="section-title">订单备注</view>
    <view class="remark-input-wrapper">
      <textarea class="remark-input" placeholder="请输入备注（如：不要香菜、少辣等）" maxlength="{{remarkMaxLength}}" value="{{remark}}" bindinput="onRemarkInput" auto-height />
      <text class="remark-count">{{remark.length}}/{{remarkMaxLength}}</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="payment-section">
    <view class="section-title">支付方式</view>
    <view wx:for="{{paymentMethods}}" wx:key="id" 
          class="payment-item {{selectedPayment === item.id ? 'selected' : ''}}"
          bindtap="selectPayment" data-id="{{item.id}}">
      <view class="payment-icon">{{item.icon}}</view>
      <view class="payment-name">{{item.name}}</view>
      <view class="payment-check" wx:if="{{selectedPayment === item.id}}">✓</view>
    </view>
  </view>

  <!-- 价格明细 -->
  <view class="price-detail-section">
    <view class="section-title">价格明细</view>
    <view class="price-detail-body">
      <view class="price-row">
        <text class="price-label">商品金额</text>
        <text class="price-value">￥{{goodsAmount}}</text>
      </view>
      <view wx:if="{{orderType === 'goods'}}" class="price-row">
        <text class="price-label">运费</text>
        <text class="price-value {{freight > 0 ? '' : 'free'}}">{{freight > 0 ? '￥' + freight : '免运费'}}</text>
      </view>
      <view class="price-row price-total-row">
        <text class="price-total-label">实付金额</text>
        <text class="price-total-value">￥{{actualPay}}</text>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <view class="total-info">
      <text>合计：</text>
      <text class="total-price">￥{{actualPay}}</text>
    </view>
    <button class="confirm-btn" bindtap="confirmOrder" disabled="{{loading}}">
      确认订单
    </button>
  </view>

  <!-- 桌台选择弹窗 -->
  <view class="table-modal" wx:if="{{showTableModal && orderType === 'food'}}">
    <view class="table-modal-content">
      <view class="table-modal-header">
        <text class="table-modal-title">选择桌台</text>
        <view class="table-modal-close" bindtap="hideTableModal">×</view>
      </view>
      <view class="table-modal-body">
        <view class="table-grid">
          <view
            wx:for="{{tableList}}"
            wx:key="id"
            class="table-item {{tableNumber === item.id ? 'selected' : ''}}"
            bindtap="selectTableNumber"
            data-table-id="{{item.id}}"
          >
            <text class="table-item-num">{{item.name}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

</view>
