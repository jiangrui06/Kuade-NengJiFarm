<farm-loading show="{{loading}}" text="加载中..."></farm-loading>
<block wx:if="{{!loading}}">
<view class="container">
  <!-- ===== 四角麦穗装饰 ===== -->
  <image class="wheat-corner-tl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-tr" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-bl" src="/images/wheat-reference.png" mode="aspectFit"/>
  <image class="wheat-corner-br" src="/images/wheat-reference.png" mode="aspectFit"/>

  <!-- 页面头部 -->
  <view class="page-header-sm">
    <view class="page-header-sm-bg"></view>
    <view class="page-header-sm-content">
      <text class="page-header-sm-icon">👤</text>
      <text class="page-header-sm-title">编辑资料</text>
      <text class="page-header-sm-subtitle">修改个人信息</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content">
    <!-- 用户头像 -->
    <view class="form-item">
      <view class="form-label">用户头像</view>
      <button class="avatar-button" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar" src="{{userInfo.avatar || 'https://img.icons8.com/ios-glyphs/64/999/user.png'}}" />
      </button>
    </view>
    
    <!-- 用户昵称 -->
    <view class="form-item">
      <view class="form-label">用户昵称</view>
      <input class="form-input" type="nickname" value="{{userInfo.nickname}}" bindinput="onNicknameChange" placeholder="点击输入或获取微信昵称" />
    </view>
    
    <!-- 性别 -->
    <view class="form-item" bindtap="chooseGender">
      <view class="form-label">性别</view>
      <view class="gender-select">
        <text class="gender-text">{{userInfo.gender || '保密'}}</text>
        <text class="gender-arrow">></text>
      </view>
    </view>
    
    <!-- 手机号码 -->
    <view class="form-item">
      <view class="form-label">手机号码</view>
      <view class="form-text">{{userInfo.phone || '未绑定'}}</view>
    </view>
    
    
  </view>
  
  <!-- 保存按钮 -->
  <view class="save-btn" bindtap="saveProfile">
    <text class="save-btn-text">保存</text>
  </view>
</view>
</block>
