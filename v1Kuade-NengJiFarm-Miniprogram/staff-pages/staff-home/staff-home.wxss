.staff-page {
  min-height: 100vh;
  background-color: #F5F0E8;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ===== 顶部信息栏 ===== */
.staff-header {
  position: relative;
  padding: 90rpx 32rpx 50rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(145deg, #D4A76A 0%, #B8915A 60%, #A07D4A 100%);
}

.header-decor-circle1 {
  position: absolute;
  top: -80rpx;
  right: -60rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.header-decor-circle2 {
  position: absolute;
  bottom: -30rpx;
  left: 15%;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.header-content {
  position: relative;
  display: flex;
  align-items: center;
}

.avatar-wrap {
  width: 108rpx;
  height: 108rpx;
  background: rgba(255,255,255,0.22);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border: 4rpx solid rgba(255,255,255,0.4);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.1);
}

.avatar-emoji {
  font-size: 48rpx;
}

.header-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.staff-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.role-badge {
  display: inline-block;
  padding: 2rpx 14rpx;
  font-size: 18rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 16rpx;
  font-weight: 500;
}

.staff-greeting {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
}

.logout-btn {
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 36rpx;
}

.logout-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ===== 今日数据卡片 ===== */
.stats-card {
  margin: -34rpx 24rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(212, 167, 106, 0.15);
  display: flex;
  justify-content: center;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.stat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #E8F5E9, #C8E6C9);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stat-emoji {
  font-size: 38rpx;
}

.stat-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 60rpx;
  font-weight: 800;
  color: #D4A76A;
  line-height: 1.1;
  letter-spacing: -2rpx;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 1rpx;
}

/* ===== 核心功能 ===== */
.work-section {
  padding: 0 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

.title-bar {
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #D4A76A, #C99A5A);
  border-radius: 3rpx;
}

.work-grid {
  display: flex;
  gap: 20rpx;
}

.work-item {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 24rpx rgba(212, 167, 106, 0.1);
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.work-item:active {
  transform: scale(0.97);
  border-color: #D4A76A;
  box-shadow: 0 6rpx 28rpx rgba(212, 167, 106, 0.2);
}

.work-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.verify-gradient {
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  box-shadow: 0 4rpx 14rpx rgba(212, 167, 106, 0.25);
}

.work-emoji {
  font-size: 42rpx;
}

.work-info {
  flex: 1;
  min-width: 0;
}

.work-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #2a2a2a;
  display: block;
  margin-bottom: 4rpx;
}

.work-desc {
  font-size: 20rpx;
  color: #aaa;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.work-arrow {
  font-size: 38rpx;
  color: #ccc;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* ===== 底部导航栏 ===== */
.custom-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(120rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #FAF6F0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #EDE8DD;
  z-index: 9999;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0 18rpx;
}

.bar-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 10rpx;
  display: block;
}

.bar-text {
  font-size: 22rpx;
  color: #B8A98E;
  line-height: 1.2;
}

.bar-text-active {
  color: #D4A76A;
  font-weight: 600;
}
