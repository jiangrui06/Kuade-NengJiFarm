/* pages/staff-login/staff-login.wxss */
.container {
  position: relative;
  width: 100%;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #2C3E50 0%, #1A252F 100%);
}

.status-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: transparent;
}

/* 背景装饰圆圈 */
.bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 0;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, #D4A76A, #E8B878);
  top: -100rpx;
  right: -100rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: linear-gradient(135deg, #E8B878, #D4A76A);
  bottom: 100rpx;
  left: -80rpx;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #D4A76A, #B8894E);
  top: 40%;
  left: 60%;
}

.content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 100vh;
  padding: 80rpx 48rpx 60rpx;
  box-sizing: border-box;
}

/* 头部区域 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 60rpx;
  animation: fadeInDown 0.8s ease-out;
}

@keyframes fadeInDown {
  from {
    opacity: 0;
    transform: translateY(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 员工徽章 */
.staff-badge {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(212, 167, 106, 0.2), rgba(184, 137, 78, 0.1));
  border: 2rpx solid rgba(212, 167, 106, 0.3);
  border-radius: 40rpx;
  padding: 12rpx 28rpx;
  margin-bottom: 40rpx;
  backdrop-filter: blur(10rpx);
}

.badge-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #D4A76A;
  font-weight: 600;
  letter-spacing: 3rpx;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.brand-tagline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  letter-spacing: 3rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  max-width: 600rpx;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 
    0 20rpx 60rpx rgba(0, 0, 0, 0.4),
    0 8rpx 24rpx rgba(0, 0, 0, 0.2);
  animation: fadeInUp 0.8s ease-out 0.2s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 卡片头部 */
.card-header {
  background: linear-gradient(135deg, #D4A76A 0%, #B8894E 100%);
  padding: 40rpx 40rpx 32rpx;
  text-align: center;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

/* 表单主体 */
.form-body {
  padding: 48rpx 40rpx 44rpx;
}

.input-group {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
}

.input-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #F5EFD8, #E8D9BE);
  border-radius: 20rpx 0 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(212, 167, 106, 0.3);
  border-right: none;
}

.input-icon {
  font-size: 24rpx;
  font-weight: 600;
  color: #8B6914;
}

.input-wrapper {
  flex: 1;
  position: relative;
  display: flex;
  align-items: center;
  background: #FAF7F0;
  border-radius: 0 20rpx 20rpx 0;
  border: 2rpx solid rgba(212, 167, 106, 0.3);
  border-left: none;
  transition: all 0.3s ease;
  height: 88rpx;
}

.input-group:focus-within .input-icon-wrapper {
  background: linear-gradient(135deg, #D4A76A, #B8894E);
  border-color: #D4A76A;
}

.input-group:focus-within .input-wrapper {
  border-color: #D4A76A;
  background: #FFFFFF;
  box-shadow: 0 0 0 4rpx rgba(212, 167, 106, 0.1);
}

.input-field {
  flex: 1;
  height: 100%;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #2C3E50;
  font-weight: 500;
}

.input-placeholder {
  color: #A8987A;
}

.password-toggle {
  padding: 0 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #B8894E;
  opacity: 0.8;
  transition: all 0.3s ease;
}

.password-toggle:active {
  opacity: 1;
  color: #D4A76A;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 108rpx;
  background: linear-gradient(135deg, #2C3E50 0%, #1A252F 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 
    0 12rpx 32rpx rgba(44, 62, 80, 0.4),
    0 4rpx 12rpx rgba(0, 0, 0, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.1);
  border: none;
  line-height: 108rpx;
  padding: 0;
  margin-top: 16rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  letter-spacing: 3rpx;
}

.login-btn::after {
  border: none;
}

.login-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
  animation: shine 3s infinite;
}

@keyframes shine {
  0% { left: -100%; }
  20% { left: 100%; }
  100% { left: 100%; }
}

.login-btn[disabled] {
  opacity: 0.6;
}

.login-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
  box-shadow: 
    0 8rpx 24rpx rgba(44, 62, 80, 0.35),
    0 4rpx 12rpx rgba(0, 0, 0, 0.25);
}

.loading-text {
  font-size: 32rpx;
  letter-spacing: 2rpx;
}

/* 底部区域 */
.footer-section {
  width: 100%;
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: fadeInUp 0.8s ease-out 0.4s both;
}

.help-tips {
  margin-bottom: 32rpx;
}

.tips-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.switch-section {
  display: flex;
  align-items: center;
}

.switch-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 600;
  padding: 16rpx 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.05);
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.switch-label {
  font-size: 26rpx;
  line-height: 1;
}

.switch-text:active {
  opacity: 0.8;
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.3);
}
