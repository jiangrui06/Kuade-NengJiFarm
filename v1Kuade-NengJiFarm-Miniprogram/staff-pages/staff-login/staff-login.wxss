/* pages/staff-login/staff-login.wxss */
.container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background-color: #FDF8EE;
}

.status-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: transparent;
}

.bg-image {
  position: absolute;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.7) 100%);
  z-index: 2;
}

.content {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 40rpx;
  padding-top: 100rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #B8945F 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(212, 167, 106, 0.4);
}

.logo-icon {
  font-size: 80rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #8B6914;
  margin-bottom: 10rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #B8894E;
}

.form-section {
  width: 100%;
  max-width: 560rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-wrapper:focus-within {
  border-color: #D4A76A;
  background: #fff;
}

.input-field {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
}

.input-placeholder {
  color: #999;
}

.password-toggle {
  padding: 0 24rpx;
  font-size: 40rpx;
  opacity: 0.6;
}

.login-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #D4A76A 0%, #B8945F 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(212, 167, 106, 0.4);
  border: none;
  line-height: 100rpx;
  padding: 0;
  margin-top: 24rpx;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  opacity: 0.6;
}

.login-btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-icon {
  margin-right: 16rpx;
  font-size: 36rpx;
}

.loading-text {
  font-size: 32rpx;
}

.switch-section {
  margin-top: 20rpx;
}

.switch-text {
  font-size: 28rpx;
  color: #B8894E;
  text-decoration: underline;
}