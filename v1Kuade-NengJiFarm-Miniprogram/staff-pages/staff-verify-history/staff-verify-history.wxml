<view class="container">
  <!-- 筛选区域 -->
  <view class="filter-section">
    <!-- 搜索框 -->
    <view class="search-box">
      <image class="search-icon" src="https://img.icons8.com/ios-glyphs/30/999999/search.png" />
      <input
        class="search-input"
        type="text"
        placeholder="搜索活动名称/用户名"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
      />
    </view>

    <!-- 筛选标签 -->
    <scroll-view 
      class="filter-tags-scroll" 
      scroll-x 
      enable-flex 
      scroll-into-view="{{scrollToView}}" 
      scroll-with-animation
    >
      <view class="filter-tags">
        <text
          id="filter-all"
          class="filter-tag {{filterType === 'all' ? 'active' : ''}}"
          data-type="all"
          bindtap="onFilterChange"
        >全部</text>
      
        <text
          wx:for="{{categories}}"
          wx:key="id"
          id="filter-{{item.id}}"
          class="filter-tag {{filterType === item.id ? 'active' : ''}}"
          data-type="{{item.id}}"
          bindtap="onFilterChange"
        >{{item.name}}</text>
        <text id="filter-date" class="filter-tag date-tag {{dateRange.startDate ? 'active' : ''}}" bindtap="selectDateRange">
          <text class="date-icon">📅</text>
          <text class="date-text">{{dateRange.startDate || '选择日期'}}</text>
        </text>
      </view>
    </scroll-view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading && historyList.length === 0}}" class="loading">
    <view class="loading-ring"></view>
    <text class="loading-txt">加载中...</text>
  </view>

  <!-- 核销记录列表 -->
  <view wx:if="{{!loading || historyList.length > 0}}" class="history-section">
    <!-- 统计信息 -->
    <view class="stats-bar">
      <text class="stats-text">共 {{total}} 条记录</text>
    </view>

    <!-- 列表 -->
    <view class="history-list">
      <view
        class="history-item"
        wx:for="{{historyList}}"
        wx:key="id"
        bindtap="viewDetail"
        data-item="{{item}}"
      >
        <view class="history-left">
          <text class="history-type {{item.tagClass}}">
            {{item.typeName}}
          </text>
          <view class="history-detail">
            <text class="history-user">{{item.userName}}</text>
            <text class="history-content">{{item.content}}</text>
            <text class="history-count" wx:if="{{item.showParticipants}}">{{item.participantCount}} 人</text>
          </view>
        </view>
        <view class="history-right">
          <text class="history-time">{{item.verifyTimeFormatted}}</text>
          <text class="history-status success">{{item.status}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{historyList.length === 0 && !loading}}" class="empty-state">
      <image class="empty-icon" src="https://img.icons8.com/ios-glyphs/100/cccccc/inbox.png" />
      <text class="empty-text">暂无核销记录</text>
      <text class="empty-subtext">核销后的记录会显示在这里</text>
    </view>

    <!-- 加载更多 -->
    <view wx:if="{{loading && historyList.length > 0}}" class="load-more">
      <view class="loading-ring small"></view>
      <text class="load-more-text">加载中...</text>
    </view>
    <view wx:elif="{{hasMore && historyList.length > 0}}" class="load-more">
      <text class="load-more-text">上拉加载更多</text>
    </view>

    <!-- 没有更多数据 -->
    <view wx:if="{{!hasMore && historyList.length > 0}}" class="no-more">
      <text class="no-more-text">没有更多数据了</text>
    </view>
  </view>

  <!-- 核销记录详情弹窗 -->
  <view class="result-modal" wx:if="{{showDetail && detailItem}}">
    <view class="result-card">
      <text class="detail-title">核销记录详情</text>

      <view class="voucher-info">
        <view class="voucher-row">
          <text class="voucher-label">券类型：</text>
          <text class="voucher-value">{{detailItem.typeName}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">持券人：</text>
          <text class="voucher-value">{{detailItem.userName}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">手机号：</text>
          <text class="voucher-value">{{detailItem.userPhone}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">券内容：</text>
          <text class="voucher-value">{{detailItem.content}}</text>
        </view>
        <view class="voucher-row" wx:if="{{detailItem.showParticipants}}">
          <text class="voucher-label">核销人数：</text>
          <text class="voucher-value">{{detailItem.participantCount}} 人</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">核销时间：</text>
          <text class="voucher-value">{{detailItem.verifyTime}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">订单号：</text>
          <text class="voucher-value">{{detailItem.orderId}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">状态：</text>
          <text class="voucher-value success-text">{{detailItem.status}}</text>
        </view>
      </view>

      <!-- 商品列表（自取订单） -->
      <view class="order-items" wx:if="{{detailItem.isGoodsPickup && detailItem.items && detailItem.items.length > 0}}">
        <view class="order-items-title">商品列表</view>
        <view class="order-item" wx:for="{{detailItem.items}}" wx:key="index">
          <image class="item-img" src="{{item.image}}" mode="aspectFill" />
          <view class="item-info">
            <text class="item-name">{{item.name}}</text>
            <text class="item-qty">× {{item.quantity}}</text>
          </view>
        </view>
      </view>

      <button class="close-result-btn" bindtap="closeDetail">关闭</button>
    </view>
  </view>
</view>
