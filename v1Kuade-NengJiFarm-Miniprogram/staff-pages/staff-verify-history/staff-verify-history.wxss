/* ============================================
   全局变量 & 基础布局
   ============================================ */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ============================================
   顶部标题栏
   ============================================ */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #c99a5a 0%, #e0b878 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.header-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-btn {
  font-size: 26rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* ============================================
   筛选区域
   ============================================ */
.filter-section {
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #eee;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-tag {
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  transition: all 0.2s;
}

.filter-tag.active {
  background: #c99a5a;
  color: #fff;
}

.filter-tag.date-tag {
  background: #fff3e0;
  color: #ff9800;
}

/* ============================================
   加载中
   ============================================ */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-ring {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #ece4d8;
  border-top-color: #c99a5a;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: #999;
}

/* ============================================
   核销记录列表
   ============================================ */
.history-section {
  margin-top: 20rpx;
}

.stats-bar {
  background: #fff;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-text {
  font-size: 24rpx;
  color: #888;
}

.history-list {
  background: #fff;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.2s;
}

.history-item:active {
  background: #fafafa;
}

.history-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-type {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  width: fit-content;
}

.history-type.pick-tag {
  background: #e8f5e9;
  color: #4caf50;
}

.history-type.activity-tag {
  background: #e3f2fd;
  color: #2196f3;
}

.history-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.history-user {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.history-content {
  font-size: 24rpx;
  color: #888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 350rpx;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  margin-left: 20rpx;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.history-status.success {
  background: #e8f5e9;
  color: #4caf50;
}

/* ============================================
   空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: #fff;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #999;
}

/* ============================================
   加载更多
   ============================================ */
.load-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  background: #fff;
}

.load-more-text,
.no-more-text {
  font-size: 24rpx;
  color: #999;
}

/* ============================================
   深色模式
   ============================================ */
@media (prefers-color-scheme: dark) {
  .container {
    background-color: #141210;
  }

  .header-bar {
    background: linear-gradient(135deg, #8a6830 0%, #a07838 100%);
  }

  .filter-section,
  .history-section,
  .stats-bar,
  .history-list,
  .empty-state,
  .load-more,
  .no-more {
    background: #1e1c18;
  }

  .search-box {
    background: #2a2820;
  }

  .filter-tag {
    background: #2a2820;
    color: #aaa;
  }

  .filter-tag.active {
    background: #c99a5a;
    color: #fff;
  }

  .history-item {
    border-bottom-color: #2a2820;
  }

  .history-user {
    color: #e8e0d4;
  }

  .history-content {
    color: #888;
  }

  .empty-text {
    color: #aaa;
  }
}
