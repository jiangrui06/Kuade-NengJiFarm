/* ============================================
   主题变量
   ============================================ */
page {
  --gold: #c99a5a;
  --gold-light: #e0b878;
  --gold-gradient: linear-gradient(135deg, var(--gold) 0%, var(--gold-light) 100%);
  --gold-shadow: rgba(201, 154, 90, 0.3);
  --orange: #ff9800;
  --orange-light: #ffb74d;
  --orange-shadow: rgba(255, 152, 0, 0.3);

  --bg: #f5f5f5;
  --card-bg: #fff;
  --text-primary: #333;
  --text-secondary: #666;
  --text-tertiary: #999;
  --text-quaternary: #888;
  --border: #eee;
  --border-light: #f5f5f5;
  --tag-bg: #f5f5f5;
  --tag-active-bg: var(--gold-gradient);
  --tag-shadow: var(--gold-shadow);
  --success: #4caf50;
  --success-bg: #e8f5e9;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* ============================================
   深色模式变量覆盖
   ============================================ */
@media (prefers-color-scheme: dark) {
  page {
    --bg: #141210;
    --card-bg: #1e1c18;
    --text-primary: #e8e0d4;
    --text-secondary: #aaa;
    --text-tertiary: #aaa;
    --text-quaternary: #888;
    --border: #2a2820;
    --border-light: #2a2820;
    --tag-bg: #2a2820;
    --tag-active-bg: var(--gold-gradient);
    --tag-shadow: rgba(201, 154, 90, 0.4);
  }
}

/* ============================================
   全局 & 基础布局
   ============================================ */
.container {
  background-color: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ============================================
   顶部标题栏
   ============================================ */
.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: var(--gold-gradient);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 48rpx;
  font-weight: 300;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.header-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-btn {
  font-size: 26rpx;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* ============================================
   筛选区域
   ============================================ */
.filter-section {
  background: var(--card-bg);
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--tag-bg);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.filter-tags-scroll {
  white-space: nowrap;
}

.filter-tags {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 16rpx;
  align-items: center;
  padding-bottom: 8rpx;
}

.filter-tags::-webkit-scrollbar {
  display: none;
}

.filter-tag {
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--tag-bg);
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  transition: all 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
  border: 2rpx solid transparent;
  font-weight: 500;
}

.filter-tag.active {
  background: var(--tag-active-bg);
  color: #fff;
  box-shadow: 0 4rpx 12rpx var(--tag-shadow);
  border-color: transparent;
}

.filter-tag:not(.active):active {
  background: color-mix(in srgb, var(--tag-bg) 80%, var(--gold));
  transform: scale(0.95);
}

.filter-tag.date-tag {
  background: #fff3e0;
  color: var(--orange);
  border: 2rpx solid #ffe0b2;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.filter-tag.date-tag.active {
  background: linear-gradient(135deg, var(--orange) 0%, var(--orange-light) 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx var(--orange-shadow);
  border-color: transparent;
}

.date-icon {
  font-size: 24rpx;
}

.date-text {
  font-size: 24rpx;
}

@media (prefers-color-scheme: dark) {
  .filter-section {
    border-bottom-color: var(--border);
  }
  .filter-tag.date-tag {
    background: #2a2010;
    color: var(--orange-light);
    border-color: #3a3020;
  }
  .filter-tag.date-tag.active {
    background: linear-gradient(135deg, var(--orange) 0%, var(--orange-light) 100%);
    color: #fff;
    box-shadow: 0 4rpx 12rpx var(--orange-shadow);
    border-color: transparent;
  }
}

/* ============================================
   加载中
   ============================================ */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-ring {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #ece4d8;
  border-top-color: var(--gold);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ============================================
   核销记录列表
   ============================================ */
.history-section {
  margin-top: 20rpx;
}

.stats-bar {
  background: var(--card-bg);
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.stats-text {
  font-size: 24rpx;
  color: var(--text-quaternary);
}

.history-list {
  background: var(--card-bg);
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid var(--border-light);
  transition: background 0.2s;
}

.history-item:active {
  background: color-mix(in srgb, var(--card-bg) 96%, var(--gold));
}

.history-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.history-type {
  font-size: 22rpx;
  padding: 1rpx 20rpx 22rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  font-weight: 500;
  display: inline-block;
  text-align: center;
  margin-right: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  line-height: 1;
  white-space: nowrap;
  box-sizing: border-box;
  height: fit-content;
}

.history-type.tag-activity {
  background: linear-gradient(180deg, #fff8e6 0%, #ffe4b8 100%);
  color: #b45309;
  border: none;
}

.history-type.tag-points {
  background: linear-gradient(180deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
  border: none;
}

.history-type.tag-pickup {
  background: linear-gradient(180deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
  border: none;
}

.history-type.tag-study {
  background: linear-gradient(180deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1e40af;
  border: none;
}

.history-type.tag-pick {
  background: linear-gradient(180deg, #fce7f3 0%, #fbcfe8 100%);
  color: #831843;
  border: none;
}

.history-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.history-user {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.history-content {
  font-size: 24rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 350rpx;
}

.history-count {
  font-size: 22rpx;
  color: var(--gold);
  font-weight: 500;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.history-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.history-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.history-status.success {
  background: var(--success-bg);
  color: var(--success);
}

/* ============================================
   空状态
   ============================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: var(--card-bg);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ============================================
   加载更多
   ============================================ */
.load-more,
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx 0;
  background: var(--card-bg);
}

.load-more-text,
.no-more-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.loading-ring.small {
  width: 28rpx;
  height: 28rpx;
  border-width: 3rpx;
  margin-bottom: 0;
}

/* ============================================
   核销记录详情弹窗
   ============================================ */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.result-card {
  width: 90%;
  max-width: 600rpx;
  background-color: var(--card-bg);
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: resultPopIn 0.35s ease-out;
}

@keyframes resultPopIn {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}

.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 28rpx;
}

.voucher-info {
  width: 100%;
  background-color: color-mix(in srgb, var(--card-bg) 98%, var(--gold));
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.voucher-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.voucher-row:last-child {
  border-bottom: none;
}

.voucher-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.voucher-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  max-width: 380rpx;
  text-align: right;
  word-break: break-all;
}

.success-text {
  color: var(--success) !important;
  font-weight: 600;
}

.close-result-btn {
  min-width: 280rpx;
  height: 76rpx;
  background-color: var(--gold);
  color: #fff;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 50rpx;
  line-height: 76rpx;
  text-align: center;
}

.close-result-btn::after {
  border: none;
}

.close-result-btn:active {
  opacity: 0.85;
}
