/* ============================================
   核销记录 - 稻田风 · 高级版
   ============================================ */

@import "../../styles/farm-theme.wxss";

page {
  --rice-cream: #FAF5EB;
  --rice-gold: #E6B877;
  --rice-gold-light: #F0D4A0;
  --rice-gold-pale: #F7E4C0;
  --rice-text: #5C3D2E;
  --rice-text-light: #9A8B78;
  --rice-text-secondary: #8B7355;
  --rice-straw: #E3D6C0;
  --rice-paper: #F5F0E6;
  --rice-shadow: rgba(92, 61, 46, 0.1);
  --rice-shadow-strong: rgba(92, 61, 46, 0.18);
  --rice-danger: #D4765E;
  --rice-danger-light: #E0937E;
  --rice-warm: #F5E6D3;

  background:
    radial-gradient(ellipse 100% 35% at 50% 70%, rgba(230, 184, 119, 0.2) 0%, transparent 100%),
    radial-gradient(ellipse 70% 30% at 30% 65%, rgba(230, 184, 119, 0.13) 0%, transparent 100%),
    radial-gradient(ellipse 60% 25% at 70% 68%, rgba(230, 184, 119, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 40% 18% at 18% 62%, rgba(124, 179, 66, 0.12) 0%, transparent 100%),
    radial-gradient(ellipse 50% 15% at 55% 60%, rgba(124, 179, 66, 0.1) 0%, transparent 100%),
    radial-gradient(ellipse 35% 20% at 82% 63%, rgba(124, 179, 66, 0.11) 0%, transparent 100%),
    linear-gradient(180deg,
      #FDF5E6 0%, #FCF0DC 12%, #FAEBD5 25%, #F9E6CE 38%,
      #F7E0C5 50%, #F5DABC 62%, #F2D4B3 75%, #EFCEAA 88%, #ECC8A1 100%);
}

.page-wrap {
  position: relative;
  min-height: 100vh;
  padding: 0 24rpx 0;
  display: flex;
  flex-direction: column;
}

/* ===== 底部稻田梯田 ===== */
.page-wrap::before {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 520rpx;
  background:

    radial-gradient(ellipse 50% 40% at 25% 60%, rgba(91,140,62,0.18) 0%, rgba(91,140,62,0.06) 45%, transparent 100%),
    radial-gradient(ellipse 40% 35% at 55% 65%, rgba(110,160,70,0.14) 0%, transparent 100%),
    radial-gradient(ellipse 140% 18% at 50% 85%, rgba(196,149,60,0.16) 0%, transparent 100%);
  pointer-events: none; z-index: 0;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  display: flex; flex-direction: column; align-items: center;
  padding: 48rpx 24rpx 16rpx; position: relative; z-index: 1;
}

.header-bar-wheat-left, .header-bar-wheat-right {
  width: 48rpx; height: 64rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite;
  opacity: 0.3; position: absolute; top: 26rpx;
}
.header-bar-wheat-left { left: 40rpx; transform: rotate(-15deg); }
.header-bar-wheat-right { right: 40rpx; transform: rotate(15deg); animation-delay: 0.6s; }

.header-title {
  font-size: 38rpx; font-weight: 800;
  background: linear-gradient(135deg, var(--rice-gold) 0%, var(--rice-green) 50%, var(--rice-gold) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 4rpx; margin-bottom: 8rpx;
  text-shadow: none; position: relative;
}

.header-title::after {
  content: ''; display: block; width: 60rpx; height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--rice-gold), transparent);
  margin: 6rpx auto 0; border-radius: 2rpx;
}

.header-subtitle {
  font-size: 22rpx; color: var(--rice-text-light);
  letter-spacing: 6rpx; font-weight: 400;
}

/* ===== 主内容区 ===== */
.main-content {
  position: relative; z-index: 1;
  padding: 0 0 0px;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* ===== 稻穗装饰 ===== */
.wheat-stalk {
  background: var(--wheat-deco) center/contain no-repeat;
}

/* ===== 底部装饰 ===== */
.footer-decoration {
  display: flex; flex-direction: column; align-items: center;
  padding: 40rpx 24rpx 30rpx; position: relative;
 
  border-top: 1rpx solid rgba(232,200,122,0.15);
  border-radius: 40rpx 40rpx 0 0;
  margin-top: auto;
  width: 100%;
  min-height: 160rpx;
}

.footer-rice { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 16rpx; }

.footer-rice-text {
  width: 42rpx; height: 54rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: gentleFloat 4s ease-in-out infinite;
}

.footer-wheat-row {
  display: flex; align-items: center; justify-content: center;
  gap: 12rpx; margin-bottom: 12rpx;
}

.footer-wheat-left, .footer-wheat-right {
  width: 36rpx; height: 48rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  display: inline-block; animation: wheatSway 3s ease-in-out infinite; opacity: 0.25;
}

.footer-wheat-right { animation-delay: 0.6s; }

.footer-wheat-sep { font-size: 14rpx; color: var(--rice-straw); }

.footer-wheat-center {
  font-size: 24rpx; color: var(--rice-text-secondary);
  letter-spacing: 3rpx; font-weight: 500;
}

.footer-text { font-size: 20rpx; color: var(--rice-text-light); letter-spacing: 4rpx; }

.footer-wheat {
  position: absolute; width: 220rpx; height: 400rpx;
  background: var(--wheat-deco) center/contain no-repeat;
  pointer-events: none; opacity: 0.7;
}
.footer-wheat-bl { bottom: 0rpx; left: -40rpx; transform: rotate(60deg); }
.footer-wheat-br { bottom: 0rpx; right: -40rpx; transform: rotate(-60deg); }

/* ===== 筛选区域 ===== */
.filter-section {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 100%);
  margin: -10rpx 20rpx 0;
  border-radius: 24rpx;
  padding: 20rpx 20rpx 16rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.12);
  position: relative;
  z-index: 2;
}

.filter-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.search-box {
  display: flex;
  align-items: center;
  background: var(--rice-cream);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--rice-paper);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  opacity: 0.4;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--rice-text);
}

.search-input::placeholder {
  color: var(--rice-text-light);
}

.filter-tags-scroll {
  white-space: nowrap;
}

.filter-tags {
  display: inline-flex;
  flex-wrap: nowrap;
  gap: 16rpx;
  align-items: center;
  padding-bottom: 8rpx;
}

.filter-tags::-webkit-scrollbar {
  display: none;
}

.filter-tag {
  font-size: 26rpx;
  color: var(--rice-text-secondary);
  background: var(--rice-paper);
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  transition: all 0.2s;
  white-space: nowrap;
  flex-shrink: 0;
  border: 2rpx solid transparent;
  font-weight: 500;
}

.filter-tag.active {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(196,149,60,0.25);
  border-color: transparent;
}

.filter-tag:not(.active):active {
  background: color-mix(in srgb, var(--rice-paper) 80%, var(--rice-gold));
  transform: scale(0.95);
}

.filter-tag.date-tag {
  background: var(--rice-cream);
  color: var(--rice-gold);
  border: 2rpx solid rgba(196,149,60,0.2);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.filter-tag.date-tag.active {
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(196,149,60,0.25);
  border-color: transparent;
}

.date-icon {
  font-size: 24rpx;
}

.date-text {
  font-size: 24rpx;
}

/* ===== 加载中 ===== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

/* ===== 加载中 ===== */
.loading-ring {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid var(--rice-paper);
  border-top-color: var(--rice-gold);
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: var(--rice-text-light);
}

/* ===== 加载更多 ===== */
.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx 0;
}

/* ===== 核销记录列表 ===== */
.history-section {
  margin: 20rpx 20rpx 0;
}

.stats-bar {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 100%);
  padding: 16rpx 24rpx;
  border-radius: 16rpx 16rpx 0 0;
  border-bottom: 1rpx solid var(--rice-paper);
  position: relative;
}

.stats-text {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

.history-list {
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 100%);
  border-radius: 0 0 24rpx 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.12);
  border-top: none;
  position: relative;
}

.history-list::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--rice-paper);
  transition: background 0.2s;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: var(--rice-cream);
}

.history-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.history-type {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  box-shadow: 0 2rpx 8rpx var(--rice-shadow);
  line-height: 1.4;
  white-space: nowrap;
  height: fit-content;
}

.history-type.tag-activity {
  background: rgba(196,149,60,0.12);
  color: var(--rice-gold);
  border: none;
}

.history-type.tag-points {
  background: rgba(232,200,122,0.2);
  color: var(--rice-gold);
  border: none;
}

.history-type.tag-pickup {
  background: rgba(91,140,62,0.12);
  color: var(--rice-green);
  border: none;
}

.history-type.tag-study {
  background: rgba(157,192,200,0.15);
  color: var(--rice-text-secondary);
  border: none;
}

.history-type.tag-pick {
  background: rgba(212,118,94,0.12);
  color: var(--rice-danger);
  border: none;
}

.history-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.history-user {
  font-size: 28rpx;
  color: var(--rice-text);
  font-weight: 500;
}

.history-content {
  font-size: 24rpx;
  color: var(--rice-text-light);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 350rpx;
}

.history-count {
  font-size: 22rpx;
  color: var(--rice-gold);
  font-weight: 500;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.history-time {
  font-size: 22rpx;
  color: var(--rice-text-light);
}

.history-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.history-status.success {
  background: var(--rice-success-bg);
  color: var(--rice-success);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  background: linear-gradient(135deg, #FEFCF7 0%, #FEF8EE 100%);
  border-radius: 0 0 24rpx 24rpx;
  box-shadow: 0 6rpx 24rpx var(--rice-shadow);
  border: 1rpx solid rgba(232,200,122,0.12);
  border-top: none;
  position: relative;
}

.empty-state::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(2rpx 2rpx at 20% 30%, rgba(196, 149, 60, 0.02) 0%, transparent 100%),
    radial-gradient(2rpx 2rpx at 65% 55%, rgba(232, 200, 122, 0.02) 0%, transparent 100%);
  pointer-events: none;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 30rpx;
  color: var(--rice-text-secondary);
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: var(--rice-text-light);
}

/* ===== 加载更多 ===== */
/* ===== 没有更多数据 ===== */
.no-more {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 50rpx;
}

.no-more-deco {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.no-more-line {
  width: 60rpx;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--rice-straw));
}

.no-more-line:last-child {
  background: linear-gradient(90deg, var(--rice-straw), transparent);
}

.no-more-wheat {
  width: 24rpx;
  height: 36rpx;
  flex-shrink: 0;
  position: relative;
}
.no-more-wheat::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--wheat-deco) center/contain no-repeat;
  opacity: 0.7;
  animation: gentleFloat 3s ease-in-out infinite;
}
.no-more-wheat:last-child::before {
  transform: scaleX(-1);
  animation-delay: 0.3s;
}

.no-more-text {
  font-size: 22rpx;
  color: var(--rice-text-light);
  letter-spacing: 3rpx;
}

.loading-ring.small {
  width: 28rpx;
  height: 28rpx;
  border-width: 3rpx;
  margin-bottom: 0;
}

/* ===== 商品列表（自取订单） ===== */
.order-items {
  width: 100%;
  background: var(--rice-cream);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(196,149,60,0.06);
}

.order-items-title {
  font-size: 24rpx;
  color: var(--rice-text-light);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(232,200,122,0.1);
}

.order-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  background: var(--rice-straw);
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  color: var(--rice-text);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.item-qty {
  font-size: 24rpx;
  color: var(--rice-text-light);
  flex-shrink: 0;
}

/* ===== 核销记录详情弹窗 ===== */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(44, 24, 16, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  animation: fadeIn 0.25s ease-out;
}

.result-card {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: scaleIn 0.35s ease-out;
  box-shadow: 0 20rpx 60rpx var(--rice-shadow-strong);
}

.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--rice-text);
  margin-bottom: 28rpx;
}

.voucher-info {
  width: 100%;
  background: var(--rice-cream);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(196,149,60,0.08);
}

.voucher-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--rice-paper);
}

.voucher-row:last-child {
  border-bottom: none;
}

.voucher-label {
  font-size: 24rpx;
  color: var(--rice-text-light);
  flex-shrink: 0;
}

.voucher-value {
  font-size: 26rpx;
  color: var(--rice-text);
  font-weight: 500;
  max-width: 380rpx;
  text-align: right;
  word-break: break-all;
}

.success-text {
  color: var(--rice-success) !important;
  font-weight: 600;
}

.close-result-btn {
  min-width: 280rpx;
  height: 76rpx;
  background: linear-gradient(135deg, var(--rice-gold), var(--rice-green));
  color: #fff;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 50rpx;
  line-height: 76rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(196,149,60,0.25);
  transition: all 0.2s;
}

.close-result-btn::after {
  border: none;
}

.close-result-btn:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* ===== 动画 ===== */
@keyframes wheatSway {
  0%, 100% { transform: rotate(-12deg) scaleX(1); }
  25% { transform: rotate(-5deg) scaleX(1.05); }
  50% { transform: rotate(12deg) scaleX(0.95); }
}

@keyframes gentleFloat {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  30% { transform: translateY(-12rpx) rotate(-2deg); }
  60% { transform: translateY(-6rpx) rotate(2deg); }
  80% { transform: translateY(-10rpx) rotate(-1deg); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}
