<view class="container">
  <!-- 顶部标题栏 -->
  <view class="header-bar">
    <text class="header-title">📋 核销工作台</text>
    <text class="header-role">员工</text>
  </view>

  <!-- 扫码区域 -->
  <view class="scan-section">
    <view class="scan-card" bindtap="scanCode">
      <image class="scan-icon" src="https://img.icons8.com/ios-glyphs/96/D4A76A/scan-qrcode.png" />
      <text class="scan-title">扫码核销</text>
      <text class="scan-desc">扫描用户活动券二维码进行核销</text>
    </view>

    <view class="scan-btn-wrapper">
      <button class="scan-btn" bindtap="scanCode">
        📷 点击扫码
      </button>
    </view>
  </view>

  <!-- 扫码结果 -->
  <view class="result-modal" wx:if="{{showResult}}">
    <view class="result-card result-{{resultCode}}">
      <image class="result-icon"
        src="{{resultCode === 'complete' ? 'https://img.icons8.com/ios-glyphs/64/22c55e/success.png' : resultCode === 'info' ? 'https://img.icons8.com/ios-glyphs/64/1989fa/info.png' : 'https://img.icons8.com/ios-glyphs/64/e74c3c/error.png'}}" />
      <text class="result-title">{{resultTitle}}</text>
      <text class="result-msg">{{resultMsg}}</text>
      
      <!-- 券信息展示 -->
      <view class="voucher-info" wx:if="{{voucherInfo}}">
        <view class="voucher-row">
          <text class="voucher-label">券类型：</text>
          <text class="voucher-value">{{voucherInfo.typeName}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">持券人：</text>
          <text class="voucher-value">{{voucherInfo.userName}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">券内容：</text>
          <text class="voucher-value">{{voucherInfo.content}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">使用时间：</text>
          <text class="voucher-value">{{voucherInfo.useTime}}</text>
        </view>
        <view class="voucher-row" wx:if="{{voucherInfo.showParticipants}}">
          <text class="voucher-label">核销人数：</text>
          <text class="voucher-value">{{voucherInfo.participantCount || 1}} 人</text>
        </view>
      </view>

      <button class="close-result-btn" bindtap="resetScan">继续核销</button>
    </view>
  </view>

  <!-- 核销历史 -->
  <view class="history-section">
    <view class="history-header">
      <text class="history-title">今日核销记录</text>
      <view class="history-header-right">
        <text class="header-count">共 {{historyList.length}} 条</text>
        <text class="view-all-btn" bindtap="goToHistory">查看全部 ›</text>
      </view>
    </view>

    <view class="history-list" wx:if="{{historyList.length > 0}}">
      <view class="history-item" wx:for="{{historyList}}" wx:key="id" bindtap="showHistoryDetail" data-item="{{item}}">
        <view class="history-left">
          <text class="history-type activity-tag">{{item.typeName}}</text>
          <view class="history-detail">
            <text class="history-user">{{item.userName}}</text>
            <text class="history-content">{{item.content}}</text>
            <text class="history-participants" wx:if="{{item.showParticipants}}">{{item.participantCount}} 人</text>
          </view>
        </view>
        <view class="history-right">
          <text class="history-time">{{item.verifyTimeFormatted}}</text>
          <text class="history-status success">{{item.status}}</text>
        </view>
      </view>
    </view>

    <view class="empty-history" wx:else>
      <text class="empty-text">暂无核销记录</text>
    </view>
  </view>

  <!-- 核销记录详情弹窗 -->
  <view class="result-modal" wx:if="{{showHistoryDetail && historyDetail}}">
    <view class="result-card">
      <text class="detail-title">核销记录详情</text>

      <view class="voucher-info">
        <view class="voucher-row">
          <text class="voucher-label">券类型：</text>
          <text class="voucher-value">{{historyDetail.typeName}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">持券人：</text>
          <text class="voucher-value">{{historyDetail.userName}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">手机号：</text>
          <text class="voucher-value">{{historyDetail.userPhone}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">券内容：</text>
          <text class="voucher-value">{{historyDetail.content}}</text>
        </view>
        <view class="voucher-row" wx:if="{{historyDetail.showParticipants}}">
          <text class="voucher-label">核销人数：</text>
          <text class="voucher-value">{{historyDetail.participantCount}} 人</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">核销时间：</text>
          <text class="voucher-value">{{historyDetail.verifyTime}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">订单号：</text>
          <text class="voucher-value">{{historyDetail.orderId}}</text>
        </view>
        <view class="voucher-row">
          <text class="voucher-label">状态：</text>
          <text class="voucher-value success-text">{{historyDetail.status}}</text>
        </view>
      </view>

      <button class="close-result-btn" bindtap="closeHistoryDetail">关闭</button>
    </view>
  </view>
</view>
