/* ============================================
   主题变量
   ============================================ */
page {
  --gold: #D4A76A;
  --gold-dark: #B8894E;
  --gold-gradient: linear-gradient(145deg, var(--gold) 0%, var(--gold-dark) 60%, #A07D4A 100%);
  --gold-shadow: rgba(212, 167, 106, 0.35);

  --bg: #FAF6F0;
  --card-bg: #fff;
  --text-primary: #333;
  --text-secondary: #666;
  --text-tertiary: #999;
  --border: #eee;
  --border-light: #f5f5f5;
  --tag-bg: #f0f8e8;
  --success: #07c160;

  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* ============================================
   全局
   ============================================ */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ============================================
   顶部标题栏
   ============================================ */
.header-bar {
  background: var(--gold-gradient);
  padding: 100rpx 40rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-role {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* ============================================
   扫码区域
   ============================================ */
.scan-section {
  padding: 40rpx 32rpx;
}

.scan-card {
  background-color: var(--card-bg);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx var(--gold-shadow);
  border: 2rpx dashed var(--gold);
  margin-bottom: 30rpx;
  transition: transform 0.2s;
}

.scan-card:active {
  transform: scale(0.98);
}

.scan-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.scan-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.scan-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
}

.scan-btn-wrapper {
  margin-top: 20rpx;
}

.scan-btn {
  width: 100%;
  height: 88rpx;
  background: var(--gold-gradient);
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 3rpx;
  box-shadow: 0 8rpx 24rpx var(--gold-shadow);
}

.scan-btn::after {
  border: none;
}

/* ============================================
   核销结果弹窗 & 详情弹窗（共用）
   ============================================ */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.result-card {
  width: 90%;
  max-width: 600rpx;
  background-color: var(--card-bg);
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: resultPopIn 0.35s ease-out;
}

@keyframes resultPopIn {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}

.result-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
}

.result-complete .result-title { color: var(--success); }
.result-fail .result-title    { color: #ff4d4f; }
.result-info .result-title   { color: #1989fa; }

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.result-msg {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

/* 券信息卡片 */
.voucher-info {
  width: 100%;
  background-color: #fafafa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.voucher-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.voucher-row:last-child {
  border-bottom: none;
}

.voucher-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.voucher-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  max-width: 400rpx;
  text-align: right;
  word-break: break-all;
}

/* 详情弹窗标题 */
.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 28rpx;
}

.success-text {
  color: var(--success) !important;
  font-weight: 600;
}

.close-result-btn {
  min-width: 280rpx;
  height: 76rpx;
  background-color: var(--gold);
  color: #fff;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 50rpx;
  line-height: 76rpx;
  text-align: center;
}

.close-result-btn::after {
  border: none;
}

.close-result-btn:active {
  opacity: 0.85;
}

/* ============================================
   确认核销弹窗按钮组
   ============================================ */
.confirm-btn-group {
  width: 100%;
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 40rpx;
  font-weight: 500;
}

.confirm-btn::after {
  border: none;
}

.confirm-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn.primary {
  background: var(--gold-gradient);
  color: #fff;
  box-shadow: 0 4rpx 16rpx var(--gold-shadow);
}

.result-card.result-confirm {
  border: 2rpx solid var(--gold);
}

.result-confirm .result-title {
  color: var(--gold-dark);
}

/* ============================================
   商品列表（自取订单）
   ============================================ */
.order-items {
  width: 100%;
  background: #fafafa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.order-items-title {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 16rpx;
  font-weight: 500;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.order-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 10rpx;
  background: #f0ece6;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-width: 0;
}

.item-name {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 12rpx;
}

.item-qty {
  font-size: 24rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.order-item-total {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 16rpx 0 4rpx;
  border-top: 1rpx solid var(--border);
  margin-top: 8rpx;
}

.item-total-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.item-total-amount {
  font-size: 30rpx;
  color: #e53e3e;
  font-weight: 700;
}

/* ============================================
   核销历史列表
   ============================================ */
.history-section {
  margin: 20rpx 32rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.view-all-btn {
  font-size: 24rpx;
  color: var(--gold);
  font-weight: 500;
}

.view-all-btn:active {
  opacity: 0.7;
}

.history-list {
  background-color: var(--card-bg);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid var(--border-light);
  transition: background 0.2s;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: color-mix(in srgb, var(--card-bg) 96%, var(--gold));
}

.history-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.history-type {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.history-type.tag-activity {
  background: linear-gradient(180deg, #fff8e6 0%, #ffe4b8 100%);
  color: #b45309;
  border: 2rpx solid #fcd34d;
}

.history-type.tag-points {
  background: linear-gradient(180deg, #fef3c7 0%, #fde68a 100%);
  color: #92400e;
  border: 2rpx solid #fbbf24;
}

.history-type.tag-pickup {
  background: linear-gradient(180deg, #d1fae5 0%, #a7f3d0 100%);
  color: #065f46;
  border: 2rpx solid #34d399;
}

.history-type.tag-study {
  background: linear-gradient(180deg, #dbeafe 0%, #bfdbfe 100%);
  color: #1e40af;
  border: 2rpx solid #60a5fa;
}

.history-detail {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  gap: 4rpx;
}

.history-user {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.history-content {
  font-size: 24rpx;
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 350rpx;
}

.history-participants {
  font-size: 22rpx;
  color: var(--gold);
  font-weight: 500;
}

.history-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.history-right .history-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.history-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.history-status.success {
  background: #e8f5e9;
  color: #4caf50;
}

.empty-history {
  background-color: var(--card-bg);
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.empty-text {
  font-size: 28rpx;
  color: #ccc;
}
