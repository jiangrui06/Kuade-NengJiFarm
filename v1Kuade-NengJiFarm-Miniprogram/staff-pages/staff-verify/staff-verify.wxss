/* 全局 */
page {
  background-color: #FAF6F0;
  font-family: Arial, sans-serif;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ===== 顶部标题栏 ===== */
.header-bar {
  background: linear-gradient(145deg, #D4A76A 0%, #B8915A 60%, #A07D4A 100%);
  padding: 100rpx 40rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.header-role {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  background-color: rgba(255, 255, 255, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

/* ===== 扫码区域 ===== */
.scan-section {
  padding: 40rpx 32rpx;
}

.scan-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(212, 167, 106, 0.12);
  border: 2rpx dashed #D4A76A;
  margin-bottom: 30rpx;
}

.scan-card:active {
  transform: scale(0.98);
}

.scan-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.scan-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.scan-desc {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.scan-btn-wrapper {
  margin-top: 20rpx;
}

.scan-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(145deg, #D4A76A, #B8894E);
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 3rpx;
  box-shadow: 0 8rpx 24rpx rgba(212, 167, 106, 0.35);
}

.scan-btn::after {
  border: none;
}

/* ===== 手动输入区域 ===== */
.manual-section {
  margin: 20rpx 32rpx;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.manual-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.manual-input {
  height: 80rpx;
  background-color: #f9f9f9;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.verify-btn {
  width: 100%;
  height: 84rpx;
  background: linear-gradient(145deg, #D4A76A, #B8894E);
  border-radius: 42rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.verify-btn[disabled] {
  opacity: 0.5;
}

.verify-btn::after {
  border: none;
}

/* ===== 核销结果 ===== */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.result-card {
  width: 90%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 28rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: resultPopIn 0.35s ease-out;
}

@keyframes resultPopIn {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}

.result-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
}

.result-complete .result-title {
  color: #07c160;
}

.result-fail .result-title {
  color: #ff4d4f;
}

.result-info .result-title {
  color: #1989fa;
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.result-msg {
  font-size: 26rpx;
  color: #666;
  text-align: center;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

/* 券信息 */
.voucher-info {
  width: 100%;
  background-color: #fafafa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.voucher-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.voucher-row:last-child {
  border-bottom: none;
}

.voucher-label {
  font-size: 24rpx;
  color: #999;
}

.voucher-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  max-width: 400rpx;
  text-align: right;
}

.close-result-btn {
  min-width: 280rpx;
  height: 76rpx;
  background-color: #D4A76A;
  color: #fff;
  border-radius: 38rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0 50rpx;
}

.close-result-btn::after {
  border: none;
}

/* ===== 核销历史 ===== */
.history-section {
  margin: 20rpx 32rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.history-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-count {
  font-size: 24rpx;
  color: #999;
}

.view-all-btn {
  font-size: 24rpx;
  color: #D4A76A;
  font-weight: 500;
}

.view-all-btn:active {
  opacity: 0.7;
}

.history-list {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.pick-tag {
  font-size: 22rpx;
  color: #D4A76A;
  background-color: #fff9e6;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 18rpx;
  white-space: nowrap;
}

.activity-tag {
  font-size: 22rpx;
  color: #5b8c00;
  background-color: #f0f8e8;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  margin-right: 18rpx;
  white-space: nowrap;
}

.history-detail {
  display: flex;
  flex-direction: column;
}

.history-user {
  font-size: 27rpx;
  font-weight: 500;
  color: #333;
}

.history-time {
  font-size: 23rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.history-status {
  font-size: 24rpx;
  color: #07c160;
  font-weight: 500;
  flex-shrink: 0;
}

.empty-history {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.empty-text {
  font-size: 28rpx;
  color: #ccc;
}
